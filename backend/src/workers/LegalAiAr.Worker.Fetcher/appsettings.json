{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Worker": {
    "BatchSize": 8,
    "MaxConcurrency": 4,
    "PollIntervalSeconds": 2,
    "EmptyPollIntervalSeconds": 10,
    "VisibilityTimeoutMinutes": 10,
    "MaxDequeueCount": 3
  },
  "WorkerControl": {
    "HubAccessKey": "local-dev-worker-hub-key-change-in-prod",
    "ApiBaseUrl": "http://localhost:5088"
  },
  "CsjnApi": {
    "BaseUrl": "https://sjconsulta.csjn.gov.ar/sjconsulta/",
    "ThrottlingDelayMs": 500,
    "ThrottlingBackoffMultiplier": 2.0,
    "ThrottlingMaxRetries": 3,
    "RequestTimeoutSeconds": 60,
    "PreferBlobApiCacheBeforeHttp": true,
    "PostAbrirParallelEnabled": true,
    "PostAbrirHttpMaxConcurrencyGlobal": 6,
    "OutboundHttpEnabled": true
  }
}
