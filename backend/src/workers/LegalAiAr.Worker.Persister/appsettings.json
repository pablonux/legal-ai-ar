{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Pipeline": {
    "QueuePrefix": "pipeline"
  },
  "Worker": {
    "BatchSize": 1,
    "PollIntervalSeconds": 1,
    "EmptyPollIntervalSeconds": 5,
    "VisibilityTimeoutMinutes": 10,
    "MaxDequeueCount": 3
  },
  "WorkerControl": {
    "HubAccessKey": "local-dev-worker-hub-key-change-in-prod",
    "ApiBaseUrl": "http://localhost:5088"
  }
}
