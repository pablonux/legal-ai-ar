# Legal AI AR — Environment variables (example)
# Copy to .env and replace secret placeholders.

# =============================================================================
# SECRETS — Replace manually
# =============================================================================
# DB_SECRET      → MSSQL_USERNAME password
# STORAGE_KEY    → Storage Account AccountKey (Azure Portal → Storage account → Access keys)
# SEARCH_KEY     → Azure AI Search Primary admin key (Azure Portal → AI Search → Keys)
# OPENAI_KEY     → Azure OpenAI API key (Azure Portal → Azure OpenAI → Keys and Endpoint)

# =============================================================================
# AZURE SQL DATABASE
# =============================================================================
# .NET format: AzureSql__ConnectionString (double underscore)
# Replace DB_SECRET with the actual password
AzureSql__ConnectionString=Server=tcp:u2zfnlvisdsp0001.database.windows.net,1433;Database=LegalAI-DEV;User ID=sqladmin;Password=DB_SECRET;Encrypt=False;TrustServerCertificate=True;Connection Timeout=30;

# =============================================================================
# AZURE BLOB STORAGE + STORAGE QUEUES (mismo Storage Account)
# =============================================================================
# Replace STORAGE_KEY with the actual AccountKey
AzureBlob__ConnectionString=DefaultEndpointsProtocol=https;AccountName=nus2slfnlvid001;AccountKey=STORAGE_KEY;EndpointSuffix=core.windows.net
AzureBlob__ContainerName=legalaiar-kb-dev

# =============================================================================
# AZURE AI SEARCH
# =============================================================================
# Replace SEARCH_KEY with the actual Primary admin key
AzureSearch__Endpoint=https://u2zfnlviadcs003.search.windows.net
AzureSearch__ApiKey=SEARCH_KEY
# Indexes: architecture uses two. Update if your environment uses different names.
AzureSearch__RulingIndexName=rulings-by-ruling
AzureSearch__ChunkIndexName=rulings-by-chunk

# =============================================================================
# AZURE OPENAI (PwC shared service)
# =============================================================================
# Replace OPENAI_KEY with the actual API key
AzureOpenAI__Endpoint=https://genai-sharedservice-americas.pwcinternal.com
AzureOpenAI__ApiKey=OPENAI_KEY
AzureOpenAI__ChatDeploymentName=azure.gpt-4o
AzureOpenAI__EmbeddingDeploymentName=azure.text-embedding-3-large

# =============================================================================
# CRAWLER — CSJN THROTTLING (R-002)
# =============================================================================
# Optional. Defaults in appsettings.json: 2000 ms, 2.0x backoff, 3 retries.
# CsjnCrawler__ThrottlingDelayMs=2000
# CsjnCrawler__ThrottlingBackoffMultiplier=2.0
# CsjnCrawler__ThrottlingMaxRetries=3

# CSJN acuerdo discovery — parallel calendar days (each day still paginates sequentially). Default 1; try 2–4 in dev and watch for 429.
# CsjnCrawler__DiscoveryDateConcurrency=2
# Optional process-wide cap on concurrent discovery HTTP requests to CSJN (0 = off). Use with DiscoveryDateConcurrency > 1 to avoid unbounded connections.
# CsjnCrawler__DiscoveryHttpMaxConcurrency=8

# =============================================================================
# PARSER — CSJN API (R-002)
# =============================================================================
# Optional. Defaults in appsettings.json: 500 ms, 2.0x backoff, 3 retries.
# CsjnApi__ThrottlingDelayMs=500
# CsjnApi__ThrottlingBackoffMultiplier=2.0
# CsjnApi__ThrottlingMaxRetries=3

# Optional. Default true: Parser reads CSJN API JSON from `_cache/csjn/api/...` before HTTP even when crawl UseCache=false.
# CsjnApi__PreferBlobApiCacheBeforeHttp=false

# Ola 4 — parallel GETs after abrirAnalisis (default true) + process-wide concurrent HTTP cap (default 6).
# CsjnApi__PostAbrirParallelEnabled=false
# CsjnApi__PostAbrirHttpMaxConcurrencyGlobal=4

# =============================================================================
# PIPELINE WORKERS — Worker section (Discoverer, Fetcher, Parser, …)
# =============================================================================
# Per poll: up to BatchSize messages are received; at most MaxConcurrency handlers run in parallel (see FetcherWorkerService).
# If BatchSize is 1, only one message is dequeued per iteration regardless of MaxConcurrency.
# Worker__BatchSize=4
# Worker__MaxConcurrency=2
# Worker__PollIntervalSeconds=2
# Worker__EmptyPollIntervalSeconds=10
# Worker__VisibilityTimeoutMinutes=30
# Worker__MaxDequeueCount=3

# Fetcher vs CSJN API gate: each ruling fetch hits sjconsulta (PrimeSjconsultaCachesAsync) under CsjnApiRequestGate — default PostAbrirHttpMaxConcurrencyGlobal=6 process-wide.
# Stress scales roughly with (worker replicas × Worker__MaxConcurrency × parallel HTTP per document). Increase BatchSize together with MaxConcurrency only after measuring 429s and gate limits.

# =============================================================================
# WORKER CONTROL — SignalR pause/resume (pipeline workers → API hub)
# =============================================================================
# Shared secret: workers send header X-Worker-Hub-Key; must match API appsettings WorkerControl:HubAccessKey.
WorkerControl__HubAccessKey=local-dev-worker-hub-key-change-in-prod
# Optional. Default in code: http://localhost:5088 (API base URL, no trailing slash).
# Set when workers run elsewhere so they connect to the correct hub.
# WorkerControl__ApiBaseUrl=https://your-api-host

# =============================================================================
# AUTH — API (session id_token cookie; see docs/design/auth-jwt-hardening.md)
# =============================================================================
# Local Development: middleware injects signed id_token cookie (appsettings.Development.json).
# Auth__Development__InjectIdentity=true
# Auth__Development__Email=dev@legal-ai.local
# Auth__Development__DisplayName=Dev User (local)

# GCaaS / production (Vault secrets):
# Auth__Platform__TenantId=
# Auth__Platform__ValidAudience=
# Auth__Platform__MetadataAddress=
# Auth__Platform__ValidIssuer=
# Auth__Platform__SigningKeyBase64=
# Auth__Platform__DefaultRole=admin
# Auth__Platform__RolesClaimType=roles
# Auth__Platform__EmailClaim=email
# Auth__Platform__IdTokenCookie=id_token

# =============================================================================
# AZURE ENTRA ID (Phase 3 — optional; GCaaS uses delegated Entra via Envoy)
# =============================================================================
# AzureAd__TenantId=
# AzureAd__ClientId=
# AzureAd__Audience=api://legal-ai-ar
