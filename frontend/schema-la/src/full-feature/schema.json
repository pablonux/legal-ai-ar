{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "SchemaLaFullFeature",
  "title": "Full feature slice schematic",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Feature name (English)",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Feature name (kebab-case or words):"
    },
    "route": {
      "type": "string",
      "description": "Spanish UI route segment",
      "x-prompt": "Route path segment (Spanish UI):"
    },
    "skipRoutes": {
      "type": "boolean",
      "description": "Do not patch app.routes.ts",
      "default": false
    }
  },
  "required": ["name", "route"]
}
