{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "SchemaLaUiWrapper",
  "title": "UI wrapper schematic",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Component name (English)",
      "$default": {
        "$source": "argv",
