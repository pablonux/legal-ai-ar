              "projects/shared-common/**/*.ts",
              "projects/shared-common/**/*.html"
            ],
            "eslintConfig": "projects/shared-common/eslint.config.js"
          }
        }
      }
    }
  },
  "cli": {
    "schematicCollections": ["schema-la", "@angular-eslint/schematics"],
    "analytics": false
  }
}
