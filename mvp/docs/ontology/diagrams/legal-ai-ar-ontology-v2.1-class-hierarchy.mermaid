    PersonaJuridica --> PJPublica["legar:PersonaJuridicaPublica"]
    PersonaJuridica --> PJPrivada["legar:PersonaJuridicaPrivada"]

    %% Roles (no subclases — aristas punteadas)
    PersonaHumana -.->|"rol"| Juez["legar:Juez"]
    PersonaHumana -.->|"rol"| Fiscal["legar:Fiscal"]
    PersonaHumana -.->|"rol"| Defensor["legar:Defensor"]
    PersonaHumana -.->|"rol"| Abogado["legar:Abogado"]

    %% OrganoEstatal
