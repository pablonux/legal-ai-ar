%% E121 - CD pipeline - F1-14 Deploy
%% Source: docs/design/f1-14-deploy.md (E120)
flowchart LR
    subgraph Trigger["Trigger"]
        Merge[Merge to main]
    end

    subgraph Build["Build"]
        BuildAPI[Build API]
        BuildSPA[Build SPA]
        BuildWorkers[Build 4 workers]
        Tests[Run tests]
    end

    subgraph Push["Push"]
        ACR[Push to Azure Container Registry]
    end

    subgraph DeployStaging["Deploy Staging"]
        DeployAPI[Deploy API to staging slot]
        DeploySPA[Deploy SPA to staging]
        DeployWorkers[Deploy workers to Container Apps]
    end

    subgraph Validate["Validate"]
        Smoke[Smoke test: crawl → index → search → chat]
        Pass{Pass?}
    end

    subgraph Promote["Promote"]
        Swap[Swap API slots]
        PromoteSPA[Promote SPA to production]
        Activate[Activate worker revision]
    end

    Merge --> BuildAPI
    Merge --> BuildSPA
    Merge --> BuildWorkers
    BuildAPI --> Tests
    BuildSPA --> Tests
    BuildWorkers --> Tests
    Tests --> ACR
    Tests --> DeploySPA
    ACR --> DeployAPI
    ACR --> DeployWorkers
    DeployAPI --> Smoke
    DeploySPA --> Smoke
    DeployWorkers --> Smoke
    Smoke --> Pass
    Pass -->|Yes| Swap
    Pass -->|No| Fail([Fail - fix and re-deploy])
    Swap --> PromoteSPA
    PromoteSPA --> Activate
    Activate --> Done([Production live])
