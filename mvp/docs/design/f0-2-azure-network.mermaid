%% Reference diagram: typical topology. Services are already created.
%% Phase 1: Storage Queues (not Service Bus), graph in Azure SQL (not Neo4j).
flowchart TB
    subgraph Internet["Internet"]
        Users["Users"]
    end

    subgraph VNet["VNet — legal-ai-vnet"]
        subgraph SubnetApps["Subnet apps (10.0.1.0/24)"]
            AppService["App Service"]
            CAEnv["Container Apps\nEnvironment"]
        end

        subgraph SubnetVM["Subnet vm (10.0.2.0/24)"]
            Neo4jVM["Neo4j VM\nbolt:7687"]
        end

        subgraph SubnetPE["Subnet private-endpoints (10.0.3.0/24)"]
            PE_SQL["PE SQL"]
            PE_Blob["PE Blob"]
            PE_Search["PE AI Search"]
            PE_SB["PE Service Bus"]
            PE_AOAI["PE Azure OpenAI"]
        end
    end

    subgraph PaaS["PaaS"]
        SQL["Azure SQL"]
        Blob["Blob Storage"]
        Search["AI Search"]
        SB["Service Bus"]
        AOAI["Azure OpenAI"]
    end

    Users -->|HTTPS| AppService
    Users -->|HTTPS| SWA["Static Web Apps"]

    AppService -->|private| PE_SQL
    AppService -->|private| PE_Blob
    AppService -->|private| PE_Search
    AppService -->|private| PE_SB
    AppService -->|private| PE_AOAI

    CAEnv -->|private| PE_SQL
    CAEnv -->|private| PE_Blob
    CAEnv -->|private| PE_Search
    CAEnv -->|private| PE_SB
    CAEnv -->|private| PE_AOAI

    AppService -->|VNet| Neo4jVM
    CAEnv -->|VNet| Neo4jVM

    PE_SQL --> SQL
    PE_Blob --> Blob
    PE_Search --> Search
    PE_SB --> SB
    PE_AOAI --> AOAI
