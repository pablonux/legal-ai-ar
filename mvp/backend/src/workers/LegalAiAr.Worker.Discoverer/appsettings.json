{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Worker": {
    "BatchSize": 4,
    "MaxConcurrency": 2,
    "PollIntervalSeconds": 2,
    "EmptyPollIntervalSeconds": 10,
    "VisibilityTimeoutMinutes": 30,
    "MaxDequeueCount": 3
  },
  "WorkerControl": {
    "HubAccessKey": "local-dev-worker-hub-key-change-in-prod",
    "ApiBaseUrl": "http://localhost:5088"
  }
}
