[{"codigo":7815102,"analisisDocumental":{"id":781510,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":250005,"valor":"DDHH- Institucional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"DE BENEDETTI, PABLO OSVALDO c/ M JUSTICIA Y DDHH s/DESAPARICION DE PERSONAS - LEY 24411 ART 6","alias":null,"caratula":"Recurso Queja Nº 1 - DE BENEDETTI, PABLO OSVALDO c/ M JUSTICIA Y DDHH s/DESAPARICION DE PERSONAS - LEY 24411  ART 6","inconstitucional":false,"falloDestacado":{"id":4963,"titulo":"Interpretación de las leyes 24.043 y 24.411","cabecilla":"<p>En una causa se discutía si al actor le correspondía una diferencia entre lo cobrado por la ley 24.043 y lo solicitado en virtud del régimen de la ley 24.411 sobre desaparición forzada de personas, con motivo del fallecimiento de su padre. La Corte revocó la sentencia de cámara -que había hecho lugar al pedido- por entender que había realizado una interpretación contraria al texto de la ley. Para así decidir, consideró que la ley 24.043 establece un único beneficio para cuyo monto se prevé un incremento por la contingencia de la muerte. Por lo cual, entendió el Tribunal, no se trata de dos beneficios independientes o autónomos sino de uno que responde a una causa indivisa que se configura con el cumplimiento de alguno de los requisitos previstos en el art. 2° de la norma referida, esto es, que la persona haya sido puesta a disposición del Poder Ejecutivo Nacional antes del 10 de diciembre de 1983 o que, en condición de civil, haya sido privada de su libertad por actos emanados de tribunales militares, haya habido o no sentencia condenatoria en este fuero.</p>","esNovedad":true,"fecha":1675911600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1676050527751,"usuarioCreacion":4,"fechaCreacion":1675971273112,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":105984,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33630783,"numeroExpediente":71503,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7347,"descripcion":"DESAPARICION DE PERSONAS - LEY 24411  ART 6","idMateria":2,"tema":null},"caratula":"Recurso Queja Nº 1 - DE BENEDETTI, PABLO OSVALDO c/ M JUSTICIA Y DDHH s/DESAPARICION DE PERSONAS - LEY 24411  ART 6","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"71503. "},"recurso":{"id":5603944,"expediente":{"id":33630783,"numeroExpediente":71503,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"C