"15","abreviatura":"FCB","descripcion":"Justicia Federal de Córdoba","estado":0,"descripcionLarga":"FCB - Justicia Federal de Córdoba"},"objetoJuicio":{"id":2584,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":80,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 2 - FIORI, PABLO c/ EJERCITO ARGENTINO s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"19206. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"FCB 019206/2013/2/RH001","identificacionExpediente":"FCB 019206/2013/2/RH001"},"piezas":1,"urgente":"N","observaciones":null,"usuarioCreacion":null,"usuarioCreacionOld":"JUR4UC","usuarioModificacion":null,"usuarioModificacionOld":"JUR4UC","fechaCreacion":201505081109,"fechaModificacion":201505081109}],"fecha":1431054000000,"fechaLong":20150508,"observaciones":null,"codigoUsuario":"JUR4UC","fechaString":"08/05/2015"},"observaciones":"La Corte -por mayoría- remite al precedente CSJ 377/2005 (41-L)  \"Leston, Juan Carlos c/Estado Nacional\", del 18-12-2007, en el que se sostuvo que a diferencia de los casos en que la lesión reconoce un origen típicamente accidental, las normas del derecho común no resultan aplicables cuando la lesión es el resultado de una acción bélica, esto es, una mera consecuencia del cumplimiento de misiones específicas de las fuerzas armadas o de seguridad, características del servicio público de defensa. \r\n- El juez Fayt, por su voto, se remite a lo resuelto en la causa CSJ 456/2011 (47-T) \"Tittaferrante, Mirta Noemí c/ Estado Nacional - Ministerio del Interior - Policía Federal Argentina s/ daños y perjuicios\" resuelta el 30/12/14 en el que estimó aplicable al caso la doctrina del precedente \"Valenzuela\" (Fallos: 315:1731) en el que descartó la posibilidad de reclamar una indemnización de daños sufridos en actos de servicio por vía del derecho civil.\r\n- La jueza Higthon, en disidencia, remite  a la causa \"Aragón, Raúl Enrique c/ Estado Nacional\" (Fallos:330:5205) , en el que  dejó sin efecto la sentencia que rechazó la demanda -fundada en disposiciones del Código Civil-, interpuesta contra el Estado Nacional por el resarcimiento de los daños y perjuicios sufridos en actos de servicios, pues la doctrina sentada en el precedente \"Azzetti\"- según la cual a diferencia de los casos en que la lesión reconoce un origen típicamente accidental, las normas del derecho común no resultan aplicables cuando la lesión es el resultado de una acción bélica-, fue circunscripta al ámbito particular de las \"acciones bélicas\". \r\n\r\n\r\n\r\n","comentarios":null,"enPreparacion":null,"formulaDesarrollo":null,"audPublica":"N","articulo16Ley48":"N","inicializacion":"N","amicue_curie":"N","conOpinion":null,"chequeoVoto":"S","cambiaJurisp":null,"sentenciaModelo":null,"citaDoctrina":null,"citaExtranjera":null,"votosOpinion":"N","art11Acordada4":null,"resolucionOriginarios":null,"cuestionesFederales":[{"tipoCuestionFederal":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":50001,"valor":"ARTÍCULO 14 DE LA LEY 48 ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JURJ3F","fechaCreacionLong":201006041222,"fechaModLong":202203141533,"orden":null,"visible":null},"usuarioCreacion":"JURJ3F","usuarioModificacion":"JURJ3F","fechaCreacion":202102121554,"fechaModificacion":202102121554}],"formulas":[],"recusExcus":[],"voces":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1298,"codigoRelacion":101298,"valor":"DAÑOS Y PERJUICIOS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":"JURJ3F","usuarioModificacion":"JURJ3F","fechaCreacion":202102121554,"fechaModificacion":202102121554},{"tipoVoz":{"codigoTabla":null,"codigoValor":1981,"codigoRelacion":101981,"valor":"FUERZAS DE SEGURIDAD","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":20100630