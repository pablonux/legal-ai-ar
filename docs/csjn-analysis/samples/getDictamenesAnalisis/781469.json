[{"codigo":7814692,"analisisDocumental":{"id":781469,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"G., M. P. c/ IOMA s/ ACCIÓN DE AMPARO","alias":null,"caratula":"G., M. P. c/ IOMA s/ACCION DE AMPARO","inconstitucional":false,"falloDestacado":{"id":4921,"titulo":"Competencia en reclamos relacionados con el derecho a la salud","cabecilla":"<p>Una afiliada al Instituto de Obra Médico Asistencial (IOMA) promovió un amparo contra dicha entidad con el objeto de obtener la cobertura integral de un tratamiento médico. Tanto el juzgado correccional como el federal se declararon incompetentes, lo que originó un conflicto negativo que la Corte tuvo que dirimir. Comenzó advirtiendo que como otras situaciones que guardaban estrecha similitud con este caso habían merecido respuestas disímiles, se imponía la necesidad de revisar la doctrina que guió la solución de estos casos hasta ahora. Expresó que la causa no versaba sobre un reclamo de naturaleza federal en razón de las personas y tampoco en razón de la materia. Consideró que para la resolución de la cuestión se imponía el examen del ordenamiento provincial <b>por lo que correspondía resolver el conflicto en favor de la justicia ordinaria provincial</b>. Agregó el Tribunal que la forma de dirimir la contienda propendía a un mejor y más rápido acceso a justicia para quien se ve obligado a promover un reclamo judicial en pos de conseguir el efectivo goce de sus derechos a la salud y a un nivel de vida adecuado.</p>","esNovedad":true,"fecha":1671591600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1671734471983,"usuarioCreacion":11,"fechaCreacion":1671734374535,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":105956,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36083716,"numeroExpediente":2758,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"G., M. P. c/ IOMA s/ACCION DE AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2758. "},"recurso":{"id":6209611,"expediente":{"id":36083716,"numeroExpediente":2758,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"G., M. P. c/ IOMA s/ACCION DE AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2758. "},"tipoRecurso":{"id":1103,"codigo":"COM","descripcion":"COMPETENCIA"},"claveRecurso":"CSJ 0027