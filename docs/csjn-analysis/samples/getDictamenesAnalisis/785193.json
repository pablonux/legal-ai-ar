[{"codigo":7851935,"analisisDocumental":{"id":785193,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - YANCOVICH, SERGIO FABIO c/ ESTADO NACIONAL s/ACCION MERAMENTE DECLARATIVA DE DERECHO","inconstitucional":false,"falloDestacado":{"id":5622,"titulo":"Alcance del deber de fiscalizar entidades sujetas a control por parte del Estado","cabecilla":"<p>La cámara  condenó al Estado Nacional a pagar al actor una suma de dólares estadounidenses en concepto de restitución de los ahorros que había depositado en una asociación mutual al considerar constatados los recaudos de procedencia exigidos para responsabilizar al Estado por su actividad legislativa lesiva. Ante el recurso del demandado la Corte dejó sin efecto este pronunciamiento. Comenzó señalando que en casos donde se discute la omisión antijurídica en el ejercicio del poder de policía -según la legislación vigente al momento en que ocurrieron los hechos- rigen los presupuestos derivados de la responsabilidad extracontractual del Estado y que solo le puede caber responsabilidad al organismo oficial si incumplió el deber legal que le imponía obstar el evento lesivo, puesto que una conclusión contraria llevaría al extremo de convertir al Estado en un ente asegurador de todo hecho dañoso que se cometiera. Expresó el Tribunal que las competencias asignadas a un ente estatal para ejercer el poder de policía, de carácter eminentemente administrativo, que se traduce en el deber de fiscalizar a la entidad sujeta a su control, no pueden ser entendidas como una garantía contra la insolvencia de las personas sujetas a esa fiscalización. Consideró que la cámara se había apartado de dichas directrices, pues había fundado su pronunciamiento en consideraciones genéricas fundadas en el desenlace falencial de la mutual, sin referir cuáles fueron concretamente los deberes legales inobservados por el Estado Nacional o el ente descentralizado a cargo de la fiscalización de las cooperativas y mutuales, y su nexo de causalidad con los daños y perjuicios invocados por el actor.</p>","esNovedad":true,"fecha":1688439600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1688568353094,"usuarioCreacion":11,"fechaCreacion":1688499757961,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":110597,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":26799003,"numeroExpediente":3234,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":2844,"descripcion":"ACCION MERAMENTE DECLARATIV