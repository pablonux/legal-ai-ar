[{"codigo":8008523,"analisisDocumental":{"id":800852,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GORRIEZ, VILMA NOEMI BASILE, DOLINDA TAMIOZZO, ELENA ALEJANDRINA s/RECURSO DE QUEJA ","inconstitucional":false,"falloDestacado":{"id":7481,"titulo":"Rechazo de recursos en un juicio criminal: falta de fundamentación","cabecilla":"<p style=\"text-indent:2em\">La corte provincial no hizo lugar a los recursos extraordinarios de inaplicabilidad de ley interpuestos por quienes habían sido condenadas como coautoras de asociación ilícita.</p><p style=\"text-indent:2em\">La defensa interpuso recurso extraordinario y la Corte dejó sin efecto esta sentencia.</p><p style=\"text-indent:2em\">Recordó que las decisiones relativas a la improcedencia de los recursos deducidos por ante los tribunales de la causa no justifican, en principio, el otorgamiento de la apelación extraordinaria pero señaló que es posible hacer excepción a dicha regla sobre la base de la doctrina de la arbitrariedad cuando la decisión apelada frustra el alcance de la vía utilizada por el justiciable sin fundamentación idónea o suficiente.</p><p style=\"text-indent:2em\">Sostuvo que el estudio en torno a los recaudos vinculados con dicha fundamentación de la impugnación local se había efectuado con un injustificado rigor formal, teniendo en cuenta para ello el tiempo transcurrido desde la vinculación de las encausadas al proceso y que por medio de afirmaciones dogmáticas había omitido el tratamiento de temas oportunamente propuestos y conducentes para la adecuada solución del litigio en relación con la afectación del plazo razonable y su incidencia en la determinación de la pena.</p>","esNovedad":true,"fecha":1725332400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1725463355195,"usuarioCreacion":4,"fechaCreacion":1725388594846,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":127238,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36545064,"numeroExpediente":841,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"GORRIEZ, VILMA NOEMI S/ RECURSO EXTRAORDINARIO DE INAPLICABILIDAD DE LEY s/","verificacionMesa":"N","etiqueta":null,"hijos":[],