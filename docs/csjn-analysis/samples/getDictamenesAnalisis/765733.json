cci&oacute;n nace rationae personae - Prerrogativa de car&aacute;cter personal que, como tal, puede ser renunciada expresa o t&aacute;citamente - El hecho de que el Gobierno de la Ciudad de Buenos Aires no impugnara la resoluci&oacute;n en la que el juez local dispuso la remisi&oacute;n de las actuaciones al fuero contencioso administrativo federal debe ser entendido como una renuncia al privilegio de litigar ante la Corte de manera originaria y una pr&oacute;rroga a favor de la jurisdicci&oacute;n federal - Se declara la incompetencia de la Corte para entender por la v&iacute;a de su instancia originaria.</p>","esNovedad":true,"fecha":1619060400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1619194564188,"usuarioCreacion":11,"fechaCreacion":1619194561659,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30860,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30554892,"numeroExpediente":1915,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10564,"descripcion":"ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","idMateria":0,"tema":null},"caratula":"ZF ARGENTINA S.A. c/ BUENOS AIRES, PROVINCIA DE s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1915. "},"recurso":{"id":5187649,"expediente":{"id":30554892,"numeroExpediente":1915,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ 