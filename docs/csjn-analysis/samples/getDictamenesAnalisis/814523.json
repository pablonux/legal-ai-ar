[{"codigo":8145232,"analisisDocumental":{"id":814523,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"LEGNOVERDE, ROBERTO ESTEVAN Y OTROS c/ BANCO MACRO S.A. s/daños y perjuicios ","inconstitucional":false,"falloDestacado":{"id":9362,"titulo":"Base de Datos de Cuentacorrentistas Inhabilitados administrada por el Banco Central de la República Argentina","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal provincial confirmó la sentencia condenatoria de primera instancia, al considerar responsable al banco demandado por los daños y perjuicios provocados por la inclusión de los actores en la Base de Datos de Cuentacorrentistas Inhabilitados, administrada por el Banco Central de la República Argentina -BCRA-. Consideró que aquel había informado prematuramente el rechazo por falta de fondos del cheque pues interpretó que la entidad demandada no había cumplido con el otorgamiento del plazo de 15 días que la comunicación “A” 3075, en su punto 8.3, le acordaba a los demandantes a los efectos de cancelar el documento y pagar las multas para, de ese modo y dado que se trataba del quinto cheque rechazado, evitar la inhabilitación.</p><p style=\"text-indent:2em\">La Corte revocó esta sentencia al entender que se había asignado a dicha comunicación una interpretación que prescindía de su contexto general, de la totalidad de sus preceptos y de los fines que la informan. </p><p style=\"text-indent:2em\">Consideró que la reglamentación a través de estas comunicaciones (\"A\" 3075, \"B\" 6662 y \"B\" 6663) ratificaba que el banco demandado no tenía obligación de esperar el transcurso de 15 días antes de informar el rechazo del cheque al Banco Central, toda vez que, si bien es indiscutible que el mencionado término es otorgado al cuentacorrentista a fin de acreditar el cumplimiento de los requisitos previstos en los puntos 8.3.1. y 8.3.2. de la comunicación citada en primer término, su finalidad no consiste en evitar la inhabilitación como sostuvo el a quo, sino lograr que un cheque rechazado y oportunamente informado al BCRA se tenga por “no computable” y, asimismo, estar en condiciones de solicitar, si fuera el caso, el “cese de la inhabilitación” decretada en base a información cursada también previamente por el banco.</p>","esNovedad":true,"fecha":1757991600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1758203841283,"usuarioCreacion":11,"fechaCreacion":1758049718795,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":142948,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35732961,"numeroExpediente":1513,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abrevi