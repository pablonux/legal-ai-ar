[{"codigo":7678403,"analisisDocumental":{"id":767840,"competencia":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":190013,"valor":"QUEJA POR RETARDO DE JUSTICIA","activo":"S","usuarioCreacion":"CYCJ3F","usuarioMod":"CYCJ3F","fechaCreacionLong":202603171152,"fechaModLong":202603171152,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Recurso Queja Nº 1 - PROCESADO: BLAQUIER, CARLOS PEDRO TADEO Y OTRO s/INF.ART 144 BIS EN CIRC.ART.142 INC 1,2,3,5 VICTIMA: AREDEZ OLGA Y OTROS","alias":null,"caratula":"Recurso Queja Nº 1 - PROCESADO: BLAQUIER, CARLOS PEDRO TADEO Y OTRO s/INF.ART 144 BIS EN CIRC.ART.142 INC 1,2,3,5 VICTIMA: AREDEZ OLGA Y OTROS","inconstitucional":false,"falloDestacado":{"id":2361,"titulo":"Habilitación de la instancia casatoria prescindiendo de la norma aplicable al caso","cabecilla":"<p>Pronunciamiento que revoc&oacute; la resoluci&oacute;n que hab&iacute;a confirmado los autos de procesamiento, sin prisi&oacute;n preventiva, dictados por la participaci&oacute;n de los procesados en hechos de privaci&oacute;n ileg&iacute;tima de la libertad agravada y dispuso su falta de m&eacute;rito - Recurso extraordinario interpuesto por el representante del Ministerio P&uacute;blico Fiscal - Decisi&oacute;n equiparable a sentencia definitiva - Expediente cuya celeridad resulta especialmente relevante por tener por objeto la dilucidaci&oacute;n de delitos de lesa humanidad cometidos hace m&aacute;s de cuarenta a&ntilde;os y cuya investigaci&oacute;n fue coartada por m&uacute;ltiples obst&aacute;culos legales - Apartamiento de la regulaci&oacute;n procesal que habilita la competencia de la C&aacute;mara Federal de Casaci&oacute;n Penal para entender en los recursos de su especialidad dirigidos contra sentencias definitivas o equiparables a tales - Habilitaci&oacute;n de su competencia por medio de un argumento que nada tiene que ver con lo dispuesto en el c&oacute;digo adjetivo, y que coloc&oacute; su intervenci&oacute;n dentro de un formato de procedimiento de consulta y control, que le es ajeno - Las cuestiones vinculadas con la legalidad de la designaci&oacute;n del fiscal, por lo que ya hab&iacute;a abierto su instancia, eran normativa y conceptualmente independientes de las cuestiones vinculadas al m&eacute;rito del procesamiento de los encausados - El r&eacute;gimen procesal previsto para el caso fue suprimido, sin que se configure una situaci&oacute;n relacionada con los l&iacute;mites interpretativos que el ordenamiento legal deja en manos de los jueces - Sentencia arbitraria - Se deja sin efecto la sentencia apelada - Disidencia del juez Rosenkrantz: el recurso extraordinario no se dirige contra una sentencia definitiva o equiparable a tal - Las decisiones cuya consecuencia sea la de seguir sometido a proceso no son susceptibles de recurso extraordinario - El recurrente no ha logrado demostrar que la sentencia genere un agravio de insuficiente, imposible o tard&iacute;a reparaci&oacute;n ulterior - No se ha demostrado la configuraci&oacute;n de una situaci&oacute;n de gravedad institucional - La decisi&oacute;n apelada no genera una ruptura del compromiso con el juzgamiento de los delitos de lesa humanidad.</p>","esNovedad":true,"fecha":1625713200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1626193290616,"usuarioCreacion":11,"fechaCreacion":1625777057704,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31530,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":27056402,"numeroExpediente":44000296,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":24,"codigo":"24","abreviatura":"FSA","descripcion":"Justicia Federal de Salta","estado":0,"descripcionLarga":"FSA - Justicia Federal de Salta"},"objetoJuicio":{"id":3101,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - PROCESADO: BLAQUIER, CARLOS PEDRO TADEO Y OTRO s/INF.ART 144 BIS EN CIRC.ART.142 INC 1,2,3,5 VICTIMA: AREDEZ Y MELIAN Y OTROS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"44000296. "},"recurso":{"id":4625240,"expediente":{"id":27056402,"numeroExpediente":44000296,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":24,"codigo":"24","abreviatura":"FSA","descripcion":"Justicia Federal de Salta","estado":0,"descripcionLarga":"FSA - Justicia Federal de Salta"},"objetoJuicio":{"id":3101,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - PROCESADO: BLAQUIER, CARLOS PEDRO TADEO Y OTRO s/INF.ART 144 BIS EN CIRC.ART.142 INC 1,2,3,5 VICTIMA: AREDEZ Y MELIAN Y OTROS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"44000296. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"FSA 044000296/2009/18/1/1/RH005","identificacionExpediente":"FSA 044000296/2009/18/1/1/RH005"},"p