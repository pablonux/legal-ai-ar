[{"codigo":7645902,"analisisDocumental":{"id":764590,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Recurso Queja Nº 1 - ASOCIACION DEL PERSONAL SUPERIOR DE AUTOPISTAS E INFRAESTRUCTURA APSAI c/ AUTOPISTAS DEL SOL S.A. s/ACCION DE AMPARO","alias":null,"caratula":"Recurso Queja Nº 1 - ASOCIACION DEL PERSONAL SUPERIOR DE AUTOPISTAS E INFRAESTRUCTURA APSAI c/ AUTOPISTAS DEL SOL S.A. s/ACCION DE AMPARO","inconstitucional":true,"falloDestacado":{"id":1661,"titulo":"Inconstitucionalidad de la exclusión de los sindicatos simplemente inscriptos del régimen de retención de aportes a sus afiliados","cabecilla":"<p>ecurso contra una sentencia que declar&oacute; la inconstitucionalidad del art&iacute;culo 38 de la ley 23.551 que establece que los empleadores est&aacute;n obligados a actuar como agente de retenci&oacute;n de las cuotas sindicales &uacute;nicamente respecto de trabajadores afiliados a sindicatos con personer&iacute;a gremial - Cuesti&oacute;n federal suficiente pues se ha cuestionado la validez constitucional de una ley del Congreso (ley 23.551) - Lesi&oacute;n a la libertad sindical, en su faz individual y colectiva - La exclusi&oacute;n de los sindicatos simplemente inscriptos configura una injerencia del Estado que reduce injustificadamente su capacidad de desarrollar funciones propias relativas a la promoci&oacute;n, ejercicio, defensa, fomento y protecci&oacute;n de intereses leg&iacute;timos de orden gremial - La autonom&iacute;a e independencia financiera de las organizaciones de trabajadores y de empleadores, al igual que la protecci&oacute;n de sus fondos y bienes, constituyen elementos esenciales del derecho a organizar libremente su administraci&oacute;n - Para los sindicatos de reciente fundaci&oacute;n, las cuotas sociales aportadas por los afiliados son casi siempre su fuente principal de ingresos - La adecuada canalizaci&oacute;n de los aportes resulta determinante para que las organizaciones de trabajadores desplieguen regularmente su gesti&oacute;n y su actividad gremial - El &aacute;gil acceso a los recursos presupuestarios fortalece la autonom&iacute;a del sindicato frente al Estado y al sector empresario - El r&eacute;gimen de retenci&oacute;n de cuotas puede influir de forma indebida en la decisi&oacute;n de los trabajadores de afiliarse a una determinada asociaci&oacute;n sindical - Resulta inocuo proclamar la autonom&iacute;a de las entidades gremiales para fijar su programa de acci&oacute;n y su estrategia con miras al cumplimiento de sus fines, si no se les asegura al mismo tiempo la disponibilidad de los medios econ&oacute;micos indispensables para su funcionamiento y su actividad externa - Inconstitucionalidad de la norma cuestionada - Se confirma la sentencia apelada - Disidencia del juez Lorenzetti: recurso extraordinario inadmisible (art. 280 CPCCN).</p>","esNovedad":true,"fecha":1614826800000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1614970157242,"usuarioCreacion":11,"fechaCreacion":1614969156265,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30466,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29794470,"numeroExpediente":52515,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - DIAZ DARIO ALEJANDRO c/ MERCURY COMMUNICATIONS S.A Y OTRO s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"52515. "},"recurso":{"id":5074086,"expediente":{"id":29794470,"numeroExpediente":52515,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - DIAZ DARIO ALEJANDRO c/ MERCURY COMMUNICATIONS S.A Y OTRO s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"52515. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CNT 052515/2011/1/RH001","identificacionExpediente":"CNT 052515/2