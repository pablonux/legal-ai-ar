[{"codigo":7869123,"analisisDocumental":{"id":786912,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"T., R.D. c/ L., E.A. s/MEDIDAS PRECAUTORIAS","inconstitucional":false,"falloDestacado":{"id":5844,"titulo":"Conflicto de competencia: mejores condiciones para alcanzar el amparo integral de los derechos fundamentales de la niña","cabecilla":"<p>La Sala J de la Cámara Nacional de Apelaciones en lo Civil y la Sala II de la Cámara de Apelaciones Civil en Familia y Sucesiones con asiento en la provincia de Tucumán discrepan respecto de su competencia  en virtud de la problemática que atañe a una niña de 2 años de edad. Básicamente, el argumento central del actor gira en torno a que la niña fue sustraída de su centro de vida en esta ciudad por voluntad unilateral e intempestiva de la progenitora. A su turno, la señora no desconoce que residieron en Buenos Aires, pero manifiesta que habían decidido separarse y que de común acuerdo habían resuelto que ella se quedaría con la niña en la provincia de Tucumán. En suma, las partes sostienen versiones enfrentadas con relación a la vinculación entre ellos y con el padre hacia la niña. Así las cosas, sostuvo el Tribunal, dado que ambos jueces en conflicto se hallarían en situación legal análoga para asumir la función de resguardo, la elección debe hacerse sopesando cuál de ellos estará en las mejores condiciones para alcanzar el amparo integral de los derechos fundamentales de la niña.  Para ello, no puede soslayarse que sus progenitores no tienen un proyecto de vida familiar en común, que desde su nacimiento vive con su madre y que hace 1 año reside establemente en la ciudad de Yerba Buena, ámbito en el cual la proximidad de la que gozan los jueces locales constituye un arbitrio ciertamente relevante en el plano de la efectividad de la labor tutelar, Que en esas condiciones, por lo tanto, se declara que resulta competente para conocer en las actuaciones el Juzgado en lo Civil en Familia y Sucesiones VI con asiento en la Provincia de Tucumán. </p>","esNovedad":true,"fecha":1693969200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1694034846071,"usuarioCreacion":11,"fechaCreacion":1694033713416,"privado":false,"posicion":0,"resumen":null},"reciboEntrada":{"id":112458,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35250762,"numeroExpediente":726,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":588,"descripcion":"MEDIDAS PRECAUTORIAS","idMater