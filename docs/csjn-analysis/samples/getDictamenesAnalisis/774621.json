[{"codigo":7746212,"analisisDocumental":{"id":774621,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"AGUIRRE, GABRIELA YOLANDA c/ QUEVEDO, EULALIA Y OTRO s/ DAÑOS Y PERJUICIOS (ACCIDENTE DE TRABAJO)","alias":null,"caratula":"AGUIRRE, GABRIELA YOLANDA c/ QUEVEDO, EULALIA Y OTRO s/DAÑOS Y PERJUICIOS ( ACCIDENTE DE TRABAJO )","inconstitucional":false,"falloDestacado":{"id":3942,"titulo":"Interpretación restrictiva de la caducidad de instancia que afecta los intereses de niños involucrados en el reclamo por la muerte de su padre","cabecilla":"<p>En una causa en que se hallaba en juego la reparaci&oacute;n de un accidente laboral que hab&iacute;a ocasionado la muerte del progenitor de los ni&ntilde;os el superior tribunal provincial confirm&oacute; la decisi&oacute;n que hab&iacute;a declarado la caducidad de la instancia. Recurrida la decisi&oacute;n, la Corte dej&oacute; sin efecto el pronunciamiento apelado. Consider&oacute; que la sentencia resultaba arbitraria en tanto hab&iacute;a ratificado dicha caducidad sin ponderar de manera adecuada la falta de intervenci&oacute;n oportuna que correspond&iacute;a otorgar al Ministerio P&uacute;blico con competencia local para ejercer la representaci&oacute;n promiscua de los ni&ntilde;os involucrados en la causa. Tuvo en cuenta que ante la verificaci&oacute;n de su situaci&oacute;n de indefensi&oacute;n jur&iacute;dica el juzgador debi&oacute; llevar a cabo un control judicial activo y disponer la notificaci&oacute;n inmediata de esta situaci&oacute;n a fin de evitar el abandono de proceso en perjuicio de aquellos. Agreg&oacute; tambi&eacute;n que teniendo en cuenta el car&aacute;cter alimentario que revest&iacute;a la indemnizaci&oacute;n objeto del reclamo y la preeminencia que cab&iacute;a otorgar al inter&eacute;s superior de los hijos del trabajador fallecido, la interpretaci&oacute;n del instituto de la caducidad de la instancia deb&iacute;a ser especialmente restrictiva.</p>","esNovedad":true,"fecha":1652151600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1652287900859,"usuarioCreacion":11,"fechaCreacion":1652207920315,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":33825,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33005602,"numeroExpediente":2561,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ -