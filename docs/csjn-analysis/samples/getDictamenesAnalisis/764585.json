[{"codigo":7645853,"analisisDocumental":{"id":764585,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"SAAVEDRA, SILVIA GRACIELA Y OTRO c/ ADMINISTRACION NACIONAL DE PARQUES NACIONALES ESTADO NACIONAL Y OTROS s/AMPARO AMBIENTAL","alias":null,"caratula":"SAAVEDRA, SILVIA GRACIELA Y OTRO c/ ADMINISTRACION NACIONAL DE PARQUES NACIONALES ESTADO NACIONAL Y OTROS Y OTRO s/AMPARO AMBIENTAL","inconstitucional":false,"falloDestacado":{"id":1642,"titulo":"Afectación de un recurso ambiental de naturaleza interjurisdiccional por derrame de un pozo petrolero abandonado","cabecilla":"<p>Amparo por da&ntilde;o ambiental colectivo a fin de obtener que se declare la inconstitucionalidad y nulidad absoluta de la continuidad de la explotaci&oacute;n petrolera en el yacimiento &ldquo;Caimancito&rdquo; - Pedido de que se ordene el cese de las conductas generadoras del da&ntilde;o ambiental, que se imponga a sus responsables el deber de recomponer progresiva y gradualmente el ambiente y que se exija a la empresa concesionaria de la explotaci&oacute;n petrolera la contrataci&oacute;n del seguro ambiental - Juez federal de primera instancia que se declar&oacute; incompetente por considerar que el proceso debe tramitar ante la instancia originaria de la Corte - Hechos denunciados que motivaron la adopci&oacute;n de medidas conducentes a obtener mayor informaci&oacute;n relevante en torno a la situaci&oacute;n ambiental del yacimiento Caimancito y del Parque Nacional Calilegua - La actividad petrolera dentro de un Parque Nacional est&aacute; expresamente prohibida por la Ley 22.351 de Parques Nacionales, Monumentos Naturales y Reservas Nacionales y viola las Leyes 17.319 de Hidrocarburos, 26.331 de Presupuestos M&iacute;nimos de Protecci&oacute;n Ambiental de Bosques Nativos y 25.675, Ley General del Ambiente - La alegada contaminaci&oacute;n importar&iacute;a el compromiso de un recurso interjurisdiccional - Proceso que corresponde a la jurisdicci&oacute;n federal tanto ratione personae como ratione materiae - La apariencia de buen derecho y el peligro en la demora est&aacute; dada no s&oacute;lo en la alegaci&oacute;n de los hechos sino tambi&eacute;n por la prueba aportada- Se declara la competencia de la Corte para conocer por v&iacute;a de su instancia originaria- Se hace lugar a la medida cautelar de cesaci&oacute;n y suspensi&oacute;n de la actividad petrolera - Disidencia de la jueza Highton de Nolasco: validez de la pr&oacute;rroga de la competencia originaria en favor de los tribunales federales de primera instancia, en los casos en los que no se advierta la concurrencia de un inter&eacute;s federal o de razones institucionales de tal magnitud que hagan impostergable la intervenci&oacute;n de la Corte - No se ha citado a&uacute;n al Estado provincial, el que, por lo tanto, no ha podido invocar todav&iacute;a la prerrogativa que ostenta por mandato constitucional - Resulta prematura la incompetencia decretada en autos.</p>","esNovedad":true,"fecha":1614222000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1614684452593,"usuarioCreacion":11,"fechaCreacion":1614350776820,"privado":fals