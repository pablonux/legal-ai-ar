[{"codigo":7956552,"analisisDocumental":{"id":795655,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"PETROARSA S.A. c/ PROVINCIA DE TUCUMAN s/INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":7322,"titulo":"Sentencia arbitraria. Planteo de inconstitucionalidad del art. 1° de la ley 8834 de la Provincia de Tucumán","cabecilla":"<p style=\"text-indent: 2em;\">Una empresa demandó la inconstitucionalidad del art. 1° de la ley 8834 de la Provincia de Tucumán que incrementa la alícuota del impuesto sobre los ingresos brutos (ISIB, en adelante) en función de los ingresos gravados, no gravados y exentos del contribuyente por el desarrollo de cualquier actividad dentro o fuera de la provincia. Sostuvo que el modo de determinar la alícuota del ISIB no respeta el requisito de sustento territorial del tributo y constituye un exceso del Fisco local.</p><p style=\"text-indent: 2em;\">La Corte declaró procedente el recurso extraordinario y revocó la sentencia apelada que había denegado el planteo de la actora.</p><p style=\"text-indent: 2em;\">Para resolver de ese modo consideró que, con posterioridad al dictado de la sentencia que la actora impugnaba con su presentación , la Corte de Tucumán declaró la inconstitucionalidad del art. 1° de la ley local 8834 en las causas “Gasnor S.A.” y “Yuhmak S.A.”</p><p style=\"text-indent: 2em;\">Con ello, sostuvo el Tribunal, se demuestra con claridad que la solución adoptada en la sentencia apelada se sustentaba en afirmaciones meramente dogmáticas que le daban un fundamento solo aparente y que la descalifican como acto jurisdiccional (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=339&amp;pagina=372\">339:372</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=342&amp;pagina=1459\">342:1459</a>), resultando descalificable con arreglo a la doctrina de esta Corte sobre arbitrariedad de las sentencias (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=301&amp;pagina=865\">301:865</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=303&amp;pagina=160\">303:160</a> y sus citas).</p>","esNovedad":true,"fecha":1724122800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1724181083555,"usuarioCreacion":4,"fechaCreacion":1724181081308,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":119359,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34625747,"numeroExpediente":225,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codi