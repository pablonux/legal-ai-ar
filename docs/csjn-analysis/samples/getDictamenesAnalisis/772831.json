[{"codigo":7728312,"analisisDocumental":{"id":772831,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"ALMIRÓN, VICTOR HUGO Y OTROS s/ IMPOSICIÓN DE TORTURA","alias":null,"caratula":"Recurso Queja Nº 7 - Principal en Tribunal Oral 0 - IMPUTADO: ALMIRON, VICTOR HUGO Y OTROS s/IMPOSICION DE TORTURA (ART.144 TER.INC.1) QUERELLANTE: COBOS, VICTOR MANUEL Y OTRO","inconstitucional":false,"falloDestacado":{"id":4681,"titulo":"Detención ilegal y tormentos con origen en la denuncia por la comisión de un delito común y calificación de lesa humanidad","cabecilla":"<p>La cámara anuló la condena de los imputados por considerar que la detención y aplicación de tormentos en sede policial en el año 1977 no podían ser calificados como delitos de lesa humanidad. Recurrida la resolución, la Corte, por mayoría, la dejó sin efecto al considerar que prescindía de circunstancias relevantes para la solución del caso y se apoyaba en afirmaciones dogmáticas. Expresó que la circunstancia de que la presunta detención ilegal y los tormentos tuvieran origen en la denuncia por la comisión de un delito común, como la defraudación, no constituía un extremo que conduzca, por sí solo, a descartar la comisión de delitos de lesa humanidad. Señaló que no podía ignorarse que los pretextos o circunstancias para la privación de la libertad durante dicho período fueron muy variados, de modo que la \"averiguación de antecedentes\" o la denuncia por delitos contra la propiedad podían ser modos de encubrimiento de otras reales motivaciones, o incluso, aun cuando hubieran sido verdaderos aquellos motivos, los informes posteriormente llegados sobre los antecedentes políticos del detenido podían determinar un cambio de actitud en los agentes de las fuerzas de seguridad. Concluyó así que las circunstancias ponderadas en la sentencia apelada no eran suficientes para restarle valor a las declaraciones testimoniales según las cuales la privación de la libertad y los tormentos sufridos también encontraban explicación en la actividad y en los vínculos gremiales del damnificado en la época de los hechos.</p>","esNovedad":true,"fecha":1666062000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1666191146719,"usuarioCreacion":11,"fechaCreacion":1666118695970,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":33202,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30382512,"numeroExpediente":14216,"anioExpediente":2003,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{