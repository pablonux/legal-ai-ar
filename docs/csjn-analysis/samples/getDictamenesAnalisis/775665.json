[{"codigo":7756652,"analisisDocumental":{"id":775665,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"BERENGUEL, GERMAN RODRIGO c/ CHEVROLET S.A. DE AHORRO PARA FINES DETERMINADOS Y OTRO s/INCIDENTE DE INCOMPETENCIA","alias":null,"caratula":"BERENGUEL, GERMAN RODRIGO c/ CHEVROLET S.A. DE AHORRO PARA FINES DETERMINADOS Y OTRO s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":4185,"titulo":"Competencia de la justicia provincial en las controversias sobre contratos de planes de ahorro previo","cabecilla":"<p>En un reclamo de un consumidor por la existencia de conductas abusivas en relaci&oacute;n con la determinaci&oacute;n y actualizaci&oacute;n de los valores de las cuotas de un&nbsp;<strong>contrato de plan de ahorro previo</strong>&nbsp;para la adquisici&oacute;n de un autom&oacute;vil se plante&oacute; un conflicto de competencia.&nbsp; La justicia provincial y la federal discreparon en torno a la competencia para entender en la acci&oacute;n por medio de la cual el actor, invocando su car&aacute;cter de consumidor, solicit&oacute; que se declare el incumplimiento del contrato. El juzgado local declin&oacute; intervenir con fundamento en que los sistemas de ahorro previo para la adquisici&oacute;n de veh&iacute;culos est&aacute;n conformados por un conjunto de relaciones contractuales conexas que se pactan, celebran y desarrollan en distintos puntos del pa&iacute;s, lo cual involucra el tr&aacute;fico comercial interjurisdiccional, mientras que el juzgado federal rechaz&oacute; la atribuci&oacute;n en virtud de que en autos se discuten aspectos relativos a una relaci&oacute;n de consumo regida por normas de derecho com&uacute;n.&nbsp;<strong>La Corte entendi&oacute; que resultaba competente la justicia provincial dado que la controversia involucraba cuestiones que no exceden el &aacute;mbito del derecho com&uacute;n derivadas de un v&iacute;nculo contractual de &iacute;ndole comercial</strong>&nbsp;que vincula al accionante con la compa&ntilde;&iacute;a oferente de los planes de ahorro previo y que no se advert&iacute;a, prima facie, que la resoluci&oacute;n del caso exigiera necesariamente precisar el alcance de normas contenidas en leyes federales. Adem&aacute;s, precis&oacute; que la causa no presentaba elementos de interjurisdiccionalidad por tratarse de una acci&oacute;n de alcance individual, basada en la relaci&oacute;n contractual de &iacute;ndole comercial que mantienen los actores con las firmas demandadas, no obstante que el sistema de ahorro previo utilizado se integre con otros ahorristas, extra&ntilde;os a la litis, domiciliados en distintos puntos del pa&iacute;s.</p>","esNovedad":true,"fecha":1656990000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1657124235710,"usuarioCreacion":4,"fechaCreacion":1657109358337,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":34217,"sec