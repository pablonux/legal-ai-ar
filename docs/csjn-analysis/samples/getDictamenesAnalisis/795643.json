[{"codigo":7956435,"analisisDocumental":{"id":795643,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - SOBRESEIDO: MAGALLANES ERNESTO RODRIGO Y OTROS s/HOMICIDIO SIMPLE QUERELLANTE: SALAS ELIO EDISON Y OTROS","inconstitucional":false,"falloDestacado":{"id":6902,"titulo":"Casación positiva y doctrina del precedente \"Duarte\" (Fallos: 337:901)","cabecilla":"<p style=\"text-indent: 2em;\">La cámara de casación condenó a quienes habían sido absueltos por el delito de homicidio por un tribunal oral. La Corte -en su anterior intervención en la causa y con aplicación del precedente \"Duarte” (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=337&amp;pagina=901\">Fallos: 337:901</a>)-, remitió las actuaciones a la cámara de casación para que se asegurara a los recurrentes el derecho consagrado en el artículo 8.2 de la Convención Americana sobre Derechos Humanos.</p><p style=\"text-indent: 2em;\">Ello derivó en una nueva intervención de la cámara de casación que, con otra integración, confirmó la condena impuesta.</p><p style=\"text-indent: 2em;\">Contra ese último pronunciamiento, la defensa dedujo un nuevo recurso extraordinario federal y la Corte lo dejó sin efecto.    </p><p style=\"text-indent: 2em;\">Consideró el Tribunal que asistía razón a la defensa oficial de los imputados en cuanto alegó que, en la sentencia apelada, se omitió tratar adecuadamente el cuestionamiento referido a la afectación a la garantía constitucional de defensa en juicio previo y debido proceso y de los principios de oralidad, contradicción, inmediación y continuidad del juicio oral que había formulado con sustento en los artículos 18, 24, y 118 de la Constitución Nacional y 8 de la Convención Americana sobre Derechos Humanos.</p>","esNovedad":true,"fecha":1716865200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1716928537429,"usuarioCreacion":11,"fechaCreacion":1716928535261,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":119358,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29102557,"numeroExpediente":65136,"anioExpediente":1997,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":10961,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - SOBRESEIDO: MAGALLANES ERNESTO RODRIGO Y OTROS s/HOMICIDIO SIMPLE QUERELLANTE: SALAS ELIO EDISON Y OTROS","verificacionMesa":"N","etiqueta":null,"hijos":[],"ol