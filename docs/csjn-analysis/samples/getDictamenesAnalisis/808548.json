[{"codigo":8085482,"analisisDocumental":{"id":808548,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":41,"codigoRelacion":80041,"valor":"DECLARA INEXISTENCIA","activo":"S","usuarioCreacion":"JURJ3F","usuarioMod":"JURJ3F","fechaCreacionLong":202509111053,"fechaModLong":202509111053,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"SUSANA CARRILLO DE QUEVEDO CORNEJO (HOY SU SUCESION) c/ BUSTAMANTE, CARLOS CIPRIANO, CRUZ SANTIAGO s/ACCION REIVINDICATORIA","inconstitucional":false,"falloDestacado":{"id":8641,"titulo":"Auto denegatorio del recurso extraordinario: omisión del traslado y firma de un solo vocal del tribunal","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal provincial tuvo por no presentado por extemporáneo un recurso extraordinario.</p><p style=\"text-indent:2em\">Ante el planteo de un recurso de queja la Corte declaró la inexistencia de dicho pronunciamiento y remitió las actuaciones al tribunal de origen para que, por medio de quien corresponda, se dicte una nueva decisión.</p><p style=\"text-indent:2em\">Tuvo en cuenta para ello la omisión en que incurrió el a quo al haber prescindido del trámite previsto por el art. 257 del Código Procesal Civil y Comercial de la Nación sin haber dado razones válidas para ello y también que la providencia fue firmada solo por una vocal del tribunal colegiado. </p>","esNovedad":true,"fecha":1746673200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1747067372477,"usuarioCreacion":11,"fechaCreacion":1746728553924,"privado":false,"posicion":0,"resumen":{"idResumen":133,"resumen":"La Corte declaró la inexistencia del pronunciamiento que declaró extemporáneo el recurso extraordinario, por omisión del trámite del art. 257 CPCCN y firma de una sola vocal.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":136800,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31350647,"numeroExpediente":76137,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":639,"descripcion":"NULIDAD DE ACTO JURIDICO","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 2 - Incidente Nº 2 - TABOADA FELIX DAMIAN Y OTRO c/ ARAMBURU, CARLOS EUGENIO Y OTROS s/EJECUCION DE HONORARIOS - INCIDENTE CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"76137. "},"recurso":{"id":5279572,"expediente":{"id":31350647,"numeroExpediente":76137,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJui