[{"codigo":7673302,"analisisDocumental":{"id":767330,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"BADOZA EDUARDO RAUL c/ EN-M§ J Y DDHH-RESOL 1653/06 s/EMPLEO PUBLICO","alias":null,"caratula":"BADOZA EDUARDO RAUL c/ EN-M§ J Y DDHH-RESOL 1653/06 s/EMPLEO PUBLICO","inconstitucional":false,"falloDestacado":{"id":2345,"titulo":"Empleo público: asignación de funciones y nivel escalafonario","cabecilla":"<p>Sentencia de c&aacute;mara que rechaz&oacute; la petici&oacute;n de reencasillamiento o, en su defecto, el pago de una suma eventual por tareas extraordinarias - R&eacute;gimen de Est&iacute;mulos para el personal del Ministerio de Justicia - Fundamento en que el nomenclador de funciones del r&eacute;gimen de est&iacute;mulos s&oacute;lo serv&iacute;a para facilitar la tarea de encasillar a los agentes en cada subgrupo, sin impedir que las funciones descriptas en un grupo puedan ser tambi&eacute;n cumplidas por personas encasilladas en otro grupo - Es criterio de hermen&eacute;utica que la primera fuente de interpretaci&oacute;n de la ley es su letra, de la que no cabe apartarse cuando ella es clara, sin que sea admisible una inteligencia que equivalga a prescindir de &eacute;sta - La ex&eacute;gesis de la norma debe practicarse sin violaci&oacute;n de sus t&eacute;rminos o su esp&iacute;ritu - La asignaci&oacute;n de funciones encomendada al recurrente no implic&oacute; un cambio de categor&iacute;a de mayor jerarqu&iacute;a ya que, al no tratarse de una designaci&oacute;n, la asignaci&oacute;n no signific&oacute; un ascenso ni una modificaci&oacute;n de su nivel escalafonario ni un reencasillamiento - El incentivo no se paga en funci&oacute;n de la funci&oacute;n ejercida, como sostiene el recurrente, sino por la funci&oacute;n conforme al nomenclador de funciones del sistema nacional de profesi&oacute;n administrativa - Se confirma la sentencia apelada - Disidencia del juez Rosatti: recurso extraordinario inadmisible (art. 280 CPCCN).</p>","esNovedad":true,"fecha":1625108400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1625228565589,"usuarioCreacion":4,"fechaCreacion":1625228299422,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31380,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":11211610,"numeroExpediente":5877,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en