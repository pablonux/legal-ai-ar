[{"codigo":7965793,"analisisDocumental":{"id":796579,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"MIÑO, MANUEL ALEJANDRO s/lesiones graves en grado de tentativa ","inconstitucional":false,"falloDestacado":{"id":6801,"titulo":"Sentencia arbitraria: violencia de género e insuficiencia de la retractación de la víctima","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal provincial absolvió a quien había sido condenado por el delito de tentativa de lesiones graves doblemente agravadas por el vínculo y por mediar violencia de género.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto el pronunciamiento por considerarlo arbitrario.</p><p style=\"text-indent:2em\">Señaló que se había fundado en la retractación de la víctima en el juicio oral, sin considerar su real alcance en el contexto de violencia de género en la que estaba inmersa, que no sólo explicaba esta retractación sino que también agravaba el delito imputado.</p><p style=\"text-indent:2em\">En tal sentido, se ha considerado que corresponde indagar sobre los motivos que llevaron a la víctima a retractarse, ya que éstos pueden ser una manifestación de la violencia denunciada a través de coacciones o intimidaciones ejercidas por el agresor para que retire la denuncia.</p><p style=\"text-indent:2em\">Tuvo en cuenta además que se habían valorado los elementos de convicción incorporados al debate en forma parcial y sin visión de conjunto, omitiendo distintos informes donde se describía la problemática y el historial de violencia del grupo familiar y también actuaciones de los juzgados de familia e instrucción.</p><p style=\"text-indent:2em\">Agregó por último que la sentencia absolutoria recurrida desatendía la obligación establecida por la Convención de Belém do Pará que obliga a actuar con la debida diligencia para prevenir, investigar y sancionar la violencia de género.</p>","esNovedad":true,"fecha":1715050800000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1715184689025,"usuarioCreacion":4,"fechaCreacion":1715095788207,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":120461,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35021724,"numeroExpediente":1137,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuici