[{"codigo":8234345,"analisisDocumental":{"id":823434,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GOBIERNO DE LA CIUDAD DE BUENOS AIRES c/ ESTADO NACIONAL (MINISTERIO DEL INTERIOR) s/REPETICION","inconstitucional":false,"falloDestacado":{"id":10262,"titulo":"Repetición contra el Estado Nacional por parte de la Ciudad de Buenos Aires: causa ajena a la competencia originaria de la Corte","cabecilla":"<p style=\"text-indent:2em\">El Gobierno de la Ciudad Autónoma de Buenos Aires (GCBA) promovió una acción de regreso contra el Estado Nacional con el objeto de obtener el pago de la suma abonada en virtud de lo ordenado en las sentencias de los juicios por daños y perjuicios iniciados y tramitados como consecuencia del siniestro ocurrido el 30 de diciembre de 2004 en el local “República de Cromañón” ubicado en dicha ciudad. Destacó que dio en pago el 100% del monto de condena dado que el Estado Nacional no mostró intención de cumplir con la obligación a su cargo, por lo que resultaría procedente la acción de repetición por la parte proporcional que le correspondía afrontar según el porcentaje de concurrencia de su responsabilidad.</p><p style=\"text-indent:2em\">La Corte declaró que la causa no corresponde a su competencia originaria.</p><p style=\"text-indent:2em\">Señaló que las actuaciones tienen como antecedente inmediato las sentencias dictadas en los distintos procesos que tramitaron ante el fuero contencioso administrativo federal, en los que la actora y el demandado tuvieron participación como demandado y tercero citado, respectivamente y concluyó que al ser un proceso en el que se persigue la repetición de lo pagado, la aplicación del principio de la <em>perpetuatio iurisdictionis</em> determina la continuidad de la competencia de los tribunales que han intervenido en las causas.</p>","esNovedad":true,"fecha":1772074800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1772201500014,"usuarioCreacion":4,"fechaCreacion":1772131173463,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":152620,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36770662,"numeroExpediente":1363,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"GOBIERNO DE LA CIUDAD DE BUENOS AIRES c/ ESTADO NACIONAL (MINISTERIO DEL INTERIOR) s/REPETICION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1363. "},"recurso":{"id":6351444,"expediente":{"id":36770662,"numeroExpediente":1363,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Sup