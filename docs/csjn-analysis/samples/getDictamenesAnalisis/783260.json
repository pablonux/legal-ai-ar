[{"codigo":7832603,"analisisDocumental":{"id":783260,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Legajo Nº 127 - IMPUTADO: BILESIO , MARIO JOSÉ Y OTROS s/LEGAJO DE APELACION","inconstitucional":false,"falloDestacado":{"id":6281,"titulo":"Delitos de lesa humanidad: prueba de la existencia de una asociación ilícita","cabecilla":"<p> </p><p>    La cámara de casación confirmó el sobreseimiento de los acusados de haber integrado una asociación ilícita por hechos de lesa humanidad al considerar no habrían actuado en base a un acuerdo previo de voluntades sino que sus acciones constituyeron el cumplimiento de órdenes emanadas del derrocado gobierno constitucional.</p><p>    La Corte, por mayoría, dejó sin efecto este pronunciamiento.</p><p>  En su sentencia, <em>consideró que carecía de todo fundamento la exigencia de que el acuerdo de voluntades fuera únicamente expreso en tanto no hay ninguna razón para que éste no pueda ser tácito</em>. Expresó asimismo, que existía un claro apartamiento de las constancias comprobadas de la causa, dado que ellas no permitían descartar en el estado del proceso que los imputados hubieran integrado una asociación ilícita. En tal contexto, señaló que no importaba tampoco si algunos de los procesados habían llevado la iniciativa y sellaron el pacto asociativo expresamente y otros habían adherido más tarde incluso de manera tácita.</p>","esNovedad":true,"fecha":1702522800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1702663256245,"usuarioCreacion":4,"fechaCreacion":1702584067013,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":108320,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34177774,"numeroExpediente":15000004,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":13,"codigo":"13","abreviatura":"FBB","descripcion":"Justicia Federal de Bahia Blanca","estado":0,"descripcionLarga":"FBB - Justicia Federal de Bahia Blanca"},"objetoJuicio":{"id":3460,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Legajo Nº 127 - IMPUTADO: BILESIO , MARIO JOSÉ Y OTROS s/LEGAJO DE APELACION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"15000004. "},"recurso":{"id":5706310,"expediente":{"id":34177774,"numeroExpediente":15000004,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":13,"codigo"