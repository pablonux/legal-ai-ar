[{"codigo":8058493,"analisisDocumental":{"id":805849,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 4 -  IMPUTADO: GRIEGO, BRANDON O, MAXIMILIANO PEREYRA s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":8302,"titulo":"Incompetencia de la justicia federal ante la falta de afectación de las actividades de una embajada o de sus funcionarios","cabecilla":"<p style=\"text-indent:2em\">A partir de la aprehensión de quien habría ingresado mediante escalamiento de un muro y una reja al interior del predio de una embajada se originó una contienda negativa de competencia entre la justicia en lo criminal federal y la justicia en lo criminal y correccional, ambas de la Ciudad de Buenos Aires.</p><p style=\"text-indent:2em\">La Corte dispuso que continúe conociendo en las actuaciones la justicia nacional. </p><p style=\"text-indent:2em\">Tuvo en cuenta para ello que los estados extranjeros y sus representaciones diplomáticas no revisten la calidad de aforados en los términos de los artículos 116 y 117 de la Constitución Nacional y 24, inciso 1°, del decreto- ley 1285/58 y que de acuerdo a las particularidades del hecho no surgía que se hubieran afectado las actividades propias de la embajada o de sus funcionarios.</p>","esNovedad":true,"fecha":1740625200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1740750630973,"usuarioCreacion":4,"fechaCreacion":1740687060734,"privado":false,"posicion":1,"resumen":{"idResumen":103,"resumen":"La Corte resolvió que la justicia nacional continúe interviniendo en la causa originada por la aprehensión de una persona en la embajada. El hecho no afectó las actividades propias de la embajada, ni sus funcionarios, y los estados extranjeros no son aforados.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":132487,"secretaria":{"id":209,"tipo":"S","descripcion":"Sec. Penal Especial","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal Especial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38345043,"numeroExpediente":18130,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":26,"codigo":"26","abreviatura":"FSM","descripcion":"Justicia Federal de San Martin","estado":0,"descripcionLarga":"FSM - Justicia Federal de San Martin"},"objetoJuicio":{"id":7081,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Incidente Nº 23 -  IMPUTADO: ALASIO, JOSE LUIS s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"18130. "},"recurso":{"id":6720049,"expediente":{"id":38345043,"numeroExpediente":18130,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":26,"codigo":"26","abreviatura":"FSM","descripcion":"Justicia Federal de San M