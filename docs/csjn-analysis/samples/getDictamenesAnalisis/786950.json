[{"codigo":7869502,"analisisDocumental":{"id":786950,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"FERRARA, PABLO Y OTRO c/ ESTADO NACIONAL Y OTROS s/AMPARO AMBIENTAL - (EXPEDIENTE DIGITAL)","inconstitucional":false,"falloDestacado":{"id":5722,"titulo":"Improcedencia de la competencia originaria para entender en un amparo colectivo ambiental","cabecilla":"<p>Un habitante de la República Argentina y una asociación civil constituida para defender el derecho a un ambiente sano, promueven acción de amparo colectivo ambiental contra el Estado Nacional a fin de obtener que, a través de los órganos estatales competentes, se lleven a cabo acciones con el fin de lograr el cese del gravísimo daño ambiental que entienden viene produciendo la sistemática pesca ilegal llevada a cabo por embarcaciones y flotas extranjeras en la Zona Económica Exclusiva Argentina (ZEE). La Corte entendió que la causa resulta <b>ajena a su competencia originaria</b>. Consideró para ello que se demanda al Estado Nacional, que sólo es aforado al fuero federal, por lo que no se configura ninguno de los supuestos que, con arreglo a lo dispuesto por el constituyente, habilitan la tramitación del pleito ante los estrados del Tribunal. Con respecto a la citación de algunas provincias como terceros sostuvo que no se había aportado prueba acerca del daño ambiental colectivo denunciado con relación a ellas, ni la afectación que justifique su citación en la causa en dicha calidad. </p>","esNovedad":true,"fecha":1691463600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1691522874134,"usuarioCreacion":11,"fechaCreacion":1691521236123,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":112577,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35332263,"numeroExpediente":281,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10562,"descripcion":"AMPARO AMBIENTAL","idMateria":0,"tema":null},"caratula":"FERRARA, PABLO Y OTRO c/ ESTADO NACIONAL Y OTROS s/AMPARO AMBIENTAL - (EXPEDIENTE DIGITAL)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"281. "},"recurso":{"id":5983335,"expediente":{"id":35332263,"numeroExpediente":281,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10562,"descripcion":"AMPARO AMBIENTAL","idMateria":0,"tema":null},"caratula":"FERRARA, PABLO Y OTRO c/ ESTADO NACIONAL Y OTROS s/AMPARO AMBIENTAL - (EXPEDIENTE DIGITAL)","verificacionMesa":"N","etiqueta":null,"hijos":[],"old