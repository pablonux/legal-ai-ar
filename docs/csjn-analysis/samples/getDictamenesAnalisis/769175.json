[{"codigo":7691752,"analisisDocumental":{"id":769175,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"ALBARENQUE, CLAUDIO DARIO s/RECURSO EXTRAORDINARIO DE INAPLICABILIDAD DE LEY EN CAUSA N° 16263 DE LA CAMARA DE APELACION Y GARANTIAS EN LO PENAL DE MAR DEL PLATA","alias":null,"caratula":"ALBARENQUE, CLAUDIO DARIO s/RECURSO EXTRAORDINARIO DE INAPLICABILIDAD DE LEY EN CAUSA N° 16263 DE LA CAMARA DE APELACION Y GARANTIAS EN LO PENAL DE MAR DEL PLATA","inconstitucional":false,"falloDestacado":{"id":2761,"titulo":"La prohibición de la “reformatio in peius” en el  proceso penal","cabecilla":"<p>Sentencia condenatoria recurrida &uacute;nicamente por el defensor -&nbsp;Resoluci&oacute;n de la c&aacute;mara de apelaciones que declar&oacute; la nulidad de la sentencia por considerar que la pena de prisi&oacute;n de tres a&ntilde;os impuesta se hallaba por debajo del m&iacute;nimo -&nbsp;Interposici&oacute;n por el defensor de un recurso de inaplicabilidad de ley en el que aleg&oacute; que la c&aacute;mara resolvi&oacute;&nbsp;<em>extra petita</em>&nbsp;y en infracci&oacute;n a la prohibici&oacute;n de reformatio in peius - El recurso fue rechazado por el superior tribunal de justicia local con sustento en que la resoluci&oacute;n contra la que iba dirigida no era la sentencia definitiva -&nbsp;Contra este pronunciamiento, la defensa interpuso el recurso ante la Corte Suprema, que resolvi&oacute; que el tribunal deb&iacute;a pronunciarse sobre el agravio vinculado con la prohibici&oacute;n de reformatio in peius -&nbsp;Nuevo rechazo del recurso de inaplicabilidad de ley -&nbsp;Conforme al principio dispositivo que rige la actividad recursiva y se expresa con el aforismo&nbsp;<em>tantum devolutum quantum apellatum</em>, la c&aacute;mara de apelaciones carece de jurisdicci&oacute;n&nbsp; para pronunciarse sobre un tema que no le es planteado por el recurrente - Al anular la pena sin que mediara recurso acusatorio, empeorando de ese modo la situaci&oacute;n legal del condenado, &uacute;nico recurrente, la c&aacute;mara ha incurrido en un supuesto de reformatio in peius (doctrina de&nbsp;<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoSumario.html?idDocumentoSumario=31451\">Fallos: 308:521</a>) que descalifica la sentencia como acto jurisdiccional v&aacute;lido - Se deja sin efecto la sentencia apelada.</p>","esNovedad":true,"fecha":1631761200000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1632241033935,"usuarioCreacion":11,"fechaCreacion":1631881911069,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31944,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Ju