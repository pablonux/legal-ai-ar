[{"codigo":7600122,"analisisDocumental":{"id":760012,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"Cornacchione, Ana María c/ Municipalidad de Marcos Paz s/ acción contencioso administrativa ","alias":null,"caratula":"CORNACCHIONE, ANA MARIA c/ MUNICIPALIDAD DE MARCOS PAZ s/ACCION CONTENCIOSO ADMINISTRATIVA","inconstitucional":false,"falloDestacado":{"id":1483,"titulo":"Ausencia de afectación de un interés jurídicamente protegido en el cuestionamiento del estatus de club de campo de un barrio","cabecilla":"Decisión que al admitir la demanda declaró la nulidad de la ordenanza y de toda otra regulación emanada de la municipalidad demandada mediante la cual se hubiera conferido estatus de club de campo - Fundamento de la decisión en no haber sido formulada la petición por una entidad que representara a todos los propietarios del mismo - Falta de gravamen determinado, real y sustancial que los hechos contenidos en la demanda irrogarían a la actora - La actora no invocó la existencia de un menoscabo cierto y concreto a sus derechos - Omisión del a quo de dar tratamiento a este planteo pese a que resultaba conducente para la resolución del litigio - La actora no explica de qué modo tangible sus derechos habrían sido afectados a través de las normas y los actos que impugna - Falta de invocación y acreditación de alguna consecuencia dañosa que resulte mensurable y jurídicamente relevante en relación al cerramiento del área o a la transferencia de la responsabilidad por la prestación de los servicios habitualmente a cargo de la comuna - Se advierte que los efectos de una decisión contraria a la adoptada alterarían relaciones jurídicas consolidadas desde el dictado de ordenanza cuestionada hace más de veinticinco años, y afectarían en forma directa a unas seiscientas treinta familias, que en forma permanente o temporaria residen en el club de campo y de buena fe adquirieron sus derechos - Se deja sin efecto la sentencia apelada y se rechaza la demanda - Disidencia del juez Rosatti: recursos extraordinarios inadmisibles (art. 280 CPCCN)","esNovedad":true,"fecha":1601521200000,"relevancia":2,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29296,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":26941352,"numeroExpediente":3192,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10882,"descripcion":"ACCION CONTENCIOSO ADMINISTR