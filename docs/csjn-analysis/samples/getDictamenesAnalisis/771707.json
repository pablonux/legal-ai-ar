[{"codigo":7717072,"analisisDocumental":{"id":771707,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"SOSA, FERNANDO PABLO c/ MONDELEZ ARGENTINA S.A. s/DESPIDO","alias":null,"caratula":"SOSA, FERNANDO PABLO c/ MONDELEZ ARGENTINA S.A. s/DESPIDO","inconstitucional":false,"falloDestacado":{"id":3303,"titulo":"Tope al cálculo de las indemnizaciones por despido sin justa causa y confiscatoriedad","cabecilla":"<p>Ante la sentencia de c&aacute;mara que elev&oacute; el monto de condena por despido sin causa y declar&oacute; la inconstitucionalidad del art&iacute;culo 245, p&aacute;rrafos segundo y tercero, de la Ley 20.744 de Contrato de Trabajo (LCT) en cuanto impone un tope a la base de la indemnizaci&oacute;n por antig&uuml;edad equivalente a 3 veces la remuneraci&oacute;n mensual promedio del convenio colectivo aplicable al trabajador, la demandada interpuso un recurso extraordinario. La Corte, por unanimidad y con remisi&oacute;n al dictamen de la Procuraci&oacute;n,&nbsp;<strong>declar&oacute;&nbsp;formalmente admisible el recurso extraordinario y dej&oacute; sin efecto la sentencia apelada</strong>. Record&oacute; que en el precedente &quot;Vizzoti&quot; (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=5665251&amp;cache=1639684291289\">Fallos: 327:3677</a>) hab&iacute;a declarado la invalidez de dicho tope, al considerar que permitir que el importe del salario devengado regularmente por el trabajador resulte disminuido en m&aacute;s de un tercio significar&iacute;a consentir un instituto jur&iacute;dico que terminar&iacute;a incumpliendo con el deber inexcusable del art&iacute;culo 14 bis de la Constituci&oacute;n Nacional, acerca de que el trabajo gozar&aacute; de la protecci&oacute;n de las leyes. Sin embargo, el Tribunal tuvo en cuenta que&nbsp;la disminuci&oacute;n de la base indemnizatoria del actor por aplicaci&oacute;n del tope representar&iacute;a un 21,33%, lo que constitu&iacute;a un porcentaje inferior al l&iacute;mite se&ntilde;alado por la doctrina referida, por lo que no correspond&iacute;a en el caso la declaraci&oacute;n de invalidez de la norma. Agreg&oacute; adem&aacute;s que el tribunal debi&oacute; demostrar que la restricci&oacute;n impuesta por el legislador y la distinci&oacute;n establecida respecto de los trabajadores de mayores ingresos resultaba arbitraria, desproporcionada y carec&iacute;a de una justificaci&oacute;n objetiva y razonable.</p>","esNovedad":true,"fecha":1639623600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1640001101488,"usuarioCreacion":11,"fechaCreacion":1639684328128,"privado":false,"posici