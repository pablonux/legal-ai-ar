[{"codigo":7798002,"analisisDocumental":{"id":779800,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"CODIUNNE c/ (ISSUNNE) - Y/O UNIVERSIDAD NACIONAL DEL NORDESTE s/ AMPARO por MORA de la ADMINISTRACIÓN","alias":null,"caratula":"Recurso Queja Nº 3 - CODIUNNE c/ (ISSUNNE)- Y/O UNIVERSIDAD NACIONAL DEL NORDESTE s/AMPARO por MORA de la ADMINISTRACION","inconstitucional":false,"falloDestacado":{"id":4782,"titulo":"Injustificado rigor formal en el marco del acceso a la información pública","cabecilla":"<p>Ante la falta de respuesta a un pedido de acceso a la información solicitado a una universidad, la interesada promovió un amparo que fue rechazado por la cámara de apelaciones por considerar que la acción había devenido abstracta y que  la impugnación del acto denegatorio de acceso a la información pública debía tramitar por la vía correspondiente. Recurrida esta decisión, <b>la Corte la revocó</b>. Tuvo en cuenta para ello, que el accionante, previo a la sustanciación de la acción, se había presentado ante el juez de primera instancia a fin de impugnar el acto por el cual se había denegado el pedido de acceso a la información pública y requirió que se le ordene a la demandada que, en el plazo de 10 días, otorgue la información solicitada. Estimó entonces el Tribunal que la decisión de la cámara que, transcurridos más de quince meses desde la resolución atacada, instó al actor a iniciar un nuevo proceso a fin de atacar el acto denegatorio, trasuntaba un injustificado rigor formal. Recordó que  no puede perderse de vista que la ley de Derecho de Acceso a la Información Púbica consagra una vía judicial rápida y expedita para la impugnar las decisiones que denieguen el acceso a la información pública.</p>","esNovedad":true,"fecha":1667876400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1668002097938,"usuarioCreacion":11,"fechaCreacion":1667994463426,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":104981,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32070269,"numeroExpediente":47444,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"ca