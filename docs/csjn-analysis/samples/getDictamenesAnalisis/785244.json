[{"codigo":7852443,"analisisDocumental":{"id":785244,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - GALLO VICTOR ALEJANDRO s/INCIDENTE DE REVISION DE COMPUTO DE PENA","inconstitucional":false,"falloDestacado":{"id":6022,"titulo":"Unificación de penas: delitos de carácter permanente","cabecilla":"<p>El tribunal oral unificó las penas impuestas a un condenado en una pena única y los acusadores público y privado impugnaron lo decidido porque consideraron que no se verificaba ninguno de los supuestos previstos en el artículo 58 del Código Penal. Ante el rechazo del recurso por parte de la cámara de casación la querellante interpuso un recurso extraordinario. Planteó que cuando el interesado resulta condenado por delitos de carácter permanente, a los efectos de la unificación de penas se debe tener en cuenta la fecha en que tales delitos cesaron de cometerse, por lo que carecería de relevancia que los ilícitos por los que fue condenado el acusado en los otros procesos previos se hayan consumado cuando aquéllos ya habían comenzado a cometerse pero sin haber cesado aún. La Corte dejó sin efecto la sentencia recurrida. Consideró que no puso en discusión esas circunstancias fácticas, sino que afirmó la existencia de un concurso real entre todos los delitos con base en que aquellos por los que había sido condenado en los otros procesos previos se cometieron cuando todavía no habían cesado de cometerse los que se le imputaron en esta causa. Sostuvo que, al resolver de ese modo, había omitido responder a la objeción de la querella que contradecía su fundamento.</p>","esNovedad":true,"fecha":1697684400000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1697746499126,"usuarioCreacion":4,"fechaCreacion":1697745193717,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":110738,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31978248,"numeroExpediente":3692,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - GALLO VICTOR ALEJANDRO s/INCIDENTE DE REVISION DE COMPUTO DE PENA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentif