[{"codigo":7823742,"analisisDocumental":{"id":782374,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"COLEGIO DE ABOGADOS DE MAR DEL PLATA c/ ANSES Y OTRO s/ AMPARO LEY 16.986","alias":null,"caratula":"COLEGIO DE ABOGADOS DE MAR DEL PLATA c/ ANSES Y OTRO s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":5182,"titulo":"Registro para actuar ante la ANSeS y potestades para la regulación de la matrícula profesional","cabecilla":"<p>Ante el planteo del Colegio de Abogados del Departamento Judicial de Mar del Plata la cámara declaró la inconstitucionalidad de las normas de la Administración Nacional de la Seguridad Social (ANSES) y otras dictadas en su consecuencia, que habían creado un<b> registro de abogados y de gestores administrativos habilitados</b> para actuar ante dicha dependencia. La demandada interpuso un recurso extraordinario y la Corte dejó sin efecto la decisión apelada. Consideró que no puede afirmarse que la ANSES desconozca o invada las potestades provinciales en la regulación de la matrícula local en tanto se trata de exigencias adicionales que únicamente deben cumplirse cuando se realicen trámites ante sus propias dependencias. Agregó que la inscripción en el registro cuestionado no significa matriculación alguna, de hecho, entre los requisitos para la inscripción resulta menester formar parte de un colegio de abogados, lo que se acredita con una credencial o certificación de la debida matriculación o ambas cosas.</p>","esNovedad":true,"fecha":1679367600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1679501572962,"usuarioCreacion":4,"fechaCreacion":1679431209565,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":107323,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24370032,"numeroExpediente":25070,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8765,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":380,"codigo":"AMPAROS"}},"caratula":"COLEGIO DE ABOGADOS DE MAR DEL PLATA c/ ANSES Y OTRO s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"25070. "},"recurso":{"id":5056802,"expediente":{"id":24370032,"numeroExpediente":25070,"anioExpediente":2014,"tomoExpediente":null,"letra