[{"codigo":7926972,"analisisDocumental":{"id":792697,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 1 - ACTOR: ACEVEDO, PATRICIA MABEL DEMANDADO: VAZQUEZ LAVERA, MARIANO RUBEN s/EJECUCION DE ALIMENTOS - INCIDENTE","inconstitucional":false,"falloDestacado":{"id":6322,"titulo":"Ejecución de alimentos y centro de vida de la niña","cabecilla":"<p>     </p><p>     En el marco de un conflicto negativo de competencia suscitado durante la ejecución de alimentos la Corte consideró que adquiría plena virtualidad el temperamento que otorga primacía al <em>lugar donde habita efectivamente la niña</em>, ya que la <em>inmediación judicial</em> contribuye a la eficacia de la actividad protectoria.</p><p>     Recordó el Tribunal que el enfoque propuesto resulta coherente con las directivas del Código Civil y Comercial de la Nación en tanto consagra como princi