[{"codigo":8054322,"analisisDocumental":{"id":805432,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":80006,"valor":"HACE LUGAR A  LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008251405,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"BUNGE ARGENTINA S.A. c/ CHACO, PROVINCIA DEL s/ACCION DECLARATIVA DE CERTEZA","inconstitucional":false,"falloDestacado":{"id":8164,"titulo":"Transporte interprovincial y pretensión de aplicar normativa local","cabecilla":"<p style=\"text-indent:2em\">La empresa actora promovió una acción declarativa de certeza contra la Provincia del Chaco, a fin de que se declare que carece de atribuciones para regular las tarifas aplicables al transporte interprovincial de carga de productos primarios sin procesar o semiprocesados (granos y oleaginosas).</p><p style=\"text-indent:2em\">La Corte, en el marco de su competencia originaria, <b>hizo lugar a la demanda y consideró que la pretensión de aplicar la normativa local resultaba violatoria de lo dispuesto en la Constitución Nacional respecto del reparto de competencias entre el Estado Nacional y las provincias</b>.</p><p style=\"text-indent:2em\">Recordó que la regulación del tránsito interprovincial de productos en general está alcanzada por los poderes que el artículo 75, inc. 13 de la Constitución Nacional confiere al gobierno central y que el tránsito que se inicia en una provincia y concluye en otra no atribuye jurisdicción local a cada una de ellas, sino que es la jurisdicción nacional la que alcanza a los servicios en los aspectos locales de su tráfico, en cuanto éste es inescindible del cometido nacional de la empresa</p><p style=\"text-indent:2em\">De no ser ello así, se obstaculizaría la actividad comercial que aquélla cumple, afectándose de ese modo el desenvolvimiento del transporte interprovincial de carga y, en definitiva, el objetivo constitucional de asegurar un régimen que mantenga y consolide la unión nacional. </p>","esNovedad":true,"fecha":1735268400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1735575999159,"usuarioCreacion":11,"fechaCreacion":1735563435648,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":132019,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28419610,"numeroExpediente":779,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION DECLARATIVA DE CERTEZA","idMateria":0,"tema":null},"caratula":"BUNGE ARGENTINA S.A. c/ CHACO, PROVINCIA DEL s/ACCION DECLARATIVA DE CERTEZA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"779. "},"recurso":{"id":4855749,"expediente":{"id":28419610,"numeroExpediente":779,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia 