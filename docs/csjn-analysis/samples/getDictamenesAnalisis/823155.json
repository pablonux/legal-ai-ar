[{"codigo":8231553,"analisisDocumental":{"id":823155,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - TAPIA ARAYA, JOSUE NAHUN ELIAS ENOC c/ STARBUCKS COFFEE ARGENTINA SRL s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":10321,"titulo":"Daños y perjuicios derivados de un robo en un local comercial","cabecilla":"<p style=\"text-indent:2em\">La cámara condenó a una cafetería a abonar una suma por los daños y perjuicios derivados del robo a mano armada sufrido por el actor en el interior del local. Sostuvo que era responsable de los daños sufridos por la sustracción de los efectos del cliente en virtud de las normas relativas al depósito necesario, concordantes con las normas sobre protección de los consumidores y descartó que el hecho constituyera un supuesto de caso fortuito o de fuerza mayor. </p><p style=\"text-indent:2em\">La Corte descalificó esta decisión con fundamento en la doctrina sobre la arbitrariedad de sentencias.</p><p style=\"text-indent:2em\">Señaló que se fundaba en una afirmación dogmática relativa a que un robo a mano armada no es un acontecimiento inevitable, lo que eximiría de responsabilidad a la demandada en los términos del artículo 1730 del Código Civil y Comercial de la Nación, pues podía adoptar “mecanismos de seguridad” y capacitar al “personal en que delega la efectiva vigilancia”. </p><p style=\"text-indent:2em\">Consideró que tal aseveración resultaba manifiestamente insuficiente para explicar cómo la demandada podría haber razonablemente evitado el hecho ilícito de un tercero que, con un arma de fuego, entró al establecimiento comercial y sustrajo un efecto del consumidor actor, máxime ante la alegación relativa a que el derecho local de la Ciudad Autónoma de Buenos Aires no le permite contar con empleados de seguridad armados en el establecimiento donde ocurrieron los hechos.</p><p style=\"text-indent:2em\">Agregó el Tribunal que tampoco se explicó de qué manera un robo a mano armada sería “una contingencia propia del riesgo de la cosa o la actividad” de un establecimiento comercial como el de la demandada a fin de descartar la eximente de responsabilidad por caso fortuito o fuerza mayor en los términos del artículo 1733, inciso e, del Código Civil y Comercial de la Nación.</p>","esNovedad":true,"fecha":1772679600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1773145521158,"usuarioCreacion":11,"fechaCreacion":1772734871483,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":152199,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33395560,"numeroExpediente":39889,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":