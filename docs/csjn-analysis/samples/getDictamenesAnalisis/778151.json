[{"codigo":7781512,"analisisDocumental":{"id":778151,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"ASOCIACION DE USUARIOS Y CONSUMIDORES DE LA PROVINCIA DE CORRIENTES c/ DIRECCION PROVINCIAL DE ENERGIA DE CORRIENTES Y ESTADO DE LA PROVINCIA DE CORRIENTES s/ AMPARO","alias":null,"caratula":"ASOCIACION DE USUARIOS Y CONSUMIDORES DE LA PROVINCIA DE CORRIENTES c/ DIRECCION PROVINCIAL DE ENERGIA DE CORRIENTES Y ESTADO DE LA PROVINCIA DE CORRIENTES s/AMPARO","inconstitucional":false,"falloDestacado":{"id":4562,"titulo":"Sentencia arbitraria: modificación en la ejecución de sentencia de una cuestión firme","cabecilla":"<p>Si bien las decisiones recaídas en los procesos de ejecución de sentencia no son, en principio, revisables en la instancia extraordinaria por no revestir el carácter de definitivas, la Corte revocó la sentencia apelada por cuanto el tribunal provincial, por un lado confirmó el pronunciamiento de primera instancia que ordenó la devolución a la actora de lo facturado en exceso en tres cuotas, dejando firme esta cuestión; y por el otro, posteriormente, durante la ejecución de sentencia, frente a un planteo de la codemandada, modificó el criterio apuntado, optando por otro, que difería del originalmente admitido, al establecer dicha devolución en 12 cuotas, en clara afectación a la garantía de la cosa juzgada de raigambre constitucional. En tales condiciones, consideró el Tribunal, la condena pronunciada a favor de una de las partes sobre un punto que había pasado en autoridad de cosa juzgada importa un desconocimiento de resoluciones anteriores firmes, que afecta los derechos de defensa en juicio y de propiedad de la actora consagrados en la Constitución Nacional.</p>","esNovedad":true,"fecha":1664247600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1664388113113,"usuarioCreacion":4,"fechaCreacion":1664308639551,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":35126,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34456796,"numeroExpediente":2814,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9482,"descripcion":"AMPARO","idMateria":4,"tema":{"id":502,"codigo":"AMPAROS"}},"caratula":"ASOCIACION DE USUARIOS Y CONSUMIDORES DE LA PROVINCIA DE CORRIENTES c/ DIRECCION PROVI