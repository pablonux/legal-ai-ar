[{"codigo":8080263,"analisisDocumental":{"id":808026,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"AYALA, ANDREA FABIANA c/ BANCO DE SERVICIOS Y TRANSACCIONES SA s/HABEAS DATA (ART. 43 C.N.)","inconstitucional":false,"falloDestacado":{"id":8644,"titulo":"Hábeas data: incompetencia del fuero federal si no se trata de bases públicas de información o interconectadas en redes interjurisdiccionales","cabecilla":"<p style=\"text-indent: 2em;\">La actora promovió acción de hábeas data a fin de obtener que un banco le brinde la información que posee en sus bases de datos respecto de su persona y rectifique los mismos en caso de existir un error o inexactitud.</p><p style=\"text-indent: 2em;\">La Cámara Nacional de Apelaciones en lo Civil y Comercial Federal confirmó la decisión del juez de primera instancia que había declarado la incompetencia del fuero y ordenado la remisión de los autos a la justicia nacional en lo comercial. </p><p style=\"text-indent: 2em;\">Ante el recurso extraordinario interpuesto por la demandante la Corte confirmó este pronunciamiento.</p><p style=\"text-indent: 2em;\">Expresó que la Ley 25.326 de Protección de los Datos Personales solo establece la competencia de excepción en los casos en que se persigue eliminar datos o contenidos que obran en bases públicas de información o interconectadas en redes interjurisdiccionales, lo que no ocurría en el caso.</p>","esNovedad":true,"fecha":1746673200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1746733496545,"usuarioCreacion":4,"fechaCreacion":1746733493915,"privado":false,"posicion":4,"resumen":{"idResumen":135,"resumen":"La Corte confirmó la incompetencia del fuero Civil y Comercial Federal en un caso de hábeas data contra un banco. La Ley 25.326 solo establece competencia federal de excepción cuando se busca eliminar datos de bases públicas o interconectadas en redes interjurisdiccionales, lo cual no se verificó en este caso.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":135918,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34946566,"numeroExpediente":15829,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateri