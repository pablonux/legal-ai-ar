[{"codigo":7798052,"analisisDocumental":{"id":779805,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"SIETE DE DICIEMBRE S.A. c/ FISCO DE LA PROVINCIA DE BUENOS AIRES s/ EXPROPIACIÓN INVERSA","alias":null,"caratula":"SIETE DE DICIEMBRE S.A. c/ FISCO DE LA PROVINCIA DE BUENOS AIRES s/EXPROPIACION INVERSA","inconstitucional":false,"falloDestacado":{"id":4744,"titulo":"Expropiación e intereses: fundamentos suficientes que descartan la tacha de arbitrariedad","cabecilla":"<p>El superior tribunal provincial dispuso que los intereses se calculen sobre el capital indemnizatorio determinado a la fecha de la desposesión del inmueble por el que se inició el juicio de expropiación inversa, aplicándose la tasa pasiva más alta fijada por el Banco de la Provincia de Buenos Aires en sus depósitos a treinta días, desde ese momento y hasta el efectivo pago. La sociedad actora interpuso recurso extraordinario fundado en que se habría omitido considerar elementos de juicio y normas conducentes y cuestionando la interpretación efectuada en el sentido de que los intereses deben calcularse sobre un capital hipotético fijado a la fecha de la desposesión. La Corte desestimó el recurso. Recordó que las cuestiones de hecho, prueba y derecho público local son ajenas, como regla y por su naturaleza, a la instancia del recurso extraordinario y que la apreciación de la tacha de arbitrariedad es particularmente restringida respecto de pronunciamientos de superiores tribunales de provincia cuando deciden sobre cuestiones de hecho y derecho público local. Consideró que no se hallaba configurado ninguno de los supuestos de excepción a esta doctrina y que la sentencia contaba con fundamentos fácticos y jurídicos mínimos que, más allá de su acierto o error o lo opinable de lo decidido, excluían la tacha de arbitrariedad invocada.</p>","esNovedad":true,"fecha":1667271600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1667407305479,"usuarioCreacion":11,"fechaCreacion":1667331765844,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":104981,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32070269,"numeroExpediente":47444,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objet