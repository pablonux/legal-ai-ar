[{"codigo":7703444,"analisisDocumental":{"id":770344,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"ADIF SE c/ GCBA s/EXPROPIACIÓN - SERVIDUMBRE ADMINISTRATIVA","alias":null,"caratula":"Recurso Queja Nº 1 - ADIF SE c/ GCBA s/EXPROPIACION-SERVIDUMBRE ADMINISTRATIVA","inconstitucional":false,"falloDestacado":{"id":2925,"titulo":"Moneda de pago de la indemnización derivada de una expropiación inversa","cabecilla":"<p>En un caso de expropiaci&oacute;n inversa, la c&aacute;mara determin&oacute; que la indemnizaci&oacute;n deb&iacute;a expresarse en pesos argentinos pues esa fue la moneda utilizada por el Tribunal de Tasaciones de la Naci&oacute;n, no obstante que&nbsp;en el fallo de&nbsp;primera instancia la indemnizaci&oacute;n fue justipreciada en d&oacute;lares estadounidenses. Contra esta sentencia, la demandante interpuso recurso extraordinario cuestionando lo resuelto respecto de la moneda de pago.&nbsp;<strong>La Corte dej&oacute; sin efecto la sentencia</strong>. Para as&iacute; decidir, consider&oacute; que la sentencia apelada omiti&oacute; evaluar si el importe resultante retribuye el valor econ&oacute;mico de que se vio privada la actora como consecuencia de la expropiaci&oacute;n, permiti&eacute;ndole, de ser posible, adquirir otro bien de similares caracter&iacute;sticas a la que pose&iacute;a aquel inmueble al momento de la desposesi&oacute;n. Tal an&aacute;lisis se impon&iacute;a, sostuvo el Tribunal, a fin de resguardar la exigencia constitucional de la &quot;<strong>justa indemnizaci&oacute;n</strong>&quot;. Es que si bien la expropiaci&oacute;n por causa de utilidad p&uacute;blica supone el ejercicio por parte del Estado de un poder jur&iacute;dico que le reconoce la Constituci&oacute;n, el sacrificio que ese poder jur&iacute;dico le impone al sujeto expropiado obliga a indemnizarlo debidamente. La soluci&oacute;n de la c&aacute;mara,&nbsp;concluye&nbsp;la Corte, ha prescindido de valorar circunstancias conducentes para la decisi&oacute;n del pleito y, por lo tanto, no satisface el requisito de debida fundamentaci&oacute;n exigible a las decisiones judiciales. En consecuencia, dej&oacute; sin efecto la sentencia apelada&nbsp;y orden&oacute; dictar un nuevo pronunciamiento.</p>","esNovedad":true,"fecha":1634785200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1637163352237,"usuarioCreacion":11,"fechaCreacion":1634909179037,"privado":false,"posicion":9,"resumen":null},"reciboEntrada":{"id":32347,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":11163168,"numeroExpediente":10727,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1116,"descripcion":"PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"RACO MARCO NICOLAS Y OTRO c/ EN-M§ SEGURIDAD-PSA-RESOL 513/09 (EXPTE SO2 441/07) s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10727. "},"recurso":{"id":5191090,"expediente":{"id":11163168,"numeroExpediente":10727,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1116,"descripcion":"PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"RACO MARCO NICOLAS Y OTRO c/ EN-M§ SEGURIDAD-PSA-RESOL 513/09 (EXPTE SO2 441/07) s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10727. "},"tipoRecurso":{"id":1166,"codigo":"REX","descripcion":"RECURSO EXTRAORDINARIO"},"claveRecurso":"CAF 010727/2011/CS001","identificacionExpediente":"CAF 010727/2011/CS001"},"piezas":4,"urgente":"N","observaciones":null,"usuarioCreacion":null,"usuarioCreacionOld":"JUR545","usuarioModificacion":null,"usuarioModificacionOld":"JUR545","fechaCreacion":202110191222,"fechaModificacion":202110191222},{"expediente":{"id":30300536,"numeroExpediente":14081,"anioExpediente":2005,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,