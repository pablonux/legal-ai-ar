[{"codigo":8193602,"analisisDocumental":{"id":819360,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"VETTORELLO, GERMAN EMANUEL c/ EN-M SEGURIDAD-PFA s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","inconstitucional":false,"falloDestacado":{"id":9841,"titulo":"Remuneraciones del personal policial: suplemento particular sin carácter remunerativo y bonificable","cabecilla":"<p style=\"text-indent:2em\">La cámara hizo lugar a la demanda promovida por el actor -personal en actividad de la Policía Federal Argentina- contra el Estado Nacional y reconoció el carácter remunerativo y bonificable del suplemento por “zona”.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto este pronunciamiento ya que consideró que ni del texto de la norma que creó el suplemento en cuestión, ni de la prueba considerada en la causa, se desprendía que lo percibiera la generalidad del personal policial en actividad.</p><p style=\"text-indent:2em\">Recordó que el carácter<b> </b>general de una asignación<b> </b>determina indudablemente su inclusión en el haber mensual, sin que sea óbice para ello su calificación normativa, en la medida en que se demuestre de un modo inequívoco que la totalidad del personal en actividad de un mismo grado o de todos los grados la percibe.</p><p style=\"text-indent:2em\">Consideró que de los términos del <a href=\"https://www.argentina.gob.ar/normativa/nacional/decreto-380-2017-275362\">decreto 380/17</a> no surge que el suplemento por “zona” haya sido otorgado a todo el personal policial en actividad de un mismo grado o de todos los grados, sino que fue previsto para que lo perciba el personal policial que sea destinado o que se encuentre destinado en determinadas regiones, es decir, como un suplemento particular de los que el artículo 77, segundo párrafo, de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-21965-45954/actualizacion\">ley 21.965</a> autoriza a crear al Poder Ejecutivo.</p>","esNovedad":true,"fecha":1763434800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1763645968044,"usuarioCreacion":11,"fechaCreacion":1763496227781,"privado":false,"posicion":8,"resumen":null},"reciboEntrada":{"id":147800,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34076504,"numeroExpediente":50080,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelacio