[{"codigo":7913912,"analisisDocumental":{"id":791391,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"SALGUERO, MANUEL DOMINGO c/ TELECOM ARGENTINA S.A. s/procedimiento sumario - accion de reinstalacion ","inconstitucional":false,"falloDestacado":{"id":6242,"titulo":"Despido discriminatorio: persecución por motivos sindicales","cabecilla":"<p>El superior tribunal provincial revocó la decisión que había determinado que el despido había obedecido a motivos discriminatorios y ordenado la reinstalación del actor en su puesto de trabajo. Consideró para ello que la empresa demandada había demostrado que el despido había obedecido a un motivo objetivo y razonable ajeno a la actividad gremial. Ante el recurso del actor la Corte dejó sin efecto esta sentencia. Afirmó que se encontraba acreditado que el recurrente desarrollaba de manera notoria actividades sindicales, y que la demandada conocía esa actividad antes de disponer el cambio de su lugar de trabajo, que había sido rechazado expresa y fehacientemente por el trabajador. Tuvo en cuenta que los argumentos brindados por la demandada no alcanzaban para desvirtuar la presunción inicial de motivo discriminatorio, en los términos de la doctrina sentada por la Corte en “Pellicori” (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=334&amp;pagina=1387\">Fallos: 334:1387</a>) y “Varela” (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=341&amp;pagina=1106\">Fallos: 341:1106</a>) en tanto el incumplimiento atribuido se había basado en la negativa de aceptar una modificación de las condiciones de labor, dispuesta en forma unilateral y arbitraria, que, de concretarse, hubiera dañado material y moralmente al actor y afectado específicamente su actividad gremial.</p>","esNovedad":true,"fecha":1701918000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1702309868123,"usuarioCreacion":11,"fechaCreacion":1701973691748,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":115948,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35075722,"numeroExpediente":1347,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMater