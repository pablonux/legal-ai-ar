[{"codigo":7674913,"analisisDocumental":{"id":767491,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"MINAS ARGENTINAS S.A. c/ MUNICIPALIDAD DE ESQUEL s/CONTENCIOSO ADMINISTRATIVO","alias":null,"caratula":"MINAS ARGENTINAS S.A. c/ MUNICIPALIDAD DE ESQUEL s/CONTENCIOSO ADMINISTRATIVO","inconstitucional":false,"falloDestacado":{"id":2341,"titulo":"Prohibición para instalar una oficina comercial e invocación de la protección del medio ambiente","cabecilla":"<p>Desestimaci&oacute;n de la acci&oacute;n promovida contra la Municipalidad de Esquel a fin de que se declarara la nulidad de las resoluciones municipales que denegaron la habilitaci&oacute;n de una oficina administrativa - Fundamento en la normativa que establece que no se otorgar&aacute; habilitaci&oacute;n comercial para el ejercicio de actividades accesorias, complementarias o conexas de actividades que se encuentren prohibidas por la legislaci&oacute;n municipal - Afirmaciones dogm&aacute;ticas que sostienen que existe accesoriedad entre la habilitaci&oacute;n comercial pretendida y la actividad minera que la actora desarrolla en una localidad vecina y que est&aacute; prohibida en el municipio demandado - La prohibici&oacute;n de la actividad minera establecida por la ordenanza local tiene por finalidad la protecci&oacute;n del medio ambiente, de los recursos naturales y de la salud humana - Omisi&oacute;n de toda explicaci&oacute;n acerca del modo en que la instalaci&oacute;n de una oficina comercial podr&iacute;a afectar los bienes jur&iacute;dicos tutelados - Principio de razonabilidad que debe regir la actividad de la Administraci&oacute;n - Se deja sin efecto la sentencia apelada - Disidencia de los jueces Maqueda y Rosatti: No puede escindirse la actividad que pretende ejecutar la actora en esa ciudad respecto de la realizada en la localidad vecina en la medida en que ambas participan de &ldquo;una interna relaci&oacute;n econ&oacute;mica&rdquo; como parte integrante de un mismo emprendimiento societario - La conclusi&oacute;n central de la sentencia no aparece rebatida en la cr&iacute;tica que desarrolla el recurrente - Argumentos no federales que resultan suficientes para sustentar la sentencia apelada.</p>","esNovedad":true,"fecha":1625108400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1625228669207,"usuarioCreacion":4,"fechaCreacion":1625224216459,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31423,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28885650,"numeroExpediente":1509,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","est