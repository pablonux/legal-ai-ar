[{"codigo":7908152,"analisisDocumental":{"id":790815,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"INDUPOLES ARGENTINA S.A. c/ TIERRA DEL FUEGO ANTARTIDA E ISLAS DEL ATLANTICO SUR, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","inconstitucional":false,"falloDestacado":{"id":6161,"titulo":"Impuesto sobre los ingresos brutos y derecho público local","cabecilla":"<p>Una empresa con domicilio en la Provincia de Buenos Aires promueve demanda contra la Provincia de Tierra del Fuego, Antártida e Islas del Atlántico Sur a raíz de la pretensión de ésta de exigirle el pago de un monto a cuenta del impuesto sobre los ingresos brutos y del “Fondo de Financiamiento de Servicios Sociales” por actividades productivas llevadas a cabo exclusivamente en territorio de la Provincia de Buenos Aires, por la sola circunstancia de que contrate con algún contribuyente que sea agente de retención en aquel Estado provincial. La Corte, por mayoría, declaró que la causa era ajena a su competencia originaria. Tuvo en cuenta que el tema planteado se vincula con el modo como Dirección General de Rentas provincial reglamentó el “sistema de ingreso en la fuente de los tributos mediante los Agentes de Retención”, planteo que exige examinar si las disposiciones de carácter general extralimitan o no las facultades y poderes reglamentarios atribuidos por el derecho público local a ese órgano.</p>","esNovedad":true,"fecha":1699930800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1699994031985,"usuarioCreacion":11,"fechaCreacion":1699994029740,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":115577,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29972757,"numeroExpediente":898,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION DECLARATIVA DE CERTEZA","idMateria":0,"tema":null},"caratula":"INDUPOLES ARGENTINA S.A. c/ TIERRA DEL FUEGO ANTARTIDA E ISLAS DEL ATLANTICO SUR, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"898. "},"recurso":{"id":5097663,"expediente":{"id":29972757,"numeroExpediente":898,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION DECLARATIVA DE CERTEZA","idMateria":0,"tema":null},"caratula":"INDUPOLES ARGENTINA S.A. c/ TIERRA DEL FUEGO ANTARTIDA E ISLAS DEL ATLANTICO SUR, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","verificacionMesa":"N","etiqueta":null,"