[{"codigo":7699223,"analisisDocumental":{"id":769922,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"PINO SEBERINO Y OTROS c/ ESTADO NACIONAL- MINISTERIO DEL INTERIOR- s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","alias":null,"caratula":"PINO SEBERINO Y OTROS c/ ESTADO NACIONAL- MINISTERIO DEL INTERIOR- s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","inconstitucional":true,"falloDestacado":{"id":2823,"titulo":"Régimen previsional de Gendarmería: inconstitucionalidad del aporte establecido por el decreto 679/97","cabecilla":"<p>Sentencia de c&aacute;mara que revoc&oacute; el fallo que hab&iacute;a declarado la inconstitucionalidad de la ley 22.788 que fij&oacute; un descuento del 8% sobre el haber mensual de los retirados y pensionados de la Gendarmer&iacute;a Nacional en car&aacute;cter de aporte personal y del decreto 679/97 que elev&oacute; dicho aporte al 11% - Recurso interpuesto por los demandantes -&nbsp;Improcedencia del cuestionamiento de la ley&nbsp;con fundamento en que hasta su dictado los actores no estaban obligados a realizar el aporte ya que la modificaci&oacute;n de una norma por otra posterior de igual jerarqu&iacute;a no da lugar a cuesti&oacute;n constitucional - Nadie tiene derecho adquirido al mantenimiento de leyes o reglamentos, ni a su inalterabilidad -&nbsp;No se encuentran satisfechos los recaudos constitucionales para el dictado del decreto de necesidad y urgencia impugnado -&nbsp;Los fundamentos dados por el Poder Ejecutivo Nacional no alcanzan para poner en evidencia que el dictado del decreto haya obedecido a la necesidad de adoptar medidas inmediatas para paliar una situaci&oacute;n de rigurosa excepcionalidad y urgencia que pusiera en riesgo el normal funcionamiento del sistema previsional sino que traducen la decisi&oacute;n de modificarlo de manera permanente, sin recorrer el cauce ordinario que la Constituci&oacute;n prev&eacute; -&nbsp;Se confirma&nbsp;la sentencia apelada en cuanto rechaz&oacute; el planteo de inconstitucionalidad de la ley 22.788 y se declara la inconstitucionalidad del decreto de necesidad y urgencia 679/97.</p>","esNovedad":true,"fecha":1633575600000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1634056159730,"usuarioCreacion":11,"fechaCreacion":1633634139638,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":32199,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":3115655,"numeroExpediente":63001541,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":2040,"descripcion":"EJ