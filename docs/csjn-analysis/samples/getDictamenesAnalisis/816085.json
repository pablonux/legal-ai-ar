[{"codigo":8160852,"analisisDocumental":{"id":816085,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 3 - Legajo Nº 7 - SOBRESEIDO: ZELAYA LUIS ALBERTO Y OTRO s/LEGAJO DE CASACION","inconstitucional":false,"falloDestacado":{"id":9483,"titulo":"Juicio criminal:  defectuosa y fragmentaria evaluación de la prueba","cabecilla":"<p style=\"text-indent:2em\">En un <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7161631\">anterior pronunciamiento la Corte</a> dejó sin efecto el rechazo del recurso de casación intentado contra la sentencia que había dispuesto el sobreseimiento de un juez en relación a hechos que se relacionarían con incumplimientos de la obligación de promover la persecución penal y la actuación con parcialidad y retardo malicioso de la administración de justicia. </p><p style=\"text-indent:2em\">Esto originó una nueva sentencia que también rechazó el recurso de casación, lo que originó la interposición por parte del fiscal de otro recurso extraordinario ante la Corte, que nuevamente dejó sin efecto esta decisión. </p><p style=\"text-indent:2em\">Expresó que había existido una parcial valoración de las pruebas para rechazar la conducta atribuida al acusado con un análisis aislado y fragmentario, que ya había sido descalificado como motivación válida en su anterior pronunciamiento en los mismos autos.</p><p style=\"text-indent:2em\">Señaló que el pronunciamiento apelado -al igual que el anterior de esa sala, con diversa integración- fue resultado de un examen parcial de la prueba, afirmaciones dogmáticas y fundamentos aparentes por los que no desvirtuó las declaraciones de funcionarios y empleados del juzgado a cargo del juez cuestionado, que dijeron que éste admitió que los imputados golpearon duramente al querellante, y que se negaba a dictar sus procesamientos debido a la repercusión que tal decisión podría tener en otra causa que tramitaba en el fuero federal. El voto mayoritario no sólo pasó por alto esos testimonios, sino que también omitió toda consideración de otras constancias de la causa. También se omitieron las declaraciones testimoniales en las que se hizo alusión a la posible amistad del juez con un imputado y las varias reuniones que mantuvieron en su despacho a puertas cerradas.</p><p style=\"text-indent:2em\">Concluyó así el Tribunal que la decisión no sólo debía ser descalificada como acto jurisdiccional válido, por ser el producto de una defectuosa y fragmentaria evaluación de la prueba y constancias de la causa, y haberse apoyado en afirmaciones dogmáticas e inferencias sin sostén jurídico, sino  que además implicó desoír el mandato impuesto por la Corte en su anterior sentencia, en el que se precisaron las pautas de fundamentación que debían ser respetadas en el nuevo pronunciamiento, lo que demuestra un manifiesto desinterés en acatar las decisiones del Tribunal que, ciertamente, implica un desconocimiento de la superior autoridad de la que está institucionalmente investido.</p>","esNovedad":true,"fecha":1759201200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1759405633160,"usuarioCreacion":4,"fechaCreacion":1759320360914,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":144658,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32804917,"numeroExpediente":13754,"anioExpediente":2004,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":10961,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 2 - Legajo Nº 7 - SOBRESEIDO: ZELAYA LUIS ALBERTO Y OTRO s/LEGAJO DE CASACION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"13754. "},"recurso":{"id":5471017,"expediente":{"id":32804917,"numeroExpediente":13754,"anioExpediente":2004,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":10961,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso