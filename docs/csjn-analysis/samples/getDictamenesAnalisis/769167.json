[{"codigo":7691672,"analisisDocumental":{"id":769167,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"MOLINOS RIO DE LA PLATA SA c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO *","alias":null,"caratula":"MOLINOS RIO DE LA PLATA SA c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","inconstitucional":false,"falloDestacado":{"id":2621,"titulo":"Impuesto a las ganancias e interpretación del convenio de doble imposición","cabecilla":"<p>Determinaci&oacute;n de oficio del impuesto a las ganancias - Necesidad de determinar si el art 11 del &ldquo;Convenio entre la Rep&uacute;blica Argentina y la Rep&uacute;blica de Chile para evitar la doble tributaci&oacute;n en materia de impuestos sobre la renta, ganancias o beneficios y sobre el capital y el patrimonio&rdquo; (&ldquo;CDI&rdquo;) imped&iacute;a al Estado Argentino gravar los dividendos originados en las acciones de las sociedades uruguayas y peruana controladas por la empresa establecida en Chile o si la actora no se encontraba amparada por esta cl&aacute;usula, y abus&oacute; de sus t&eacute;rminos en contra del Tratado y del principio de la realidad econ&oacute;mica al constituir una &ldquo;sociedad conducto&rdquo; amparada por los beneficios tributarios de la ley chilena de promoci&oacute;n de sociedades plataforma de inversiones - Ning&uacute;n tratado internacional vigente en nuestro pa&iacute;s puede ser invocado de forma abusiva - Las normas internacionales deben ser interpretadas de acuerdo con el principio de buena fe - El art&iacute;culo 11 del Tratado debe ser interpretado conforme con la buena fe y la prohibici&oacute;n del abuso&nbsp;del derecho - La buena fe como gu&iacute;a estructural de interpretaci&oacute;n de los pactos internacionales - El supuesto de hecho en la causa no ser&iacute;a evitar la doble imposici&oacute;n sino procurar doblemente una no imposici&oacute;n, por lo que no se encontrar&iacute;a alcanzada por el &aacute;mbito de validez material del CDI interpretado de buena fe - No se discute un l&iacute;mite a la potestad tributaria chilena emanado del CDI sino la actitud que puede adoptar el Estado argentino frente a la decisi&oacute;n de un contribuyente de valerse de esta legislaci&oacute;n for&aacute;nea para desvirtuar los fines del tratado bilateral suscripto y eludir sus obligaciones tributarias - Las conclusiones a las que llegaron el Tribunal Fiscal de la Naci&oacute;n y la C&aacute;mara Nacional de Apelaciones en lo Contencioso Administrativo Federal no se advierten como irrazonables o desprovistas de fundamento de acuerdo a la doctrina de la arbitrariedad - Se confirma la sentencia - Disidencia del juez Rosenkrantz:&nbsp; Por obra de lo dispuesto por la legislaci&oacute;n chilena quedaban excluidos del impuesto a la renta de ese pa&iacute;s los dividendos provenientes de inversiones en el exterior de Chile - El CDI no contiene norma alguna que establezca que la renuncia sobreviniente a la potestad tributaria por parte de un Estado contratante habilite al otro Estado a ejercer la suya, resignada al suscribir dicho convenio - No corresponde a los jueces introducir distinciones cuando la norma convencional no lo hace ni presumir la inconsecuencia o falta de previsi&oacute;n del legislador -&nbsp;El principio de la fuente adoptado por el CDI conlleva la posibilidad cierta de que ninguno de los Estados contratantes grave un determinado tipo de renta - La conducta del Estado Nacional, por intermedio de la AFIP, consistente en aplicar su legislaci&oacute;n interna para desconocer lo dispuesto por el art&iacute;culo 11 del CDI resulta incompatible con el principio cardinal de la buena fe seg&uacute;n el cual deben interpretarse los tratados internacionales.</p>","esNovedad":true,"fecha":1630551600000,"relevancia":3,"usuarioModificacion":11,"fechaModificacion":1632241053635,"usuarioCreacion":11,"fechaCreacion":1630674650986,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31937,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":16591453,"numeroExpediente":1351,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2,"tema":null},"caratula":"MOLINOS RIO DE LA PLATA SA c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":28813159,"numeroExpedie