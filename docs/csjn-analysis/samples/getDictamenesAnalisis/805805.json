[{"codigo":8058052,"analisisDocumental":{"id":805805,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"N.N. s/ incidente de incompetencia. Víctima: B., S. D.\r\n","alias":null,"caratula":"N. N. s/INCIDENTE DE INCOMPETENCIA VICTIMA: BECERRA, SERGIO DANIEL","inconstitucional":false,"falloDestacado":{"id":8282,"titulo":"Conflictos de competencia en los delitos a distancia","cabecilla":"<p style=\"text-indent:2em\">A raíz de la denuncia originada en llamados telefónicos de personas desconocidas solicitando una suma de dinero a cambio de no divulgar fotos íntimas se originó un conflicto negativo de competencia entre la justicia de la Provincia Santa Fe y la de la Provincia de Buenos Aires. </p><p style=\"text-indent:2em\">La Corte recordó su doctrina en el sentido de que en los llamados delitos a distancia, así como en aquellos hechos en que los diferentes pasos del <em>iter criminis</em> no se producen en el mismo lugar, el delito se estima cometido en todas las jurisdicciones en las cuales se ha desarrollado la acción típica, y también en el lugar de realización del resultado y que por ello la selección debe hacerse de conformidad con las exigencias planteadas por la economía procesal y la necesidad de favorecer el buen servicio de justicia.</p><p style=\"text-indent:2em\">Teniendo en cuenta que el denunciante tiene residencia permanente en Venado Tuerto, y que de su exposición surge que sólo circunstancialmente se encontraba en la localidad de Hurlingham al momento de recibir el llamado, la Corte dispuso que continúe interviniendo la justicia de Santa Fe, que previno y en cuya jurisdicción además se encontraban los otros miembros del grupo familiar que también recibieron mensajes.</p>","esNovedad":true,"fecha":1740020400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1740145923096,"usuarioCreacion":4,"fechaCreacion":1740076997612,"privado":false,"posicion":3,"resumen":{"idResumen":109,"resumen":"La Corte resolvió que siga interviniendo la justicia de Santa Fe en una causa por extorsión telefónica, priorizando la jurisdicción donde reside el denunciante y su familia, aplicando criterios de economía procesal y buen servicio de justicia.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":132458,"secretaria":{"id":209,"tipo":"S","descripcion":"Sec. Penal Especial","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal Especial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35612617,"numeroExpediente":1177,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ANDERSEN, PABLO ENRIQUE 