[{"codigo":7932062,"analisisDocumental":{"id":793206,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"PIONEER ARGENTINA SRL TF 38718-A c/ DGA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","inconstitucional":false,"falloDestacado":{"id":6463,"titulo":"Infracción de declaración inexacta y empresas vinculadas","cabecilla":"<p style=\"text-indent:2em\">La cámara revocó la sentencia del Tribunal Fiscal de la Nación que había confirmado la multa por infracción al art. 954, ap. 1°, inc. c), del Código Aduanero aplicada a la actora.</p><p style=\"text-indent:2em\">Contra esta sentencia el Fisco interpuso recurso ante la Corte expresando que la sentencia recurrida valoraba de manera incorrecta la prueba producida, lo que desvirtuaba la aplicación al caso de la figura contemplada en la norma mencionada.</p><p style=\"text-indent:2em\">La Corte confirmó el pronunciamiento apelado. Expresó que la cámara tuvo por demostrado que los precios declarados por la empresa actora se correspondían con los efectivamente pagados por ella a una empresa vinculada por las compras realizadas, lo que eliminaba toda posibilidad de configuración de la infracción imputada y que tal afirmación, basada en la valoración de los elementos de hecho y prueba que obran el expediente, resulta irrevisable en la instancia extraordinaria pues el auto de concesión del recurso extraordinario fue suficientemente explícito en cuanto circunscribió la admisibilidad de la apelación a la cuestión federal y el recurrente no interpuso queja con relación a la arbitrariedad denegada.</p><p style=\"text-indent:2em\">Agregó que esta interpretación de la norma del Código Aduanero coincide con la interpretación realizada por el Comité Técnico de Valoración en Aduana de la Organización Mundial de Aduanas, órgano encargado de asegurar, a nivel técnico, la uniformidad de la interpretación y aplicación del “Acuerdo relativo a la aplicación del artículo VII del Acuerdo General sobre Aranceles Aduaneros y Comercio de 1994”. Y que no le cabe al Tribunal apartarse del principio primario de la sujeción de los jueces a la ley ni atribuirse el rol de legislador para crear excepciones no admitidas por éste.</p>","esNovedad":true,"fecha":1709175600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1709309045581,"usuarioCreacion":4,"fechaCreacion":1709233343368,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":117243,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"