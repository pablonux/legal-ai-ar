[{"codigo":7575652,"analisisDocumental":{"id":757565,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Farina, Haydée Susana s/ homicidio culposo ","alias":null,"caratula":"FARINA, HAYDEE SUSANA s/HOMICIDIO CULPOSO","inconstitucional":false,"falloDestacado":{"id":1289,"titulo":"Prescripción de la acción penal y el derecho del imputado a ser juzgado en un plazo razonable ","cabecilla":"<p>Resoluciones que denegaron el planteo de prescripci&oacute;n al asignar car&aacute;cter interruptivo a los decisorios de los tribunales intermedios que confirmaron la sentencia condenatoria - Finalidad del instituto de la prescripci&oacute;n de la acci&oacute;n penal - Derecho del imputado a ser juzgado en plazo razonable - Un procedimiento recursivo que se ha prolongado durante m&aacute;s de catorce a&ntilde;os excede todo par&aacute;metro de razonabilidad de un proceso penal - La excesiva duraci&oacute;n del tr&aacute;mite recursivo torna improcedente una nueva suspensi&oacute;n del tr&aacute;mite de la queja a los fines de que resuelvan los jueces de la causa - Tiempo empleado por el Estado para dilucidar los hechos investigados que resulta incompatible con el derecho a ser juzgado en un plazo razonable - Accionar de los tribunales provinciales que intervinieron en la causa - Apartamiento manifiesto de las claras y precisas directivas emanadas de la Corte Suprema en reiteradas intervenciones - Las autoridades de una provincia no pueden trabar o turbar la acci&oacute;n de los jueces que forman parte del Poder Judicial de la Naci&oacute;n - Tema que reviste trascendencia institucional al generar una afectaci&oacute;n al funcionamiento de todo un fuero - Alzamiento del tribunal a quo y los tribunales que de &eacute;l dependen contra la autoridad de la Corte Suprema - Corresponde declarar la extinci&oacute;n de la acci&oacute;n penal por prescripci&oacute;n y disponer el sobreseimiento de la recurrente - Declarar que la doctrina judicial del Tribunal referida a la interpretaci&oacute;n del art. 67, inc. e), del C&oacute;digo Penal es de seguimiento obligatorio para todos los tribunales del pa&iacute;s - Disidencia parcial del juez Rosenkrantz: la determinaci&oacute;n por parte de la Corte Suprema del alcance de una norma de derecho com&uacute;n no puede asimilarse al ejercicio de una funci&oacute;n casatoria o unificadora de jurisprudencia</p>","esNovedad":true,"fecha":1577329200000,"relevancia":3,"usuarioModificacion":13,"fechaModificacion":1598878014598,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":28394,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":26775513,"numeroExpediente":2148,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExp