[{"codigo":7783352,"analisisDocumental":{"id":778335,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"A., B.R. c/ SWISS MEDICAL SA MEDICINA PRIVADA s/AMPARO LEY 16.986","alias":null,"caratula":"A., B.R. c/ SWISS MEDICAL SA MEDICINA PRIVADA s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":4503,"titulo":"Medicina prepaga: ocultamiento de enfermedades preexistentes y rescisión del contrato","cabecilla":"<p>La Corte revocó una sentencia que había admitido un amparo contra una empresa de medicina prepaga con el objeto de obtener la cobertura de una intervención quirúrgica e internación. En su sentencia, la cámara había reconocido el ocultamiento premeditado en el que había incurrido el actor al completar su declaración jurada de admisión pero concluyó que no podía negarse su afiliación aunque sí la facultó a renegociar la cuota. Recurrida la sentencia, la Corte consideró que el marco regulatorio de la medicina prepaga previó la situación planteada asignándole una clara consecuencia, como es la rescisión del contrato por iniciativa de la empresa prestadora, cuando no haya mediado buena fe en el usuario. Explicó que para la procedencia de dicha rescisión no basta con verificar la simple omisión de información, sino que se exige que el usuario, obrando sin la buena fe requerida, haya falseado la declaración. Fundó su decisión en que no corresponde presumir la falta de previsión del legislador o atribuir a las normas un alcance que implique la tacha de inconsecuencia en el órgano del cual emanan.</p><p> </p><p>En la misma fecha y con idénticos fundamentos, la Corte resolvió la causa <b>\"<a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7783331\">FMP 3317/2019 C., H.</a>\" </b>donde se debatía la desafiliación del actor y la consecuente negativa de la cobertura integral del tratamiento de rehabilitación por consumo de drogas y alcohol.</p>","esNovedad":true,"fecha":1663642800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1663787814209,"usuarioCreacion":4,"fechaCreacion":1663699022810,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":35188,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28459504,"numeroExpediente":12572,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP -