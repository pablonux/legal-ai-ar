[{"codigo":7513261,"analisisDocumental":{"id":751326,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":{"codigoTabla":null,"codigoValor":380,"codigoRelacion":90380,"valor":"COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201903220947,"fechaModLong":201903220947,"orden":null,"visible":null},"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Gobierno de la Ciudad Autónoma de Buenos Aires c/ Córdoba, Provincia de s/ ejecución fiscal ","alias":null,"caratula":"GOBIERNO DE LA CIUDAD DE BUENOS AIRES c/ CORDOBA, PROVINCIA DE s/EJECUCION FISCAL","inconstitucional":false,"falloDestacado":{"id":671,"titulo":"Competencia originaria de la Corte en las causas en que la Ciudad de Buenos Aires es parte ","cabecilla":"<p>Presentaci&oacute;n ante un Juzgado en lo Contencioso Administrativo y Tributario de la Ciudad Aut&oacute;noma de Buenos Aires - Excepci&oacute;n de incompetencia - Precedente &quot;Gobierno de la Ciudad de Buenos Aires&quot; (Fallos: 330:5279) - Cambio en los principios que informaron sus fundamentos a partir del caso &quot;Nisman&quot; (Fallos: 339:1342) - Supuesto excepcional que exige que la Corte modifique su doctrina - Necesidad de reexaminar el modo de coordinar la plena autonom&iacute;a jurisdiccional porte&ntilde;a con la prerrogativa de las provincias como aforadas a la competencia originaria de la Corte - Reforma constitucional de 1994 que introduce a la Ciudad de Buenos Aires como un actor aut&oacute;nomo del sistema federal - Se modifica la hist&oacute;rica premisa seg&uacute;n la cual la uni&oacute;n nacional requer&iacute;a suspender la participaci&oacute;n de la ciudad como sujeto aut&oacute;nomo - Afectaci&oacute;n de la autonom&iacute;a de la Ciudad Aut&oacute;noma cuando es forzada a litigar ante tribunales de extra&ntilde;a jurisdicci&oacute;n - La Ciudad Aut&oacute;noma de Buenos Aires tiene el mismo puesto que las provincias en el sistema normativo que rige la jurisdicci&oacute;n de los tribunales federales y, por lo tanto, el mismo derecho a la competencia originaria de la Corte Suprema - Se declara dicha competencia en esta causa - Voto del juez Rosenkrantz: la Constituci&oacute;n contiene normas que incluyen tanto a las provincias como a la Ciudad de Buenos Aires pese a que los textos solo hacen menci&oacute;n de las primeras - Calificaci&oacute;n de la ciudad como un estado que merece el mismo trato que una provincia a los fines de la jurisdicci&oacute;n federal como juicio congruente con la reforma constitucional de 1994 y con la sanci&oacute;n de la ley 1467 y el debate legislativo - Es constitucionalmente inadmisible equiparar la Ciudad Aut&oacute;noma de Buenos Aires a un vecino de provincia - Disidencia de la jueza Highton de Nolasco: precedente &quot;Cincunegui&quot; (Fallos: 332:2856) - El constituyente marc&oacute; una diferenciaci&oacute;n entre el estatus jur&iacute;dico de las provincias y el de la Ciudad de Buenos Aires - Los constituyentes no concibieron a la Ciudad como una provincia ni a su autonom&iacute;a con el mismo alcance que la de aquellas - La Ciudad no es una provincia ni es asimilable a una provincia a los fines de la competencia originaria - No se advierte cambio que justifique el apartamiento de la doctrina firmemente sostenida y consolidada por el Tribunal</p>","esNovedad":true,"fecha":1554346800000,"relevancia":3,"usuarioModificacion":5,"fechaModificacion":1599070670817,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":25728,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30643070,"numeroExpediente":2084,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"GOBIERNO DE LA CIUDAD DE BUENOS AIRES c/ CORDOBA, PROVINCIA DE s/EJECUCION FISCAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2084. "},"recurso":{"id":5200876,"expediente":{"id":30643070,"numeroExpediente":2084,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"GOBIERNO DE LA CIUDAD DE BUENOS AIRES c/ CORDOBA, PROVINCIA DE s/EJECUCION FISCAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2084. "},"tipoRecurso":{"id":1243,"codigo":"CIR","descripcion":"CIRCULACION DEL EXPEDIENTE"},"claveRecurso":null,"identificacionExpediente":"CSJ 2084/2017"},"piezas":0,"urgente":"N","observaciones":null,"usuarioCreacion":null,"usuarioCreacion