[{"codigo":8254292,"analisisDocumental":{"id":825429,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"EGUSQUIZA MAMANI, MAYCOL CHRISTIAN Y OTRO s/ EXTRADICION - ART. 54","alias":null,"caratula":"REQUERIDO: EGUSQUIZA MAMANI, MAYCOL CHRISTIAN Y OTRO s/EXTRADICION - ART. 54 ","inconstitucional":false,"falloDestacado":{"id":10541,"titulo":"Procedimiento de extradición: audiencia prevista en el artículo 27 de la ley 24.767","cabecilla":"<p style=\"text-indent:2em\">La jueza de primera instancia resolvió conceder la extradición de dos ciudadanos que estimó requerida por las autoridades de la República del Perú para someterlos a un proceso por la presunta comisión del delito contra la salud pública – tráfico ilícito de drogas.</p><p style=\"text-indent:2em\">Ante el recurso interpuesto por la defensa oficial de los requeridos la Corte dejó sin efecto esta decisión.</p><p style=\"text-indent:2em\">Consideró para ello que la documentación valorada para sustentar lo resuelto constituía solamente una solicitud de detención preventiva con fines de extradición y, por el otro, que la solicitud de extradición fue incorporada al legajo con posterioridad al dictado de dicha sentencia. Como consecuencia de ello no se cumplió con la audiencia regulada en el artículo 27 de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-24767-41442/texto\">ley 24.767</a> ni se celebró el juicio previsto en el artículo 30 de la citada norma, como paso previo para el pronunciamiento de la sentencia de extradición.</p><p style=\"text-indent:2em\">Recordó que el artículo 30 de la ley 24.767 es suficientemente claro en cuanto consagra que finalizado el trámite administrativo y recibido el pedido de extradición en sede judicial, luego de la audiencia prevista por el artículo 27, el juez dispondrá la citación a juicio salvo que el requerido diera su consentimiento para ser extraditado (artículo 28) o si se comprobara que la persona detenida no es la requerida (artículo 29). Recién, una vez superada la etapa de juicio (artículo 30, segundo y tercer párrafos), el ordenamiento legal (artículo 32) habilita a la autoridad judicial a pronunciarse acerca de la procedencia o improcedencia del pedido de extradición. </p><p style=\"text-indent:2em\">En función de ello, el Tribunal dejó sin efecto la sentencia apelada para que, con posterioridad al cumplimiento de la audiencia mencionada, la jueza de la causa realice todos los pasos procesales específicos, previstos en el código, que operan como presupuesto formal de validez del pronunciamiento de la sentencia definitiva, obtenida, pues, mediante juicio, y por un procedimiento respetuoso del ejercicio de la defensa de los requeridos.</p>","esNovedad":true,"fecha":1775703600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1776088700140,"usuarioCreacion":11,"fechaCreacion":1775769468052,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":155538,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30166435,"numeroExpediente":9796,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"REQUERIDO: JARAMILLO GAMERO, JUAN MANUEL Y OTROS s/EXTRADICION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"9796. "},"recurso":{"id":7084191,"expediente":{"id":30166435,"numeroExpediente":9796,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"REQUERIDO: JARAMILLO GAMERO, JUAN MANUEL Y OTROS s/EXTRADICION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"9796. "},"tipoRecurso":{"id":1168,"codigo":"ROR","descripcion":"RECURSO ORDINARIO"},"claveRecurso":"CFP 009796/2017/CS001","identificacionExpediente":"CFP 009796/2017/CS001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":10,"nombreUsuario":"27179020438","apellido":"Messuti","nombre":"Mariana","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583843772000,"nombreUsuarioMigrado":null,"codigo":"JURW6J","mail":"mmessuti@csjn.gov.ar","intentos":0,"notificacion":false},"usuarioCreacionOld":"JURW6J","usuarioModificacion":{"id":10,"nombreU