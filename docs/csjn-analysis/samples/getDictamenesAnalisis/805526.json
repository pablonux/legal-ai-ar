[{"codigo":8055263,"analisisDocumental":{"id":805526,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ASOCIACION DE MAGISTRADOS Y FUNCIONARIOS DE LA JUSTICIA DEL NEUQUEN Y OTROS c/ PROVINCIA DEL NEUQUEN s/accion de inconstitucionalidad","inconstitucional":false,"falloDestacado":{"id":8122,"titulo":"Reforma constitucional provincial: interpretación de derecho público local","cabecilla":"<p style=\"text-indent:2em\">La Asociación de Magistrados y Funcionarios de la Provincia del Neuquén solicitó la declaración de nulidad de una reforma introducida en la Constitución provincial que incorporaba, como órgano extrapoder, el Consejo de la Magistratura, otorgándole facultades para evaluar periódicamente la idoneidad y el desempeño de los magistrados y funcionarios. Basó su pretensión en que la Convención había excedido su competencia material al extralimitarse del mandato habilitado por la ley local 2471.</p><p style=\"text-indent:2em\">El superior tribunal provincial hizo lugar a la pretensión y la Corte desestimó el recurso interpuesto por la provincia contra dicho pronunciamiento.</p><p style=\"text-indent:2em\">Señaló que los agravios resultaban inadmisibles ya que remitían al examen de cuestiones de derecho público local propias de los jueces de la causa y ajenas –como regla y por su naturaleza– a la competencia federal de la Corte reglada por los artículos 31, 116 y 117 de la Constitución Nacional y por el artículo 14 de la ley 48, sin que la apelante haya demostrado la arbitrariedad que alega.</p><p style=\"text-indent:2em\">Consideró que la recurrente solo había expresado su desacuerdo con la interpretación de las normas locales que llevó a cabo el tribunal superior local pero que los defectos hermenéuticos que sostenían la tacha distaban de alcanzar el estándar definido por el Tribunal para dar lugar a un supuesto de inequívoco carácter excepcional como es la arbitrariedad.</p>","esNovedad":true,"fecha":1735268400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1735576138633,"usuarioCreacion":11,"fechaCreacion":1735334132790,"privado":false,"posicion":9,"resumen":null},"reciboEntrada":{"id":132072,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29925042,"numeroExpediente":828,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ASOCIACION DE MAGISTRADOS Y FUNCIONARIOS DE LA JUSTICIA DEL NEUQUEN Y OTROS c/ PROVINCIA DEL NEUQUEN s/acc