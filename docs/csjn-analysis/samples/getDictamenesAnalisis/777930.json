[{"codigo":7779302,"analisisDocumental":{"id":777930,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":" AFIP s/AMPARO LEY 16.986. ACTOR: VESPASIANI, MARIO OSCAR","alias":null,"caratula":"DEMANDADO: AFIP s/AMPARO LEY 16.986 ACTOR: VESPASIANI, MARIO OSCAR","inconstitucional":false,"falloDestacado":{"id":4884,"titulo":"Suspensión transitoria del registro fiscal de operadores en la compraventa de granos. Régimen jurídico y razonabilidad","cabecilla":"<p>La sentencia hizo lugar al amparo y ratificó la reincorporación del contribuyente en el “Registro Fiscal de Operadores en la Compraventa de Granos y Legumbres Secas”, implementado por la resolución general (AFIP) 129/97. Contra esa decisión, el Fisco interpuso el recurso extraordinario. La Corte revocó la sentencia. Expresó que, de acuerdo a la normativa, es claro que la suspensión transitoria establecida en la RG 2300/07 no perseguía una sanción sino que se limitaba, cautelarmente, a impedir el goce de los beneficios fiscales previstos en el régimen hasta tanto se aclarase la situación del contribuyente frente al Fisco. Tal decisión, temporaria y provisional, no se adoptaba con la finalidad de herir de manera definitiva al presunto infractor en su patrimonio sino de proteger el erario público hasta que concluyeran las tareas de fiscalización que el ente recaudador se encontraba obligado a realizar. Cabe tener presente, en este punto, que la constitucionalidad de una reglamentación como la aquí examinada está condicionada, por una parte, a la circunstancia de que los derechos afectados sean respetados en su sustancia y, por la otra, a la adecuación de las restricciones a las necesidades y fines públicos que las justifican, de manera que no aparezcan infundadas o arbitrarias, sino razonables, es decir, proporcionadas a las circunstancias que las originan y a los fines que se procuran alcanzar con ellas (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=247&amp;pagina=121\">Fallos: 247:121</a>). En tales condiciones, la Corte no encontró configurada la lesión constitucional que la sentencia recurrida reprocha a la reglamentación atacada, pues la suspensión transitoria establecida por esta última luce apta para servir, razonablemente, a la finalidad esencial que ella persigue, esto es, asegurar el correcto desempeño de las facultades de verificación y fiscalización que le corresponden a la AFIP.</p>","esNovedad":true,"fecha":1671073200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1671130735830,"usuarioCreacion":11,"fechaCreacion":1671130705272,"privado":false,"posicion":6,"resumen":null},"reciboEntra