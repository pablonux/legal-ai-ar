[{"codigo":7519691,"analisisDocumental":{"id":751969,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":{"codigoTabla":null,"codigoValor":396,"codigoRelacion":90396,"valor":"PENAL","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201903221043,"fechaModLong":201903221043,"orden":null,"visible":null},"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Canales, Mariano Eduardo y otro s/ homicidio agravado - impugnación extraordinaria ","alias":null,"caratula":"CANALES, MARIANO EDUARDO Y OTRO s/homicidio agravado - impugnacion extraordinaria","inconstitucional":false,"falloDestacado":{"id":658,"titulo":"Juicio por jurado popular","cabecilla":"<p>Cuestionamiento relacionado con la facultad de la provincia para regular la materia - Aplicaci&oacute;n de ley provincial que entr&oacute; en vigencia durante el tr&aacute;mite de la causa - Las leyes modificatorias de la jurisdicci&oacute;n y competencia se aplican de inmediato a las causas pendientes - No existe derecho adquirido a ser juzgado por un determinado r&eacute;gimen procesal - Inexistencia de conculcaci&oacute;n de la garant&iacute;a de juez natural - Interpretaci&oacute;n de la Constituci&oacute;n Nacional y sus alusiones al juicio por jurado - Facultad no delegada por las provincias al Gobierno Nacional de organizar su administraci&oacute;n de justicia - La Constituci&oacute;n Nacional concibi&oacute; al juicio por jurado como una instituci&oacute;n sustancial para el juzgamiento de los delitos que corresponde conocer al Poder Judicial de la Naci&oacute;n - Competencia del Congreso Nacional para legislar en lo relativo a su conformaci&oacute;n y funcionamiento en el &aacute;mbito nacional - Facultad de la Provincia para dictar esta regulaci&oacute;n procesal - Rechazo del cuestionamiento de la mayor&iacute;a especial del jurado aceptada por el legislador neuquino para dictar veredictos de culpabilidad - Inexistencia de un mandato constitucional que imponga n&uacute;mero determinado de votos para afirmar la culpabilidad o la inocencia de un imputado por parte del jurado - El federalismo permite a las provincias darse sus propias instituciones y regular lo atinente a su composici&oacute;n y funcionamiento - Juicio por jurados como alternativa que permite conjugar la &quot;precisi&oacute;n&quot; propia del saber t&eacute;cnico con la &quot;apreciaci&oacute;n&quot; propia del saber popular - Voto del juez Rosatti: la omisi&oacute;n parlamentaria de implementar el juicio por jurados no puede conllevar una derogaci&oacute;n de hecho de la instituci&oacute;n - Las provincias y la CABA pueden establecerlo ya sea que se interprete esta competencia como una atribuci&oacute;n transitoria hasta tanto lo haga el Poder Legislativo Nacional o que se interprete como una derivaci&oacute;n l&oacute;gica de la competencia constitucional de asegurar su administraci&oacute;n de justicia - Derecho del pueblo a juzgar y no solo el derecho de una persona a ser juzgada por sus pares - Disidencia del juez Rosenkrantz: Agravios inadmisibles debido a la conducta procesal asumida por los acusados - Ni los imputados ni sus defensas cuestionaron la realizaci&oacute;n del juicio frente al tribunal constituido por jurados populares ni objetaron las normas que lo regulan</p>","esNovedad":true,"fecha":1556766000000,"relevancia":3,"usuarioModificacion":5,"fechaModificacion":1599071082495,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":25965,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28174566,"numeroExpediente":461,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"CANALES, MARIANO EDUARDO Y OTRO s/homicidio agravado - impugnacion extraordinaria ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"461. "},"recurso":{"id":4817969,"expediente":{"id":28174566,"numeroExpediente":461,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"CANALES, MARIANO EDUARDO Y OTRO s/homicidio agravado - impugnacion extraordinaria ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"461. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECUR