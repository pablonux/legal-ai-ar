[{"codigo":7677712,"analisisDocumental":{"id":767771,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"INC SA (TF 24746-I) c/ DGI s/","alias":null,"caratula":"INC SA (TF 24746-I) c/ DGI s/","inconstitucional":false,"falloDestacado":{"id":2401,"titulo":"Impuesto a las ganancias: deducción válida de intereses y gastos","cabecilla":"<p>Determinaci&oacute;n de oficio de la obligaci&oacute;n tributaria en el impuesto a las ganancias, ajuste de quebrantos y liquidaci&oacute;n de intereses resarcitorios y aplicaci&oacute;n de multa con fundamento en que la empresa hab&iacute;a deducido improcedentemente intereses y gastos originados en la emisi&oacute;n de obligaciones negociables pues la operaci&oacute;n no se encontraba destinada a obtener, mantener y conservar ganancias gravadas - Resoluci&oacute;n del Tribunal Fiscal de la Naci&oacute;n que revoc&oacute; el ajuste efectuado por la AFIP al considerar que la deducci&oacute;n de los conceptos impugnados era correcta - Sentencia de c&aacute;mara que confirm&oacute; dicha resoluci&oacute;n - La aplicaci&oacute;n del &quot;principio de pertenencia&quot; o &quot;principio de afectaci&oacute;n patrimonial&quot; en materia de deducci&oacute;n de gastos no queda limitada a las personas f&iacute;sicas y sucesiones indivisas sino que tambi&eacute;n se aplica a los sujetos &quot;de la tercera categor&iacute;a&quot; o &quot;empresa&quot;, los que, en consecuencia, no se encuentran autorizados para deducir sus gastos en forma promiscua seg&uacute;n lo propone la tesis de la &quot;universalidad del pasivo&quot; - Los gastos cuya deducci&oacute;n admite la ley son aquellas erogaciones dirigidas a la obtenci&oacute;n de ganancias gravadas o al mantenimiento o conservaci&oacute;n de su fuente - Las ventajas impositivas que consagra el r&eacute;gimen de la ley 23.576 tienen por objeto facilitar la obtenci&oacute;n de fondos del mercado de capitales para destinarlos exclusivamente al financiamiento de actividades productivas por parte de las empresas privadas - En ese marco, resulta inadmisible la deducci&oacute;n de los conceptos devengados con motivo de la obtenci&oacute;n de los fondos provenientes de la emisi&oacute;n y colocaci&oacute;n de las obligaciones negociables pues tales sumas no fueron destinadas a refinanciar pasivos afectados al desarrollo de sus actividades productivas sino a cancelar el precio de compra de las acciones de otra empresa a su anterior due&ntilde;o - Se revoca la sentencia apelada.</p>","esNovedad":true,"fecha":1626318000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1626442240188,"usuarioCreacion":11,"fechaCreacion":1626440913917,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31506,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descri