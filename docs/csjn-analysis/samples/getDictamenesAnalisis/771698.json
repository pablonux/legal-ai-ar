[{"codigo":7716982,"analisisDocumental":{"id":771698,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"DAVILA LUIS CESAR c/ ARCANGEL MAGGIO S.A. Y OTRO s/ACCIDENTE - ACCION CIVIL","alias":null,"caratula":"Recurso Queja Nº 1 - DAVILA LUIS CESAR c/ ARCANGEL MAGGIO S.A. Y OTRO s/ACCIDENTE - ACCION CIVIL","inconstitucional":false,"falloDestacado":{"id":3322,"titulo":"Carácter excepcional de la arbitrariedad","cabecilla":"<p>Una empresa fue condenada al pago de una reparaci&oacute;n integral por la enfermedad profesional que incapacit&oacute; al trabajador. En la sentencia, se consider&oacute; que la prueba testimonial&nbsp;acreditaba que el actor realizaba tareas repetitivas de carga y descarga de pliegos de papel, manipulando diariamente y durante m&aacute;s de tres a&ntilde;os un peso aproximado de 10 kilogramos por carga y que, conforme a la pericia m&eacute;dica, la dolencia f&iacute;sica que presentaba era atribuible a las tareas de esfuerzo invocadas. Sobre esa base, se consider&oacute; que dicha labor constituy&oacute; la actividad riesgosa a la que se refiere el art&iacute;culo 1757 del C&oacute;digo Civil y Comercial. Contra este pronunciamiento la condenada interpuso un recurso extraordinario con base en la doctrina de la arbitrariedad, que al ser denegado origin&oacute; la correspondiente queja. La Corte consider&oacute; que el recurso hab&iacute;a sido bien denegado&nbsp;<strong>pues los agravios referidos a la acreditaci&oacute;n del nexo causal&nbsp;</strong>entre la afecci&oacute;n y la prestaci&oacute;n de tareas, la cuantificaci&oacute;n del da&ntilde;o y la atribuci&oacute;n de responsabilidad derivada de una enfermedad profesional remiten al examen de cuestiones f&aacute;cticas y de derecho com&uacute;n y procesal, materia propia de los jueces de la causa y<strong>&nbsp;ajena a la instancia extraordinaria,</strong>&nbsp;m&aacute;xime cuando la sentencia se funda en argumentos no federales que, m&aacute;s all&aacute; de su grado de acierto, resultan suficientes para sustentarla. Record&oacute; que&nbsp;<strong>la doctrina de la arbitrariedad es de car&aacute;cter excepcional</strong>&nbsp;<strong>y no tiene por objeto corregir fallos meramente equivocados</strong>, sino aquellos en los que las deficiencias l&oacute;gicas del razonamiento o la total ausencia de fundamento normativo impide&nbsp;considerar el decisorio como sentencia fundada en ley.</p>","esNovedad":true,"fecha":1639623600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1640001046095,"usuarioCreacion":11,"fechaCreacion":1639742989824,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":32830,"secretaria":{"id":13,"tipo":"