[{"codigo":7793712,"analisisDocumental":{"id":779371,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"TELEFÓNICA DE ARGENTINA SA Y OTRO c/ EN-AFIP-DGI s/ DIRECCIÓN GENERAL IMPOSITIVA","alias":null,"caratula":"Recurso Queja Nº 1 - TELEFONICA DE ARGENTINA SA Y OTRO c/ EN-AFIP-DGI s/DIRECCION GENERAL IMPOSITIVA","inconstitucional":false,"falloDestacado":{"id":4703,"titulo":"Impuesto a las ganancias: aplicación de mecanismos de actualización y confiscatoriedad","cabecilla":"<p>La cámara admitió la demanda de la actora y ordenó al Fisco Nacional que le restituya las sumas abonadas en exceso en concepto de impuesto a las ganancias al entender que se había acreditado la confiscatoriedad en los términos de <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=332&amp;pagina=1571\">\"Candy\" (Fallos: 332:1571)</a>. La demandada presentó un recurso extraordinario y la Corte, por mayoría confirmó la sentencia apelada. Recordó que  la aplicación del mecanismo de ajuste por inflación en los términos del precedente mencionado lo es al solo efecto de evitar la confiscatoriedad que se produciría al absorber el Estado una porción sustancial de la renta o del capital, lo que impide utilizar tal método correctivo para el reconocimiento de un mayor quebranto que pueda ser utilizado por el contribuyente en períodos posteriores, porque en tal supuesto no hay tributo a pagar que pueda ser cotejado con el capital o la renta gravados. Agregó que ello no importa la negativa a actualizar los quebrantos con los que ya contaba la empresa a fin de analizar la confiscatoriedad en cada uno de los períodos fiscales cuestionados, sino que solo implica la imposibilidad de reconocer nuevos créditos, o acrecentar los existentes, que puedan trasladarse a períodos fiscales futuros.  Descartó el Tribunal el argumento de la recurrente referido a que solo debía ser usado el índice singular ya que la ley del impuesto a las ganancias fijaba el empleo de índices acumulativos. También recordó que el aumento del monto nominal en función de los índices oficiales de precios al consumidor no hace la deuda más onerosa en su origen sino que sólo mantiene el valor económico real frente al paulatino envilecimiento de la moneda.</p>","esNovedad":true,"fecha":1666666800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1666874635357,"usuarioCreacion":11,"fechaCreacion":1666725039358,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":104741,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripc