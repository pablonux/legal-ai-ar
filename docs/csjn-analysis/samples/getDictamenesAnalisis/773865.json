[{"codigo":7738652,"analisisDocumental":{"id":773865,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"CHEHADI, MALLID c/ ADUANA LA QUIACA s/ IMPUGNACIÓN de ACTO ADMINISTRATIVO","alias":null,"caratula":"CHEHADI, MALLID c/ ADUANA LA QUIACA s/IMPUGNACION de ACTO ADMINISTRATIVO","inconstitucional":false,"falloDestacado":{"id":4423,"titulo":"Condonación de infracciones aduaneras: exigencia de perjuicio fiscal e infracción formal ","cabecilla":"<p>La Cámara tuvo por condenada en el marco de la ley 27.260 la multa impuesta a la empresa actora por la infracción de manifestación inexacta prevista en el Código Aduanero. Interpuesto un recurso extraordinario por la demandada, la Corte, por mayoría, revocó la sentencia apelada. Consideró para ello que para acceder a la aplicación del beneficio debe existir previamente una obligación tributaria que se encuentre regularizada o cancelada antes de la entrada en vigencia de la ley mencionada, situación que no se presenta si la conducta sancionada no se encuentra relacionada con el incumplimiento de una obligación de naturaleza tributaria. Expresó que la conducta punible no resulta apta para generar un perjuicio fiscal sino que guarda relación con el incumplimiento en sí de deberes u obligaciones asumidas respecto de destinaciones o regímenes aduaneros por lo que no concurren en el caso las condiciones previstas en las disposiciones aplicables que tornen procedente la condonación de la multa.</p>","esNovedad":true,"fecha":1661828400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1661889026789,"usuarioCreacion":11,"fechaCreacion":1661889017734,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":33564,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":15811403,"numeroExpediente":8622,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":24,"codigo":"24","abreviatura":"FSA","descripcion":"Justicia Federal de Salta","estado":0,"descripcionLarga":"FSA - Justicia Federal de Salta"},"objetoJuicio":{"id":3184,"descripcion":"IMPUGNACION de ACTO ADMINISTRATIVO","idMateria":112,"tema":{"id":186,"codigo":"CONTADM"}},"caratula":"CHEHADI, MALLID c/ ADUANA LA QUIACA s/IMPUGNACION de ACTO ADMINISTRATIVO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"8622. "},"recurso":{"id":5228560,"expediente":{"id":15811403,"numeroExpediente":8622,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":24,"codigo":"24","abreviatura":"FSA","descripcion":"Justicia Federal de Salta","estado":0,"descripcionLarga":"FSA - Justicia Federal de Salta"},"objetoJuicio":{"id":3184,"descripcion":"IMPUGNACION de ACTO