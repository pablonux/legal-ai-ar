[{"codigo":8045515,"analisisDocumental":{"id":804551,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GONZALEZ, FLORENCIO ANTONIO. c/ COLICHEO, FLORENTINO Y OTROS s/interdicto (sumarisimo)","inconstitucional":false,"falloDestacado":{"id":8003,"titulo":"Interdicto de recobrar y ocupación de tierras por parte de comunidades indígenas","cabecilla":"<p style=\"text-indent:2em\">El actor es titular de un permiso precario otorgado en el año 1986, en base a una posesión que se remonta al año 1956 de un inmueble ubicado en la Provincia de Río Negro. En el año 2015 un grupo de personas ocuparon ese terreno e impidieron el acceso al actor, quien efectuó una denuncia penal e inició un interdicto de recobrar posesión. Los demandados invocaron lo previsto en el artículo 2° de la ley 26.160 que dispuso la suspensión por cuatro años de la ejecución de sentencias, actos procesales o administrativos, cuyo objeto fuera el desalojo o desocupación de tierras que tradicionalmente ocupan las comunidades indígenas originarias del país.</p><p style=\"text-indent:2em\">Luego de dos pronunciamientos que hicieron lugar al interdicto el superior tribunal provincial ordenó que las actuaciones volvieran a primera instancia para su reserva hasta el vencimiento del plazo de la ley mencionada y/o, en su defecto, hasta que se realice el relevamiento técnico jurídico, catastral de las tierras y que de dicho trámite surja que no son las tradicionalmente ocupadas por la Comunidad Mapuche Tripal-Co Rañing.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto este pronunciamiento y, teniendo en cuenta que la naturaleza sumarísima del proceso ameritaba una pronta solución, confirmó el pronunciamiento de primera instancia que había hecho lugar al interdicto de recobrar, ordenando la restitución del inmueble al actor.</p><p style=\"text-indent:2em\">Expresó que no toda tenencia o posesión de tierras por parte de un grupo o comunidad que se reivindica como aborigen es susceptible de tutela constitucional y, a su vez, que el acceso irregular a ellas no fue un objetivo buscado por el constituyente.</p><p style=\"text-indent:2em\">Señaló que el tribunal provincial interpretó incorrectamente la ley 26.160, en primer lugar, porque su artículo 2° excluía a quienes no acreditaran una “posesión actual, tradicional y pública” y en segundo término porque la norma no autorizaba la suspensión de todo el proceso, sino sólo de ciertas medidas concretas de ejecución. Finalmente, porque sujetaba la suspensión al resultado del relevamiento técnico jurídico catastral a realizarse en sede administrativa y, en particular, a que de dicho estudio resultase que las tierras en litigio no eran las que tradicionalmente había ocupado la Comunidad Mapuche Tripal-co Rañing y tal inversión de la carga de la prueba operaba como una condición para continuar el trámite que no exigía norma alguna.</p>","esNovedad":true,"fecha":1733367600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1733745298369,"usuarioCreacion":11,"fechaCreacion":1733438150487,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":131318,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34976088,"numeroExpediente":1007,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"GONZALEZ, FLORENCIO ANTONIO. c/ COLICHEO, FLORENTINO Y OTROS s/interdicto (sumarisimo)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1007. "},"recurso":{"id":5868297,"expediente":{"id":34976088,"numeroExpediente":1007,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"GONZALEZ, FLORENCIO ANTONIO. c/ COLICHEO, FLORENTINO Y OTROS s/interdicto (sumarisimo)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1007. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CSJ 001007/2020/RH001","identificacionExpediente":"CSJ 001007/2020/RH001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":15,"nombreUsuario":"20383896151","apellido":"Diaz Solimine","nombre":"Ignacio