[{"codigo":7984161,"analisisDocumental":{"id":798416,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Skanska S.A. y otros s/ incidente de nulidad.","alias":null,"caratula":"Recurso Queja Nº 6 - Incidente Nº 267 - VINCULADO EN SUMARIO POLICIAL: SKANSKA SA Y OTROS s/INCIDENTE DE NULIDAD","inconstitucional":false,"falloDestacado":{"id":7121,"titulo":"Sentencia definitiva: supuestos en los que el recurso se dirige a lograr la plena efectividad de la prohibición de la doble persecución penal","cabecilla":"<p style=\"text-indent:2em\">La Corte dejó sin efecto una sentencia de la Cámara Federal de Casación Penal al considerar que, en la causa, se verifica el requisito de resolución equiparable a definitiva a los fines del artículo 14 de la ley 48, motivo por el cual la cámara de casación no debió rehusar el examen de la cuestión federal planteada (referida a la afectación de las garantías que amparan la cosa juzgada y <em>ne bis in idem</em>) llevada a su conocimiento por la defensa. Señaló además que, al decidir de ese modo, se apartó del criterio fijado en el precedente “Di Nunzio”.</p><p style=\"text-indent:2em\">Es de recordar que, según los precedentes de la Corte, corresponde hacer excepción a la doctrina según la cual no revisten la calidad de sentencia definitiva las resoluciones cuya consecuencia sea la obligación de seguir sometido a proceso penal, en los supuestos en los que el recurso se dirige a lograr la plena efectividad de la prohibición de la doble persecución penal (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=329&amp;pagina=1541\">329:1541</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=337&amp;pagina=1252\">337:1252</a>) pues ese derecho solo es susceptible de tutela inmediata (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=319&amp;pagina=43\">319:43</a>) y no veda únicamente la aplicación de una nueva sanción por un hecho anteriormente penado, sino también la exposición al riesgo de que ello ocurra mediante un nuevo sometimiento a juicio de quien ya lo ha sufrido por el mismo hecho (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=314&amp;pagina=377\">314:377</a>). Por ese motivo resultaría tardío atender el agravio en ocasión del fallo final pues aunque la sentencia fuese absolutoria, el perjuicio que se quiere evitar ya se habría concretado (conf. dictamen de la Procuración General al que remitió la Corte en Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=331&amp;pagina=1744\">331:1744</a>).</p>","esNovedad":true,"fecha":1719889200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1720029807546,"usuarioCreacion":4,"fechaCreacion":1719946405733,"privado":false,"posicion":11,"resumen":null},"reciboEntrada":{"id":122478,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33843446,"numeroExpediente":18579,"anioExpediente":2006,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 6 - Incidente Nº 267 - VINCULADO EN SUMARIO POLICIAL: SKANSKA SA Y OTROS s/INCIDENTE DE NULIDAD","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"18579. "},"recurso":{"id":5644097,"expediente":{"id":33843446,"numeroExpediente":18579,"anioExpediente":2006,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 6 - Incidente Nº 267 - VINCULADO EN SUMARIO POLICIAL: SKANSKA SA Y OTROS s/INCIDENTE DE NULIDAD","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"18579. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CFP 018579/2006/267/6/RH009","identificacionExpediente":"CFP 018579/2006/267/6/RH009"},"piezas":1,"urgente":