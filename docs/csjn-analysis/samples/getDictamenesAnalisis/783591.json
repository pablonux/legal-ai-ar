amiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"VICENTIN S.A.I.C. c/ ESTADO NACIONAL - PODER EJECUTIVO s/CIVIL y COMERCIAL-VARIOS","inconstitucional":true,"falloDestacado":{"id":5363,"titulo":"Impuesto a las ganancias: exportaciones realizadas a sujetos vinculados","cabecilla":"<p>La cámara confirmó la sentencia que había declarado la inconstitucionalidad del art. 1°, inc. h), primer y cuarto párrafo y del art. 2° del decreto 916/04, así como también de su similar 1287/05. Disconforme, la demandada interpuso un recurso extraordinario ante la Corte, quien confirmó la sentencia apelada. Coincidió en que el art. 1°, inc. h), primer párrafo, del decreto 916/04 es portador de un serio defecto de origen y resulta chocante con el principio de reserva de ley en materia tributaria en cuanto pretende modificar uno de los elementos esenciales del impuesto a las ganancias -la base imponible- mediante un mecanismo que se halla claramente a extramuros de la única forma que la Constitución Nacional prevé, es decir, mediante ley formal. En cuanto al cuarto párrafo del artículo mencionado consideró que altera la sustancia de los derechos otorgados por la ley 25.784 e introduce una deducción ajena a su letra, lo cual configura un exceso en el ejercicio de las atribuciones que se conceden al Poder Ejecutivo. Con respecto al art. 2° del cuestionado decreto 916/04 el Tribunal señaló que si bien comparte la tacha de inconstitucionalidad discrepa con la cámara en sus fundamentos y advierte que avanza más allá de la ley que reglamenta, al establecer una fecha de entrada en vigor anterior a la allí fijada, en contra de lo expresamente previsto en los artículos 28 y 99, inciso 2°, de la Constitución Nacional</p>","esNovedad":true,"fecha":1683082800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1683218667699,"usuarioCreacion":4,"fechaCreacion":1683141838476,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":108738,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":21025312,"numeroExpediente":41000184,"anioExpediente":2006,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":23,"codigo":"23","abreviatura":"FRE","descripcion":"Justicia Federal de Resistencia","estado":0,"descripcionLarga":"FRE - Justicia Federal de Resistencia"},"objetoJuicio":{"id":9024,"descripcion":"CIVIL y COMERCIAL-VARIOS","idMateria":112,"tema":{"id":421,"codigo":"CYCF"}},"caratula":"VICENTIN S.A.I.C. c/ ESTADO NACIONAL - PODER EJECUTIVO s/CIVIL y COMERCIAL-VARIOS","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":30520915,"numeroExpediente":41000184,"anioExpediente":2006,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":23,"codigo":"23","abreviatur