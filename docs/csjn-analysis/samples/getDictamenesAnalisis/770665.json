[{"codigo":7706652,"analisisDocumental":{"id":770665,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"XU, BINGBIN c/ DIRECCION NACIONAL DE MIGRACIONES DELEGACION CORDOBA s/RECURSO DIRECTO A JUZGADO","alias":null,"caratula":"XU, BINGBIN c/ DIRECCION NACIONAL DE MIGRACIONES DELEGACION CORDOBA s/RECURSO DIRECTO A JUZGADO","inconstitucional":false,"falloDestacado":{"id":3042,"titulo":"Acumulación de presentaciones individuales a procesos colectivos y conflicto de competencia","cabecilla":"<p>Ante una causa iniciada por un migrante de nacionalidad china a fin de impugnar judicialmente los actos mediante los cuales se hab&iacute;a dispuesto su expulsi&oacute;n del territorio nacional, la C&aacute;mara Federal de C&oacute;rdoba orden&oacute; su remisi&oacute;n a un juzgado nacional en lo contencioso administrativo a los fines de la eventual acumulaci&oacute;n a otra causa iniciada mediante&nbsp;un amparo colectivo, por entender que&nbsp;la cuesti&oacute;n debatida era an&aacute;loga. A partir de la devoluci&oacute;n de los autos por parte del juzgado por considerar que no se trataba de un proceso colectivo sino de una acci&oacute;n individual, qued&oacute; planteado un conflicto de competencia, que la&nbsp;<strong>Corte dirimi&oacute; al disponer que la causa deb&iacute;a continuar su tr&aacute;mite ante la justicia federal provincial.</strong>&nbsp;Para as&iacute; decidir, consider&oacute; que correspond&iacute;a rechazar la acumulaci&oacute;n de los autos al amparo colectivo, toda vez que &eacute;stos se originaron a partir de la presentaci&oacute;n individual efectuada por el migrante a los fines de cuestionar los actos dictados por la Direcci&oacute;n Nacional de Migraciones, en cuyo contexto impugn&oacute; la constitucionalidad de la normativa aplicada a su caso particular, todo lo cual conduc&iacute;a a descartar la existencia de un proceso colectivo, &uacute;nico supuesto previsto en el Reglamento de Actuaci&oacute;n en Procesos Colectivos (acordada 12/2016) a los fines de la pretendida acumulaci&oacute;n.</p>","esNovedad":true,"fecha":1635994800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1636135978080,"usuarioCreacion":11,"fechaCreacion":1636111460800,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":32463,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30568955,"numeroExpediente":70664,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio"