[{"codigo":7891302,"analisisDocumental":{"id":789130,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"O., A. L. c/ Swiss Medical ART s/ amparo.\r\n","alias":null,"caratula":"OCAMPO, ANDREA LUCRECIA c/ SWISS MEDICAL ART s/AMPARO","inconstitucional":false,"falloDestacado":{"id":6005,"titulo":"Competencia en el marco de una acción de amparo iniciada contra la aseguradora de riesgos del trabajo","cabecilla":"<p>La actora, en representación de su madre, interpuso acción de amparo contra la aseguradora de riesgos del trabajo a fin de obtener la cobertura total de su internación para rehabilitación en el centro a donde el médico había requerido su traslado, según lo requeriría el tratamiento de las secuelas ocasionadas por la patología profesional que invocaba. En ese marco, se originó un conflicto negativo de competencia entre la justicia de garantías local y la justicia federal provincial. La Corte resolvió que resultaba competente el Juzgado de Garantías de Lomas de Zamora. Explicó que, dado que la cuestión en disputa aparecía directamente vinculada con aspectos de derecho laboral común y la acción se dirigía contra un sujeto de derecho privado, su tratamiento resultaba ajeno al fuero federal y correspondía atribuir la causa a la justicia ordinaria.</p>","esNovedad":true,"fecha":1696906800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1697112297328,"usuarioCreacion":11,"fechaCreacion":1696967405997,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":114406,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36857442,"numeroExpediente":1542,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"O., A. L. c/ SWISS MEDICAL ART s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1542. "},"recurso":{"id":6368529,"expediente":{"id":36857442,"numeroExpediente":1542,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"O., A. L. c/ SWISS MEDICAL ART s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1542. "},"tipoRecurso":{"id":1103,"codigo":"COM","descripcion":"COMPE