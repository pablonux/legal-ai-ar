[{"codigo":7985022,"analisisDocumental":{"id":798502,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 3 -  IMPUTADO: TORRES, MARCELO ANGEL  s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":7183,"titulo":"Vulnerabilidad y trata de personas: competencia de la justicia federal","cabecilla":"<p style=\"text-indent:2em\">A raíz de una denuncia ante la situación de precariedad advertida en los damnificados, de más de sesenta años de edad, que no se encontrarían registrados en el sistema laboral y que se encontraban en un predio rural donde la tranquera de acceso se encontraría cerrada con candado, se originó un conflicto negativo de competencia.</p><p style=\"text-indent:2em\">La Corte resolvió que correspondía a la justicia federal proseguir con el trámite de la causa ya que no se podía descartar la existencia de conductas en infracción a la ley de prevención y sanción de la trata de personas.</p><p style=\"text-indent:2em\">Tuvo en cuenta para ello que las víctimas se dedicaban diariamente, sin días francos ni vacaciones, a las actividades de esquila, desoje, señalamiento y marcación de ganado ovino, así como también al mantenimiento del campo, con abuso de la condición de vulnerabilidad y la dominación de su voluntad, junto con los demás indicadores que surgían de sus testimonios como analfabetismo, ofrecimiento engañoso de mejora laboral, aislamiento en un lugar inhóspito e incomunicado de los centros de población, retención del pago de los salarios y de los documentos de identidad, falta de agua potable, de electricidad y retaceo en la provisión de alimentos e indumentaria, entre otros.</p>","esNovedad":true,"fecha":1720666800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1720803227349,"usuarioCreacion":4,"fechaCreacion":1720724420617,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":122638,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36463201,"numeroExpediente":110,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":14,"codigo":"14","abreviatura":"FCR","descripcion":"Justicia Federal de Comodoro Rivadavia","estado":0,"descripcionLarga":"FCR - Justicia Federal de Comodoro Rivadavia"},"objetoJuicio":{"id":4561,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Incidente Nº 3 -  IMPUTADO: TORRES, MARCELO ANGEL  s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"110. "},"recurso":{"id":6288814,"expediente":{"id":36463201,"numeroExpediente":110,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"ca