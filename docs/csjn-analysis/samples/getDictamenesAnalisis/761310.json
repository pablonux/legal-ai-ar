[{"codigo":7613103,"analisisDocumental":{"id":761310,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"V., M. c/ S. Y., C. R. s/ restitución internacional de niños ","alias":null,"caratula":"Recurso Queja Nº 1 - V.,M c/ S.Y.,C.R s/RESTITUCION INTERNACIONAL DE NIÑOS","inconstitucional":false,"falloDestacado":{"id":1528,"titulo":"El concepto de \"residencia habitual\" en la restitución internacional de niños, niñas y adolescentes  Sentencia de cámara que ordenó la inmediata restitución internacional de la niña a Francia","cabecilla":"Convenio de La Haya de 1980 - Interpretación - Inexistencia de incompatibilidad o contradicción entre el citado CH 1980 y la Convención sobre los Derechos del Niño en razón de que ambos propenden a la protección del interés superior del niño - En materia de restitución internacional de menores de edad, la celeridad en la resolución del conflicto constituye un mandato central - Importancia y alcance de la expresión residencia habitual para la resolución del caso - Concordancia con el Código Civil y Comercial de la Nación - No cabe tener por configurada a la residencia habitual a partir de un concepto de simple residencia - Las notas de estabilidad y permanencia deben caracterizar a la residencia, que debe tener un grado suficiente de continuidad que permita otorgarle el exigido carácter de habitual, esto es, que habilite a concluir que en dicho lugar el niño desarrollaba con naturalidad su vida - La circunstancia de que de los tres meses y medio que duró el viaje a Europa, la niña permaneció con sus progenitores tan solo un mes y algunos días en la ciudad francesa, sumado a que contaba con tan solo cinco meses de edad cuando viajó a ese continente, resulta insuficiente para atribuirle la estabilidad y permanencia requeridas para considerar a dicho estado extranjero como el centro de gravedad de su vida - Circunstancias que impiden admitir la existencia de una intención común que autorice el reintegro pretendido  Existencia de elementos probatorios y fácticos que dan cuenta de que desde sus inicios el desarrollo de la vida de pareja y familiar se fue consolidando en la ciudad de Buenos Aires  Falta de configuración de una retención ilícita - Se declara admisible el recurso extraordinario y se revoca la sentencia apelada. Asimismo, en uso de las facultades previstas por el art. 16 de la ley 48, se rechaza la demanda","esNovedad":true,"fecha":1603335600000,"relevancia":2,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29750,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34699835,"numeroExpediente":62230,"anioExpediente":2019,"tomoExped