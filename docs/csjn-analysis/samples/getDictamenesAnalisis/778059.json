[{"codigo":7780592,"analisisDocumental":{"id":778059,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"QIU, WENZHAN c/ DIRECCIÓN NACIONAL DE MIGRACIONES s/ IMPUGNACIÓN de ACTO ADMINISTRATIVO","alias":null,"caratula":"Recurso Queja Nº 1 - QIU, WENZHAN c/ DIRECCION NACIONAL DE MIGRACIONES s/IMPUGNACION de ACTO ADMINISTRATIVO","inconstitucional":false,"falloDestacado":{"id":4521,"titulo":"Migraciones: necesidad de solicitud concreta de la dispensa por reunificación familiar","cabecilla":"<p>La cámara declaró la nulidad de la denegación de la residencia temporaria solicitada por un migrante de nacionalidad china sobre quien, además, se había dispuesto declarar su permanencia irregular y su respectiva expulsión. Para decidir de este modo, la cámara se basó en que la dispensa solicitada por el migrante se había fundado tanto en la reunificación familiar como en aspectos laborales. Recurrida la sentencia, la Corte, por unanimidad, la revocó. Señaló que la dispensa por razones de reunificación familiar no constituye sino una facultad discrecional de la Administración de carácter excepcional y restrictivo, lo cual presupone necesariamente la existencia de una solicitud concreta por parte del interesado ante la autoridad migratoria y su correspondiente fundamentación. Añadió que  según surgía de las actuaciones administrativas, el migrante no había invocado en momento alguno ante la Dirección mencionada la referida dispensa y que no fue sino hasta la interposición del recurso judicial cuando se refirió a dicho instituto, por lo que mal pudo aquélla haber tenido la oportunidad de ponderar dicho extremo.</p>","esNovedad":true,"fecha":1663642800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1663787924623,"usuarioCreacion":11,"fechaCreacion":1663702267279,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":35080,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33914278,"numeroExpediente":22150,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 1 - HUANG, LITONG c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","verificacio