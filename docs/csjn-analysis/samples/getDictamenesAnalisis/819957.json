[{"codigo":8199572,"analisisDocumental":{"id":819957,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"B. M. Y OTROS c/ M. S., R. M. J. Y OTROS s/DAÑOS Y PERJUICIOS","alias":null,"caratula":"BEHAL MABEL Y OTROS c/ MARTINEZ SUAREZ ROSA MARIA JUANA Y OTROS s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":9822,"titulo":"Doctrina de la real malicia: expresiones amparadas por el derecho a la libertad de expresión","cabecilla":"<p style=\"text-indent:2em\">La cámara revocó la sentencia que había admitido la demanda que perseguía los daños y perjuicios ocasionados por la difusión de información que tuvo lugar en cuatro programas televisivos, que podría relacionarse con la sustracción y comercialización de niños y que involucraba figuras de la política.</p><p style=\"text-indent:2em\">Los actores interpusieron recurso extraordinario y la Corte<b> confirmó esta sentencia</b> por entender que el tratamiento de la noticia y las expresiones cuestionadas estaban <b>amparadas por el derecho a la libertad de expresión</b> y no violaban el derecho al honor de los accionantes.</p><p style=\"text-indent:2em\">Invocó la <b>doctrina de la real malicia</b> y señaló que no se encontraba acreditado que los demandados hubieran difundido información falsa con conocimiento de su falsedad o con notoria despreocupación al respecto. Agregó que, a esos fines, cabe tener en cuenta la información disponible al momento de la divulgación, sin que los resultados posteriores de una investigación penal puedan alterar, en forma retroactiva, la concurrencia de dicha doctrina.</p><p style=\"text-indent:2em\">Resaltó que en los distintos programas televisivos la conductora abordó el tema brindando espacio suficiente para que se escucharan las diferentes versiones del caso y para que sus invitados plantearan libremente sus ideas y posiciones y también aclaró que la información provenía de la causa judicial en trámite.</p><p style=\"text-indent:2em\">El Tribunal consideró que los actores no cumplieron con la carga de acreditar que la conductora, al momento de divulgar la hipótesis según la cual ellos estaban vinculados con la desaparición de la niña, conocía su falsedad u obró con notoria despreocupación al respecto. El manejo de la información no reflejó una versión parcializada -y, menos aún, falsa- de los hechos, sino que permitió que se escucharan las diversas voces y conjeturas elaboradas en relación con una cuestión tan sensible.</p><p style=\"text-indent:2em\">Agregó que el modo en que los accionados organizaron la comunicación de las expresiones cuestionadas no produjo una intromisión en la esfera de intimidad de los actores y de las niñas de suficiente entidad para prevalecer frente al interés público involucrado en la difusión de esos contenidos y que tampoco se había logrado demostrar una violación al derecho a la imagen. </p><p style=\"text-indent:2em\">Concluyó así la Corte que los dichos de los entrevistados, las preguntas y comentarios de la conductora y el modo en que fueron dispuestas las entrevistas por la producción no excedieron el legítimo interés social que ampara la libertad de expresión y justifica cierta intromisión en la vida privada, sin que pudiera vislumbrarse una conducta por la que los demandados debieran responder</p>","esNovedad":true,"fecha":1763434800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1763645792714,"usuarioCreacion":11,"fechaCreacion":1763493624667,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":148420,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":13060700,"numeroExpediente":84820,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":8520,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"B. M. Y OTROS c/ M. S., R. M. J. Y OTROS s/DAÑOS Y PERJUICIOS","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"84820. "},"recurso":{"id":5260687,"expediente":{"id":13060700,"numeroExpediente":84820,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara