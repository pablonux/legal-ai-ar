[{"codigo":7875752,"analisisDocumental":{"id":787575,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 1 - ACTOR: ALFARO, OSVALDO DANTE  s/ART. 250 C.P.C. - INCIDENTE CIVIL","inconstitucional":false,"falloDestacado":{"id":6003,"titulo":"Competencia en materia sucesoria: sucesiones vinculadas. Excepción.","cabecilla":"<p>El Juzgado Nacional de Primera Instancia en lo Civil y el Juzgado en lo Civil y Comercial de La Matanza, provincia de Buenos Aires, discrepan sobre su competencia para conocer en el proceso sucesorio del causante. La Corte resolvió que <b>tratándose de sucesiones vinculadas</b> y atendiendo a razones de economía procesal, seguridad jurídica y unidad sucesoria, las actuaciones deben radicarse ante el juzgado provincial. En tal sentido, consideró que concurren las situaciones especiales de conexidad para apartarse del principio basal del último domicilio del causante (art. 2336, Código Civil y Comercial de la Nación) y <b>admitir la acumulación de sucesiones</b>, cuando se trata del mismo patrimonio, existe identidad de herederos y no se inscribió la partición; todo lo cual, sumado a la economía procesal, convalida que siga entendiendo en el expediente un juzgado que no es el establecido por la citada regla.</p>","esNovedad":true,"fecha":1696906800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1697112252268,"usuarioCreacion":4,"fechaCreacion":1696966307535,"privado":false,"posicion":0,"resumen":null},"reciboEntrada":{"id":113583,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36098674,"numeroExpediente":66483,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":521,"descripcion":"SUCESION AB-INTESTATO","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Incidente Nº 1 - ACTOR: ALFARO, OSVALDO DANTE  s/ART. 250 C.P.C. - INCIDENTE CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"66483. "},"recurso":{"id":6215206,"expediente":{"id":36098674,"numeroExpediente":66483,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":521,"descripcion":"SUCESION AB-INTESTATO","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Incidente Nº 1 - ACTOR: ALFARO, OSVALDO DANTE  s/ART. 