[{"codigo":8101313,"analisisDocumental":{"id":810131,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"CODAPRI S.A. c/ BANCO MACRO S.A. s/DAÑOS Y PERJUICIOS - RECURSO DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":8921,"titulo":"El rol de la equidad en el sistema jurídico y la arbitrariedad de la sentencia","cabecilla":"<p style=\"text-indent:2em\">La corte provincial confirmó la sentencia condenatoria de primera instancia, al considerar responsable a la entidad bancaria por los daños y perjuicios provocados por la inhabilitación del presidente del directorio para firmar cheques.</p><p style=\"text-indent:2em\">Contra dicha sentencia se dedujo recurso extraordinario. <b>La Corte dejó sin efecto la sentencia.</b></p><p style=\"text-indent:2em\">Para decidir de ese modo, entendió que la sentencia impugnada realizó un análisis apartado del sistema sancionatorio de rechazos de cheques (<a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-24452-14733/actualizacion\">ley 24.452</a>, <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-25730-83397/texto\">ley 25.730</a>, <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/decreto-1085-2003-90379/texto\">decreto 1085/03</a>).</p><p style=\"text-indent:2em\">Entre otros fundamentos, para la Corte la sentencia adolece de graves falencias de fundamentación que se ven profundizadas mediante las referencias a \"razones morales\", la  equidad\" y los \"principios éticos\" que cierran el decisorio y con las que el <em>a quo</em> parece querer justificar el manifiesto apartamiento de las normas aplicables en que incurrió.</p><p style=\"text-indent:2em\">Así, con cita de un único trabajo de doctrina y con referencia a un artículo del Código Civil y Comercial de la Nación que no menciona ni identifica de manera alguna -sostiene el Tribunal- el fallo afirma que \"no pueden quedar dudas razonables acerca de la posibilidad de dictar fallos de equidad dentro de nuestro sistema jurídico\". Sin perjuicio de que la cita que efectúa no apoya tal conclusión, pues se limita a mencionar el rol de la equidad para integrar \"lagunas jurídicas\" o en tanto sea referida expresamente por una norma jurídica, lo que no ocurre en la causa, resulta de toda evidencia que -entendió la Corte-  cualquiera que fuere el valor jurídico de nociones como la equidad en el derecho argentino, este no le otorga el rol de justificar la lisa y llana prescindencia de normas positivas aplicables (doctrina de Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=306&amp;pagina=783\">306:783</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=313&amp;pagina=634\">313:634</a>; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=315&amp;pagina=727\">315:727</a>; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=322&amp;pagina=1017\">322:1017</a>; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=324&amp;pagina=2169\">324:2169</a>, entre otros), que es precisamente lo que hizo el superior tribunal de la causa</p><p style=\"text-indent:2em\">En ese contexto, la invocación de las nociones referidas no es más que un fundamento aparente que pretende sustentar una decisión basada en la sola voluntad de los jueces.</p>","esNovedad":true,"fecha":1749524400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1749743502208,"usuarioCreacion":11,"fechaCreacion":1749658045946,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":138582,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35840421,"numeroExpediente":1834,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"CODAPRI S.A. c/ BANCO MACRO S.A. s/DAÑOS Y PERJUICIOS - RECURSO DE INCONSTITUCIONALIDAD","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1834. "},"recurso":{"id":6131979,