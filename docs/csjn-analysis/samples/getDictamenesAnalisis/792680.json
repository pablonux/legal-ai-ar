[{"codigo":7926802,"analisisDocumental":{"id":792680,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"BARBATO, JUAN CARLOS c/ OBRA SOCIAL DEL PERSONAL MARITIMO s/AMPARO","inconstitucional":false,"falloDestacado":{"id":6343,"titulo":"Competencia del fuero federal cuando se trata de la aplicación de normas inherentes al sistema nacional de salud","cabecilla":"<p> </p><p>     Ante el planteo del actor para que se deje sin efecto su suspensión como Secretario de Acción Social y miembro del consejo directivo de una obra social se originó un conflicto de competencia entre un juzgado del trabajo y un juzgado civil comercial federal. El primero argumentó que solo puede abarcar acciones donde el conflicto individual deba resolverse, directa o indirectamente, con apoyo en el derecho del trabajo y el segundo rechazó la radicación por considerar que no se encontraban comprometidas prestaciones médico asistenciales.</p><p>    La Corte resolvió que el fuero federal era competente para entender en la acción pues su objeto se vinculaba con la integración del consejo directivo de la obra social accionada. Sostuvo que el planteo del actor se dirigía a cuestionar las potestades y la dinámica de funcionamiento de un agente natural del Sistema Nacional de Seguro de Salud, que se halla sometido exclusivamente, en su faz pasiva, a la jurisdicción de los tribunales federales (arts. 1, 2, 15 y 38, ley 23.661).</p>","esNovedad":true,"fecha":1703127600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1703259110387,"usuarioCreacion":4,"fechaCreacion":1703247263954,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":116774,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34867489,"numeroExpediente":12175,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":1226,"descripcion":"AMPARO","idMateria":3,"tema":{"id":460,"codigo":"AMPAROS"}},"caratula":"BARBATO, JUAN CARLOS c/ OBRA SOCIAL DEL PERSONAL MARITIMO s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"12175. "},"recurso":{"id":6281973,"expediente":{"id":34867489,"numeroExpediente":12175,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":1226,"descripcion":"AMPARO"