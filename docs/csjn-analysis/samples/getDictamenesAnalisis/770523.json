[{"codigo":7705232,"analisisDocumental":{"id":770523,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"MANFREDOTTI, MARIO ALBERTO c/ IPAUSS s/ACCION CONTENCIOSO ADMINISTRATIVA","alias":null,"caratula":"MANFREDOTTI, MARIO ALBERTO c/ IPAUSS s/ACCION CONTENCIOSO ADMINISTRATIVA","inconstitucional":true,"falloDestacado":{"id":3021,"titulo":"Ley provincial de jubilación, reciprocidad y cómputo de los servicios prestados","cabecilla":"<p>El actor vio rechazada su demanda promovida para el&nbsp;<strong>reconocimiento del derecho jubilatorio</strong>&nbsp;en los t&eacute;rminos del R&eacute;gimen de Jubilaciones y Pensiones para el Personal de los Tres Poderes del Estado Provincial, sobre la base que si bien cumpl&iacute;a con los a&ntilde;os de edad y servicios generales exigidos por la norma local, no acredit&oacute; los 10 a&ntilde;os de aportes en el r&eacute;gimen jubilatorio provincial, lo que le imped&iacute;a, seg&uacute;n la sentencia, acceder a las prestaciones de la ley. En esa l&iacute;nea, la sentencia rechaz&oacute; los agravios planteados por el actor con relaci&oacute;n a la falta de consideraci&oacute;n como locales de los servicios que prest&oacute; en la Administraci&oacute;n del entonces Territorio Nacional de la Tierra del Fuego desde el a&ntilde;o 1971 hasta 1977. Contra dicha decisi&oacute;n adversa, el actor recurri&oacute; la sentencia ante la Corte Suprema.&nbsp;<strong>El Tribunal, por unanimidad, la dej&oacute; sin efecto y orden&oacute; dictar un nuevo pronunciamiento.</strong>&nbsp;Entre los fundamentos, y con cita de diversos precedentes, sostuvo que la ley 561 que establece una distinci&oacute;n entre los servicios prestados con anterioridad y con posterioridad a enero de 1985 a la Administraci&oacute;n del entonces&nbsp;<strong>Territorio Nacional de la Tierra del Fuego</strong>&nbsp;restringe indebidamente la tutela prevista en el art&iacute;culo 23 de la ley 23.775. Ello, por cuanto este precepto, a fin de evitar perjuicios a los trabajadores derivados del cambio de estatus de la entidad estatal, impone el reconocimiento de la totalidad de los servicios con aportes prestados en el territorio nacional, con anterioridad a su transformaci&oacute;n en provincia.</p>","esNovedad":true,"fecha":1635994800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1636136087192,"usuarioCreacion":11,"fechaCreacion":1636053233431,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":32414,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"exped