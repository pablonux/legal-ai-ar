[{"codigo":7980292,"analisisDocumental":{"id":798029,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"SANCHEZ, RAMON (VICTIMA) s/MUERTE POR CAUSA DUDOSA","inconstitucional":false,"falloDestacado":{"id":7081,"titulo":"Colisión en el Río Paraná: seguridad de la navegación y competencia federal","cabecilla":"<p style=\"text-indent:2em\">En la causa instruida por la Prefectura Naval Argentina a raíz de que un navío remolcador con doce barcazas de bandera paraguaya embistió a una lancha de pesca, se originó un conflicto negativo de competencia entre la justicia provincial y la justicia federal.</p><p style=\"text-indent:2em\">La Corte decidió que esta última debía seguir conociendo en las actuaciones.</p><p style=\"text-indent:2em\">Señaló que si bien las embarcaciones siniestradas no habrían afectado la navegabilidad del canal del Río Paraná, dado que el remolcador de empuje, por sus dimensiones y potencia, habría continuado su trayecto y la lancha damnificada habría quedado a la deriva, fuera de aquel curso de agua, la colisión habría comprometido la seguridad de la navegación que compete preservar a la Prefectura en aguas de tráfico y circulación fluvial interjurisdiccional, en tanto la embarcación deportiva dio vuelta campana y resultó muerto uno de sus tripulantes.</p>","esNovedad":true,"fecha":1719284400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1719403391730,"usuarioCreacion":4,"fechaCreacion":1719401460076,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":122202,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30283193,"numeroExpediente":1435,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10579,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"SANCHEZ, RAMON (VICTIMA) s/MUERTE POR CAUSA DUDOSA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1435. "},"recurso":{"id":5143578,"expediente":{"id":30283193,"numeroExpediente":1435,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10579,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"SANCHEZ, RAMON (VICTIMA) s/MUERTE POR CAUSA DUDOSA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdenti