[{"codigo":7779802,"analisisDocumental":{"id":777980,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"MENDOZA ROMERO, MIGUEL ANGEL s/EXTRADICION","alias":null,"caratula":"REQUERIDO: MENDOZA ROMERO, MIGUEL ANGEL  s/EXTRADICION","inconstitucional":false,"falloDestacado":{"id":4822,"titulo":"Extradición e interés superior del niño","cabecilla":"<p>Una persona extraditada a la República del Perú por el delito de violación de menor de edad planteó la nulidad de la sentencia. Ante el rechazo de sus planteos recurrió a la <b>Corte que, por unanimidad confirmó la sentencia apelada.</b> Para decidir de ese modo, el Tribunal entendió que, contrariamente a lo esgrimido por el extraditado, en este caso no se daban las circunstancias de los precedentes de Fallos <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=331&amp;pagina=1352\">331:1352</a> y <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=338&amp;pagina=342\">338:342</a>. Por otra parte, constató la Corte que el juez de la causa no se desentendió del deber de garantizar el “interés superior de los niños\" adoptándose las medidas conducentes al respecto. Al margen de ello, se indica en la sentencia, que no solo es el juez de la extradición, durante el \"trámite judicial\", el que puede y debe velar por hacer efectivo el \"interés superior del niño\", sino también cada una de las demás autoridades estatales que intervinieron durante el \"trámite judicial\" como las que intervendrán en lo que resta del procedimiento de extradición, en las sucesivas decisiones y medidas que se adopten, quienes deberán estudiar, en la oportunidad y bajo la modalidad que mejor se ajuste a las particularidades del caso y en forma sistemática, cómo los derechos y los intereses de los menores a cargo de personas requeridas pueden verse afectados.</p>","esNovedad":true,"fecha":1668481200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1668706926669,"usuarioCreacion":11,"fechaCreacion":1668534999220,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":35062,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23860894,"numeroExpediente":31345,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descripcionLarga":"FLP - Justicia Federal de La Plata"},"objetoJuicio":{"id":7921,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"REQUERIDO: MENDOZA ROMERO, MIGUEL ANGEL  s/EXTRADICION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"31345.