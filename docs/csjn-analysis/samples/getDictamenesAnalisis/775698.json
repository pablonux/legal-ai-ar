ales. La recurrente cuestion&oacute; la decisi&oacute;n fundada en que el interinato prolongado en el tiempo hab&iacute;a generado una expectativa de estabilidad susceptible de protecci&oacute;n jurisdiccional. La Corte confirm&oacute; la sentencia apelada con base en que el cese en las funciones transitorias se encontraba firme, lo que constitu&iacute;a un obst&aacute;culo insalvable para la procedencia de cualquier reparaci&oacute;n econ&oacute;mica. Record&oacute;, por su parte, que al no mediar declaraci&oacute;n de ilegitimidad no puede haber resarcimiento o pago de suma de dinero alguna pues falta la causa de tales obligaciones.</p>","esNovedad":true,"fecha":1655348400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1655823002107,"usuarioCreacion":11,"fechaCreacion":1655415071766,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":34226,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":11245322,"numeroExpediente":29069,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"LEDESMA ALICIA NOEMI c/ HOSPITAL GARRAHAN-CONSEJO ADM-RESOL 106/10 Y 625/09 s/PROCESO DE CONOCIMIENTO","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"29069. "},"recurso":{"id":5322682,"expediente":{"id":11245322,"numeroExpediente":29069,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abrevia