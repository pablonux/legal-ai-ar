[{"codigo":7598842,"analisisDocumental":{"id":759884,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"ADEMUS y otros c/ Municipalidad de la Ciudad de Salta y otro s/ amparo sindical ","alias":null,"caratula":"ADEMUS Y OTROS c/ MUNICIPALIDAD DE LA CIUDAD DE SALTA- Y OTRO s/AMPARO SINDICAL","inconstitucional":false,"falloDestacado":{"id":1497,"titulo":"Validez constitucional de la potestad de los sindicatos con personería gremial para negociar convenios colectivos de trabajo","cabecilla":"Decisión de cámara que consideró violatoria del principio de libertad sindical e inconstitucional la resolución que homologó un convenio colectivo de trabajo en virtud de que en su negociación fueron excluidos los sindicatos simplemente inscriptos del sector - Declaración de inconstitucionalidad del art. 31, inc. a, de la ley 23.551, sin advertir que no era esa la norma que regía específicamente el caso - Fundamentos que exhiben una notoria distorsión de la doctrina constitucional establecida por la Corte en la materia - La prerrogativa de los sindicatos con personería gremial para intervenir en las negociaciones colectivas no está reglada en el art. 31, inc. a, de la ley 23.551 sino específicamente en el inc. c de dicho artículo - Omisión de la cámara, que no examinó dicho inciso a fin de discernir si resultaba o no compatible con la Constitución Nacional - Decisión desprovista de sustento pues no ha sido desarrollada en torno al texto legal que rige el caso - Sentencia de cámara que ha dado a la doctrina constitucional establecida por la Corte sobre la materia un alcance que no tiene - Observaciones de la Comisión de Expertos en la Aplicación de Convenios y Recomendaciones de la OIT y el Comité de Libertad Sindical que lejos de otorgar respaldo a la tesitura expuesta por el a quo la desacredita - El reconocimiento a los sindicatos que cuentan con personería gremial de una prioridad en la negociación colectiva, no resulta constitucionalmente objetable - Falta de sustento de la objeción constitucional formulada por la cámara respecto de la resolución que homologó el convenio - Se deja sin efecto la sentencia apelada - Disidencia del juez Rosatti: El art. 14 bis, primer párrafo de la Constitución Nacional estableció para nuestro país, de manera concluyente, un modelo sindical libre, democrático y desburocratizado - El régimen legal infraconstitucional no puede retacear tales derechos justificándolo en la mayor representatividad del sindicato con personería gremial - La mayor representatividad de un sindicato debe expresarse en la composición cuantitativa de la mesa paritaria, sin que ello autorice a excluir a los sindicatos menos representativos - Los precedentes del Tribunal en la materia han sido interpretados correctamente por el a quo y no entran en colisión con la decisión de baja instancia - Las cláusulas de la normativa internacional y sus interpretaciones no pueden ser entendidas como una modificación o restricción de los derechos y garantías establecidos en la Constitución Nacional","esNovedad":true,"fecha":1599102000000,"relevancia":3,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29247,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24627904,"numeroExpediente":648,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":24,"codigo":"24","abreviatura":"FSA","descripcion":"Justicia Federal de Salta","estado":0,"descripcionLarga":"FSA - Justicia Federal de Salta"},"objetoJuicio":{"id":3107,"descripcion":"AMPARO SINDICAL","idMateria":112,"tema":{"id":180,"codigo":"AMPAROS"}},"caratula":"ADEMUS Y OTROS c/ MUNICIPALIDAD DE LA CIUDAD DE SALTA- Y OTRO s/AMPARO SINDICAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"648. "},"recurso":{"id":4943513,"expediente":{"id":24627904,"numeroExpediente":648,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":24,"codigo":"24","abreviatura":"FSA","descripcion":"Justicia Federal de Salta","estado":0,"descripcionLarga":"FSA - Justicia Federal de Salta"},"objetoJuicio":{"id":3107,"descripcion":"AMPARO SINDICAL","idMateria":112,"tema":{"id":180,"codigo":"AMPAROS"}},"caratula":"ADEMUS Y OTROS c/ MUNICIPALIDAD DE LA CIUDAD DE SALTA- Y OTRO s/AMPARO SINDICAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"648. "},"tipoRecurso":{"id":1166,"codigo":"REX","descripcion":"RECURSO EXTRAORDINARIO"},"claveRecurso":"FSA 000648/2015/CS001","identificacionExpediente":"FSA 000648/2015/CS001"},"piezas":2,"urgente":"S","observaciones":null,"usuarioCreacion":nul