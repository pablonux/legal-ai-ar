[{"codigo":7645842,"analisisDocumental":{"id":764584,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"Recurso Queja Nº 2 - GRINDETTI, NESTOR OSVALDO c/ EDESUR S.A. Y OTRO s/AMPARO COLECTIVO","alias":null,"caratula":"Recurso Queja Nº 2 - GRINDETTI, NESTOR OSVALDO c/ EDESUR S.A. Y OTRO s/AMPARO COLECTIVO","inconstitucional":false,"falloDestacado":{"id":1761,"titulo":"Falta de legitimación colectiva de la autoridad municipal en reclamo por cortes de suministro eléctrico","cabecilla":"<p>Acci&oacute;n de amparo iniciada por un intendente contra la empresa distribuidora y el Ente Nacional Regulador de la Energ&iacute;a El&eacute;ctrica (ENRE) - Invocaci&oacute;n de la tutela de los derechos de los habitantes del municipio afectados por cortes de suministro a los que calific&oacute; de derechos de incidencia colectiva referentes a intereses individuales homog&eacute;neos - Sentencia de c&aacute;mara que confirm&oacute; la medida cautelar solicitada y orden&oacute; restablecer inmediatamente el servicio el&eacute;ctrico y mantenerlo en forma ininterrumpida, devolver a los usuarios los importes correspondientes a las tarifas abonadas m&aacute;s la reparaci&oacute;n integral de los da&ntilde;os causados y acordar un protocolo de actuaci&oacute;n en caso de reiteraci&oacute;n de los cortes- Recurso interpuesto por la demandada - Necesidad de analizar la legitimaci&oacute;n invocada por el actor aunque sea un tema ajeno a los agravios planteados en el recurso extraordinario - Legitimaci&oacute;n como presupuesto necesario para que exista un caso o controversia - El art&iacute;culo 43, segundo p&aacute;rrafo, solo reconoce legitimaci&oacute;n extraordinaria para intervenir en el proceso en defensa de derechos de incidencia colectiva al afectado, al Defensor del Pueblo y a las asociaciones que propendan a los fines indicados en la norma - No se habilita la actuaci&oacute;n de las autoridades locales, provinciales o municipales - La legislaci&oacute;n local no puede ampliar la legitimaci&oacute;n colectiva fijada en las normas nacionales para litigar ante la justicia federal - No cabe reconocer la legitimaci&oacute;n colectiva invocada por el actor en su calidad de afectado por la interrupci&oacute;n del servicio de energ&iacute;a en las dependencias municipales y en la v&iacute;a p&uacute;blica - El car&aacute;cter de intendente y la afectaci&oacute;n del servicio en dependencias municipales son insuficientes para representar a los habitantes afectados ante los tribunales federales - Se revoca la sentencia apelada y se desestima la acci&oacute;n de amparo - Disidencia del juez Rosatti: Aceptaci&oacute;n de la legitimaci&oacute;n - Representaci&oacute;n que el intendente ejerce de la municipalidad entendida como el conjunto de instalaciones, recursos materiales y dotaci&oacute;n de personal encaminados al cumplimiento de cometidos primarios espec&iacute;ficos dentro del ejido territorial asignado invocando su calidad de afectado - Modificaci&oacute;n sustancial de los hechos que sustentaron la pretensi&oacute;n cautelar encontr&aacute;ndose radicada la medida cautelar ante la Corte- Inoficioso expedirse actualmente.</p>","esNovedad":true,"fecha":1618455600000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1618841329741,"usuarioCreacion":11,"fechaCreacion":1618841324011,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30463,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28361166,"numeroExpediente":177,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descripcionLarga":"FLP - Justicia Federal de La Plata"},"objetoJuicio":{"id":7936,"descripcion":"AMPARO COLECTIVO","idMateria":112,"tema":{"id":360,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 2 - GRINDETTI, NESTOR OSVALDO c/ EDESUR S.A. Y OTRO s/AMPARO COLECTIVO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"177. "},"recurso":{"id":4845595,"expediente":{"id":28361166,"numeroExpediente":177,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descripcionLarga":"FLP - Justicia Federal de La Plata"},"objetoJuicio":{"id":7936,"descripcion":"AMPARO COLECTIVO","idMateria":112,"tema":{"id":360,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 2 - GRINDETTI, NESTOR OSVALDO c/ EDESUR S.A. Y OTRO s/AMPARO COLECTIVO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"177. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECUR