[{"codigo":7853062,"analisisDocumental":{"id":785306,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"MENENDEZ, LUCIANO BENJAMIN Y OTROS s/INCIDENTE DE RECURSO EXTRAORDINARIO","alias":null,"caratula":"Incidente Nº 93 - VICTIMA: SALAMANCA, RENEE RUFINO Y OTROS IMPUTADO: MENENDEZ, LUCIANO BENJAMIN Y OTROS s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":6141,"titulo":"Falta de mayoría de opiniones sustancialmente coincidentes en la sentencia apelada","cabecilla":"<p>La cámara rechazó el recurso interpuesto contra la sentencia que no hizo lugar al planteo de nulidad de la intervención judicial de una empresa durante la dictadura militar. La Corte dejó sin efecto esta decisión. Recordó que la validez de un fallo depende no solamente de que la mayoría convenga en la parte dispositiva, sino que también exhiba una sustancial coincidencia en los fundamentos. Consideró que se trata de un caso especialmente flagrante de ausencia de coincidencia acerca de los fundamentos de lo que se resolvió ya que los dos magistrados cuyos votos confluyen en la resolución adoptada no sólo no comparten los fundamentos en los que se apoyan, sino que defienden posiciones opuestas. En efecto, un juez sostuvo que la jurisdicción penal carecía de competencia para pronunciarse sobre la validez de la intervención judicial de la empresa mientras que el otro consideró que el tribunal oral, con base en una correcta valoración de la prueba, había descartado fundadamente la hipótesis fáctica en la que se sostenía la pretensión de la recurrente, lo que implicaba la negación de la tesis de su colega. Agregó el Tribunal que en el caso de los tribunales pluripersonales los jueces profesionales tienen el deber de asegurar una clara y explícita mayoría sustancial de fundamentos en sus decisiones, pues, de lo contrario, se correría el riesgo de incurrir en el absurdo de suponer que, para impugnar, sean las partes del proceso quienes deban escoger cualesquiera de los fundamentos de los votos individuales que confluyeron en la decisión.</p>","esNovedad":true,"fecha":1699930800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1700073186587,"usuarioCreacion":11,"fechaCreacion":1699993037263,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":110858,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33006495,"numeroExpediente":93000136,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1