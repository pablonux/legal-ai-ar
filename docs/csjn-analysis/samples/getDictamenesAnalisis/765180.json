[{"codigo":7651802,"analisisDocumental":{"id":765180,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"GCBA c/ CENTRO MEDICO SANTA ISABEL S.A. s/EJECUCION FISCAL-INGRESOS BRUTOS-CONVENIO MULTILATERAL","alias":null,"caratula":"GCBA c/ CENTRO MEDICO SANTA ISABEL S.A. s/EJECUCION FISCAL-INGRESOS BRUTOS-CONVENIO MULTILATERAL","inconstitucional":false,"falloDestacado":{"id":1762,"titulo":"La excepción de inexistencia de deuda exigible en el juicio de apremio","cabecilla":"<p>Desestimaci&oacute;n de la excepci&oacute;n de inhabilidad de t&iacute;tulo y orden de llevar adelante la ejecuci&oacute;n - Omisi&oacute;n del tratamiento de cuestiones oportunamente introducidas por la apelante y relevantes para la correcta soluci&oacute;n del pleito - Si bien en principio las sentencias en los juicios ejecutivos no re&uacute;nen el car&aacute;cter de definitivas, a los fines del recurso previsto en el art. 14 de la ley 48, ello no implica que pueda exagerarse el formalismo hasta el extremo de admitir una condena por deuda inexistente cuando ello resulta manifiesto de las actuaciones - Es doctrina de la Corte que los tribunales se encuentran obligados a tratar y resolver adecuadamente en tales pleitos las defensas fundadas en la inexistencia de deuda siempre y cuando ello no presuponga el examen de otras cuestiones cuya acreditaci&oacute;n exceda el limitado &aacute;mbito de estos procesos, raz&oacute;n por la cual se concluye, sin dificultad, que no pueden ser tenidas como sentencias v&aacute;lidas las que omitan tratar en forma adecuada las defensas aludidas, toda vez que aqu&eacute;llas han de gravitar fundamentalmente en el resultado de la causa - Decisi&oacute;n que no valor&oacute; las constancias probatorias aportadas por la ejecutada - La sencilla verificaci&oacute;n del planteo, oportunamente introducido por la ejecutada, no afectaba el car&aacute;cter ejecutivo de la acci&oacute;n promovida - Se revoca la sentencia apelada.</p>","esNovedad":true,"fecha":1618455600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1618841540485,"usuarioCreacion":11,"fechaCreacion":1618841390218,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30685,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33149324,"numeroExpediente":188,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descrip