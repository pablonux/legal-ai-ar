[{"codigo":7953434,"analisisDocumental":{"id":795343,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ESTEPA, HECTOR DANIEL s/recurso extraordinario de inaplicabilidad de ley","inconstitucional":false,"falloDestacado":{"id":6661,"titulo":"Juicio criminal: restricción sustancial que afecta el debido proceso y la defensa en juicio","cabecilla":"<p style=\"text-indent:2em\">En el marco de una condena por el delito de homicidio el tribunal de casación declaró extemporáneo el recurso interpuesto porque tomó como fecha que daba comienzo al plazo para impugnar aquella en la cual el imputado había sido notificado personalmente del rechazo del recurso de casación, que fue anterior a la notificación de su defensora oficial.</p><p style=\"text-indent:2em\">El recurrente consideró que dicho rechazo resultaba arbitrario y que se había frustrado el derecho de defensa y a recurrir la sentencia de condena. El superior tribunal provincial consideró mal concedido el recurso afirmando que los agravios solo remitían al análisis de una cuestión fundada en el derecho procesal local.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta decisión. Consideró que omitió pronunciarse sobre la cuestión federal mediante la cual se había cuestionado la arbitrariedad en la que habría incurrido el tribunal de casación al clausurar la vía de queja local y cómo ese proceder había impactado en el ejercicio del derecho de defensa. Agregó que ello adquiría singular importancia por cuanto, de ese modo, se había frustrado el último recurso disponible para que el imputado pudiera controvertir eficazmente su condena, extremo que debió haber sido ponderado en el marco del \"deber de garantizar\" el derecho al recurso que asiste a toda persona inculpada de delito.</p>","esNovedad":true,"fecha":1712631600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1712773085180,"usuarioCreacion":11,"fechaCreacion":1712691691922,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":119011,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32700929,"numeroExpediente":2047,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ESTEPA, HECTOR DANIEL s/recurso extraordinario de inaplicabilidad de ley","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2047. "},"recurso":{"id":5451752,"expediente":{"id":32700929,"numeroExpediente":2047,"anioExpediente":2018,"tomoExp