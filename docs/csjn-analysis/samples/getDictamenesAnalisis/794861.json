[{"codigo":7948613,"analisisDocumental":{"id":794861,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - FRANCO, ANA DEL VALLE c/ RENAULT S.A.S. Y OTROS s/DESPIDO","inconstitucional":false,"falloDestacado":{"id":6641,"titulo":"Reconocimiento de una sentencia francesa y cosa juzgada","cabecilla":"<p style=\"text-indent:2em\">La cámara laboral, si bien admitió la existencia de una sentencia de un tribunal del trabajo de la República de Francia, rechazó la defensa de cosa juzgada interpuesta por las demandadas.</p><p style=\"text-indent:2em\">Consideró que éstas no cumplimentaron todos los requisitos que aprueba la Convención de Cooperación Judicial suscripta con la República Francesa, para que la resolución extranjera sea reconocida en nuestro país.</p><p style=\"text-indent:2em\"><b>La Corte dejó sin efecto el pronunciamiento </b>por considerar que dichos requisitos sí estaban cumplidos.</p><p style=\"text-indent:2em\">En primer lugar señaló que de las constancias del expediente resultaba que las recurrentes habían acompañado en su conteste una copia de la sentencia extranjera cuyo reconocimiento se pretendía, traducida y apostillada.</p><p style=\"text-indent:2em\">El Tribunal apreció que era erróneo el argumento de que la decisión francesa había vulnerado el orden público laboral argentino al haber admitido el pago de la condena mediante un cheque que no estaba dirigido nominalmente a la trabajadora y que no había una constancia documentada que diera cuenta de su efectiva percepción por ella. Afirmó en este sentido que el pago o la ejecución de la sentencia constituyen actos autónomos e independientes de la decisión de fondo, <em>por lo que lo relativo a su cumplimiento o incumplimiento no afecta su firmeza ni su alcance de cosa juzgada.</em></p><p style=\"text-indent:2em\">También consideró incorrecto lo argumentado en el sentido de que las actuaciones judiciales argentinas fueron promovidas antes que las francesas y que, por ello, se encontraba incumplido el requisito previsto en el artículo 2, inciso 6, de la ley 24.107. Ello es así porque el inicio del proceso judicial argentino se produjo con las actuaciones ante el Servicio de Conciliación Laboral Obligatoria (SECLO), por lo que se trata de una etapa administrativa y la pretensión de equiparar dichas actuaciones con las judiciales para descartar el reconocimiento de la sentencia extranjera, se aparta del texto del precepto mencionado.</p><p style=\"text-indent:2em\">Por todo ello, consideró que los argumentos de la sentencia atacada dirigidos a rechazar la excepción de cosa juzgada no se corresponden con las constancias de la causa.</p>","esNovedad":true,"fecha":1712199600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1712598128688,"usuarioCreacion":4,"fechaCreacion":1712320019874,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":118659,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31947324,"numeroExpediente":24094,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - FRANCO, ANA DEL VALLE c/ RENAULT S.A.S. Y OTROS s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"24094. "},"recurso":{"id":5344290,"expediente":{"id":31947324,"numeroExpediente":24094,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - FRANCO, ANA DEL VALLE c/ RENAULT S.A.S. Y OTROS s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"24094. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CNT 024094/2010/1/RH001","identificacionExpediente":"CNT 024094/2010/1/RH001"},"piezas":1,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":10,"nombreUsuario":"27179020438","apellido":"Messuti","nombre":"Mariana","estado":"