[{"codigo":8094131,"analisisDocumental":{"id":809413,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ZARATE, PABLO FEDERICO Y OTROS c/ ENTE NACIONAL REGULADOR DE LA ELECTRICIDAD s/DIFERENCIAS DE SALARIOS","inconstitucional":false,"falloDestacado":{"id":8761,"titulo":"Capitalización de intereses en los créditos laborales: Precedente \"Oliva\"","cabecilla":"<p style=\"text-indent:2em\">La cámara hizo lugar a la demanda iniciada por varios trabajadores contra el Ente Nacional Regulador de la Electricidad a fin de obtener el cobro de las sumas adeudadas en concepto de premio o gratificación anual extraordinaria, más su correspondiente incidencia sobre el sueldo anual complementario, por los períodos 2017 a 2020.</p><p style=\"text-indent:2em\">La Corte declaró parcialmente procedente el recurso extraordinario interpuesto por la demandada y dejó sin efecto la sentencia.</p><p style=\"text-indent:2em\">En cuanto al fondo del asunto entendió que la apelación no cumplía con el requisito de fundamentación autónoma ni rebatía todos y cada uno de los fundamentos de la sentencia, en los términos de la jurisprudencia del Tribunal, que señala que el escrito de interposición debe contener una crítica concreta y razonada de los argumentos en que se basa la sentencia que se impugna, a cuyo efecto no basta sostener un criterio interpretativo distinto del que se ha seguido en la misma.</p><p style=\"text-indent:2em\">Por el contrario, en lo referido al agravio vinculado al cómputo de los intereses, consideró que la cuestión planteada resultaba sustancialmente análoga a la examinada en el precedente \"<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=347&amp;pagina=100\">Oliva</a>\". Allí la Corte sostuvo que la capitalización periódica y sucesiva ordenada con base en el acta 2764/2022 de la Cámara Nacional del Trabajo no encuentra sustento en las disposiciones del Código Civil y Comercial de la Nación, pues el artículo 770 de dicho código establece una regla clara según la cual no se deben intereses de los intereses y las excepciones que el mismo artículo contempla son taxativas y de interpretación restrictiva, de modo que no puede ser invocada, como hace el acta mencionada, para imponer capitalizaciones periódicas sucesivas durante la tramitación del juicio.</p>","esNovedad":true,"fecha":1748487600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1767031019551,"usuarioCreacion":11,"fechaCreacion":1748546273511,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":137752,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37767977,"numeroExpediente":1798,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9722,"descripcion":"DIFERENCIAS DE SALARIOS","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - ZARATE, PABLO FEDERICO Y OTROS c/ ENTE NACIONAL REGULADOR DE LA ELECTRICIDAD s/DIFERENCIAS DE SALARIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1798. "},"recurso":{"id":6564932,"expediente":{"id":37767977,"numeroExpediente":1798,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9722,"descripcion":"DIFERENCIAS DE SALARIOS","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - ZARATE, PABLO FEDERICO Y OTROS c/ ENTE NACIONAL REGULADOR DE LA ELECTRICIDAD s/DIFERENCIAS DE SALARIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1798. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CNT 001798/2019/1/RH001","identificacionExpediente":"CNT 001798/2019/1/RH001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":9,"nombreUsuario":"27203847888","apellido":"Sicardi","nombre":"Alexia","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583843697000,"nombreUsuarioMigrado":null,"codigo":"JUR545","mail":"asicardi@csjn.gov.ar","intentos":0,"notifica