pa&ntilde;&iacute;a financiera y varias aseguradoras solicitando que se ajuste a valores de mercado el precio de las primas de seguros que se exig&iacute;an a los adquirentes de veh&iacute;culos con financiaci&oacute;n prendaria - Acuerdo homologado que obligaba a la financiera a devolver las diferencias a los clientes y a publicar edictos en el Bolet&iacute;n Oficial y en un diario de circulaci&oacute;n nacional - Pedido de la actora de medidas complementarias (suministro de datos y publicaci&oacute;n de nuevos edictos) arguyendo que pocos clientes con contratos finiquitados se hab&iacute;an presentado a reclamar sus cr&eacute;ditos - Negativa de la demandada basada en que implicaban la modificaci&oacute;n del acuerdo homologado - Excesivo ritualismo - Homologaci&oacute;n de un convenio alcanzado en el marco de una acci&oacute;n colectiva y no de un reclamo individual - Frente al inter&eacute;s general involucrado en las acciones de incidencia colectiva y a la ausencia de una norma integral que las regule se impone un plus en la intervenci&oacute;n de los jueces en orden a la direcci&oacute;n de estos litigios - Necesidad de tutelar a las partes m&aacute;s vulnerables en las relaciones de consumo- Derecho de los consumidores a una informaci&oacute;n adecuada y veraz y a la protecci&oacute;n de sus intereses econ&oacute;micos - Notable desproporci&oacute;n que, en la satisfacci&oacute;n del cr&eacute;dito, se comprob&oacute; entre los clientes de la demandada que mantuvieron el contrato vigente al tiempo de la homologaci&oacute;n y los ex clientes de aqu&eacute;lla - Significativa visi&oacute;n de conjunto que fue eludida por el a quo, quien -mediante un excesivo ritualismo- se neg&oacute; a alcanzar la concreci&oacute;n del valor justicia y salvaguardar la garant&iacute;a de defensa en juicio - Se deja sin efecto la sentencia apelada - Disidencia de la jueza Highton de Nolasco: recurso inadmisible (art. 280 CPCCN).</p>","esNovedad":true,"fecha":1619665200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1619808233506,"usuarioCreacion":11,"fechaCreacion":1619792821510,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30867,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24263129,"numeroExpediente":19073,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":9481,"descripcion":"ORDINARIO","idMateria":4,"tema":{"id":501,"codigo":"JUIORD"}},"caratula":"Recurso Queja Nº 1 - ADECUA c/ BANCO PRIVADO DE INVERSIONES S.A. s/ORDINARIO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"19073. "},"recurso":{"id":3592276,"expediente":{"id":24263129,"numeroExpediente":19073,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":9481,"descripcion":"ORDINARIO","idMateria":4,"tema":{"id":501,"codigo":"JUIORD"}},"caratula":"Recurso Queja Nº 1 - ADECUA c/ BANCO PRIVADO DE INVERSIONES S.A. s/ORDINARIO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"19073. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"COM 019073/2007/1/RH001","identificacionExpediente":"COM 019073/2007/1/RH001"},"piezas":4,"urgente":"N","observaciones":null,"usuarioCreacion":null,"usuarioCreacionOld":"JUR545","usuarioModificacion":null,"u