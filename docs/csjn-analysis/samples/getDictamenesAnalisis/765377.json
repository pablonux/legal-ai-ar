[{"codigo":7653774,"analisisDocumental":{"id":765377,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":40,"codigoRelacion":80040,"valor":"PROCEDIMIENTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201512101503,"fechaModLong":201512101503,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"DE AGUIRRE, MARIA LAURA Y OTRO c/ LA PAMPA, PROVINCIA DE Y OTRO (ESTADO NACIONAL) s/AMPARO AMBIENTAL","alias":null,"caratula":"DE AGUIRRE, MARIA LAURA Y OTRO c/ LA PAMPA, PROVINCIA DE Y OTRO (ESTADO NACIONAL) s/AMPARO AMBIENTAL","inconstitucional":false,"falloDestacado":{"id":1748,"titulo":"Medidas dispuestas con fundamento en la Ley General del Ambiente para evaluar el impacto ambiental de una obra ","cabecilla":"<p>Acci&oacute;n de amparo contra la Provincia de La Pampa y el Estado Nacional a fin de que la primera cumpla con el estudio y evaluaci&oacute;n de impacto ambiental respecto de una obra de provisi&oacute;n transitoria de agua - Reclamo por no haberse efectuado la reglamentaci&oacute;n de la ley 25.688 de R&eacute;gimen de Gesti&oacute;n Ambiental - Manifestaci&oacute;n de que la obra est&aacute; planificada sin el correspondiente estudio de impacto ambiental y sin cumplir con el proceso de participaci&oacute;n ciudadana requeridos por la legislaci&oacute;n ambiental - Requerimiento de medida cautelar para que cese y se suspenda la totalidad de acciones direccionadas a iniciar la obra - Corresponde que la Corte, como custodio de las garant&iacute;as constitucionales, y con fundamento en la Ley General del Ambiente, ordene medidas - Se dispone requerir a la provincia la presentaci&oacute;n del programa ejecutivo de la obra, que acompa&ntilde;en todas las actuaciones relativas a los distintos aspectos ambientales del proyecto, en especial: la evaluaci&oacute;n de impacto ambiental, el sistema de control sobre el desarrollo de las actividades antr&oacute;picas, el sistema de diagn&oacute;stico e informaci&oacute;n ambiental y los mecanismos de participaci&oacute;n ciudadana.</p>","esNovedad":true,"fecha":1617850800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1618230608463,"usuarioCreacion":11,"fechaCreacion":1618230602723,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30735,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32798594,"numeroExpediente":2214,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10562,"descripcion":"AMPARO AMBIENTAL","idMateria":0,"tema":null},"caratula":"DE AGUIRRE, MARIA LAURA Y OTRO c/ LA PAMPA, PROVINCIA DE Y OTRO (ESTADO NACIONAL) s/AMPARO AMBIENTAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2214. "},"recurso":{"id":5469750,"expediente":{"id":32798594,"numeroExpediente":2214,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la N