[{"codigo":7730712,"analisisDocumental":{"id":773071,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"MAIDANA, RICARDO ALEJANDRO s/ RECURSO EXTRAORDINARIO DE INAPLICABILIDAD DE LEY","alias":null,"caratula":"MAIDANA, RICARDO ALEJANDRO s/recurso extraordinario de inaplicabilidad de ley","inconstitucional":false,"falloDestacado":{"id":4004,"titulo":"La posibilidad de obtener un nuevo pronunciamiento judicial a través de los recursos procesales como facultad del encausado y no del defensor","cabecilla":"<p>La Suprema Corte de Justicia provincial rechaz&oacute; el recurso de un condenado a prisi&oacute;n perpetua por considerarlo extempor&aacute;neo. Recurrida esta decisi&oacute;n, la Corte la dej&oacute; sin efecto pues consider&oacute; que&nbsp;el tribunal provincial hab&iacute;a omitido un escrito que el condenado hab&iacute;a hecho llegar a su defensor donde adem&aacute;s de su voluntad recursiva hab&iacute;a manifestado que no hab&iacute;a sido informado oportunamente de su derecho a impugnar la sentencia ni del plazo para hacerlo. Por otra parte, tuvo en cuenta adem&aacute;s,&nbsp;que no hab&iacute;a ninguna constancia de que se le haya advertido al condenado&nbsp;de su derecho a recurrir, ni del plazo para hacerlo. Bajo estas circunstancias&nbsp;record&oacute; el Tribunal que, la posibilidad de obtener un nuevo pronunciamiento judicial a trav&eacute;s de los recursos procesales constituye una facultad del encausado y no una potestad t&eacute;cnica del defensor por lo que es necesario adoptar los recaudos suficientes que garanticen plenamente el derecho de defensa.</p>","esNovedad":true,"fecha":1653361200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1653655241990,"usuarioCreacion":11,"fechaCreacion":1653420450147,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":33273,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29569855,"numeroExpediente":364,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MAIDANA, RICARDO ALEJANDRO s/recurso extraordinario de inaplicabilidad de ley","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"364. "},"recurso":{"id":5048033,"expediente":{"id":29569855,"numeroExpe