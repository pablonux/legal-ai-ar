[{"codigo":8070433,"analisisDocumental":{"id":807043,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - BUDEGUER JUAN JOSE c/ ESTADO NACIONAL - ONABE Y OTRO s/PRESCRIPCIÓN ADQUISITIVA","inconstitucional":false,"falloDestacado":{"id":8483,"titulo":"Usucapión: arbitrariedad en la valoración de la posesión del inmueble","cabecilla":"<p style=\"text-indent:2em\">La cámara hizo lugar a la demanda de prescripción adquisitiva promovida en contra del Estado Nacional basada en que el predio que se intentaba usucapir no tuvo uso público y que el actor había detentado la posesión pública, pacífica e ininterrumpida del inmueble por veinte años.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia.</p><p style=\"text-indent:2em\">Recordó que la comprobación de los extremos para usucapir un bien -en este caso de dominio del Estado- debe efectuarse de manera insospechable, clara y convincente, toda vez que la posesión veinteañal constituye un medio excepcional de adquisición de dominio. Agregó que no basta con que se acredite un relativo desinterés por el inmueble por parte del demandado, sino que es necesaria la cabal demostración de los actos posesorios efectuados por quien pretende usucapir y que sean lo suficientemente idóneos como para poner al propietario, que debe haber tenido conocimiento de ellos, en el trance de hacer valer por la vía que corresponde los derechos que le han sido desconocidos.</p><p style=\"text-indent:2em\">Señaló el Tribunal que el a quo tuvo por cumplido el plazo veinteañal para usucapir, adicionando el tiempo de los supuestos poseedores que precedieron al actor sin ponderar que las escrituras públicas por los cuales se efectuaron sucesivas cesiones de derechos y acciones posesorios sobre el predio en cuestión, no alcanzaban para acreditar que quienes cedieron la posesión hubieran estado legitimados para hacerlo ni que hubieran poseído el inmueble durante veinte años.</p>","esNovedad":true,"fecha":1743649200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1743720295478,"usuarioCreacion":4,"fechaCreacion":1743720174917,"privado":false,"posicion":3,"resumen":{"idResumen":151,"resumen":"La Corte revocó la sentencia que había dado lugar a la demanda de prescripción adquisitiva contra el Estado. Se exige prueba clara y convincente de la posesión veinteañal para usucapir, especialmente bienes del Estado, lo cual no se verificó en el caso.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":134562,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descr