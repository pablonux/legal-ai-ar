[{"codigo":7671863,"analisisDocumental":{"id":767186,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"H., A. O. s/INFRACCION LEY 23.737","alias":null,"caratula":"Recurso Queja Nº 1 - IMPUTADO: H., A. O. s/INFRACCION LEY 23.737","inconstitucional":false,"falloDestacado":{"id":2301,"titulo":"Convocatoria a prestar declaración indagatoria a un adolescente y límites de la responsabilidad penal","cabecilla":"<p>Resoluci&oacute;n del juez que dispuso tomarle declaraci&oacute;n indagatoria a un menor de quince a&ntilde;os - Oposici&oacute;n de la defensa -&nbsp;Rechazo de la objeci&oacute;n sobre la base que &ldquo;la declaraci&oacute;n indagatoria es un acto de defensa del imputado&quot; - Recurso extraordinario deducido por la Defensora P&uacute;blica Oficial - La legislaci&oacute;n penal de menores de nuestro pa&iacute;s ha mantenido, de modo invariable, la decisi&oacute;n de excluir del r&eacute;gimen punitivo a aquellos individuos que a&uacute;n no alcanzaron determinada edad - Criterio de pol&iacute;tica criminal que descansa en la consideraci&oacute;n de una presunci&oacute;n irrefutable, juris et de jure, de inexistencia de los requisitos intelectuales y volitivos necesarios que habilitan a fundar un juicio de responsabilidad a su respecto - A partir de la incorporaci&oacute;n de la Convenci&oacute;n sobre los Derechos del Ni&ntilde;o a nuestro sistema normativo, la necesidad de limitar la responsabilidad penal respecto de una determinada franja etaria forma parte del programa de nuestra Constituci&oacute;n en la materia - Argumento relativo a que del acto objeto de impugnaci&oacute;n pudiese finalmente emerger alguna utilidad real para la situaci&oacute;n del menor como afirmaci&oacute;n dogm&aacute;tica que nunca fue apoyada en circunstancias concretas de la causa - No resulta correcto buscar una justificaci&oacute;n del acto apelado bajo el ropaje del derecho del menor a ser o&iacute;do reconocido por el art&iacute;culo 12 de la Convenci&oacute;n sobre los Derechos del Ni&ntilde;o - Trasfondo real del sentido de la decisi&oacute;n que resulta ser la aparente necesidad de que el menor aportase alg&uacute;n dato relevante para la investigaci&oacute;n - No aparece como una decisi&oacute;n &eacute;tica valorable que el Estado persiga instrumentalizar a un sujeto al que expresamente preserva de su sistema represivo - Fundamentos que se apartan inequ&iacute;vocamente del r&eacute;gimen normativo aplicable a la soluci&oacute;n del caso - Se revoca el pronunciamiento apelado.</p>","esNovedad":true,"fecha":1624503600000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1628617957270,"usuarioCreacion":11,"fechaCreacion":1624622254922,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31339,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"P