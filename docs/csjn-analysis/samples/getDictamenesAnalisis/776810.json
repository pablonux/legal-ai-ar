[{"codigo":7768102,"analisisDocumental":{"id":776810,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"GCBA - PROCURACION c/ EN-Mº DE PLANIFICACIÓN s/ PROCESO DE CONOCIMIENTO","alias":null,"caratula":"Recurso Queja Nº 1 - GCBA-PROCURACION c/ EN-Mº DE PLANIFICACION s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":4186,"titulo":"Exceso de jurisdicción que altera el equilibrio procesal de los litigantes","cabecilla":"<p>El Gobierno de la Ciudad Aut&oacute;noma de Buenos Aires promovi&oacute; demanda con el objeto de que se declare la nulidad del decreto que dispuso operada, a favor del Estado Nacional, la prescripci&oacute;n adquisitiva de un inmueble, con fundamento en que se encontraba afectado al dominio p&uacute;blico, era imprescriptible e inalienable y, en tal car&aacute;cter, integraba el patrimonio de la Ciudad Aut&oacute;noma de Buenos Aires. La c&aacute;mara concluy&oacute; que se trataba de un bien del dominio p&uacute;blico del Estado Nacional, que fue quien lo hab&iacute;a construido y quien lo administraba en ese momento pero&nbsp;destac&oacute; que exist&iacute;a otro fundamento, distinto a la titularidad, que pod&iacute;a justificar la legitimaci&oacute;n procesal del actor para cuestionar la validez del decreto.&nbsp;La Corte, por mayor&iacute;a, dej&oacute; sin efecto la sentencia apelada con fundamento en que el pronunciamiento judicial que desconoce o acuerda derechos no debatidos en la causa es incompatible con las garant&iacute;as de los arts. 17 y 18 de la Constituci&oacute;n Nacional. Expres&oacute; que&nbsp;el fallo de primera instancia claramente hab&iacute;a se&ntilde;alado, sin que fuera controvertido por las partes, que el objeto del pleito se hallaba limitado al examen de la validez del decreto cuestionado y que no correspond&iacute;a determinar qui&eacute;n era el titular de la zona involucrada. As&iacute;, concluy&oacute; la Corte que la c&aacute;mara, so pretexto de pronunciarse acerca de la legitimaci&oacute;n de la Ciudad Aut&oacute;noma de Buenos Aires,&nbsp;se hab&iacute;a adentrado justamente en una&nbsp;<strong>cuesti&oacute;n sustancial respecto de la cual su jurisdicci&oacute;n no se encontraba habilitada</strong>.</p>","esNovedad":true,"fecha":1656990000000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1657112642914,"usuarioCreacion":11,"fechaCreacion":1657112445747,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":34656,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":27817302,"numeroExpediente":16881,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en l