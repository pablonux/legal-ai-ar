[{"codigo":7678912,"analisisDocumental":{"id":767891,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"GIMENEZ, ROSA ELISABE c/ COMISION MEDICA CENTRAL Y/O ANSES S/RECURSO DIRECTO LEY 24.241 s/RECURSO DIRECTO LEY 24.241","alias":null,"caratula":"GIMENEZ, ROSA ELISABE c/ COMISION MEDICA CENTRAL Y/O ANSES S/RECURSO DIRECTO LEY 24.241 s/RECURSO DIRECTO LEY 24.241","inconstitucional":true,"falloDestacado":{"id":2381,"titulo":"Tutela judicial efectiva a personas en situación de vulnerabilidad","cabecilla":"<p>Pedido del beneficio de pensi&oacute;n por el fallecimiento del padre de la actora en su car&aacute;cter de hija incapacitada para el trabajo - Rechazo por parte de la Comisi&oacute;n M&eacute;dica Central por no alcanzar el 66% de minusval&iacute;a requerido por la ley - Interposici&oacute;n del recurso directo ante la C&aacute;mara Federal de Salta y no ante la C&aacute;mara Federal de la Seguridad Social, como lo establece el art. 49, inc. 4 de la ley 24.241 - Planteo de inconstitucional de dicha norma, que la obliga a litigar a m&aacute;s de 1400 kil&oacute;metros de distancia de su domicilio - Decisi&oacute;n de la C&aacute;mara declar&aacute;ndose incompetente - Recurso extraordinario que plantea que se encuentra en situaci&oacute;n de especial vulnerabilidad pues padece una incapacidad, no percibe ingreso alguno y falleci&oacute; su padre, que era su sost&eacute;n econ&oacute;mico - Sujeto que demanda la tutela judicial efectiva - Colectivos de personas en situaci&oacute;n de vulnerabilidad - Costo mayor para el litigante, si tuviera que trasladarse para las revisaciones m&eacute;dicas, o una dilaci&oacute;n en la soluci&oacute;n del caso, si los ex&aacute;menes m&eacute;dicos se ordenaran mediante exhorto, a la par que irrazonable restricci&oacute;n en las posibilidades de defensa - A la excesiva distancia se suma el colapso en que se encuentra la C&aacute;mara Federal de la Seguridad Social debido a la sobrecarga de expedientes - No es razonable que personas que se encuentran en condiciones de vulnerabilidad y formulan pretensiones de car&aacute;cter alimentario, que se relacionan con su subsistencia y mejor calidad de vida, se vean compelidas a acudir a tribunales que distan centenares o miles de kil&oacute;metros del lugar donde residen - La competencia asignada a la C&aacute;mara Federal de la Seguridad Social por el art. 49, inciso 4, primer p&aacute;rrafo, de la ley 24.241 para ejercer el control judicial suficiente de las resoluciones de la Comisi&oacute;n M&eacute;dica Central, no resulta un medio adecuado, id&oacute;neo, necesario o proporcional a los derechos, intereses y valores que el Estado est&aacute; llamado a proteger en la materia bajo examen - Se revoca la sentencia apelada y se declara la inconstitucionalidad de la norma cuestionada.</p>","esNovedad":true,"fecha":1626318000000,"relevancia":2,"usuarioModificacion":4,"fechaMo