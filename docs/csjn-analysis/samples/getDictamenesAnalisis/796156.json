[{"codigo":7961562,"analisisDocumental":{"id":796156,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"MUNICIPALIDAD DE ALMIRANTE BROWN c/ BARRAZA, ELBA CRISTINA s/MEDIDA CAUTELAR AUTÓNOMA","inconstitucional":false,"falloDestacado":{"id":6761,"titulo":"Competencia en una causa vinculada al cumplimiento de la causa “Mendoza”","cabecilla":"<p style=\"text-indent:2em\">La Cámara Federal de San Martín y el Juzgado en lo Contencioso Administrativo n° 1 del Departamento Judicial de Lomas de Zamora, Provincia de Buenos Aires, discrepan sobre la competencia para entender en la acción cautelar autónoma entablada por la Municipalidad de Almirante Brown. La actora pretende que se disponga un allanamiento a los efectos de permitir el acceso de personal, herramientas y maquinarias, para llevar a cabo el desmantelamiento de edificaciones e instalaciones en un predio que pertenece a la provincia de Buenos Aires.</p><p style=\"text-indent:2em\">En ese marco, según la Corte,  resultan relevantes para dirimir el conflicto de competencia los criterios sentados por la Corte Suprema en sus sentencias del 8 de julio de 2008, 10 de noviembre de 2009 (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=331&amp;pagina=1622\">331:1622</a> y <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=332&amp;pagina=2522\">332:2522</a>, respectivamente) y 19 de diciembre de 2012, dictadas en la causa “Mendoza”.</p><p style=\"text-indent:2em\">Bajo ese prisma – señala el dictamen del Procurador al que adhiere el Tribunal -  las cuestiones planteadas en el  caso se vinculan al cumplimiento de la sentencia de la causa “Mendoza” y, en particular, a la ejecución de los programas vinculados con la prevención y remediación ambiental y con la relocalización de vecinos y vecinas de la cuenca, y se encuadran por ello, en la esfera de competencia del tribunal federal de Morón.</p>","esNovedad":true,"fecha":1714446000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1714653756616,"usuarioCreacion":4,"fechaCreacion":1714506421828,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":120118,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24770350,"numeroExpediente":14431,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":26,"codigo":"26","abreviatura":"FSM","descripcion":"Justicia Federal de San Martin","estado":0,"descripcionLarga":"FSM - Justicia Federal de San Martin"},"objetoJuicio":{"id":7186,"descripcion":"MEDIDA CAUTELAR AUTÓNOMA","idMateria":112,"tema":{"id":329,"codigo":"PROCESAL"}},"caratula":"MUNICIPALIDAD DE ALM