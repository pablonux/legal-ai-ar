[{"codigo":8045162,"analisisDocumental":{"id":804516,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"SOSA DE MICHLIG, LIGIA AMELIA c/ PROVINCIA DEL CHACO s/ACCION DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":8021,"titulo":"Apartamiento de las normas aplicables al declarar la inconstitucionalidad de una ley","cabecilla":"<p style=\"text-indent:2em\">El Superior Tribunal de Justicia de la Provincia del Chaco declaró la inconstitucionalidad de la ley local 2425-F (ex 7751) y de su decreto reglamentario 2092/16, mediante los cuales se imponen medios y modalidades de cancelación respecto de los montos que debe abonar el Estado provincial por haber sido condenado en el expediente.</p><p style=\"text-indent:2em\">Ante los recursos interpuestos por los representantes del Poder Legislativo y la provincia demandada la Corte dejó sin efecto la sentencia.</p><p style=\"text-indent:2em\">Consideró que el tribunal se extralimitó al declarar la inconstitucionalidad de la ley local -que establece una modalidad de pago de los créditos provenientes de las sentencias de condena dictadas contra la provincia- cuando la actora solo esgrimió y fundó la inconstitucionalidad del decreto reglamentario.</p><p style=\"text-indent:2em\">Señaló que el ordenamiento local que regula la acción de inconstitucionalidad ante la instancia originaria provincial contiene preceptos que exigen determinadas condiciones a los efectos de su procedencia formal cuyo cumplimiento fue verificado por el superior tribunal local en forma previa al tratamiento de las cuestiones de fondo únicamente en lo que concierne al decreto impugnado por la actora y, no obstante ello, el sentenciante consideró que se encontraba habilitado a examinar la validez de la ley aun de oficio.</p><p style=\"text-indent:2em\">Concluyó el Tribunal que el tribunal provincial no sólo se apartó de lo dispuesto por los arts. 9° de la Constitución provincial y 6° de la ley 1966-B (ex ley 6863) en cuanto requieren que, para la procedencia de esta acción específica, exista un pedido expreso de inconstitucionalidad por la parte legitimada para impugnar la norma, sino que también omitió examinar si la acción fue iniciada dentro del plazo previsto o se había extinguido su competencia originaria para entender en ella, produciendo así una violación a los derechos y garantías que la demandada invocaba.</p>","esNovedad":true,"fecha":1733367600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1733745158835,"usuarioCreacion":4,"fechaCreacion":1733505447096,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":