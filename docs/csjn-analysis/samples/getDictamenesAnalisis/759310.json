[{"codigo":7593103,"analisisDocumental":{"id":759310,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Rearte, Adriana Sandra y otro c/ Superior Gobierno de la Provincia de Córdoba s/ amparo - recuso de apelación ","alias":null,"caratula":"Rearte, Adriana Sandra y otro c/ Superior Gobierno de la Provincia de Córdoba s/amparo - recurso de apelación","inconstitucional":false,"falloDestacado":{"id":1464,"titulo":"La Corte reitera su doctrina de Fallos 340:437 en materia de sindicalización del personal del servicio penitenciario","cabecilla":"<p>Acci&oacute;n de amparo promovida para que se autorice al personal del servicio penitenciario provincial a ejercer el derecho de asociaci&oacute;n sindical - Planteo de inconstitucionalidad de la norma local que veda la posibilidad de agremiarse - Invocaci&oacute;n del derecho a constituir sindicatos reconocido por la Constituci&oacute;n Nacional - Servicios penitenciarios como parte integrante de las fuerzas de seguridad estatales - Semejanza existente entre la labor policial y la cumplida en los establecimientos penitenciarios - El derecho a sindicalizarse reconocido a los miembros de la polic&iacute;a y los dem&aacute;s cuerpos de seguridad interna por los tratados internacionales sobre derechos humanos est&aacute; sujeto a las restricciones o a la prohibici&oacute;n que surjan de una ley formal que es del resorte del legislador provincial - Cuesti&oacute;n an&aacute;loga a la resuelta en el precedente &quot;Sindicato Policial Buenos Aires&quot; (Fallos: 340:437) - Se confirma la sentencia del superior tribunal provincial que no admiti&oacute; el planteo de inconstitucionalidad del precepto cuestionado - Disidencia del juez Rosatti: el derecho de sindicalizaci&oacute;n del personal de las fuerzas de seguridad no confronta con valores constitucionales como la paz interior, la seguridad de las personas o el orden p&uacute;blico - La organizaci&oacute;n jer&aacute;rquica y vertical de las fuerzas no resulta contradictoria con la deliberaci&oacute;n democr&aacute;tica que debe guiar la acci&oacute;n gremial - El derecho del personal del servicio penitenciario provincial a constituir una asociaci&oacute;n sindical resulta de la aplicaci&oacute;n directa del art. 14 bis, primer p&aacute;rrafo, in fine de la Constituci&oacute;n Nacional - Toda norma infraconstitucional que proh&iacute;ba el ejercicio de tal derecho deviene manifiestamente inconstitucional - Los derechos emergentes de la sindicalizaci&oacute;n s&iacute; pueden ser reglamentados y aun prohibidos por ley formal</p>","esNovedad":true,"fecha":1597287600000,"relevancia":2,"usuarioModificacion":5,"fechaModificacion":1599514025140,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29050,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcio