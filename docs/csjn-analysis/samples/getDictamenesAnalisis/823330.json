[{"codigo":8233303,"analisisDocumental":{"id":823330,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - SOMINAR SOCIEDAD MINERA ARGENTINA SA c/ YPF SA s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":10322,"titulo":"Inclusión de intereses en la base de cálculo de la tasa de justicia","cabecilla":"<p style=\"text-indent:2em\">Luego de la distribución de las costas en un 40% a la actora y en un 60% a la demandada esta última se opuso al pago, cuestionando la inclusión de intereses en la base de cálculo de la tasa de justicia. La cámara entendió que los intereses integraban dicho cálculo en la medida en que fueron reclamados al inicio de la demanda.</p><p style=\"text-indent:2em\">La Corte revocó esta sentencia.</p><p style=\"text-indent:2em\">Señaló que de la lectura armónica de las disposiciones pertinentes de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-23898-298/actualizacion\">ley 23.898</a> surge que –como regla general– la tasa del 3% de justicia se calcula sobre el valor del objeto litigioso que constituye la pretensión del obligado al pago (artículo 2°); que debe ser abonada por el actor, por quien reconviniere o por quien promueva la acción o requiera el servicio de justicia (artículo 9°, primer párrafo); y es soportada, en definitiva, por las partes, en la misma proporción en que dichas costas debieren ser satisfechas (artículo 10).</p><p style=\"text-indent:2em\">Expresó que de dichas normas no puede inferirse una regla según la cual este tributo deba calcularse computando los intereses devengados durante el proceso, ya que el artículo 4°, inciso a, refiere al monto de la pretensión “al momento del ingreso de la tasa” y, de conformidad con el artículo 9°, inciso a, esta debe ser abonada “en el acto de iniciación de las actuaciones”. En estas condiciones, la inclusión de “los intereses devengados, que se hubieren reclamado” a que refiere el artículo 4°, inciso a, solo comprende los accesorios generados hasta el inicio de las actuaciones y en la medida en que sean reclamados en la demanda.</p><p style=\"text-indent:2em\">Concluyó así el Tribunal que no es posible afirmar que los intereses a los que refiere dicha norma sean aquellos devengados con posterioridad al inicio de las actuaciones, pues ello implicaría desconocer y privar de todo efecto al artículo 9°, inciso a, en el que se excluyen expresamente este tipo de intereses para los supuestos en los que se debe reajustar el tributo cuando el monto de condena deriva en un importe mayor al reclamado al inicio del pleito.</p>","esNovedad":true,"fecha":1772679600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1773145555011,"usuarioCreacion":11,"fechaCreacion":1772736667148,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":152458,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33670014,"numeroExpediente":10216,"anioExpediente":1999,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 2 - SOMINAR SOCIEDAD MINERA ARGENTINA SA c/ YPF SA s/PROCESO DE CONOCIMIENTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10216. "},"recurso":{"id":5611595,"expediente":{"id":33670014,"numeroExpediente":10216,"anioExpediente":1999,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 2 - SOMINAR SOCIEDAD MINERA ARGENTINA SA c/ YPF SA s/PROCESO DE CONOCIMIENTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10216. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CAF 010216/1999/2/RH002","identificacionExpediente":"CAF 010216/1999/2/RH002"},"piezas":1,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":9,"nombreUsuario":"27203847888","apellido":"Sicardi","nombre":"Alexia","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":158