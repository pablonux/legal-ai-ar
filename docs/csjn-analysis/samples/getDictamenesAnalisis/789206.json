[{"codigo":7892065,"analisisDocumental":{"id":789206,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":80006,"valor":"HACE LUGAR A  LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008251405,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"FISCO NACIONAL -ADMINIST.FED.ING.PUBLICOS- c/ SAN LUIS, PROVINCIA DE s/ACCION DE LESIVIDAD","inconstitucional":false,"falloDestacado":{"id":5961,"titulo":"Beneficios fiscales","cabecilla":"<p>La Administración Federal de Ingreso Públicos promueve demanda contra la Provincia de San Luis, a fin de que se declare la nulidad de un decreto local y sus normas complementarias en tanto –según afirma- contravienen lo dispuesto en los arts. 22 de la<a href=\"https://www.boletinoficial.gob.ar/detalleAviso/primera/7079261/19790704?busqueda=1\"> ley 22.021</a> y 11 de la <a href=\"https://www.boletinoficial.gob.ar/detalleAviso/primera/7108524/19890110?busqueda=1\">ley 23.658</a>, por haber otorgado beneficios fiscales a una firma excediendo los límites autorizados. La Corte declaró que el decreto impugnado, dictado por la Provincia de San Luis, resulta nulo, de nulidad absoluta, por haber producido una duplicación de los costos fiscales presupuestados, excediendo los límites autorizados tanto por los arts. 10 de la <a href=\"https://www.boletinoficial.gob.ar/detalleAviso/primera/7074059/19770727?busqueda=1\">ley 21.608</a> y 22 de la <a href=\"https://www.boletinoficial.gob.ar/detalleAviso/primera/7079261/19790704?busqueda=1\">ley 22.021</a>, como por las respectivas leyes de presupuesto que incluyeron el cupo total para dichos costos fiscales teóricos en los términos previstos en las normas citadas. Para sentenciar, la Corte recordó que, en materia de regímenes de promoción, los beneficios tributarios tienen fundamento en la Constitución Nacional: art. 67, inc. 16 [actual 75, inc. 18] –cláusula del progreso- (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=314&amp;pagina=1088\">Fallos: 314:1088</a> y su cita) y, por ende, configuran medidas de fomento de carácter nacional que responden al ejercicio de una competencia constitucional. Al margen de ello, sostuvo el Tribunal que tratándose de actos administrativos producidos contra legem, basta el hecho objetivo de violación legal para que se configure el vicio de ilegitimidad (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=330&amp;pagina=2849\">Fallos: 330:2849</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=341&amp;pagina=289\">341:289</a> y sus citas).</p>","esNovedad":true,"fecha":1696302000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1696506567275,"usuarioCreacion":11,"fechaCreacion":1696366968966,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":114483,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23780854,"numeroExpediente":34,"anioExpediente":2004,"tomoExpediente":40,"letraExpediente":"F","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abrevia