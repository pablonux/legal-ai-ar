[{"codigo":8008953,"analisisDocumental":{"id":800895,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ASTILLERO NAVAL FEDERICO CONTESSI SACIFAN c/ AFIP - DGI s/COBRO DE PESOS/SUMAS DE DINERO","inconstitucional":false,"falloDestacado":{"id":7585,"titulo":"Repetición de impuestos: norma aplicable para el cálculo de los intereses","cabecilla":"<p style=\"text-indent: 2em;\">En el marco de la repetición de los montos que se originaron al aplicar el mecanismo de ajuste por inflación del impuesto a las ganancias la cámara consideró que procedía aplicar el art. 142 de la ley 11.683 (t.o. por decreto 821/98) que dispone que la actualización se realizará desde la fecha del pago. Agregó que no correspondía aplicar el art. 179 de la ley citada ya que dicha norma se encuentra ubicada en el Título II, Capítulo II, que contempla las acciones y recursos ante el Tribunal Fiscal de la Nación.</p><p style=\"text-indent: 2em;\">La Corte revocó esta sentencia.</p><p style=\"text-indent: 2em;\">Consideró que el art. 179 mencionado regula el modo de cálculo de los intereses que se aplica a toda acción de repetición, sin distinguir entre las que tramitan en sede judicial y aquellas que se inician ante el Tribunal Fiscal de la Nación.</p><p style=\"text-indent: 2em;\">Recordó, en lo que concierne a la aplicación del art. 179 de la ley de rito fiscal, que esta norma dispone que, en los casos de repetición de tributos, <em>los intereses comenzarán a correr contra el Fisco desde la interposición del recurso o de la demanda ante el Tribunal Fiscal de la Nación, según el caso, o bien, si fuere menester el reclamo administrativo previo, a partir de la fecha de éste.</em></p><p style=\"text-indent: 2em;\">Agregó que la aplicación de esta norma no puede verse condicionada por la vía que elige el contribuyente para reclamar la repetición de los tributos ingresados en exceso, pues una interpretación que pretenda limitar los alcances del precepto no solo desconocería la pauta interpretativa que desaconseja distinguir allí donde la ley no distingue, sino que restringiría indebidamente aquel modo de cálculo de los accesorios a los casos en que se acude al Tribunal Fiscal mencionado.</p>","esNovedad":true,"fecha":1726542000000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1726605132944,"usuarioCreacion":11,"fechaCreacion":1726605131061,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":127338,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaEx