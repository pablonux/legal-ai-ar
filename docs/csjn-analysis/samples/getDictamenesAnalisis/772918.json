[{"codigo":7729182,"analisisDocumental":{"id":772918,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"LA MERIDIONAL COMPAÑÍA DE SEGUROS S.A. s/ CASACIÓN","alias":null,"caratula":"LA MERIDIONAL CIA DE SEGUROS S.A. s/CASACION","inconstitucional":false,"falloDestacado":{"id":3523,"titulo":"Interrupción de la prescripción y obligaciones concurrentes","cabecilla":"<p>En el marco de un proceso por da&ntilde;os y perjuicios el tribunal superior de justicia provincial declar&oacute; la prescripci&oacute;n de la acci&oacute;n interpuesta conforme al plazo bienal que establec&iacute;a el c&oacute;digo civil anterior. Contra dicho pronunciamiento, el actor interpuso recurso extraordinario que, una vez denegado, dio lugar a la queja.&nbsp;Entre otras consideraciones, argument&oacute; el recurrente que el tribunal provincial hab&iacute;a omitido considerar el efecto interruptivo que hab&iacute;a producido la promoci&oacute;n del pedido de un embargo preventivo, en el marco del art. 3986, antes de cumplirse el plazo de prescripci&oacute;n previsto. En un fallo un&aacute;nime, la Corte revoc&oacute; la sentencia apelada y orden&oacute; dictar un nuevo pronunciamiento al considerar, como lo hab&iacute;a dictaminado el Procurador General, que la omisi&oacute;n incurrida por el tribunal provincial tornaba arbitraria la sentencia atacada.</p>","esNovedad":true,"fecha":1646276400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1646406961605,"usuarioCreacion":11,"fechaCreacion":1646339305191,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":33224,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31304975,"numeroExpediente":257,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"LA MERIDIONAL CIA DE SEGUROS S.A. s/CASACION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"257. "},"recurso":{"id":5273846,"expediente":{"id":31304975,"numeroExpediente":257,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de J