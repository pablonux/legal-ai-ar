[{"codigo":7772223,"analisisDocumental":{"id":777222,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"PAZ, CARLOS EDUARDO s/INCIDENTE DE INCOMPETENCIA","alias":null,"caratula":"Incidente Nº 1 -  BENEFICIARIO: PAZ, CARLOS EDUARDO s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":4363,"titulo":"Conflictos de competencia en supuestos de hábeas corpus interpuestos por detenidos en establecimientos penitenciarios.","cabecilla":"<p>En una acción de hábeas corpus correctivo se originó una contienda negativa de competencia entre la justicia Criminal y Correccional Federal y la justicia Criminal y Correccional. La Corte decidió que esta última debía entender en la causa ya que no debe entenderse que en los establecimientos de la Ciudad de Buenos Aires los agentes del servicio penitenciario cumplan funciones de específico carácter federal. Agregó que no resultaba aplicable al caso el precedente \"Corrales\" (Fallos: 338:1517) ya que allí se denunciaba un acto emanado de autoridad nacional, agravatorio de las condiciones de detención de sujetos alojados en diversas unidades carcelarias del Servicio Penitenciario Federal en distintas provincias, fuera de la Ciudad de Buenos Aires y a disposición de jueces federales de varias y distintas jurisdicciones territoriales mientras que en el caso a decidir se trataba de un reclamo de un detenido en el Complejo Penitenciario Federal de la Ciudad de Buenos Aires a disposición de un tribunal de la misma.</p>","esNovedad":true,"fecha":1660791600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1660920094891,"usuarioCreacion":4,"fechaCreacion":1660853601019,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":34767,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29943248,"numeroExpediente":30518,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXPEDIENTES PENALES","idMateria":9,"tema":null},"caratula":"Incidente Nº 1 -  BENEFICIARIO: PAZ, CARLOS EDUARDO s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"30518. "},"recurso":{"id":5093248,"expediente":{"id":29943248,"numeroExpediente":30518,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXPEDIENTES PENALES","idMateria":9,"tema":null},"caratula":"Incidente Nº 1 -  BENEFICIARIO: PAZ, CARLOS EDUARDO s/INCIDENTE D