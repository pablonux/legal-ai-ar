[{"codigo":7665512,"analisisDocumental":{"id":766551,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"SHI, JINCHUI c/ MUNICIPALIDAD DE LA CIUDAD DE ARROYITO s/accion declarativa de inconstitucionalidad *","alias":null,"caratula":"SHI, JINCHUI c/ MUNICIPALIDAD DE LA CIUDAD DE ARROYITO s/accion declarativa de inconstitucionalidad","inconstitucional":false,"falloDestacado":{"id":1961,"titulo":"Trascendencia del municipio y descentralización institucional","cabecilla":"<p>Poder de polic&iacute;a del municipio y reglamentaci&oacute;n razonable - Acci&oacute;n deducida por el propietario de un establecimiento comercial contra el municipio a fin de que se declare la inconstitucionalidad de la ordenanza denominada de &ldquo;Descanso Dominical del Trabajador&rdquo; - Prohibici&oacute;n a los supermercados de la ciudad de abrir los d&iacute;as domingo - Sentencia del superior tribunal provincial que hizo lugar a la demanda y declar&oacute; la inconstitucionalidad de la norma - Voto de los jueces Maqueda y Rosatti: Trascendencia del municipio en el dise&ntilde;o institucional argentino en tanto orden de gobierno de mayor proximidad con la ciudadan&iacute;a - Sistema participativo con miras a la consecuci&oacute;n de fines con arreglo a valores - Legitimidad democr&aacute;tica de la decisi&oacute;n - Car&aacute;cter no absoluto de la libertad de comercio - La imposici&oacute;n de un descanso dominical puede provenir de las disposiciones locales dictadas en ejercicio del poder de polic&iacute;a que no suponen en modo alguno una regulaci&oacute;n del contrato de trabajo, materia que compete a la legislaci&oacute;n nacional- No se verifican elementos que permitan concluir que la ordenanza incurra en una reglamentaci&oacute;n irrazonable o desproporcionada- Voto del juez Lorenzetti: Principio de la descentralizaci&oacute;n institucional, inspirado en el objetivo de lograr una sociedad m&aacute;s abierta y participativa - No se trata de una antinomia de reglas, sino de una colisi&oacute;n de principios - No puede asimilarse en modo alguno a una regulaci&oacute;n propia del derecho laboral, materia que es de competencia exclusiva del Congreso de la Naci&oacute;n- Aspectos que ata&ntilde;en, directamente al desarrollo de la vida cotidiana de la comunidad - Norma que se inserta en el ejercicio del poder de polic&iacute;a y no en cuestiones de derecho laboral - No se advierte una interferencia relevante entre la norma local y la nacional - Se revoca la sentencia apelada y se rechaza la demanda - Disidencia de los jueces Rosenkrantz y Highton de Nolasco: la recurrente no ha desvirtuado lo sostenido por el a quo en el sentido de que la ordenanza tiene por objeto establecer la obligatoriedad del descanso dominical para un sector de trabajadores de dicha ciudad y de que la regulaci&oacute;n de tal materia corresponde al Congreso de la Naci&oacute;n - El Municipio demandado ha invadido una competencia ya que todo lo que queda comprendido en el derecho del trabajo y la seguridad social es parte integrante del derecho de fondo - Las facultades que el Municipio tiene en ejercicio del poder de polic&iacute;a, como es la fijaci&oacute;n de los horarios de apertura y cierre, no puede desnaturalizar los aspectos del contrato de trabajo regulados por el derecho com&uacute;n - Respeto de las autonom&iacute;as provinciales</p>","esNovedad":true,"fecha":1621479600000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1622059446210,"usuarioCreacion":4,"fechaCreacion":1622059438866,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31150,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32510372,"numeroExpediente":1751,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"SHI, JINCHUI c/ MUNICIPALIDAD DE LA CIUDAD DE ARROYITO s/accion declarativa de inconstitucionalidad ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1751. "},"recurso":{"id":5418579,"expediente":{"id":32510372,"numeroExpediente":1751,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"SHI, JINCHUI c/ MUNICIPALIDAD DE LA CIUDAD DE ARROYITO s/accion declarativa de i