[{"codigo":7656452,"analisisDocumental":{"id":765645,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"Recurso Queja Nº 1 - CACERES CARVAJAL, HECTOR OMAR c/ EN-M SEGURIDAD-PNA s/AMPARO LEY 16.986","alias":null,"caratula":"Recurso Queja Nº 1 - CACERES CARVAJAL, HECTOR OMAR c/ EN-M SEGURIDAD-PNA s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":1845,"titulo":"Protección para las personas que padecen epilepsia y obligatoriedad de dictámenes profesionales","cabecilla":"<p>Decisi&oacute;n que dej&oacute; sin efecto los actos de la Prefectura Naval Argentina (PNA) que dispon&iacute;an la licencia especial por enfermedad del actor y resolvi&oacute; que, previa acreditaci&oacute;n de su aptitud laboral seg&uacute;n lo dicta la ley de medidas especiales de protecci&oacute;n para las personas que padecen epilepsia, se lo restituyera a las tareas que la demandada dispusiera - Fundamento en que dichos actos eran inv&aacute;lidos porque no cumpl&iacute;an con el procedimiento establecido por la ley mencionada en cuanto estipulaba que, ante controversia judicial o extrajudicial, era obligatorio requerir el dictamen de los profesionales afectados al programa sanitario del Ministerio de Salud - Ley que tiene por finalidad conceder a las personas que sufren epilepsia determinados derechos para neutralizar, dentro de lo posible, la desventaja que su enfermedad discapacitante les genera - Protecci&oacute;n que constituye una pol&iacute;tica p&uacute;blica de estado que concuerda con los compromisos internacionales asumidos por el Estado Nacional en materia de derechos humanos y de personas con discapacidad - Ley que integra y complementa a las normas del r&eacute;gimen de personal de la fuerza demandada y no las sustituye, como interpreta el organismo estatal - Se confirma la sentencia apelada.</p>","esNovedad":true,"fecha":1619665200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1619808299457,"usuarioCreacion":11,"fechaCreacion":1619793076576,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30822,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":10876537,"numeroExpediente":20293,"anioExpediente":2008,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJui