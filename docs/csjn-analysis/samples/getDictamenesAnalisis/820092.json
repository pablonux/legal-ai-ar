[{"codigo":8200922,"analisisDocumental":{"id":820092,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - AQUINO MARIA ALEJANDRA c/ METROVIAS SA Y OTROS s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":9941,"titulo":"Responsabilidad del transportista: omisión de un tratamiento adecuado de las constancias de la causa","cabecilla":"<p style=\"text-indent:2em\">La cámara rechazó la demanda interpuesta por los daños y perjuicios que habría sufrido la actora en virtud de un accidente producido al descender de la formación del subterráneo. </p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia al considerar que prescindió de la consideración de elementos conducentes para decidir la cuestión relativa a la responsabilidad que se le atribuye a la demandada.</p><p style=\"text-indent:2em\">Señaló que el tribunal omitió considerar que la interpretación del alcance de la obligación de seguridad y la consecuente atribución de responsabilidad debe ser efectuada teniendo en cuenta el derecho a la seguridad previsto en la Constitución Nacional para los consumidores y usuarios. Expresó en este sentido que, en virtud de dicho deber de seguridad de trasladar al pasajero sano y salvo al lugar de destino, para interrumpir el nexo causal y exonerarse de responsabilidad, debe acreditar la existencia de fuerza mayor, la culpa de la víctima o de un tercero por el cual no debe responder.</p><p style=\"text-indent:2em\">Agregó el Tribunal que la cámara sustentó la ruptura del nexo causal en el supuesto actuar imprudente de la actora, en base a lo dictaminado por la fiscal en la causa penal, pero el dictamen en cuestión estaba dirigido a analizar si los hechos descriptos en la denuncia cuadraban con el delito penal  de lesiones culposas, lo cual derivó en un archivo de las actuaciones por inexistencia de delito. Tuvo en cuenta que la circunstancia de que el hecho no encuadre en alguno de los tipos previstos por el ordenamiento penal no obsta a que, en sede civil, se considere responsable a la empresa.</p>","esNovedad":true,"fecha":1764212400000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1765900698634,"usuarioCreacion":4,"fechaCreacion":1764336161212,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":148538,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32650685,"numeroExpediente":9624,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"