[{"codigo":7978362,"analisisDocumental":{"id":797836,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 6 -  IMPUTADO: GONZALEZ, CLAUDIO MARTIN Y OTROS s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":7042,"titulo":"Competencia en la comercialización de estupefacientes en forma organizada","cabecilla":"<p style=\"text-indent:2em\">A partir de algunas escuchas telefónicas se ordenaron allanamientos en los que se hallaron diversos estupefacientes.</p><p style=\"text-indent:2em\">La jueza federal declinó su competencia por considerar que no existían en la causa elementos de mérito que pudieran dar fundamento a la hipótesis de que el hecho excedería el comercio al menudeo. El magistrado local rechazó esa atribución con base en que el objeto de la pesquisa sería la conducta de un grupo de individuos que comercializaría estupefacientes en forma organizada y con distribución de roles para tal fin, cuya investigación pertenecería a la órbita de la justicia de excepción.</p><p style=\"text-indent:2em\">La Corte resolvió que es la justicia federal la que debe entender en la causa. Expresó que si bien la ley 26.052 modificó sustancialmente la competencia material para algunas de las conductas típicas contenidas en la ley 23.737, la intervención del fuero federal es prioritaria en la materia (arts. 3 y 4 de la misma norma). En ese sentido, de la investigación realizada podría inferirse que el hecho en estudio excedería la mera comercialización de estupefacientes al consumidor final dado que surge del informe de la fuerza policial que uno de los denunciados proveería de estupefacientes a otro y que un tercero de ellos se encontraría en un eslabón superior a ellos en la cadena de comercialización.</p>","esNovedad":true,"fecha":1718247600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1718370102092,"usuarioCreacion":11,"fechaCreacion":1718365537289,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":121980,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35847444,"numeroExpediente":1865,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"CABRERA, JUAN CARLOS s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1865. "},"recurso":{"id":6139214,"expediente":{"id":35847444,"numeroExpediente":1865,"anioExpediente":2021,"tomoExp