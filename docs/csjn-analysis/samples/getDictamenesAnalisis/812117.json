,"usuarioModificacion":"SJC702","fechaCreacion":202507180938,"fechaModificacion":202507181106,"fechaString":"09/10/2020","anioFallo":2020,"titulo":"DICTAMEN MPF CFP 012099/1998/TO01/12/2/1/3/RH015"},{"codigo":8121172,"analisisDocumental":{"id":812117,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 3 - Incidente Nº 1 - PROCESADO: COSSIO RICARDO JUAN ALFREDO Y OTROS s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":9201,"titulo":"Exigencia de sustancial coincidencia en los fundamentos de las sentencias","cabecilla":"<p style=\"text-indent:2em\"> La cámara revocó el auto que había declarado la prescripción de la acción penal y ordenó al tribunal de origen que fijara audiencia de debate para la continuación de la causa. </p><p style=\"text-indent:2em\">La defensa interpuso un recurso extraordinario ante la Corte, que dejó sin efecto esta sentencia. </p><p style=\"text-indent:2em\">La decisión de rechazar la prescripción ya había sido resuelta en un pronunciamiento anterior del tribunal recurrido y el mismo había sido anulado por la Corte, que entendió esta vez que, al igual que en su anterior intervención, la sentencia exhibía, en cuanto a la formación de mayoría de votos, el mismo defecto.</p><p style=\"text-indent:2em\">Recordó en primer lugar que si bien las decisiones que rechazan la prescripción de la acción penal no constituyen sentencia definitiva, no cabe duda que resultan a ella equiparables a los fines del recurso extraordinario cuando el agravio se basa en la garantía a ser juzgado en un plazo razonable y la duración de la persecución penal permite considerar, prima facie, la posibilidad de su afectación.</p><p style=\"text-indent:2em\">Señaló que la coincidencia en la conclusión referida a la imprescriptibilidad no resultaba de fundamentos sustancialmente convergentes sino completamente diferentes entre sí: normas o reglas distintas basadas en premisas totalmente diversas que sólo tienen en común una pretensión de interpretación o argumentación constitucional. </p><p style=\"text-indent:2em\">El Tribunal reiteró su doctrina en el sentido de que es arbitraria la sentencia si ella no exhibe una coincidencia mayoritaria sustancial sobre los fundamentos que dan apoyo a la decisión que el tribunal adopta. </p>","esNovedad":true,"fecha":1752721200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1752853895288,"usuarioCreacion":4,"fechaCreacion":1752839415349,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":140698,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoR