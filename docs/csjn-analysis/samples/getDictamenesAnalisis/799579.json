[{"codigo":7995793,"analisisDocumental":{"id":799579,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"U., L. N. c/ Instituto de Obra Social de la Provincia de Entre Ríos s/ acción de amparo.","alias":null,"caratula":"UDRIZARD, LILIANA NOEMI c/ INSTITUTO DE OBRA SOCIAL DE LA PROVINCIA DE ENTRE RIOS s/accion de amparo ","inconstitucional":false,"falloDestacado":{"id":7341,"titulo":"Excesivo rigor formal al rechazar un amparo destinado a obtener la cobertura de salud de una persona mayor","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal provincial rechazó la acción de amparo interpuesta por la actora a fin de obtener la incorporación como afiliada al Instituto de Obra Social de Entre Ríos ya que señaló que la admisibilidad de la vía excepcional exige ponderar la existencia de urgencia y necesidad de la pretensión así como también si el derecho constitucional que se invoca ha sido violentado y la irreparabilidad del daño denunciado requiere un trámite expedito y rápido. </p><p style=\"text-indent:2em\">La Corte revocó esta decisión.</p><p style=\"text-indent:2em\">Consideró que había interpretado con infundado ritualismo los recaudos para la admisibilidad del amparo al exigir que la actora acredite la ausencia de otra cobertura de salud, sin ponderar la naturaleza de los derechos implicados en dicha acción.</p><p style=\"text-indent:2em\">Recordó que la la vía del amparo es particularmente pertinente cuando se trata de la preservación de la salud y la integridad psicofísica y que la peticionaria pertenece al colectivo de personas mayores, cuyos derechos a la vida y a vivir con dignidad en la vejez, a la salud, y a la protección judicial efectiva, se encuentran especialmente protegidos por la Convención Interamericana sobre Protección de los Derechos Humanos de las Personas Mayores.</p><p style=\"text-indent:2em\">Por otro lado, afirmó que, contrariamente a lo sostenido por el tribunal, la actora no se encontraba afiliada a un plan privado de salud contratado ya que dicha cobertura había sido dada de baja. </p>","esNovedad":true,"fecha":1724122800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1724335431386,"usuarioCreacion":4,"fechaCreacion":1724182641941,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":123719,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35490056,"numeroExpediente":72870,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","d