[{"codigo":7677161,"analisisDocumental":{"id":767716,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"FARMACITY S.A. c/ FISCO DE LA PROVINCIA DE BUENOS AIRES Y OTRO s/pretension anulatoria - recurso extraordinario de inaplicabilidad de ley","alias":null,"caratula":"FARMACITY S.A. c/ FISCO DE LA PROVINCIA DE BUENOS AIRES Y OTRO s/pretension anulatoria - recurso extraordinario de inaplicabilidad de ley","inconstitucional":false,"falloDestacado":{"id":2321,"titulo":"Comercialización de medicamentos en la Provincia de Buenos Aires: habilitación del estado local para legislar y examen de razonabilidad","cabecilla":"<p>Demanda tendiente a obtener la declaraci&oacute;n de nulidad de los actos por los cuales se deneg&oacute; a la actora una solicitud gen&eacute;rica para operar en el &aacute;mbito provincial y un pedido de habilitaci&oacute;n para poner en funcionamiento una farmacia - Planteo de inconstitucionalidad de los arts. 3&deg; y 14 de la ley local 10.606 (T.O. ley 11.328) - Norma que al enumerar las personas que pueden ser autorizadas a instalar farmacias, no incluye a las sociedades an&oacute;nimas - Sentencia del superior tribunal provincial que confirm&oacute; el rechazo de la demanda - Recurso de la demandante que cuestiona la competencia de la provincia para legislar la materia y tambi&eacute;n la afectaci&oacute;n de los principios de razonabilidad, igualdad, y libertad econ&oacute;mica - Voto de los jueces Lorenzetti y Highton de Nolasco: Competencia de incumbencia compartida y concurrente - Expendio de medicamentos como actividad inescindible del ejercicio de la profesi&oacute;n farmac&eacute;utica y competencias provinciales respecto al ejercicio de las profesiones liberales en sus respectivas jurisdicciones - Principio de aplicaci&oacute;n eficaz de los derechos del consumidor - La norma impugnada pretende proteger la salud de quienes consumen medicamentos, que constituyen un grupo especialmente vulnerable - La actora no prob&oacute; que la aplicaci&oacute;n de la ley provincial entorpec&iacute;a severamente la pol&iacute;tica nacional fijada en la ley 17.565 y los decretos 2284/91 y 240/99 - La ley local impugnada no configura un indebido avance provincial sobre la atribuci&oacute;n del Congreso Nacional para dictar los c&oacute;digos de fondo y legislar sobre el derecho de comprar y vender bienes - Finalidad constitucionalmente v&aacute;lida pues se refiere a un derecho fundamental como el de la salud - La ley provincial es razonable a la luz de los est&aacute;ndares fijados en la jurisprudencia del Tribunal y no es arbitraria pues se bas&oacute; en prop&oacute;sitos de salud p&uacute;blica, ampliando la protecci&oacute;n de los pacientes garantizada en la regulaci&oacute;n nacional - Se confirma la sentencia apelada - Voto del conjuez Irurz&uacute;n: la regulaci&oacute;n atacada supera el control de razonabilidad por cuanto evidencia que ha sido sustentada en fines leg&iacute;timos - Las alegaciones de la impugnante no logran demostrar m&aacute;s que el disenso con la pol&iacute;tica sanitaria adoptada por las autoridades provinciales sin poder evidenciar su repugnancia con la Constituci&oacute;n Nacional - La preeminencia que se ha asignado al derecho a la salud como derecho humano b&aacute;sico, esencial y colectivo, justifica con suficiencia la mayor intensidad reglamentaria aplicada al ejercicio de la actividad farmac&eacute;utica y las restricciones impuestas para garantizar la efectividad de las garant&iacute;as fundamentales en juego - Disidencia de la conjueza Sotelo de Andreau: Conflicto relativo al ejercicio del poder de polic&iacute;a de salubridad - Car&aacute;cter concurrente del poder de polic&iacute;a entre el gobierno nacional y las provincias en materia de salubridad - Restricci&oacute;n que no aparece como razonable, pues no se advierte el cumplimiento de qu&eacute; finalidad p&uacute;blica vinculada a la protecci&oacute;n de la salud se persigue con el hecho de exigir que la propiedad de las farmacias sea exclusivamente de ciertos sujetos y no de otros, excluyendo tipos societarios - No se advierte que el medio guarde una relaci&oacute;n de adecuaci&oacute;n y proporcionalidad con la finalidad declarada protegida en la Constituci&oacute;n Nacional y los tratados internacionales de proteger la salud y la vida de la poblaci&oacute;n - Violaci&oacute;n al principio de igualdad.</p>","esNovedad":true,"fecha":1625022000000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1625091503493,"usuarioCreacion":4,"fechaCreacion":1625091020000,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31491,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29406530,"numeroExpediente":118,"anioExpediente":2017,"