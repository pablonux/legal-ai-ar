[{"codigo":7654003,"analisisDocumental":{"id":765400,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Recurso Queja Nº 1 - PIEDRABUENA ANIBAL ARIEL c/ FEDERACION PATRONAL SEGUROS SA s/ACCIDENTE - LEY ESPECIAL","alias":null,"caratula":"Recurso Queja Nº 1 - PIEDRABUENA ANIBAL ARIEL c/ FEDERACION PATRONAL SEGUROS SA s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":1830,"titulo":"Límite para las incapacidades permanentes y suma de factores de ponderación","cabecilla":"<p>Sentencia de c&aacute;mara que elev&oacute; el porcentaje de incapacidad y consider&oacute; aplicables las mejoras introducidas por la ley 26.773 - Actualizaci&oacute;n de las prestaciones a trav&eacute;s del &iacute;ndice de Remuneraciones Imponibles Promedio de los Trabajadores Estables (RIPTE) - Recurso interpuesto por la ART - Remisi&oacute;n a precedente &quot;Esp&oacute;sito&quot; (<a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7311992&amp;cache=1619195317105\">Fallos: 339:781</a>) - Pronunciamiento que prescinde de lo dispuesto en el decreto 49/2014 - Norma que procura impedir que se transforme en total una incapacidad parcial mediante la suma de los factores de ponderaci&oacute;n cuya determinaci&oacute;n permite cierto margen de discrecionalidad por parte de los peritos - Incapacidad f&iacute;sica fijada en el 52,28% de la total obrera sobre la base de un 40,13% de minusval&iacute;a y de un 12,15% atribuible a los factores de ponderaci&oacute;n, que sumado al 15% correspondiente a la incapacidad ps&iacute;quica lleg&oacute; a un grado de minusval&iacute;a total del 67,28% - Sentencia que soslay&oacute; el l&iacute;mite del 65% establecido en el decreto mencionado para las incapacidades de car&aacute;cter permanente y parcial - Superaci&oacute;n que se debi&oacute; claramente a la incidencia de los factores de ponderaci&oacute;n y no a la cuantificaci&oacute;n de la minusval&iacute;a en s&iacute; - Prescindencia de la normativa aplicable en forma dogm&aacute;tica y sin fundamento suficiente - Se deja sin efecto la sentencia apelada.</p>","esNovedad":true,"fecha":1619060400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1619206134924,"usuarioCreacion":11,"fechaCreacion":1619195213014,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30741,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28892128,"numeroExpediente":19881,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Traba