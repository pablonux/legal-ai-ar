plemento por “función policial operativa” que percibe y que fuera creado por los decretos 380/17 y 463/17 pues no se trata de sumas meramente accesorias o adicionales. Precisó el Tribunal, que la propia Policía Federal informó en otros expedientes que los suplementos mencionados eran pagados a más del 91% del personal policial en actividad y, por lo tanto, deben considerarse como acordados en concepto de sueldo.</p>","esNovedad":true,"fecha":1660791600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1660920109766,"usuarioCreacion":4,"fechaCreacion":1660852089259,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":34738,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31468431,"numeroExpediente":18184,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1116,"descripcion":"PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"DI NANNO, CAMILO c/ EN-M SEGURIDAD-PFA s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"18184. "},"recurso":{"id":5742267,"expediente":{"id":31468431,"numeroExpediente":18184,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJui