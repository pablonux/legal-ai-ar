[{"codigo":8109835,"analisisDocumental":{"id":810983,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"SIMSA AIRE ACONDICIONADO S.R.L. Y OTRO c/ MINISTERIO DE ECONOMIA Y PRODUCCION Y OTRO s/CONTENCIOSO ADMINISTRATIVO-VARIOS","inconstitucional":false,"falloDestacado":{"id":9001,"titulo":"Declaración aduanera inexacta y procedimiento especial de despacho en forma conjunta","cabecilla":"<p style=\"text-indent: 2em;\">La cámara confirmó la multa aplicada por la Dirección General de Aduanas (DGA) a la despachante de aduana y a la importadora por la comisión de la infracción prevista en el artículo 954, ap. 1, inc. a, del Código Aduanero por considerar que las mercaderías importadas (unidades evaporadoras y condensadoras de aire acondicionado) constituían una unidad clasificatoria a la que le resultaba aplicable el procedimiento especial de despacho en forma conjunta (equipo de aire acondicionado tipo \"split\").</p><p style=\"text-indent: 2em;\">La Corte, por mayoría, revocó este pronunciamiento. </p><p style=\"text-indent: 2em;\">Consideró que la interpretación sostenida conllevaba tornar en obligatoria una de las normas -el pto. 2 a) del Anexo II de la resolución general 2212/2007- incluidas en un régimen opcional para aquellos sujetos que no optaron por acogerse a sus beneficios y que, por lo tanto, no se encuentran alcanzados por sus disposiciones.</p><p style=\"text-indent: 2em;\">Recordó que son aplicables a las infracciones aduaneras las disposiciones generales del Código Penal, conforme a las cuales sólo puede ser reprimido quien sea culpable, es decir, aquel a quien la acción punible pueda ser atribuida tanto objetiva como subjetivamente y  señaló que tales circunstancias no se verificaban en autos. Concluyó que resultaba improcedente la sanción impuesta ya que no surgía de las actuaciones que se hubiese efectuado una “declaración que difiera con lo que resultare de la comprobación”, en tanto las partes fueron contestes en que la mercadería despachada y librada a plaza era la misma en cada una de las declaraciones.</p>","esNovedad":true,"fecha":1750820400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1750877606170,"usuarioCreacion":11,"fechaCreacion":1750877588471,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":139319,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":15815934,"numeroExpediente":34200003,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":15,"codigo":"15","abreviatura":"FCB","descripcion":"Justicia Federal de Córdoba","estado":0,"descripcionLarga":"FCB - Justicia Federal de Córdoba"},"objetoJuicio":{"id":2662,"descripcion":"CONTEN