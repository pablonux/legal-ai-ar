[{"codigo":7887112,"analisisDocumental":{"id":788711,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"MINISTERIO DE TRABAJO EMPLEO Y SEGURIDAD SOCIAL c/ SINDICATO PETROLERO DE CORDOBA s/LEY DE ASOC.SINDICALES","inconstitucional":false,"falloDestacado":{"id":5942,"titulo":"Otorgamiento de la personería gremial y debido proceso","cabecilla":"<p>La Cámara confirmó la Resolución del Ministerio de Trabajo, que otorgó personería gremial al Sindicato de Estaciones de Servicio, Playas de Estacionamiento, Garages, Lavaderos, Gomerías y Anexos de la provincia de Córdoba (STESyPE) para representar a los trabajadores dependientes de estaciones de servicio, con exclusión de los dependientes de YPF SA o sus subsidiarias y de los trabajadores de establecimientos comerciales o gastronómicos que se encuentren dentro del predio de las estaciones, con zona de actuación en la provincia de Córdoba. Contra esa decisión, el Sindicato Petrolero de Córdoba dedujo recurso extraordinario federal. La Corte, hizo lugar al recurso, dejó sin efecto la sentencia y consideró que la representación de los dependientes de estaciones de servicio, cuya actividad principal es la venta de subproductos del petróleo, se encuentra comprendida en la personería del SPC en forma precisa y, en consecuencia, resulta preexistente a la otorgada al STESyPE en la resolución ministerial. A criterio del Tribunal la cámara confirmó la resolución ministerial que otorgó personería gremial al STESyPE para representar a los trabajadores dependientes de estaciones de servicio de Córdoba <em>sin realizar el cotejo de afiliados</em> previsto en los artículos 25 y 28 de la Ley de Asociaciones Sindicales con base en que la personería del recurrente no es preexistente.</p>","esNovedad":true,"fecha":1696302000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1696506588548,"usuarioCreacion":11,"fechaCreacion":1696365238215,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":114192,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29151138,"numeroExpediente":97257,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9732,"descripcion":"LEY DE ASOC.SINDICALES","idMateria":5,"tema":null},"caratula":"MINISTERIO DE TRABA