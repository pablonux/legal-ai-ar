[{"codigo":7661262,"analisisDocumental":{"id":766126,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"Recurso Queja Nº 2 - C., M. I. c/ OBRA SOCIAL DEL PERSONAL DE CONTROL EXTERNO (OSPOCE) Y OTRO s/PRESTACIONES FARMACOLÓGICAS","alias":null,"caratula":"Recurso Queja Nº 2 - C., M. I. c/ OBRA SOCIAL DEL PERSONAL DE CONTROL EXTERNO (OSPOCE) Y OTRO s/PRESTACIONES FARMACOLÓGICAS","inconstitucional":false,"falloDestacado":{"id":2365,"titulo":"Cobertura del costo de medicamentos por parte de las obras sociales ","cabecilla":"<p>Sentencia que hizo lugar a la acci&oacute;n de amparo entablada con el objeto de que se cubriera a la actora el costo de un medicamento y elev&oacute; el porcentaje de cobertura del 70 al 100% - Droga que no se encuentra prevista en la resoluci&oacute;n que establece los medicamentos integrantes del Plan M&eacute;dico Obligatorio por lo que es facultad del agente del seguro de salud ampliar los l&iacute;mites de cobertura de acuerdo a las necesidades individuales de los beneficiarios - Derecho a la salud como derecho fundamental pero no absoluto sino que debe ser ejercido con arreglo a las leyes que reglamentan su ejercicio - La decisi&oacute;n de obligar a la entidad social a afrontar el 100% de la cobertura del remedio no resulta razonable en tanto desconoce la plataforma normativa, cuya constitucionalidad no ha sido objetada - La actora no es discapacitada y cuenta con ingresos propios - Se deja sin efecto la sentencia apelada - Disidencia del juez Rosatti: decisi&oacute;n sustentada en una interpretaci&oacute;n arm&oacute;nica del PMO y las previsiones de las leyes que sientan las bases y objetivos del sistema nacional de seguro de salud - La c&aacute;mara sigui&oacute; el criterio expuesto por el Cuerpo M&eacute;dico Forense que resalt&oacute; la importancia de la opini&oacute;n del profesional de la medicina que trata la patolog&iacute;a del paciente - Planteos de la recurrente que constituyen una mera discrepancia con el criterio sostenido por el tribunal.</p>","esNovedad":true,"fecha":1625713200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1626193326791,"usuarioCreacion":11,"fechaCreacion":1625782442463,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30995,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31056088,"numeroExpediente":42058,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":26,"codigo":"26","abreviatura":"FSM","descripcion":"Justicia Federal de San Martin","estado":0,"descripcionLarga":"FSM - Justicia Federal de San Martin"},"objetoJuicio":{"id":7089,"descripcion":"PRESTACIONES FARMACOLÓGICAS","idMateria":112,"tema":{"id":320,"codigo":"AMPAROS"}},"caratula":"Recurso Qu