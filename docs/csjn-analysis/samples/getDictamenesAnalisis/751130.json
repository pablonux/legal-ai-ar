[{"codigo":7511301,"analisisDocumental":{"id":751130,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":80006,"valor":"HACE LUGAR A  LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008251405,"orden":null,"visible":null},"materia":{"codigoTabla":null,"codigoValor":381,"codigoRelacion":90381,"valor":"CONSTITUCIONAL","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"SJC287","fechaCreacionLong":201903220948,"fechaModLong":201909170908,"orden":null,"visible":null},"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Unión Cívica Radical de la Provincia de La Rioja y otro c/ La Rioja, Provincia de s/ amparo ","alias":null,"caratula":"UNION CIVICA RADICAL DE LA PROVINCIA DE LA RIOJA Y OTRO c/ LA RIOJA, PROVINCIA DE s/AMPARO","inconstitucional":true,"falloDestacado":{"id":676,"titulo":"Validez de enmienda a la constitución provincial","cabecilla":"<p>Inter&eacute;s federal de tal nitidez que exige la intervenci&oacute;n de la Corte - Palmario contenido federal del pleito por estar en tela de juicio la garant&iacute;a republicana - Gobierno federal como garante del goce y ejercicio de las instituciones provinciales y Corte Suprema como responsable de asegurar el cumplimiento del orden institucional establecido - Naturaleza compleja del acto jur&iacute;dico que reviste el proceso de enmienda constitucional - Necesidad de perfeccionamiento de dos etapas sucesivas: aprobaci&oacute;n del proyecto de ley de enmienda por parte de la C&aacute;mara de Diputados provincial y consulta popular obligatoria - Oportunidad en que debe realizarse la consulta popular - Al decir &quot;primera elecci&oacute;n general que se realice&quot; se est&aacute; aludiendo a la &quot;primera elecci&oacute;n general que se realice para cubrir el cargo cuya regulaci&oacute;n constitucional se procura enmendar&quot; - Interpretaci&oacute;n del art. 84 de la constituci&oacute;n provincial que pretende sostener que el 35% establecido en la norma debe ser alcanzado &uacute;nicamente por los votos emitidos a favor del &quot;NO&quot; - Planteo que implica considerar que la voluntad de todos los ciudadanos que no fueron a votar o que votaron en blanco fue aprobar la reforma, lo cual no traduce la conformaci&oacute;n de una mayor&iacute;a expl&iacute;cita a favor del cambio constitucional propuesto - La vigencia del sistema republicano presupone de manera primordial la fiabilidad del mecanismo elegido para considerar que la voluntad del pueblo ha sido v&aacute;lidamente expresada - La voluntad del pueblo no se presume sino que se expresa en el marco de procesos electorales transparentes- Mecanismo para validar la expresi&oacute;n de la voluntad popular que resulta inconsistente con el que demanda un sistema republicano - La enmienda cuestionada implic&oacute; trastocar la decisi&oacute;n del constituyente provincial de 2007 - Se hace lugar a la demanda y se declara la invalidez de la enmienda de los arts. 120 y 171 de la Constituci&oacute;n de La Rioja - Voto del juez Rosenkrantz: Consulta popular llevada a cabo en una oportunidad que no es la exigida por la norma constitucional - Est&aacute;ndar aplicado de manera uniforme por el Tribunal en decisiones anteriores - Obligaci&oacute;n de respetar los principios consagrados en sus pr&aacute;cticas interpretativas pasadas - Voto de la jueza Highton de Nolasco: clara intenci&oacute;n de la constituci&oacute;n provincial de hacer coincidir la consulta popular con la primera elecci&oacute;n que se celebre dentro del calendario electoral, est&eacute; fijado o no - La actuaci&oacute;n de la Corte no resulta una intromisi&oacute;n indebida ya que no est&aacute; ejerciendo una facultad revisora del ordenamiento constitucional sino que con su intervenci&oacute;n persigue su efectivo cumplimiento</p>","esNovedad":true,"fecha":1553223600000,"relevancia":3,"usuarioModificacion":5,"fechaModificacion":1599066510936,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":25645,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33119916,"numeroExpediente":96,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9875,"descripcion":"AMPARO","idMateria":0,"tema":null},"caratula":"PERONISTAS SIN FRONTERAS c/ LA RIOJA, PROVINCIA DE s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"96. "},"recurso":{"id":5525145,"expediente":{"id":33119916,"numeroExpediente":96,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9875,"descripcion":"AMPARO","idMateria":0,"tema":null},"caratula":"PERONISTAS SIN FRONTERAS c/ LA RIOJA, PROVINCIA DE s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentifica