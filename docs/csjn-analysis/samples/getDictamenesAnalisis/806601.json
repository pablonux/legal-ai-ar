[{"codigo":8066012,"analisisDocumental":{"id":806601,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - BAEZ, DIEGO JESUS c/ ASOCIART ART S.A. s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":8421,"titulo":"Falta de definitividad de la sentencia que resuelve la competencia en un reclamo laboral","cabecilla":"<p style=\"text-indent:2em\">La Cámara Nacional del Trabajo declaró la incompetencia territorial de la justicia nacional del trabajo para intervenir en las actuaciones en las que el actor demandaba a una ART persiguiendo el cobro de las prestaciones previstas en las leyes 24.557, 26.733 y 27.348 por la incapacidad laboral que le habría ocasionado un accidente <em>in itinere</em>.</p><p style=\"text-indent:2em\">La Corte desestimó el recurso contra este pronunciamiento. </p><p style=\"text-indent:2em\">Recordó que las decisiones en materia de competencia no constituyen fallos definitivos en los términos del artículo 14 de la ley 48, excepto que ocurran circunstancias que autoricen su equiparación y consideró que ninguna de esas excepciones se presentaba en el caso.</p><p style=\"text-indent:2em\">Por un lado, la sentencia recurrida no había denegado el fuero federal ni las partes habían solicitado su intervención. Por otro lado, la decisión cuestionada no colocaba a la recurrente en una situación de privación de justicia que afectara en forma directa e inmediata la defensa en juicio pues no clausuraba la vía procesal promovida en tanto atribuía competencia a una jurisdicción determinada donde podía seguir defendiendo sus derechos.</p>","esNovedad":true,"fecha":1742353200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1742473574992,"usuarioCreacion":4,"fechaCreacion":1742473381364,"privado":false,"posicion":4,"resumen":{"idResumen":123,"resumen":"La Corte desestimó la apelación, recordando que las decisiones sobre competencia no son definitivas según la ley 48, a menos que ocurran excepciones, las cuales no se presentaron en este caso.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":133818,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30070644,"numeroExpediente":42691,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuic