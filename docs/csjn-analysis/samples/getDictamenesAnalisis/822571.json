[{"codigo":8225713,"analisisDocumental":{"id":822571,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - DECIMA, VERONICA MABEL c/ ISS ARGENTINA S.A. Y OTRO s/DESPIDO","inconstitucional":false,"falloDestacado":{"id":10181,"titulo":"Excesos en la jurisdicción conferida por el recurso de apelación","cabecilla":"<p style=\"text-indent:2em\">La cámara admitió la apelación deducida por ambas codemandadas, excluyó de la condena el rubro horas extras y consideró que resultaba menester expedirse sobre los intereses a la luz de las circunstancias del momento, por lo que ordenó que al capital se le adicionaran accesorios a calcularse según los términos del acta 2764/2022 de dicha cámara.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia por considerar que se había incurrido en un exceso de jurisdicción.</p><p style=\"text-indent:2em\">En efecto, la sentencia de primera instancia había fijado intereses conforme a las tasas activas a las que aludían las actas 2601/2014, 2630/2016 y 2658/2017 y ello fue impugnado únicamente por las codemandadas quienes cuestionaron los resultados que se obtendrían por la aplicación de las referidas tasas y pidieron su disminución. En consecuencia la cámara, al ordenar la aplicación del acta 2764/2022 y, en función de ello, establecer la capitalización periódica de los accesorios, transgredió los límites de su competencia toda vez que se expidió sobre una cuestión que no le había sido sometida a su escrutinio incurriendo en una indebida <em>reformatio in pejus</em> que perjudica a los demandados.</p>","esNovedad":true,"fecha":1770692400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1770836464740,"usuarioCreacion":11,"fechaCreacion":1770751103732,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":151258,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37265103,"numeroExpediente":31631,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9702,"descripcion":"ACCIDENTE - ACCION CIVIL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - BALADA, IRMA ESTHER Y OTRO c/ CLUB CIUDAD DE BOLIVAR Y OTRO s/ACCIDENTE - ACCION CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"31631. "},"recurso":{"id":6459671,"expediente":{"id":37265103,"numeroExpediente":31631,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descri