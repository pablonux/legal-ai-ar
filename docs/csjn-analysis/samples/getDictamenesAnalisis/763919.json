[{"codigo":7639192,"analisisDocumental":{"id":763919,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":80006,"valor":"HACE LUGAR A  LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008251405,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"Comunidad Mapuche Catalán y Confederación Indígena Neuquina c/ Provincia del Neuquen s/acción de Inconstitucionalidad","alias":null,"caratula":"Comunidad Mapuche Catalán y Confederación Indígena Neuquina c/ Provincia del Neuquen s/acción de Inconstitucionalidad","inconstitucional":false,"falloDestacado":{"id":1744,"titulo":"Creación de un municipio y vulneración de los derechos a la consulta y a la participación de los pueblos indígenas","cabecilla":"<p>Sentencia del superior tribunal provincial que rechaz&oacute; la acci&oacute;n intentada para que se declare la inconstitucionalidad de la ley provincial que cre&oacute; el municipio de Villa Pehuenia y del decreto que convoc&oacute; a elecciones para conformar la comisi&oacute;n municipal respectiva - Planteo fundado en que no se habr&iacute;a resguardado el derecho a la consulta de los pueblos ind&iacute;genas y se omiti&oacute; reconocer su preexistencia &eacute;tnica y cultural - Incorporaci&oacute;n del art. 75, inciso 17, de la Constituci&oacute;n Nacional y de diversos instrumentos internacionales que tutelan los derechos humanos de los pueblos ind&iacute;genas - Nuevo paradigma de protecci&oacute;n de la diversidad cultural - Consagraci&oacute;n de los derechos colectivos de los pueblos ind&iacute;genas a ser consultados y a participar en la toma de decisiones sobre cuestiones que afecten sus intereses - La creaci&oacute;n de un municipio es susceptible de afectar, en forma concreta y directa, a las comunidades mapuches en relaci&oacute;n con la adecuada protecci&oacute;n de su tierra y territorio - La ley cuestionada incide directamente en los derechos e intereses colectivos de los ind&iacute;genas - La creaci&oacute;n del municipio demandaba o&iacute;r a las comunidades a fin de tomar en cuenta sus intereses, opiniones y puntos de vista y, en definitiva, evitar que se menoscabe su identidad cultural - Corresponde revocar la sentencia apelada y hacer lugar a la demanda- La declaraci&oacute;n de invalidez de las normas impugnadas podr&iacute;a generar graves y complejas consecuencias institucionales - Corresponde admitir la validez de la creaci&oacute;n del Municipio y de todos los actos jur&iacute;dicos que celebraron sus autoridades y que generaron derechos y obligaciones hasta tanto la provincia adec&uacute;e las normas impugnadas a la Constituci&oacute;n y a los instrumentos internacionales - Condenar a la provincia a que, en forma conjunta con las comunidades ind&iacute;genas, establezca una mesa de di&aacute;logo con las actoras para que implementen la consulta que fuera omitida y dise&ntilde;en mecanismos permanentes de comunicaci&oacute;n y consulta - Establecer que el superior tribunal provincial ser&aacute; el encargado de controlar la ejecuci&oacute;n de la sentencia - Disidencia del juez Rosenkrantz: las comunidades ind&iacute;genas no pueden pretender derechos pol&iacute;ticos que ning&uacute;n colectivo diferente al pueblo de la Naci&oacute;n y de las provincias tiene ni podr&iacute;a aspirar a tener dado el modo representativo, republicano y federal adoptado por esta Constituci&oacute;n para el gobierno de la Naci&oacute;n - La consulta previa a los pueblos ind&iacute;genas es obligatoria &uacute;nicamente respecto de las medidas administrativas o legislativas que son capaces de menoscabar o perjudicar derechamente, y no de modo indirecto o remoto, a los derechos de las comunidades ind&iacute;genas - La creaci&oacute;n de un gobierno municipal es una norma general que no menoscaba de un modo directo los derechos reconocidos a las comunidades ind&iacute;genas.</p>","esNovedad":true,"fecha":1617850800000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1618842446148,"usuarioCreacion":11,"fechaCreacion":1618230238474,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30277,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23279560,"numeroExpediente":1490,"anioExpediente":2011,"tomoExpediente":47,"letraExpediente":"C","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"Comunidad Mapuche Catalán y Confederación Indígena Neuquina c/ Provincia del Ne