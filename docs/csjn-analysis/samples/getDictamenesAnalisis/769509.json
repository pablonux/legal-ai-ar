[{"codigo":7695092,"analisisDocumental":{"id":769509,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"ADDUC Y OTROS c/ AYSA SA Y OTRO s/ PROCESO DE CONOCIMIENTO","alias":null,"caratula":"Recurso Queja Nº 1 - ADDUC Y OTROS c/ AYSA SA Y OTRO s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":2841,"titulo":"Beneficio de justicia gratuita en el marco del proceso colectivo de consumo","cabecilla":"<p>Condena en costas a la asociaci&oacute;n de consumidores. La razonable interpretaci&oacute;n arm&oacute;nica de los art&iacute;culos&nbsp;55 y 53 permite sostener que, al sancionarse la ley 26.361, que introdujo modificaciones al texto de la ley 24.240, el Congreso Nacional ha tenido la voluntad de eximir a quienes inician una acci&oacute;n en los t&eacute;rminos de la Ley de Defensa del Consumidor del pago de las costas del proceso. La norma no requiere a quien demanda en el marco de sus prescripciones la demostraci&oacute;n de una situaci&oacute;n de pobreza para otorgar el beneficio,&nbsp;<em>sino que se lo concede autom&aacute;ticamente</em>. Solo en supuestos de acciones iniciadas en defensa de intereses individuales se admite que la contraparte acredite la solvencia del actor para hacer cesar la eximici&oacute;n. Voluntad expresada por los legisladores en el debate parlamentario que precedi&oacute; a la sanci&oacute;n de la ley 26.361.&nbsp;Si los legisladores descartaron la utilizaci&oacute;n del t&eacute;rmino &ldquo;beneficio de litigar sin gastos&rdquo; en la norma no fue porque pretendieran excluir de la eximici&oacute;n a las costas del juicio, sino para preservar las autonom&iacute;as provinciales en materia de tributos locales vinculados a los procesos judiciales.&nbsp;En igual l&iacute;nea de razonamiento la Corte entendi&oacute; que no correspond&iacute;a la imposici&oacute;n de costas en el marco de los recursos tra&iacute;dos a su conocimiento en acciones que propenden a la protecci&oacute;n de derechos de usuarios y consumidores.&nbsp;Se deja sin efecto la sentencia apelada en lo concerniente a la imposici&oacute;n de costas.</p>","esNovedad":true,"fecha":1634180400000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1634833419994,"usuarioCreacion":4,"fechaCreacion":1634298822782,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":32077,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":26850562,"numeroExpediente":17990,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Cont