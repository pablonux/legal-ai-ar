[{"codigo":7651843,"analisisDocumental":{"id":765184,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"DEFENSOR DEL PUEBLO DE LA NACION c/ ESTADO NACIONAL Y OTRO s/PROCESO DE CONOCIMIENTO","alias":null,"caratula":"DEFENSOR DEL PUEBLO DE LA NACION c/ ESTADO NACIONAL  Y OTRO s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":1743,"titulo":"La Corte Suprema como garante de la Constitución Nacional ante la emergencia sanitaria, alimentaria, educacional y de vivienda de pueblos indígenas","cabecilla":"<p>Causa tendiente a que se condene al Estado Nacional y a la Provincia del Chaco a adoptar las medidas necesarias para modificar la condici&oacute;n de vida de habitantes, en su gran mayor&iacute;a pertenecientes a la etnia Toba - Situaci&oacute;n de emergencia extrema y de necesidades b&aacute;sicas y elementales insatisfechas - Presentaci&oacute;n del Instituto del Aborigen Chaque&ntilde;o (I.D.A.CH.), como representante de los pueblos ind&iacute;genas Qom, Mocov&iacute; y Wichi solicitando su intervenci&oacute;n en el proceso - Gravedad y urgencia de los hechos denunciados que determinaron que la Corte adopte las medidas conducentes a la salvaguarda de esos derechos fundamentales y difiera la decisi&oacute;n atinente a su competencia - Audiencia p&uacute;blica - Dictado de decreto local en el que se declar&oacute; el estado de emergencia - Convocatoria de un comit&eacute; de crisis - Realizaci&oacute;n de audiencia y asunci&oacute;n de compromiso de estudiar soluciones conjuntas - Programa orientado a asegurar la inclusi&oacute;n social de las comunidades habitantes de las &aacute;reas comprometidas - Se ha producido un cambio en la situaci&oacute;n descripta en la demanda y se ha alcanzado el prop&oacute;sito perseguido con la intervenci&oacute;n asumida por la Corte en su condici&oacute;n de garante de la Constituci&oacute;n Nacional - Corresponde que el Tribunal se expida acerca de su competencia para seguir entendiendo en el asunto por v&iacute;a de su instancia originaria - No procede la competencia originaria ratione personae, pues la acumulaci&oacute;n subjetiva de pretensiones contra la provincia y el Estado Nacional resulta, en las actuales circunstancias, inadmisible - El hecho de que el actor les atribuya responsabilidad a las dos demandadas no exige que ambas cuestiones deban ser necesariamente acumuladas en un proceso - El camino tendiente a alcanzar la superaci&oacute;n de la situaci&oacute;n de miseria estructural fue allanado y con ello se ha cumplido el objetivo para el que fue abierta la instancia - Las autoridades judiciales y administrativas nacionales y locales deber&aacute;n continuar llevando adelante eficazmente todas las medidas - Se declara que la causa es ajena a la competencia originaria de la Corte.</p>","esNovedad":true,"fecha":1617850800000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1618230181910,"usuarioCreacion":11,"fechaCreacion":1618230175170,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30689,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":