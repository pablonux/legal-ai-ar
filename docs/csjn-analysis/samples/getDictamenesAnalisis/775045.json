[{"codigo":7750452,"analisisDocumental":{"id":775045,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"MANZABA CAGUA, JESSICA c/ EN-M INTERIOR OP Y V-DNM s/ RECURSO DIRECTO","alias":null,"caratula":"MANZABA CAGUA, JESSICA c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":3943,"titulo":"Causales de impedimento para la permanencia de un extranjero en el país y condena por tenencia simple de estupefacientes","cabecilla":"<p>La Direcci&oacute;n Nacional de Migraciones declar&oacute; irregular la permanencia en el pa&iacute;s de la migrante, de nacionalidad ecuatoriana, orden&oacute; su expulsi&oacute;n del territorio nacional y prohibi&oacute; su reingreso al pa&iacute;s, por haber sido condenada por el delito de tenencia simple de estupefacientes. La C&aacute;mara hizo lugar al recurso de la actora y declar&oacute; la nulidad de estas disposiciones y, ante el recurso de la demandada, la Corte confirm&oacute; la sentencia apelada. Tuvo en cuenta que&nbsp;para determinar si se configuraba la causal de impedimento para permanecer en el pa&iacute;s era preciso dilucidar si el delito en el que se fund&oacute; la condena deb&iacute;a considerarse equivalente, a los fines migratorios, al de tr&aacute;fico de estupefacientes, ya que la condena por este &uacute;ltimo resulta causal de expulsi&oacute;n m&aacute;s all&aacute; del monto de la condena. El Tribunal consider&oacute; que&nbsp;se configura la causal por la existencia de una condena por tr&aacute;fico de estupefacientes solo si el delito se refiere a uno de los eslabones de esa actividad&nbsp;pero que&nbsp;en los supuestos en los que la condena se refiere a un delito vinculado con estupefacientes sin relaci&oacute;n con el proceso de tr&aacute;fico de esas sustancias, resulta aplicable la doctrina establecida en el precedente de <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=341&amp;pagina=500\">Fallos: 341:500 (&ldquo;Apaza Le&oacute;n&quot;)</a> por lo que no se encontraba superado el plazo de tres (a&ntilde;os) al que hace referencia la ley.</p>","esNovedad":true,"fecha":1652151600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1652285734090,"usuarioCreacion":11,"fechaCreacion":1652209749602,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":33982,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32154040,"numeroExpediente":49605,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Naci