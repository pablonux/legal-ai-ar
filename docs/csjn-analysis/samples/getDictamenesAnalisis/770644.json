[{"codigo":7706442,"analisisDocumental":{"id":770644,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"CHUKWUDI, ANTHONI s/ INCIDENTE DE RECURSO EXTRAORDINARIO","alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 -  IMPUTADO: CHUKWUDI, ANTHONI s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":3081,"titulo":"Escala penal única para el delito de contrabando consumado y su tentativa: ejercicio razonable de las facultades del legislador","cabecilla":"<p>La C&aacute;mara anul&oacute; parcialmente la sentencia que hab&iacute;a condenado al imputado como coautor del delito de contrabando en grado de tentativa y declar&oacute; la inconstitucionalidad del&nbsp;<strong>art&iacute;culo 872 del C&oacute;digo Aduanero</strong>, en tanto reprime al contrabando consumado con la misma escala penal que cuando el delito queda en estado de tentativa. Recurrido el fallo por el Fiscal, la Corte Suprema, por unanimidad,&nbsp;dej&oacute; sin efecto la sentencia recurrida sobre la base que, por un lado,&nbsp;<em>l</em><em>a declaraci&oacute;n de inconstitucionalidad constituye un remedio que debe evitarse de ser posible mediante una interpretaci&oacute;n del texto legal en juego compatible con la Ley Fundamental</em>&nbsp;y, por el otro, que el m&eacute;rito, conveniencia o acierto de las soluciones legislativas no son puntos sobre los que al Poder Judicial quepa pronunciarse. En esa l&iacute;nea argumental, se&ntilde;al&oacute; asimismo que la decisi&oacute;n del legislador se asienta en que para la configuraci&oacute;n del delito de contrabando resulta irrelevante que la mercader&iacute;a logre o no ser retenida por la Aduana ya que el bien jur&iacute;dico protegido no consiste en la integridad de la renta aduanera, sino el adecuado ejercicio de las funciones que las leyes acuerdan al servicio aduanero para el control sobre las importaciones y las exportaciones.&nbsp;Por lo dem&aacute;s, agreg&oacute; la Corte, con independencia de si se comparte el criterio escogido por el legislador, la soluci&oacute;n punitiva ha sido adoptada sin vulnerar los principios de lesividad, culpabilidad y proporcionalidad de las penas y que el poder legislativo, en vez de establecer dos escalas penales diferentes para el delito consumado y la tentativa, escogi&oacute; para ambos supuestos una escala penal &uacute;nica, pero de mayor amplitud. Con base en todo ello,&nbsp;<strong>el Tribunal dej&oacute; sin efecto la sentencia recurrida.</strong></p>","esNovedad":true,"fecha":1636599600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1636656578295,"usuarioCreacion":4,"fechaCreacion":1636656554082,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":32468,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaE