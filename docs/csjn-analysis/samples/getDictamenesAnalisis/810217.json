[{"codigo":8102173,"analisisDocumental":{"id":810217,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"LOPEZ, BERNARDO c/ SERVICIO DE CATASTRO E INFORMACION TERRITORIAL s/recurso de amparo ","inconstitucional":false,"falloDestacado":{"id":8981,"titulo":"Carácter excepcional de la doctrina de la arbitrariedad: necesidad de constatar un apartamiento de los criterios mínimos de argumentación jurídica","cabecilla":"<p style=\"text-indent:2em\">La suprema corte provincial anuló una sentencia de la cámara en lo civil y comercial que había hecho lugar a una acción de amparo tendiente a que se ordene la inscripción del plano de mensura presentado por el accionante. Consideró que la cámara dictó la sentencia sin analizar la cuestión de competencia planteada por la demandada ni los recaudos de procedencia de la acción de amparo intentada y resolvió que la causa debía tramitar ante la justicia en lo contencioso administrativo. </p><p style=\"text-indent:2em\">El actor interpuso un recurso extraordinario aduciendo que, transcurridos más de cuatro años desde el inicio del litigio, la decisión de la corte local que anulaba la sentencia y ordenaba una nueva tramitación ante otro fuero afectaba sus derechos constitucionales.</p><p style=\"text-indent:2em\">La Corte desestimó el recurso.</p><p style=\"text-indent:2em\">Comenzó recordando que la arbitrariedad no puede resultar de la sola disconformidad con la solución adoptada, sino que requiere la constatación de un apartamiento de los criterios mínimos de argumentación jurídica. Concluyó que el recurso intentado era formalmente inadmisible, toda vez que el apelante solo expresaba su discrepancia con la valoración del tribunal respecto de los presupuestos de habilitación formal del amparo efectuados por el a quo sobre la base de prescripciones de derecho público local, sin demostrar apartamiento de las reglas aplicables, la falta de fundamentación en los hechos conducentes del caso o la irrazonabilidad de las conclusiones.</p><p style=\"text-indent:2em\">Señaló que la decisión del superior tribunal local encontraba fundamento suficiente, por un lado, en la consideración de que la vía elegida no resultaba procedente por estar en tela de juicio un acto al que no podía endilgársele arbitrariedad o ilegalidad manifiesta por versar sobre una materia opinable que exigiera una mayor amplitud de debate o de prueba. Por otra parte, el tribunal fundaba su decisión en la existencia de un procedimiento específico en el ámbito local, regulado por la ley provincial 11.330, para debatir las pretensiones de naturaleza administrativa.</p><p style=\"text-indent:2em\">Agregó que no se advertía así una aplicación irrazonable del ordenamiento local ni una decisiva carencia de fundamentación ni que la resolución atacada colocara al recurrente en una situación de privación de justicia que afectara -en forma directa e inmediata- su defensa en juicio ya que, tal como había resuelto la corte local, aquél quedaba sometido a la jurisdicción de un tribunal determinado donde podía seguir defendiendo sus derechos.</p>","esNovedad":true,"fecha":1750302000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1750707397083,"usuarioCreacion":11,"fechaCreacion":1750361584765,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":138660,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34071824,"numeroExpediente":66186,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":9189,"descripcion":"DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"SISTO, MATIAS NICOLAS c/ CANAL, IGNACIO Y OTRO s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"66186. "},"recurso":{"id":7125001,"expediente":{"id":34071824,"numeroExpediente":66186,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":9189,"descripcion":"DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","idMa