[{"codigo":8172603,"analisisDocumental":{"id":817260,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"CAMARA ARGENTINA DE PRODUCTORES DE FONOGRAMAS Y VIDEOGRAMAS Y OTROS s/MEDIDA AUTOSATISFACTIVA","inconstitucional":false,"falloDestacado":{"id":9782,"titulo":"Internet y redes virtuales interjurisdiccionales: competencia federal","cabecilla":"<p style=\"text-indent:2em\">Los actores solicitaron el dictado de una medida autosatisfactiva tendiente a que se bloquee el acceso a un sitio web que permite la descarga de obras musicales y fonogramas por parte de usuarios con IP de Argentina, en presunta infracción a la <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-11723-42755/texto\">ley 11.723</a>.</p><p style=\"text-indent:2em\">Ello originó un conflicto negativo de competencia entre la justicia nacional en lo civil y la justicia nacional en lo civil y comercial federal y la Corte la atribuyó a esta última.</p><p style=\"text-indent:2em\">Recordó que en los casos en los que se pretendía eliminar datos obrantes en bases de datos de internet, lo que implicaba que se encontraban interconectadas en redes virtuales interjurisdiccionales, había declarado la competencia de la justicia federal, con fundamento en lo dispuesto por el artículo 36, inciso b, de la <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-25326-64790/actualizacion\">ley 25.326 </a>de Protección de los Datos Personales y que, por otra parte, en las causas en las que la pretensión se vinculaba con la interpretación, sentido y alcance de aspectos relativos a los derechos de autor y propiedad intelectual, regulados por la ley 11.723, había atribuido competencia a la justicia nacional en lo civil.</p><p style=\"text-indent:2em\">Concluyó así que, teniendo en cuenta la materia involucrada, así como el medio interjurisdiccional implicado, correspondía <b>atribuir la competencia a la justicia nacional en lo civil y comercial federal</b>.</p>","esNovedad":true,"fecha":1762830000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1762884341017,"usuarioCreacion":4,"fechaCreacion":1762879368406,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":145798,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34507385,"numeroExpediente":47866,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"DIAZ, SERGIO RAUL c/ VALIÑO, CARMEN ANTONIA s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"47866. "},"recurso":{"id":7047933,"expediente":{"id":34507385,"numeroExpediente":47866,"anioExpediente":2019,"tomo