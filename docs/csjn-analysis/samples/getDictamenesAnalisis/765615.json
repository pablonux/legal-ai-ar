[{"codigo":7656152,"analisisDocumental":{"id":765615,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"SISTI, PEDRO LUIS Y OTRO c/ ESTADO NACIONAL Y OTROS s/AMPARO","alias":null,"caratula":"SISTI, PEDRO LUIS Y OTRO c/ ESTADO NACIONAL Y OTROS s/AMPARO","inconstitucional":false,"falloDestacado":{"id":1765,"titulo":"Impugnación de criterios para la asignación de bancas en la Cámara de Diputados y competencia originaria de la Corte ","cabecilla":"<p>Acci&oacute;n para que se declare la invalidez de los arts. 3&deg; y 4&deg; del decreto-ley 22.847 y se ordene al Congreso que actualice la representaci&oacute;n con arreglo al &uacute;ltimo censo realizado en 2010 - Pedido de citaci&oacute;n como terceros de las provincias y la Ciudad Aut&oacute;noma de Buenos Aires - El alcance de la pretensi&oacute;n no permite atribuirles a las mencionadas el car&aacute;cter de partes sustanciales - El Estado Nacional, a trav&eacute;s del Poder Legislativo, es el &uacute;nico que resultar&iacute;a obligado y con posibilidades de cumplir con el mandato restitutorio de los derechos que se denuncian como violados, en el supuesto de admitirse la demanda - Pretensi&oacute;n que exigir&iacute;a apartarse del procedimiento habilitado por la Constituci&oacute;n para la formaci&oacute;n de las leyes, arrog&aacute;ndose el Poder Judicial mayores facultades que las que le han sido conferidas expresamente - Competencias exclusivas del Congreso Nacional - Misi&oacute;n de la justicia de saberse mantener dentro de la &oacute;rbita de su jurisdicci&oacute;n - No es posible transformar al Tribunal en un nuevo foro en el que se debatan cuestiones que deber ser tratadas en otros cauces deliberativos - Raigambre constitucional de la competencia originaria y exclusiva de la Corte que impide ampliar su r&iacute;gido contenido con fundamento en reglas funcionales de orden procedimental - Causa ajena a la competencia originaria de la Corte - Disidencia del juez Maqueda: los cuestionamientos a la norma aparecen como una cuesti&oacute;n directa y exclusivamente basada en las normas constitucionales que estructuran la C&aacute;mara de Diputados - Planteo que resulta central a nuestra organizaci&oacute;n federal ya que se enlaza, en &uacute;ltima instancia, con definir a qui&eacute;n debe representar dicha C&aacute;mara - Cuesti&oacute;n federal que radica en definir qu&eacute; quiere decir la Constituci&oacute;n cuando indica que los diputados representan al &ldquo;pueblo de las provincias&rdquo; - La definici&oacute;n sobre la competencia originaria se superpone con el planteo de inconstitucionalidad de los demandantes.</p>","esNovedad":true,"fecha":1618455600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1618841762826,"usuarioCreacion":11,"fechaCreacion":1618841628857,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30815,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28395460,"numeroExpediente":738,"anioExpediente"