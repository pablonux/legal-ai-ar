[{"codigo":7601632,"analisisDocumental":{"id":760163,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"Barrios Rojas, Zoyla Cristina c/ EN ?DNM resol. 561/11- (exp. 2091169/06 (805462/95)) y otro s/ recuso directo para juzgados ","alias":null,"caratula":"BARRIOS ROJAS ZOYLA CRISTINA c/ EN -DNM RESOL 561/11- (EXP 2091169/06 (805462/95)) Y OTRO s/RECURSO DIRECTO PARA JUZGADOS","inconstitucional":false,"falloDestacado":{"id":1487,"titulo":"Permanencia de extranjeros en territorio nacional y reunificación familiar como excepción a la regla de expulsión","cabecilla":"Resolución administrativa que canceló la residencia precaria de una migrante, ordenó su expulsión del país y le prohibió el reingreso por el término de quince años - Fundamento de la decisión en la condena previa por el delito de tenencia de estupefacientes con fines de comercialización - Sentencia de cámara que declaró la nulidad de dicha resolución por considerar que se presentaba un supuesto de reunificación familiar - Cuestionamiento del Estado Nacional a través de un recurso extraordinario - Voto de los jueces Rosenkrantz y Highton de Nolasco: La dispensa por razones humanitarias o de reunificación familiar cuya concesión por parte de la administración es discrecional, constituye una excepción a la regla de la expulsión y como tal debe ser especialmente motivada - La solución alcanzada por la cámara implica alterar el recto sentido de las disposiciones legales aplicables - La conveniencia o interés jurídico en ampliar las salvedades previstas a una regla legal, aun cuando fuera en protección de derechos individuales, es un problema de política legislativa que solo al legislador incumbe resolver - Sentencia que contraría un texto legal, incurriendo en una indebida sustitución de las atribuciones que la ley concedió a la autoridad migratoria competente - Voto de los jueces Maqueda y Lorenzetti: la circunstancia de que la Administración obre en ejercicio de facultades discrecionales en manera alguna puede constituir un justificativo de su conducta arbitraria - La perturbación de las relaciones familiares per se, como consecuencia necesaria de la orden de expulsión del migrante, dictada en un procedimiento legítimo con las debidas garantías procesales, no alcanza para considerar afectado el derecho de reunificación familiar - La interpretación asignada por el a quo a dicho derecho no se compadece con el propósito perseguido por el legislador, ni guarda armonía con el principio jurisprudencial tendiente a evitar que situaciones excepcionales se conviertan en regla general - No resultan suficientemente acreditadas las razones de reunificación familiar - Voto del juez Rosatti: el a quo no valoró adecuadamente la causal que la Dirección Nacional de Migraciones invocó para cancelar el permiso precario con el que contaba la peticionaria y disponer su expulsión del país - La fórmula legislativa aplicable no agravia al pluralismo y diversidad en el que se afinca nuestra máxima expresión de juridicidad y los tratados internacionales de protección de los derechos humanos - No resulta aplicable de modo decisivo la noción de interés superior del niño ya que la reunificación familiar invocada no incluye prioritariamente a menores de edad sino a personas adultas - Se deja sin efecto la sentencia apelada","esNovedad":true,"fecha":1600916400000,"relevancia":2,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29351,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":10741748,"numeroExpediente":31968,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1068,"descripcion":"RECURSO DIRECTO PARA JUZGADOS","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"BARRIOS ROJAS ZOYLA CRISTINA c/ EN -DNM RESOL 561/11- (EXP 2091169/06 (805462/95)) Y OTRO s/RECURSO DIRECTO PARA JUZGADOS","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"31968. "},"recurso":{"id":4740553,"expediente":{"id":10741748,"numeroExpediente":31968,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"}