[{"codigo":8181202,"analisisDocumental":{"id":818120,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ROJAS, CARLOS DANIEL c/ SWISS MEDICAL ART S.A. s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":10041,"titulo":"Tutela judicial efectiva y requisito de fundamentación autónoma del recurso extraordinario","cabecilla":"<p style=\"text-indent: 2em;\">La cámara habilitó la instancia ante la justicia nacional del trabajo para entender en la acción y advirtió que, en tanto las actuaciones tramitaban en dicho fuero desde hacía ya unos años, resultaba improcedente suspender el acceso a la tutela jurisdiccional efectiva durante tanto tiempo a fin de que el actor transite el procedimiento administrativo y luego acceda a la revisión judicial de lo dictaminado.</p><p style=\"text-indent: 2em;\">La aseguradora interpuso un recurso que la Corte desestimó por considerar que no contaba con la fundamentación autónoma requerida por el artículo 15 de la ley 48. </p><p style=\"text-indent: 2em;\">Efectivamente, la alzada había argumentado que de no habilitar la instancia judicial se vulneraría el derecho a la tutela judicial efectiva que consagra la Constitución Nacional y preceptos de fuente internacional y la recurrente, no obstante, se circunscribió a cuestionar el apartamiento del procedimiento de la ley 27.348 y a manifestar su disconformidad con lo decidido por el tribunal. Omitió así rebatir adecuadamente el argumento en que se basó el fallo para habilitar la instancia judicial.</p><p style=\"text-indent: 2em;\">Recordó el Tribunal que para la procedencia del recurso extraordinario no basta la aserción de una determinada solución jurídica si ella no está razonada y constituye un agravio concretamente referido a las circunstancias del caso, mediante una prolija crítica, de todos y cada uno de los argumentos en que se apoya.</p>","esNovedad":true,"fecha":1766026800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1766086819374,"usuarioCreacion":11,"fechaCreacion":1766083236299,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":146626,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36865072,"numeroExpediente":6120,"anioExpediente":2008,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":3,"codigo":"3","abreviatura":"CCF","descripcion":"Cámara Nacional de Apelaciones en lo Civil y Comercial Federal","estado":0,"descripcionLarga":"CCF - Cámara Nacional de Apelaciones en lo Civil y Comercial Federal"},"objetoJuicio":{"id":1431,"descripcion":"PROGRAMAS DE PROPIEDAD PARTICIPADA","idMateria":3,"tema":{"id":451,"codigo":"PROCESOCON"}},"caratula":"Recurso Queja Nº 5 - GUZMAN FERNANDO M