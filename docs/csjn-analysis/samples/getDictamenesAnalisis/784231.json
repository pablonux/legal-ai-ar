[{"codigo":7842312,"analisisDocumental":{"id":784231,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"RAMOS, JOSE LUIS s/HOMICIDIO AGRAVADO POR ALEVOSIA-CASACION CRIMINAL","inconstitucional":false,"falloDestacado":{"id":7323,"titulo":"Violencia contra la mujer: consideración fragmentaria y aislada de las pruebas","cabecilla":"<p style=\"text-indent: 2em;\">El superior tribunal provincial revocó la pena de prisión perpetua como autor del delito de homicidio agravado por ensañamiento y confirmó  la condena por el delito de homicidio simple.</p><p style=\"text-indent: 2em;\"><b>La Corte dejó sin efecto la sentencia</b> por entender que el superior tribunal se había basado en una <em>parcial apreciación</em> de las argumentaciones del tribunal apelado para contemplar que hubo ensañamiento en el accionar del acusado.</p><p style=\"text-indent: 2em;\">Consideró que el superior tribunal afirmó que la decisión se había basado en las apreciaciones que realizó el médico forense y solamente a partir de ello había encontrado colmado el aspecto subjetivo pero, sin embargo, del fallo surgía que se había emprendido el examen de cada uno de los testimonios brindados y demás elementos probatorios de relevancia. Y, en esta línea, al abordar específicamente el análisis de la agravante en cuestión, describió las características de las heridas provocadas en vida de la víctima y la de carácter fatal y, a su vez, contrastó la reconstrucción de lo sucedido con la versión que dio el imputado.</p><p style=\"text-indent: 2em;\">Agregó además el Tribunal que la conclusión resultaba de mayor entidad si se atendía a que los antecedentes y circunstancias lo situaban en el contexto de violencia contra la mujer, que el tribunal había dejado sin respuesta.</p>","esNovedad":true,"fecha":1724122800000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1724181958678,"usuarioCreacion":11,"fechaCreacion":1724181956710,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":109478,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33461067,"numeroExpediente":785,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"RAMOS, JOSE LUIS s/HOMICIDIO AGRAVADO P