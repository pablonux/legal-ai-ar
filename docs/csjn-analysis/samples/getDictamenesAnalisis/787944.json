[{"codigo":7879442,"analisisDocumental":{"id":787944,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"MUNICIPALIDAD DEL DEPARTAMENTO CAPITAL DE LA RIOJA c/ LA RIOJA, PROVINCIA DE s/AMPARO","inconstitucional":false,"falloDestacado":{"id":5843,"titulo":"Coparticipación de impuestos: causa ajena a la competencia originaria de la Corte","cabecilla":"<p>La Intendenta de la Municipalidad del Departamento Capital de La Rioja promovió una acción de amparo contra la Provincia de La Rioja, a fin de que se ordene restablecer los órdenes constitucionales federal y provincial, que aseguran la autonomía municipal que habría sido vulnerada por las autoridades de la provincia demandada en sus aspectos institucionales, políticos, financieros y administrativos. Señaló que el gobierno provincial realizó una incorrecta y discriminatoria aplicación del régimen de coparticipación que afectó la distribución, el reparto y la entrega de los fondos de coparticipación al Municipio. Manifestó también que se produjeron reclamos de trabajadores y diversos actos de violencia, sin que la policía y la justicia de la provincia tomaran intervención alguna para brindar protección, resguardo y seguridad. La Corte declaró que la causa era ajena a su competencia originaria. Recordó que para que la causa revista manifiesto contenido federal la demanda debe fundarse directa y exclusivamente en prescripciones constitucionales de carácter nacional, en leyes del Congreso o en tratados con las naciones extranjeras, de tal suerte que la cuestión federal sea la predominante y que ello no sucede cuando se debaten cuestiones de índole local que traen aparejada la necesidad de hacer mérito de ellas. Afirmó que la cuestión constitucional invocada no revestía un manifiesto contenido federal ya que para resolver lo medular de las cuestiones planteadas tenía que acudirse, necesaria e ineludiblemente, a las normas provinciales que conforman el régimen propio del asunto debatido. </p>","esNovedad":true,"fecha":1693969200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1694192932697,"usuarioCreacion":11,"fechaCreacion":1694032989956,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":113808,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36048337,"numeroExpediente":2661,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9875,"descripcion":"AMPARO","idMateria":0,"tema":null},"caratula":"MUNICIPALIDAD DEL DEPARTAMENTO CAPITAL DE LA RIOJA c/ LA RIOJA, PROVINCIA DE s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2661. "},"recurso":{"id":6199865,"expediente":{"id":36048337,"numeroExpediente":2661,"anioExpediente":2021,"tomoExpedien