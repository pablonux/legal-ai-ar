[{"codigo":7986092,"analisisDocumental":{"id":798609,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"CANTALUPPI, SANTIAGO Y OTRO s/accion de inconstitucionalidad ","inconstitucional":false,"falloDestacado":{"id":7122,"titulo":"“Ecotasa”: impugnación por falta de individualización de la actividad estatal que sirve de causa a la obligación tributaria","cabecilla":"<p style=\"text-indent:2em\">El Superior Tribunal de Justicia de la Provincia de Río Negro rechazó la acción deducida por los titulares o representantes de diversos establecimientos hoteleros, contra el Municipio de San Carlos de Bariloche (Provincia de Río Negro), con el objeto de que se declare la inconstitucionalidad de las ordenanzas locales en cuanto establecieron la denominada \"ecotasa”.</p><p style=\"text-indent:2em\">Al respecto, según la sentencia esa gabela es la contraprestación que se cobra a los turistas que pernoctan en la ciudad de San Carlos de Bariloche, cualquiera sea el tipo y categoría del establecimiento de alojamiento, por los servicios de infraestructura turística brindados por el ente demandado.</p><p style=\"text-indent:2em\">Recurrida la cuestión,<em> la Corte revocó la sentencia apelada.</em></p><p style=\"text-indent:2em\">Para resolver de ese modo, el Tribunal consideró que la tasa en cuestión no cumple ni con la concreta individualización  de la actividad estatal que sirve de causa a la obligación tributaria, ni de la efectiva prestación de los servicios y puesta a disposición de los contribuyentes.</p><p style=\"text-indent:2em\">Recordó además la Corte, lo expresado por el Tribunal en la causa de Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=312&amp;pagina=1575\">312:1575</a>, en el voto concurrente del Dr. Belluscio, sobre un tributo de similar, en cuanto a que si los servicios que se pretenden hacer retribuir por una tasa son prestados <em>uti universi</em>, la norma resulta irrazonable, \"toda vez que carga sobre aquellos contribuyentes que realizan actividades comerciales, industriales o de servicios la supuesta manutención de servicios públicos indiscriminados que beneficiarían a toda la comunidad, consagrando así una manifiesta iniquidad\".</p><p style=\"text-indent:2em\">En suma, aplicada dicha doctrina a esta causa – sostuvo la Corte -  queda en evidencia que la pretensión fiscal de la demandada carece de todo ajuste a los principios y reglas mencionados, los cuales encuentran sustento en el art. 17 de la Constitución Nacional, por lo que resulta ilegítimo su cobro (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=312&amp;pagina=1575\">312:1575</a> y sus citas).</p>","esNovedad":true,"fecha":1719889200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1720029632228,"usuarioCreacion":4,"fechaCreacion":1719948183000,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":122719,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36099347,"numeroExpediente":2808,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"CANTALUPPI, SANTIAGO Y OTRO s/accion de inconstitucionalidad ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2808. "},"recurso":{"id":6214194,"expediente":{"id":36099347,"numeroExpediente":2808,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"CANTALUPPI, SANTIAGO Y OTRO s/accion de inconstitucionalidad ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2808. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CSJ 002808/2021/RH001","identificacionExpediente":"CSJ 002808/2021/RH001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":9,"nombreUsuario":"27203847888","apellido":"