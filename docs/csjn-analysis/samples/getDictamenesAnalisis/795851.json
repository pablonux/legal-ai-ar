[{"codigo":7958513,"analisisDocumental":{"id":795851,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":19,"codigoRelacion":80019,"valor":"CONFIRMA PARCIALMENTE","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009281029,"fechaModLong":201009281029,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"PILAGA S.A. c/ PROVINCIA DE FORMOSA s/SUMARIO","inconstitucional":false,"falloDestacado":{"id":6762,"titulo":"Impuesto sobre los ingresos brutos: principio de la ley y prescripción\r\n\r\n","cabecilla":"<p style=\"text-indent: 2em;\">El superior tribunal provincial confirmó la resolución del Ministerio de Economía, Hacienda y Finanzas (MEHF), que había determinado de oficio el impuesto sobre los ingresos brutos.</p><p style=\"text-indent: 2em;\">Recurrida la decisión, la Corte encontró ajenos a la jurisdicción extraordinaria los agravios que remitían al examen de aspectos de hecho, prueba y derecho procesal y confirmó en ese aspecto la sentencia apelada pero la dejó sin efecto en lo referido a la violación del principio de reserva de ley y al rechazo de la defensa de prescripción.</p><p style=\"text-indent: 2em;\">En relación al rechazo de <b>la defensa de prescripción</b> – sostuvo -  la cuestión se circunscribe a dilucidar si el Código Fiscal puede disponer un momento distinto para <em>el inicio del cómputo</em> del plazo de prescripción que el previsto por el legislador nacional de manera uniforme para toda la República, que se halla regulado en el art. 3956 del Código Civil.</p><p style=\"text-indent: 2em;\">Al respecto, según el Tribunal,  siguiendo la doctrina de sus precedentes (ver Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=342&amp;pagina=1903\">342:1903</a>) consideró que <em>si las provincias no tienen competencia en materia de prescripción para apartarse de los plazos estipulados por el Congreso Nacional, tampoco la tendrían para modificar la forma en que éste fijó su cómputo.</em></p>","esNovedad":true,"fecha":1714446000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1714507248805,"usuarioCreacion":4,"fechaCreacion":1714507245853,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":119638,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35049984,"numeroExpediente":1220,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateri