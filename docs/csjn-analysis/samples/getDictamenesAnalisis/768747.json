[{"codigo":7687472,"analisisDocumental":{"id":768747,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"GRIPPO GUILLERMO OSCAR, CLAUDIA P.ACUÑA Y OTROS c/ CAMPOS ENRIQUE OSCAR Y OTROS s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","alias":null,"caratula":"Recurso Queja Nº 1 - GRIPPO GUILLERMO OSCAR, CLAUDIA P.ACUÑA Y OTROS c/ CAMPOS ENRIQUE OSCAR Y OTROS s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","inconstitucional":false,"falloDestacado":{"id":2642,"titulo":"Derecho a la reparación plena del daño y reducción infundada de la indemnización","cabecilla":"<p>Sentencia de c&aacute;mara que redujo sustancialmente la indemnizaci&oacute;n establecida por la primera instancia, por los da&ntilde;os sufridos por el matrimonio accionante y una de sus hijas menores y por el fallecimiento de otra hija como consecuencia de un accidente de tr&aacute;nsito - Criterios inadecuados que llevaron a establecer resarcimientos insuficientes - Si de acuerdo con el razonamiento del a quo, aun cuando los padres hubieran actuado de modo diligente, el da&ntilde;o sufrido por la muerte de su hija no hubiera podido ser menor, reducir el resarcimiento del rubro en cuesti&oacute;n por la actuaci&oacute;n de los padres por la falta de cintur&oacute;n y por llevar a la menor en los brazos de la madre resulta contradictorio y arbitrario - Derecho que tiene toda persona a una reparaci&oacute;n integral de los da&ntilde;os sufridos como principio basal del sistema de reparaci&oacute;n civil&nbsp; que encuentra su fundamento en la Constituci&oacute;n Nacional y est&aacute; expresamente reconocido por el plexo convencional incorporado al art&iacute;culo 75, inciso 22 - La reparaci&oacute;n plena no se logra si el resarcimiento que se admite como modo de reparar los da&ntilde;os ocasionados se concreta en valores econ&oacute;micos insignificantes en relaci&oacute;n con la entidad del da&ntilde;o que pretende resarcirse - Las razones otorgadas por el tribunal para realizar una sustancial reducci&oacute;n de la indemnizaci&oacute;n por incapacidad sobreviniente, no logran sustentar la exigencia constitucional de adecuada fundamentaci&oacute;n -&nbsp;Se revoca la sentencia.</p>","esNovedad":true,"fecha":1630551600000,"relevancia":3,"usuarioModificacion":11,"fechaModificacion":1632241071087,"usuarioCreacion":11,"fechaCreacion":1630674912193,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31793,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24695087,"numeroExpediente