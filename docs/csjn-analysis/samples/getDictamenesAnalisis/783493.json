[{"codigo":7834934,"analisisDocumental":{"id":783493,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"PATTERER, SUSANA ALICIA c/ ESTADO NACIONAL s/AMPARO","inconstitucional":true,"falloDestacado":{"id":5341,"titulo":"Inconstitucionalidad del decreto 267/2006 sobre la prestación mensual por desempleo","cabecilla":"<p>Una trabajadora presentó un amparo debido al reducido importe que le había sido abonado en concepto de la prestación por desempleo. La cámara hizo lugar al mismo y <b>declaró la inconstitucionalidad del decreto 267/2006</b> <b>que establece un tope máximo y condenó al Poder Ejecutivo Nacional a abonar a la actora un importe mensual equivalente al salario mínimo, vital y móvil vigente, de conformidad con la escala y por el tiempo fijado en el art. 118 de la ley 24.013 (Ley Nacional de Empleo).</b> Recurrida la sentencia por el Estado Nacional, <b>la Corte confirmó la sentencia</b>. Expresó que la asignación por desempleo debe estar sujeta a dos requerimientos claros y precisos: que sea determinada en proporción al salario en actividad del trabajador cotizante y que preserve su significación económica en el tiempo mediante una razonable movilidad de los montos mínimos y máximos estipulados. Concluyó que dichos requerimientos no se hallaban respetados debido a la pérdida de valor del tope de la asignación cuya vigencia se mantuvo inalterada por más de diez años. Agregó el Tribunal que la ayuda reconocida representaba tan solo el 13% del salario que la reclamante había dejado de percibir como consecuencia del despido y que la desvalorización del importe se produjo debido a que la administración no emitió en tiempo propio la normativa pertinente que, en un contexto inflacionario, contemplara los ajustes necesarios. Señaló que dicha omisión había convertido en irrisoria e inequitativa la asignación y desnaturalizado de esta forma el mecanismo de protección social, frustrando un derecho que cuenta con sustento en la Constitución Nacional y en la normativa internacional sobre derechos humanos.</p>","esNovedad":true,"fecha":1682391600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1682522810149,"usuarioCreacion":11,"fechaCreacion":1682448072802,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":108637,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":3487298,"numeroExpediente":22000073,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":2995,"descripcion":"AMPARO","idMateria":112,"tema":null},"caratula":"PATTERE