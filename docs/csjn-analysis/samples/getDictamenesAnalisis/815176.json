[{"codigo":8151763,"analisisDocumental":{"id":815176,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"BAZAN, NORA MABEL c/ SUAREZ, RAMON ANTONIO Y/U OTROS s/RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":9461,"titulo":"Accidente de trabajo: argumentaciones dogmáticas e insuficientes para eximir de responsabilidad a la dueña de la obra","cabecilla":"<p style=\"text-indent:2em\">A raíz del fallecimiento del esposo de la actora como consecuencia de un accidente de trabajo al caer de un andamio, el superior tribunal provincial condenó al empleador principal por ser el dueño de la cosa viciosa y riesgosa que provocó el daño y a la aseguradora debido al incumplimiento de los deberes de prevención, seguridad y contralor. Descartó sin embargo la responsabilidad de la empresa dueña de la obra con sustento en la cláusula del contrato de locación celebrado con la empleadora, en virtud de la cual la última asumía la responsabilidad por la seguridad de los trabajadores durante la prestación de tareas y en que la cosa riesgosa que provocó el daño era propiedad del empleador directo.</p><p style=\"text-indent:2em\">Ante el recurso extraordinario interpuesto por la actora la Corte dejó sin efecto esta sentencia </p><p style=\"text-indent:2em\">Consideró que al analizar la responsabilidad de la dueña de la obra el tribunal omitió considerar los artículos 4° y 112 d el decreto <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/decreto-911-1996-38568/actualizacion\">911/1996</a> que establece el Reglamento de Higiene y Seguridad para la Industria de la Construcción sin brindar fundamento alguno y basando su decisión exclusivamente en la existencia de una cláusula contractual.</p><p style=\"text-indent:2em\">Efectivamente, en trabajos en altura como el que prestaba el trabajador, el dueño de la obra se encuentra obligado en forma solidaria a cumplir con las obligaciones de seguridad y prevención. En el caso existía un contrato en virtud del cual el comitente delegaba esa obligación legal en la contratista pero la solución del caso requería analizar si esa delegación era o no oponible al trabajador que sufrió el accidente y, en su caso, bajo qué circunstancias y con qué alcance. </p>","esNovedad":true,"fecha":1759201200000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1759269537238,"usuarioCreacion":11,"fechaCreacion":1759264395894,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":143539,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripc