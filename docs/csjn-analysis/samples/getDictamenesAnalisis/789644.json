[{"codigo":7896442,"analisisDocumental":{"id":789644,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - FLORES PEDRO ROLANDO c/ TUFESA Y OTRO s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":6102,"titulo":"Sentencia arbitraria en materia de responsabilidad del Estado","cabecilla":"<p>La cámara condenó al Estado Nacional al pago de los daños y perjuicios que habría sufrido el actor a raíz de la lesión que padeció mientras viajaba como pasajero en una formación ferroviaria de su propiedad desde la Provincia de Tucumán hasta la Ciudad Autónoma de Buenos Aires. Ante el recurso del Estado Nacional, la Corte revocó el pronunciamiento. Afirmó que la cámara resolvió responsabilizar al Estado Nacional, por su carácter de propietario de la cosa en los términos de los arts. 1113, segundo párrafo, del Código Civil, 184 del Código de Comercio y 42 de la ley 24.240 y en el deber de seguridad, cuando lo cierto es que resultaba necesario acreditar la concurrencia de los presupuestos que la doctrina y la jurisprudencia han establecido para que aquélla resulte procedente, recaudos que operan en los supuestos de responsabilidad del Estado. Señaló que <b>la sentencia apelada había prescindido de toda ponderación acerca de la existencia del contrato de concesión celebrado entre el Estado Nacional y la Provincia de Tucumán </b>por el cual aquél transfirió en concesión a esta última, la explotación comercial del servicio interurbano de pasajeros que comunicaba dicha provincia con la Ciudad de Buenos Aires, al igual que del contrato de subconcesión celebrado entre la provincia y la empresa que operaba la formación ferroviaria y, por ende, la incidencia que pudieron tener tales hechos en la imputación de responsabilidad al Estado. Agregó que si bien la seguridad es un valor que debe guiar tanto la conducta de los organizadores de los servicios públicos como la del Estado, ello por sí solo, no es suficiente para condenar a este último.</p>","esNovedad":true,"fecha":1699326000000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1700770363524,"usuarioCreacion":11,"fechaCreacion":1699384974490,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":114800,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34932594,"numeroExpediente":3422,"anioExpediente":2000,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":3,"codigo":"3","abreviatura":"CCF","descripcion":"Cámara Nac