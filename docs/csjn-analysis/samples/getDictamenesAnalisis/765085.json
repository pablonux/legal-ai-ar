[{"codigo":7650852,"analisisDocumental":{"id":765085,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"MENENDEZ, LUCIANO BENJAMIN Y OTROS s/LEGAJO DE CASACION","alias":null,"caratula":"Recurso Queja Nº 1 - Legajo Nº 1 - QUERELLANTE: FIGUEROA, LAURA IMPUTADO: MENENDEZ, LUCIANO BENJAMIN Y OTROS s/LEGAJO DE CASACION","inconstitucional":false,"falloDestacado":{"id":1725,"titulo":"Deficiencias de fundamentación en el cuestionamiento de la suspensión del goce de haberes previsionales que dispone la legislación penal","cabecilla":"<p>Sentencia que declar&oacute; la inconstitucionalidad del art&iacute;culo 19, inciso 4, del C&oacute;digo Penal - Fundamento en que la suspensi&oacute;n del goce de los haberes previsionales durante el tiempo de la condena importar&iacute;a una &quot;especie de confiscaci&oacute;n transitoria&quot; capaz de lesionar el derecho inviolable de propiedad y pondr&iacute;a en riesgo la subsistencia del afectado - Apartamiento de la doctrina seg&uacute;n la cual la declaraci&oacute;n de inconstitucionalidad de una ley constituye la m&aacute;s delicada de las funciones a encomendar a un tribunal de justicia y un acto de suma gravedad que debe ser considerado la ultima ratio del orden jur&iacute;dico - Desconocimiento de que el derecho de propiedad sobre los haberes previsionales no tiene car&aacute;cter absoluto - Derechos susceptibles de ser objeto de reglamentaciones razonables - Afirmaci&oacute;n de la existencia de una lesi&oacute;n al derecho de propiedad de un modo puramente abstracto, sin acompa&ntilde;ar explicaci&oacute;n alguna dirigida a demostrar el perjuicio concreto que provocar&iacute;a en las circunstancias espec&iacute;ficas de cada uno de los condenados - Omisi&oacute;n de considerar que la norma establece que el importe de los haberes previsionales que corresponden al condenado ser&aacute; percibido por los parientes que tengan derecho a pensi&oacute;n - Decisi&oacute;n que pasa por alto que la ley 24.660 establece que el tratamiento del encarcelado deber&aacute; atender a sus condiciones personales, intereses y necesidades durante la internaci&oacute;n y al momento del egreso - Las incapacidades civiles que la ley impone a los condenados a penas privativas de la libertad superiores a tres a&ntilde;os no pueden ser calificadas como un trato inhumano o contrario a la dignidad del hombre - Criterios de pol&iacute;tica criminal y penitenciaria que son atribuci&oacute;n del legislador nacional - Se deja sin efecto la sentencia apelada.</p>","esNovedad":true,"fecha":1616468400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1629719288093,"usuarioCreacion":11,"fechaCreacion":16166816906