[{"codigo":7702192,"analisisDocumental":{"id":770219,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"B., C. B. Y OTRO c/ I.O.S.P.E.R. Y OTROS s/ACCION DE AMPARO","alias":null,"caratula":"B., C. B. Y OTRO c/ I.O.S.P.E.R. Y OTROS s/ACCION DE AMPARO","inconstitucional":false,"falloDestacado":{"id":2901,"titulo":"Obras sociales y cobertura del costo del “aceite de cannabis\"","cabecilla":"<p>Decisi&oacute;n del superior tribunal provincial que rechaz&oacute; la acci&oacute;n de amparo promovida por los padres de un joven con discapacidad contra una obra social y una provincia para que se reconozca el costo del &ldquo;<strong>aceite de cannabis</strong>&rdquo; en la cantidad que el m&eacute;dico neur&oacute;logo lo indicara. Contra dicha sentencia los actores interpusieron el recurso extraordinario cuestionando la interpretaci&oacute;n de la ley 27.350 por considerarla indebidamente restrictiva. La Corte revoc&oacute; la sentencia apelada haciendo lugar a la acci&oacute;n de amparo y en consecuencia conden&oacute; al IOSPER a cubrir el 100% del costo del &ldquo;aceite de cannabis&rdquo;en las dosis que indique su m&eacute;dico neur&oacute;logo y en los t&eacute;rminos del decreto 883/2020. Entre sus fundamentos, valor&oacute; que no se encuentra discutido que, luego de un a&ntilde;o de tratamiento, el uso del aceite de cannabis por parte del menor produjo mejoras sustanciales en su estado de salud y en su calidad de vida. Por otra parte, mientras se hallaba la causa a estudio de la Corte, el Poder Ejecutivo Nacional dict&oacute; el decreto 883/2020 por el que aprob&oacute; la reglamentaci&oacute;n de la ley 27.350 y derog&oacute; el anterior decreto en el que se hab&iacute;a apoyado el superior tribunal local para rechazar la pretensi&oacute;n. En esos t&eacute;rminos, sostuvo que las obras sociales deben brindar cobertura para la adquisici&oacute;n de los derivados de la planta de cannabis a aquellos pacientes que cuenten con indicaci&oacute;n m&eacute;dica seg&uacute;n la propia letra del art&iacute;culo 3 inciso d, del Anexo del decreto mencionado. Por lo dem&aacute;s, expres&oacute; que la evidencia sobre la efectividad del aceite de cannabis para tratar diversas enfermedades y, en particular, la epilepsia refractaria, fue uno de los motivos de la sanci&oacute;n de la ley 27.350.&nbsp;</p>","esNovedad":true,"fecha":1634785200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1634924891245,"usuarioCreacion":11,"fechaCreacion":1634903609632,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":32297,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31468275,"numeroExpediente":417,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"