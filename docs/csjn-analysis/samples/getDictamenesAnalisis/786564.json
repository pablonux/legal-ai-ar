[{"codigo":7865644,"analisisDocumental":{"id":786564,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ALAGUIBE, ANA MARIA c/ AFIP s/CONTENCIOSO","inconstitucional":false,"falloDestacado":{"id":5763,"titulo":"Amplitud de criterio de la Administración en el ejercicio de sus facultades discrecionales","cabecilla":"<p>La cámara hizo lugar a la demanda y ordenó a la AFIP que reintegrara a la actora al cargo en el que se desempeñaba al entender que el cambio de funciones no había sido el resultado de un razonable ejercicio del <em>ius variandi</em>. La demandada interpuso un recurso extraordinario y la Corte revocó esta sentencia. Expresó que es de la esencia de la relación de empleo público la potestad del empleador de variar las funciones encomendadas en razón de la concreta necesidad del servicio, siempre que tales modificaciones sean impuestas de modo razonable y no signifiquen la asignación de tareas impropias de la posición escalafonaria que corresponde al agente. Agregó que en aras de lograr el buen servicio, debe reconocerse a la Administración una razonable amplitud de criterio en el ejercicio de sus facultades discrecionales, sin que las decisiones atinentes a la política administrativa constituyan una materia justiciable, en tanto las medidas adoptadas no impliquen respecto de los agentes una descalificación o una medida disciplinaria encubierta. Concluyó entonces que la demandada había ejercido de manera regular sus potestades de organización, supervisión y asignación de funciones de su personal a cargo, en aras de garantizar eficazmente el interés público que le es inherente.</p>","esNovedad":true,"fecha":1692241200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1692302822757,"usuarioCreacion":11,"fechaCreacion":1692300966479,"privado":false,"posicion":0,"resumen":null},"reciboEntrada":{"id":111979,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":3467336,"numeroExpediente":21009971,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":3054,"descripcion":"CONTENCIOSO","idMateria":112,"tema":null},"caratula":"ALAGUIBE, ANA MARIA c/ AFIP s/CONTENCIOSO","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"21009971. "},"recurso":{"id":5002500,"expediente":{"id":3467336,"numeroExpediente":21009971,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"de