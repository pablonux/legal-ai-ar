[{"codigo":7961153,"analisisDocumental":{"id":796115,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"REQUERIDO: GENTIL TENCA, OZEDES  s/EXTRADICION","inconstitucional":false,"falloDestacado":{"id":6781,"titulo":"Extradición: cuestiones relacionadas con la validez de la prueba o de los actos celebrados\r\n","cabecilla":"<p style=\"text-indent: 2em;\">El juez de primera instancia concedió la extradición del requerido a la República del Paraguay para ser sometido a proceso por el delito de lesión de confianza.</p><p style=\"text-indent: 2em;\">La defensa particular dedujo recurso ordinario de apelación y la Corte confirmó este pronunciamiento.</p><p style=\"text-indent: 2em;\">Señaló que el agravio traído remite al análisis de la validez de un acto procesal cumplido en el proceso extranjero que compromete el modo en que cabe interpretar las reglas procedimentales vinculadas con la decisión que lo declaró rebelde y con el domicilio en el que la notificación previa fue llevada a cabo y que dichos aspectos resultan ajenos al procedimiento de extradición y propios de los jueces foráneos, ante los cuales corresponde que sean planteados los reparos.</p><p style=\"text-indent: 2em;\">Agregó que razones de equidad y justicia que reconocen sustento en las normas de derecho internacional de los derechos humanos, aconsejan que el juez de la causa ponga en conocimiento del país requirente el tiempo de privación de libertad al que estuvo sujeto el requerido en el trámite de extradición, con el fin de que las autoridades judiciales extranjeras arbitren las medidas a su alcance para que ese plazo de detención se compute como si el extraditado lo hubiese sufrido en el curso del proceso que motivó el requerimiento.</p>","esNovedad":true,"fecha":1714446000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1714506507671,"usuarioCreacion":4,"fechaCreacion":1714506505217,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":120039,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34599372,"numeroExpediente":733,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":21,"codigo":"21","abreviatura":"FPO","descripcion":"Justicia Federal de Posadas","estado":0,"descripcionLarga":"FPO - Justicia Federal de Posadas"},"objetoJuicio":{"id":2401,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"REQUERIDO: GENTIL TENCA, OZEDES  s/EXTRADICION","verificacionMesa":"N","etiqu