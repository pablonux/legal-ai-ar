[{"codigo":7984052,"analisisDocumental":{"id":798405,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"M., D. A Y OTROS c/ V., C. R. s/NULIDAD DE CONVENIO - INCIDENTE FAMILIA","inconstitucional":false,"falloDestacado":{"id":7682,"titulo":"Acción de nulidad del convenio de liquidación de bienes gananciales: competencia del juzgado a cargo del proceso universal","cabecilla":"<p style=\"text-indent:2em\">En un proceso en el que el actor —hoy fallecido— promovió acción de nulidad del convenio de liquidación de la masa de bienes gananciales de la sociedad conyugal, suscripto y presentado para su homologación, se originó un conflicto negativo de competencia. El juzgado nacional declinó entender con base en el fuero de atracción que ejerce el sucesorio del causante y la jueza local rechazó la radicación de la causa con sustento en que en el proceso sucesorio se había efectuado la partición de los activos denunciados.</p><p style=\"text-indent:2em\">La Corte expresó que razones de seguridad jurídica aconsejan que la causa deba radicarse ante el juzgado provincial a cargo del proceso universal pues, más allá de que el divorcio entablado ante la justicia nacional está concluido y que las actuaciones fueron promovidas por el causante, su fallecimiento compromete directamente la asignación de bienes al haber relicto.</p><p style=\"text-indent:2em\">Recordó el Tribunal que en los casos de disolución de la sociedad conyugal por la muerte de uno de sus integrantes, la liquidación y partición de los bienes de esa sociedad opera corrientemente en el juicio sucesorio, trámite en el que se incluye la determinación de su carácter, propio o ganancial y también que las reglas que rigen el fuero de atracción del sucesorio son imperativas o de orden público, pues tienden a facilitar la liquidación del patrimonio hereditario tanto en beneficio de los acreedores como de la sucesión, por lo que no pueden ser dejadas de lado, ni aun por convenio de partes.</p>","esNovedad":true,"fecha":1728356400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1728485077288,"usuarioCreacion":4,"fechaCreacion":1728476812028,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":122458,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35079107,"numeroExpediente":403,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1861,"descripcion":"EXPEDIENTES PENALES","idMateria":9,"tema":null},"caratula":"Incidente Nº 1 -  NN: N.N. s/INC