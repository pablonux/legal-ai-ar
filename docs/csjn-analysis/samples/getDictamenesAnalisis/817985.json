[{"codigo":8179852,"analisisDocumental":{"id":817985,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Legajo Nº 1 - DENUNCIANTE: CARRIO , ELISA MARIA IMPUTADO: POCHETTI, CAROLINA s/LEGAJO DE CASACION","inconstitucional":false,"falloDestacado":{"id":9646,"titulo":"Decomiso de bienes y desarchivo de la causa","cabecilla":"<p style=\"text-indent: 2em;\">La cámara de casación hizo lugar al recurso de la defensa contra la decisión de la cámara de apelaciones que revocó el archivo de la causa, y dispuso estar al sobreseimiento firme dictado por el juez de primera instancia. </p><p style=\"text-indent: 2em;\">Contra esa decisión el Fiscal General y la Unidad de Información Financiera dedujeron recursos extraordinarios y la <b>Corte la dejó sin efecto</b>. </p><p style=\"text-indent: 2em;\">Entendió que la interpretación según la cual el archivo de las actuaciones sería definitivo al existir un obstáculo para proceder por haber sido los hechos juzgados con anterioridad queda desvirtuada por la circunstancia de que el proceso anterior, que culminó con el sobreseimiento por considerarse que el patrimonio del imputado no había crecido de manera injustificada durante su paso por la función pública, se refiere a las variaciones patrimoniales observadas en ese período mientras que la presente causa trata sobre operaciones posteriores.</p><p style=\"text-indent: 2em;\">Agregó que tampoco los hechos comprendidos en dicho período estarían alcanzados por la garantía del <em>ne bis in ídem</em> ya que el tratamiento que el Fiscal General le deparó a la cuestión deja en claro que los tipos penales de enriquecimiento ilícito y lavado de dinero describen conductas materialmente distintas, con independencia de las relaciones o conexiones que puedan darse entre ellas.</p>","esNovedad":true,"fecha":1761620400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1761689315232,"usuarioCreacion":11,"fechaCreacion":1761689245204,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":146506,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29510934,"numeroExpediente":3878,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"cara