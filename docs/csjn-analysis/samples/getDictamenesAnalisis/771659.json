[{"codigo":7716592,"analisisDocumental":{"id":771659,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"HUANG, QIUMING c/ EN - DNM s/RECURSO DIRECTO DNM","alias":null,"caratula":"HUANG, QIUMING c/ EN - DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":3286,"titulo":"Ingreso irregular de extranjeros al territorio nacional y cancelación de permanencia","cabecilla":"<p>Frente a las disposiciones de la Direcci&oacute;n Nacional de Migraciones que declararon irregular la permanencia de una persona de nacionalidad china en el pa&iacute;s, ordenaron su expulsi&oacute;n y prohibieron su reingreso por el t&eacute;rmino de cinco a&ntilde;os, la C&aacute;mara decret&oacute; la nulidad de los actos impugnados y orden&oacute; devolver las actuaciones a la autoridad migratoria a fin de que dicte un nuevo acto. Entendi&oacute;&nbsp;para ello que se hab&iacute;a considerado el haber ingresado de modo irregular a nuestro pa&iacute;s pero no se hab&iacute;a tenido en cuenta, que salvo la constancia de ingreso al pa&iacute;s, la recurrente cumpl&iacute;a con todas las condiciones que la legislaci&oacute;n requiere para obtener la residencia temporaria.&nbsp;<strong>La Corte, por unanimidad</strong>, revoc&oacute; la sentencia apelada al considerar que la decisi&oacute;n de la autoridad migratoria no hizo m&aacute;s que ajustarse a las previsiones establecidas en los preceptos legales por lo que desde esta perspectiva no resulta pasible de objeci&oacute;n alguna. Descart&oacute; tambi&eacute;n como argumento la norma que se refiere a la regularizaci&oacute;n de la situaci&oacute;n al considerar evidente que el precepto solo alcanza a los casos en que se verifique una irregularidad en la &ldquo;permanencia&rdquo; de un extranjero en el pa&iacute;s, excluyendo supuestos como el examinado, en el que la irregularidad se plante&oacute; en el momento del ingreso al territorio nacional.</p>","esNovedad":true,"fecha":1638846000000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1639398436441,"usuarioCreacion":11,"fechaCreacion":1639054032052,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":32815,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31073470,"numeroExpediente":89674,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"HUANG, QIUMING c/ EN -