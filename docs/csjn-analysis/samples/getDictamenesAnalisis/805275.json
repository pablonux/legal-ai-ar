[{"codigo":8052755,"analisisDocumental":{"id":805275,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"CRUZ, JOSE MARIA Y OTRO c/ PROVINCIA DE TUCUMAN Y OTROS s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":8084,"titulo":"Arbitrariedad en la cuantificación del daño moral","cabecilla":"<p style=\"text-indent: 2em;\">Los actores reclamaron la reparación de los perjuicios causados por la muerte de su madre en un accidente vial en el que fallecieron cerca de cincuenta personas. El superior tribunal provincial hizo lugar parcialmente a la demanda y confirmó la condena. </p><p style=\"text-indent: 2em;\">Ante el recurso de los demandantes la Corte hizo lugar a los agravios formulados por el monto de condena y consideró arbitraria la sentencia por desnaturalizar el derecho a la reparación por daño moral que ella misma reconoce a los actores.</p><p style=\"text-indent: 2em;\">Recordó el Tribunal que la cuantificación del daño moral prevista en el artículo 1078 del antiguo Código Civil —que regía el caso—debe tener en cuenta el carácter resarcitorio de este rubro, la índole del hecho generador de la responsabilidad, la entidad del sufrimiento causado, que no tiene necesariamente que guardar relación con el daño material, pues no se trata de un daño accesorio a este.</p><p style=\"text-indent: 2em;\">Señaló que los jueces provinciales aplicaron las pautas generales previstas en la legislación civil para fijar la indemnización pero, sin embargo, el resultado al que arribaron cuando determinaron la suma debida por las inconductas de los demandados en concepto de daño moral es insignificante. Destacó que la cuantificación de los montos aparece desprovista de fundamentos reales y basada en la sola voluntad de los jueces.</p>","esNovedad":true,"fecha":1734577200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1734639509418,"usuarioCreacion":4,"fechaCreacion":1734639488255,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":131842,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29594343,"numeroExpediente":415,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9191,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"CRUZ, JOSE MARIA Y OTRO c/ PROVINCIA DE TUCUMAN Y OTROS s/DAÑOS Y PERJUICIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"415. "},"recurso":{"id":5051625,"expediente":{"id":29594343,"numeroExped