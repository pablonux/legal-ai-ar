[{"codigo":8019892,"analisisDocumental":{"id":801989,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"F., C. S. s/ amparo. ","alias":null,"caratula":"FREYTES, CANDELA SOLEDAD s/AMPARO","inconstitucional":false,"falloDestacado":{"id":7663,"titulo":"Competencia territorial en procesos relativos a niñas y niños","cabecilla":"<p style=\"text-indent:2em\">En las jurisdicciones de la ciudad de La Rioja y de La Matanza, Provincia de Buenos Aires, se iniciaron paralelamente procesos referidos a la responsabilidad parental, cuidado personal y régimen de comunicación que involucran a una niña, en los que ambos tribunales declinaron de oficio su propia competencia por razones territoriales.</p><p style=\"text-indent:2em\">La Corte, por mayoría, entendió que corresponde al foro riojano entender en la causa.</p><p style=\"text-indent:2em\">Comenzó recordando que el Código Civil y Comercial de la Nación asigna el conocimiento de los procesos relativos a niños, niñas y adolescentes, al juez del foro en el cual se sitúa su centro de vida (art. 716) entendido como el lugar donde la persona menor de edad hubiese transcurrido, en condiciones legítimas, la mayor parte de su existencia, conforme disponen el artículo 3, inciso f, de la Ley 26.061 de Protección Integral de los Derechos de las Niñas, Niños y Adolescentes y su decreto reglamentario 415/06.</p><p style=\"text-indent:2em\">Adicionalmente, resaltó que la proximidad de la que gozan esos tribunales con el domicilio donde vive la niña con su padre constituye un arbitrio ciertamente relevante en el plano de la efectividad de la labor tutelar y, además, la decisión guarda coherencia con la directiva del artículo 706 del código ya mencionado, en cuanto consagra la necesidad de valorar el mejor interés de la niña involucrada, así como el respeto de la tutela judicial efectiva y la inmediación, como principios generales que deben regir los procesos de familia.</p>","esNovedad":true,"fecha":1728356400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1728475169982,"usuarioCreacion":4,"fechaCreacion":1728420145747,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":128560,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38271758,"numeroExpediente":1878,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"F., C. S. s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"187