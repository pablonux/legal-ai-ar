ón.</p><p style=\"text-indent:2em\"> </p><p style=\"text-indent:2em\">La Corte rechazó la demanda. </p><p style=\"text-indent:2em\"> </p><p style=\"text-indent:2em\">Consideró para ello que la defensa de falta de acción opuesta por la provincia demandada debía prosperar ya que la resolución cuestionada fue dejada sin efecto en el ámbito local mediante el dictado de la resolución 54/06 del Ministerio de Industria, Comercio y Empleo de la Provincia de La Rioja</p>","esNovedad":true,"fecha":1755140400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1755525314791,"usuarioCreacion":11,"fechaCreacion":1755203364855,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":141518,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23536517,"numeroExpediente":94,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"E","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ESTADO NACIONAL c/ LA RIOJA, PROVINCIA DE s/Nulidad de Acto Administrativo","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"E. 94. XLIX. "},"recurso":{"id":3083714,"expediente":{"id":23536517,"numeroExpediente":94,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"E","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ESTADO NACIONAL c/ LA RIOJA, PROVINCIA DE s/Nulidad de Acto Admini