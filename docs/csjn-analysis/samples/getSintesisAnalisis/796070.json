[{"codigo":7960703,"analisisDocumental":{"id":796070,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":30,"codigoRelacion":80030,"valor":"DECLARA INADMISIBLE","activo":"S","usuarioCreacion":"JUR202","usuarioMod":"JUR202","fechaCreacionLong":201111141045,"fechaModLong":201111141045,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":230008,"valor":"RECURSO EXTRAORDINARIO POR SALTO DE INSTANCIA","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201311070841,"fechaModLong":201311071335,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":250005,"valor":"DDHH- Institucional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Salto Instancia Nº 1 - GIL DOMINGUEZ, ANDRES c/ EN s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":6741,"titulo":"Inexistencia de caso o controversia","cabecilla":"<p style=\"text-indent: 2em;\">El juzgado de primera instancia desestimó por ausencia de legitimación activa el proceso autosatisfactivo promovido con el objeto de que se ordene a la Cámara de Diputados y a la Cámara de Senadores del Congreso de la Nación que se aboquen al expreso e inmediato tratamiento del decreto de necesidad y urgencia 70/2023, a efectos de su aprobación o rechazo.</p><p style=\"text-indent: 2em;\">Contra esa decisión el actor interpuso recurso extraordinario por salto de instancia.</p><p style=\"text-indent: 2em;\">La Corte declaró inadmisible el recurso. En primer lugar recordó que la admisibilidad del recurso extraordinario se encuentra subordinada a la existencia de un caso o controversia y que dicho requisito surge de los principios del ordenamiento constitucional argentino.</p><p style=\"text-indent: 2em;\">Señaló que la pretendida calidad de titular de una \"porción de la soberanía popular” resulta indistinguible de la condición de ciudadano a la que el Tribunal ha desconocido invariablemente legitimación para demandar y agregó que no se había explicado cuál sería la afectación concreta y particularizada que tendría el apelante.</p>","esNovedad":true,"fecha":1713841200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1713897580877,"usuarioCreacion":4,"fechaCreacion":1713897578430,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":119979,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38740078,"numeroExpediente":1794,"anioExpediente":2024,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Salto Instancia Nº 1 - GIL DOMINGUEZ, ANDRES c/ EN s/PROCESO DE CONOCIMIENTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1794. "},"recurso":{"id":6829549,"expediente":{"id":38740078,"numeroExpediente":1794,"anioExpediente":2024,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","desc