[{"codigo":8043334,"analisisDocumental":{"id":804333,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 5 - Legajo Nº 37 - PROCESADO: BOFILL ALEJANDRO ARTURO Y OTROS s/LEGAJO DE CASACION","inconstitucional":false,"falloDestacado":{"id":7981,"titulo":"El conocimiento real y efecto del daño es el comienzo del cómputo de la prescripción","cabecilla":"<p style=\"text-indent:2em\">La cámara de casación rechazó el recurso interpuesto por el Ministerio de Defensa dejando firme la declaración de prescripción de la acción penal y de la acción civil deducida por Talleres Navales Dársena Norte (Tandanor) en el marco del delito de administración fraudulenta en perjuicio de una administración pública.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto lo vinculado con la acción civil, por considerar que se había omitido un tratamiento adecuado a la contienda de acuerdo a los términos en que fue planteada, al derecho aplicable y a la prueba rendida.</p><p style=\"text-indent:2em\">Expresó que en el caso de la responsabilidad el punto de partida del plazo de prescripción debe computarse a partir del momento en que el damnificado tomó conocimiento real y efectivo de los daños cuya reparación reclama, sin que obste a ello la circunstancia de que los perjuicios pudieran presentar un proceso de duración prolongada o indefinida, pues el curso del plazo de la prescripción comienza cuando sea cierto y susceptible de apreciación el daño futuro  (Fallos: <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=325&amp;pagina=491\">325:491</a>; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=326&amp;pagina=1420\">326:1420</a> y <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=338&amp;pagina=161\">338:161</a>,entre muchos otros).</p><p style=\"text-indent:2em\">En ese sentido, consideró el Tribunal que el Estado Nacional no recibió respuesta alguna sobre el agravio referido a que recién estuvo en condiciones jurídicamente exigibles de conocer el daño civil cuya reparación reclamaba, consistente en el dinero con el que debió afrontar el mantenimiento y funcionamiento de Tandanor desde el año 2007 por los perjuicios generados a partir de esa fecha –posteriores incluso a su constitución como querellante – luego de la toma efectiva del control de la empresa tras la sanción del <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/decreto-315-2007-126933\">decreto 315/2007</a>.</p><p style=\"text-indent:2em\">En esas condiciones dejó sin efecto la sentencia apelada en lo concerniente a la prescripción de la acción civil y ordenó un nuevo pronunciamiento.</p>","esNovedad":true,"fecha":1732590000000,"relevancia":1,"usuarioModificacion"