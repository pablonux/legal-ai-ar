[{"codigo":7869634,"analisisDocumental":{"id":786963,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"UNIVERSIDAD NACIONAL DE LA MATANZA Y OTROS c/ EN-M CULTURA Y EDUCACION s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":5841,"titulo":"El Ministerio Público Fiscal no puede apelar la sentencia final de una causa que fue consentida por los litigantes","cabecilla":"<p>Frente a una sentencia  que declaró la inconstitucionalidad de los artículos 2° y 4° de la ley 27.204 de Educación Superior,  el Ministerio Público dedujo un recurso de apelación que fue desestimado por considerarse que la sentencia había sido consentida por la parte actora y la demandada. Deducido el recurso extraordinario, <b>la Corte confirmó la decisión por mayoría</b>. Recordó el Tribunal que la existencia de un caso judicial es una precondición para la intervención de los tribunales nacionales y constituye un requisito <em>sine qua non</em> de su accionar y que para que exista un caso es imprescindible que quien reclama tenga un interés suficientemente directo, concreto y personal en el resultado del pleito que propone. Señaló también que <b>la reforma constitucional de 1994 no le otorgó legitimación procesal al Ministerio Público para instar una suerte de acción popular o en defensa de la mera legalidad</b>, por fuera de los recaudos fijados por el artículo 116 de la Constitución y que tampoco está habilitado a perseguir pretensiones abstractas sobre la validez o invalidez constitucional de las normas o actos de otros poderes. Agregó el Tribunal que las leyes que regularon las funciones del Ministerio Público tampoco le otorgaron una legitimación extraordinaria para intervenir en cualquier asunto en materia no penal con total prescindencia de la actitud procesal de las partes en conflicto. Concluyó así que el recurrente, que sí había tenido ocasión de pronunciarse sobre la competencia del tribunal interviniente y sobre la inconstitucionalidad solicitada, no estaba autorizado a cuestionar en forma autónoma la sentencia definitiva que había puesto fin a la controversia.  </p>","esNovedad":true,"fecha":1693969200000,"relevancia":3,"usuarioModificacion":11,"fechaModificacion":1694192813410,"usuarioCreacion":11,"fechaCreacion":1694032802235,"privado":false,"posicion":-1,"resumen":null},"reciboEntrada":{"id":112617,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":27858052,"numeroExpediente":80419,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara 