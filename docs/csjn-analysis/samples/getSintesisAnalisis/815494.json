[{"codigo":8154943,"analisisDocumental":{"id":815494,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":23,"codigoRelacion":80023,"valor":"DECLARA MAL CONCEDIDO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201010151430,"fechaModLong":201010151430,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"M., P.M c/ M., K.A s/RESTITUCION INTERNACIONAL DE MENORES ( vigente hasta 31/07/2015 )","inconstitucional":false,"falloDestacado":{"id":9441,"titulo":"Recurso extraordinario presentado en primera instancia y carácter perentorio de los plazos procesales","cabecilla":"<p style=\"text-indent:2em\">La cámara confirmó la sentencia que ordenó la restitución de las niñas a la República de Bielorrusia y, contra dicha decisión, la demandada interpuso recurso extraordinario federal, que presentó ante el juzgado de primera instancia. El juzgado remitió el escrito a la cámara, que lo recibió cuando ya se encontraba vencido el plazo establecido por el artículo 257 del Código Civil y Comercial de la Nación, por lo que resultaba inadmisible por extemporáneo.</p><p style=\"text-indent:2em\">La Corte consideró que las circunstancias de que la cámara -soslayando tal cuestión- hubiera intimado a la recurrente a adecuar el escrito a la acordada 4/2007 y de que la parte hubiera dado cumplimiento a ello con la presentación de un nuevo remedio federal, no pudieron llevar a que se lo tuviera por presentado y luego se lo concediera parcialmente.</p><p style=\"text-indent:2em\">Señaló que no correspondía prescindir del carácter perentorio de los plazos procesales en desmedro del derecho al debido proceso garantizado para ambas partes y declaró <b>mal concedido el recurso</b>. </p><p style=\"text-indent:2em\">Añadió que el único recurso extraordinario sobre cuya admisibilidad debía expedirse la cámara era el presentado ante el juzgado de primera instancia dado que, a los fines de considerar su tempestividad, la presentación de un nuevo escrito adecuado a la citada acordada carecía de efectos procesales.</p>","esNovedad":true,"fecha":1758596400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1758803787436,"usuarioCreacion":11,"fechaCreacion":1758655317464,"privado":false,"posicion":0,"resumen":null},"reciboEntrada":{"id":143878,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":39301091,"numeroExpediente":71278,"anioExpediente":2024,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":9188,"descripcion":"RESTITUCION INTERNACIONAL DE MENORES ( vigente hasta 31/07/2015 )","idMateria":1,"tema":{"id":400,"codigo":"FAM"}},"caratula":"M., P.M c/ M., K.A s/RESTITUCION INTERNACIONAL DE MENORES ( vigente hasta 31/07/2015 )","v