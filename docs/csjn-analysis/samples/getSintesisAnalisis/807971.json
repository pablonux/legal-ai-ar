[{"codigo":8079716,"analisisDocumental":{"id":807971,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"SOUZA AMANDA GRACIELA c/ ENTE 23283 Y23412COOPERADOR LEYES Y OTRO s/OTROS RECLAMOS","inconstitucional":false,"falloDestacado":{"id":8622,"titulo":"Aportes previsionales y competencia del fuero de la seguridad social","cabecilla":"<p style=\"text-indent:2em\">La actora, ya jubilada, acciona en su condición de ex agente estatal para que se esclarezca centralmente si el incentivo enmarcado en el régimen de colaboración de las leyes <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-23283-23986/texto\">23.283</a> y <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-23412-22298/texto\">23.412</a>, que habría abonado un ente cooperador durante el curso de la relación laboral, devengó aportes y contribuciones en los términos de la ley <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-24241-639/actualizacion\">24.241</a> y debe computarse a los efectos del cálculo del haber previsional.</p><p style=\"text-indent:2em\">La Cámara Federal de la Seguridad Social y la Cámara Nacional del Trabajo discrepan acerca de su competencia para conocer en el planteo.</p><p style=\"text-indent:2em\">La Corte dispuso que continúe interviniendo en las actuaciones la justicia federal de primera instancia de la seguridad social. </p><p style=\"text-indent:2em\">Tuvo en cuenta para ello la específica versación que posee dicho fuero, especialmente referida a las cuestiones que conciernen a la aplicación del sistema establecido por la ley 24.241 y sus modificatorias. </p>","esNovedad":true,"fecha":1745982000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1746544322993,"usuarioCreacion":11,"fechaCreacion":1746039875763,"privado":false,"posicion":2,"resumen":{"idResumen":137,"resumen":"La Corte resolvió que la justicia federal de la seguridad social debe intervenir en el caso sobre el incentivo abonado a la actora, por su experiencia en la ley 24.241.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":135878,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34014257,"numeroExpediente":81604,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":5,"codigo":"5","abreviatura":"CSS","descripcion":"Camara Federal de la Seguridad Social","estado":0,"descripcionLarga":"CSS - Camara Federal de la Seguridad Social"},"objetoJuicio":{"id":10638,"descripcion":"PRESTACIONES VARIAS","idMateria":6,"tema":{"id":540,"codigo":"PREV"}},"caratula":"SOUZA AMANDA GRACIELA c/ ENTE 23283 Y23412COOPERADOR LEYES Y OTRO s/PRESTACIONES VARIAS","verificacionMesa":"N","etiqueta":null,"hijos":[