[{"codigo":7799384,"analisisDocumental":{"id":779938,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"CARDONE LORENA DE LOS ANGELES c/ BE ENTERPRISES S.A. s/DESPIDO","alias":null,"caratula":"Recurso Queja Nº 1 - CARDONE LORENA DE LOS ANGELES c/ BE ENTERPRISES S.A. s/DESPIDO","inconstitucional":false,"falloDestacado":{"id":4742,"titulo":"Indemnización de las horas extraordinarias e interpretación del límite a las jornadas laborales","cabecilla":"<p>Un trabajador despedido promovió el reclamo indemnizatorio laboral. La cámara condenó por indemnizaciones y multas derivadas del despido pero rechazó el planteo por horas extraordinarias ya que consideró que, al cumplir la actora una jornada diaria de 7 horas de lunes a viernes y 12 horas los días sábado, no superaba el límite semanal de 48 horas previsto en la ley. La Corte, por unanimidad, <b>dejó sin efecto este pronunciamiento</b>. Expresó que de la normativa nacional aplicable se desprende en forma clara y precisa que <em>existen dos límites de jornada, uno diario y otro semanal, independientes y autónomos entre sí</em> y que en caso de distribución desigual de horas, modalidad en la que se desempeñaba la trabajadora, el límite diario de jornada es de 9 horas y no se encuentra condicionado por el límite semanal. Concluyó que la interpretación de la cámara se había apartado de la solución prevista en la norma y había eliminado en forma tácita el límite diario, con las graves consecuencias que ello podría provocar en la economía y salud de los trabajadores teniendo en cuenta la jornada de 12 horas que la actora cumplía los días sábado.</p>","esNovedad":true,"fecha":1667271600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1667407163754,"usuarioCreacion":4,"fechaCreacion":1667328085896,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":105068,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34914400,"numeroExpediente":7728,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - CARDONE LORENA DE LOS ANGELES c/ BE ENTERPRISES S.A. s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"7728. "},"recurso":{"id":5850720,"expedie