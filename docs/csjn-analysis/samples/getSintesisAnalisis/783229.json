[{"codigo":7832294,"analisisDocumental":{"id":783229,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"REQUERIDO: DE OLIVEIRA, ANTONIO JAVIER  s/EXTRADICION","inconstitucional":false,"falloDestacado":{"id":5584,"titulo":"Procedencia de la extradición ante el rechazo de los agravios de la defensa","cabecilla":"<p>El juzgado federal declaró procedente la extradición requerida por las autoridades de la República Federativa de Brasil  para la ejecución de la pena que le resta cumplir a quien se le impuso una pena por el delito de tráfico trasnacional de estupefacientes. El Defensor General interpuso un recurso extraordinario y la <b>Corte confirmó la sentencia</b>. Recordó que en los casos de extradición el proceso judicial no va enderezado a determinar la inocencia o la culpabilidad de la persona reclamada y que el carácter contencioso del debate que se desarrolla en él es fruto de la contraposición de intereses que subyacen al pugnar el interés del Estado Nacional de dar satisfacción al requerimiento de la potencia reclamante y el del sujeto requerido a que tal solicitud sea rehusada. Señaló que la mera invocación de la situación general del sistema penitenciario en el estado requirente, no alcanzaba a los fines que la defensa reiteraba ya que la consulta de los actuados muestra que ninguna prueba fue solicitada para certificar esa circunstancia personal siquiera indiciariamente. Sumó además la existencia de la expresa garantía ofrecida por las autoridades del país requirente que se comprometió en el pedido a no someter al extraditado a tortura o a otros tratamientos o penas crueles, deshumanos o degradantes. Agregó que resulta ajena a la fase jurisdiccional del procedimiento de extradición la pretensión de la parte de que se resuelva en esta instancia la petición de cumplimentar la pena aplicada en el extranjero en nuestro país, extremo que, a todo evento, debe ser canalizado por la autoridad administrativa competente.</p>","esNovedad":true,"fecha":1687402800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1700076892844,"usuarioCreacion":11,"fechaCreacion":1687524239949,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":108258,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33106514,"numeroExpediente":14394,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descr