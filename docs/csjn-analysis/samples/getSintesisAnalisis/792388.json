[{"codigo":7923884,"analisisDocumental":{"id":792388,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"VELIZ, ROBERTO ARIEL s/ROBO ","inconstitucional":false,"falloDestacado":{"id":6301,"titulo":"Prohibición de la doble persecución penal y aplicación de la doctrina \"Di Mascio\"","cabecilla":"<p> </p><p>   Ante la sentencia que había declarado de oficio la nulidad de la audiencia de debate, de la sentencia condenatoria y había ordenado que se lleve a cabo un nuevo juicio oral y público, la defensa interpuso un recurso de inconstitucionalidad ante el superior tribunal provincial.</p><p>   El tribunal local desestimó la vía por entender que las decisiones que resuelven nulidades no constituyen sentencias definitivas.</p><p><b>   La Corte dejó sin efecto el pronunciamiento apelado.</b> Sostuvo que resultaba aplicable la doctrina de los precedentes \"Strada\" (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=308&amp;pagina=490\">Fallos: 308:490</a>) y \"Di Mascio\" (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=311&amp;pagina=2478\">Fallos: 311:2478</a>) y que la corte provincial había desestimado el recurso local sin hacerse cargo debidamente de lo expuesto por el apelante –con fundamentos suficientes- en cuanto a que la decisión impugnada era equiparable a una sentencia definitiva al afectar de manera irreparable la garantía de <em>ne bis in ídem.</em></p>","esNovedad":true,"fecha":1702522800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1702663290634,"usuarioCreacion":11,"fechaCreacion":1702586881175,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":116536,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35054278,"numeroExpediente":16,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":26,"codigo":"26","abreviatura":"FSM","descripcion":"Justicia Federal de San Martin","estado":0,"descripcionLarga":"FSM - Justicia Federal de San Martin"},"objetoJuicio":{"id":7081,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - IMPUTADO: ARANZASTI, ADRIAN MARIO s/INCIDENTE DE RECURSO EXTRAORDINARIO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"16. "},"recurso":{"id":5893220,"expediente":{"id":35054278,"numeroExpediente":16,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":26,"codigo":"26","abreviatura":"FSM","descripcion":"Justicia Federal de San Martin","estado":0,"descripcionLarga":"FSM - Justicia Federal de San Martin"},"objetoJuicio":{"id":7081,"descripcion