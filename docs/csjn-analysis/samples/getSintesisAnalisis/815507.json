[{"codigo":8155075,"analisisDocumental":{"id":815507,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"K. V. A. c/ P. A. s/RESTITUCION INTERNACIONAL DE MENORES DE EDAD","inconstitucional":false,"falloDestacado":{"id":9421,"titulo":"Restitución internacional de niños: invocación de la condición de refugiados","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal provincial confirmó la sentencia que admitió el pedido de restitución internacional formulado por la progenitora de los niños a la Federación Rusa y el progenitor y el Defensor Público dedujeron recursos extraordinarios. </p><p style=\"text-indent:2em\">El padre solicitó, además, la suspensión del proceso con sustento en la petición de reconocimiento de la condición de refugiado de sus hijos ante la Comisión Nacional para los Refugiados (CONARE) que se encuentra en trámite.</p><p style=\"text-indent:2em\">La Corte entendió que este pedido no resulta atendible y que la sola circunstancia de que los niños cuenten con una solicitud en trámite no condiciona la continuación del trámite propio de estos procesos tendientes a determinar la configuración de un supuesto de traslado internacional ilícito de aquellos por parte de un progenitor y, en su caso, el retorno de los niños a su país de residencia habitual. Señaló que una ponderación armoniosa del régimen de restitución internacional de menores con el régimen aplicable a los refugiados conduce a la necesidad de adoptar, como primera cuestión, una pronta resolución sobre los recursos extraordinarios de modo que se ponga fin al asunto debatido en el juicio, sin perjuicio de que, como segunda cuestión, la condición de refugiado de los niños -de mantenerse vigente- pueda ser nuevamente evaluada en la etapa de ejecución de la sentencia firme que admite el pedido de restitución.</p><p style=\"text-indent:2em\">En cuanto al estudio de los recursos el Tribunal entendió que estos resultaban inadmisibles y los desestimó con invocación del artículo 280 del Código Procesal Civil y Comercial de la Nación.</p><p style=\"text-indent:2em\">Finalmente, exhortó a la Comisión Nacional para los Refugiados (CONARE) a que examine de manera definitiva el mérito de la solicitud de refugio con la mayor celeridad posible y priorizando el interés superior de los niños.</p>","esNovedad":true,"fecha":1758596400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1758803731653,"usuarioCreacion":11,"fechaCreacion":1758652310583,"privado":false,"posicion":-1,"resumen":null},"reciboEntrada":{"id":143878,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"ac