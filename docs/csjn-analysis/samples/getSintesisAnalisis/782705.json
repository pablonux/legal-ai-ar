[{"codigo":7827052,"analisisDocumental":{"id":782705,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"GARCÍA, ÁNGEL ALBERTO Y OTRO c/ MINISTERIO DE TRABAJO EMPLEO Y SEGURIDAD SOCIAL s/ LEY DE ASOC. SINDICALES","alias":null,"caratula":"GARCIA, ANGEL ALBERTO Y OTRO c/ MINISTERIO DE TRABAJO EMPLEO Y SEGURIDAD SOCIAL s/LEY DE ASOC.SINDICALES","inconstitucional":false,"falloDestacado":{"id":5241,"titulo":"Interpretación del estado de acefalía de una asociación sindical de trabajadores","cabecilla":"<p>Frente a un conflicto surgido en el ámbito de la Unión del Personal de Seguridad de la República Argentina, la autoridad administrativa entendió configurada una situación de “acefalía” y, en consecuencia, el titular de la cartera laboral dictó la resolución por la cual designó “delegado normalizador”, con “facultades administrativas y ejecutivas de los órganos de conducción de la entidad”. La resolución fue apelada ante la Cámara Nacional de Apelaciones del Trabajo que rechazó el recurso. Recurrida la cuestión, la Corte, por unanimidad, consideró que las facultades otorgadas al Ministerio de Trabajo por la enumeración del artículo 56, inciso 4, de la ley 23.551 deben interpretarse de modo restrictivo, mediante un escrutinio estricto sobre la configuración de las circunstancias a las que alude la ley. Por ende, al ser ello así, es evidente que el pronunciamiento de la Sala VI de la Cámara Nacional de Apelaciones del Trabajo, en tanto afirmó la validez de la designación del delegado normalizador por entender configurada la situación de acefalía prevista en la ley, no se ajustó al estándar anunciado. A resultas de ello, la Corte en ejercicio de la atribución que le otorga el artículo 16 de la ley 48, hizo lugar al recurso del artículo 62 de la ley 23.551 interpuesto por la citada Unión y declaró la invalidez de la resolución 998/2016 del Ministerio de Trabajo, Empleo y Seguridad Social.</p>","esNovedad":true,"fecha":1680577200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1680700915963,"usuarioCreacion":11,"fechaCreacion":1680631734307,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":107646,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30273907,"numeroExpediente":53147,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9732,"descripcion":"LEY DE ASOC.SINDICALES","idMateria":5,"tema":null},"caratula":"GARCIA, ANGEL ALBERTO Y OTRO c/ MINISTERIO DE TRABAJO EMPLEO Y SEGURIDAD SOCIAL s/LEY DE ASOC.SINDICALES","verificacionM