[{"codigo":8034116,"analisisDocumental":{"id":803411,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - DOMECQ TATIANA AGUSTINA c/ TRENES DE BUENOS AIRES S.A Y OTROS s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","inconstitucional":false,"falloDestacado":{"id":7963,"titulo":"Daños y perjuicios ocasionados a un pasajero de tren: exigencia de acreditar la falta de servicio atribuible al Estado","cabecilla":"<p style=\"text-indent:2em\">A raíz de los daños y perjuicios ocasionados a la actora por una piedra u objeto que ingresó al tren y provocó el estallido de una ventanilla, la cámara atribuyó responsabilidad a la empresa operadora y extendió la condena al Estado Nacional considerando que el transportista sólo podía exonerarse de responsabilidad acreditando que el suceso había ocurrido por caso fortuito, culpa de la víctima o por el hecho de un tercero.</p><p style=\"text-indent:2em\"><b>La Corte revocó esta sentencia</b> con fundamento en que la mera remisión a algunas cláusulas del contrato de gerenciamiento que vinculaba al Estado con la codemandada no resultaba suficiente para condenar al órgano estatal.</p><p style=\"text-indent:2em\">Expresó que se trataba – a todo evento -  de un supuesto de responsabilidad extracontractual y que, a los fines de condenar al Estado Nacional, la sentencia debió examinar si el deber de responder podía ser calificado en la presunta <b>falta de servicio por el cumplimiento irregular de las funciones estatales</b> que le son propias o en su carácter de titular de dominio de un bien destinado al uso y goce de los particulares, o bien, sustentado en la omisión o deficiente ejercicio del poder de policía de seguridad.</p><p style=\"text-indent:2em\">El tribunal debió efectuar el estudio e interpretación del régimen jurídico administrativo de los ferrocarriles y establecer, entre otras circunstancias, la relación entre la actividad o inactividad del Estado y el daño ocasionado, recordando que, para considerar que éste o sus organismos son responsables por \"falta de servicio\", no basta con enumerar genéricamente una serie de actos o conductas, sino que es preciso examinar cada uno de ellos desde el punto de vista de su legitimidad y de su aptitud para constituirse en factor causal del daño cuyo resarcimiento se reclama.</p><p style=\"text-indent:2em\">Al margen de ello, señaló el Tribunal, si bien el vocablo seguridad, incorporado por el art. 42 de la Constitución Nacional, es un valor que debe guiar tanto la conducta de los organizadores de los servicios públicos como la del Estado, ese argumento por sí solo, no es suficiente para condenar a este último, desde que la responsabilidad extracontractual del Estado únicamente puede surgir de la efectiva concurrencia de los recaudos y presupuestos que le dan origen.</p>","esNovedad":true,"fecha":1732590000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1732717946298,"usuarioCreacion":11,"fechaCreacion":1732654528289,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":130022,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30311218,"numeroExpediente":93008124,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":1942,"descripcion":"ACCION MERAMENTE DECLARATIVA DE INCONSTITUCIONALIDAD","idMateria":112,"tema":{"id":1,"codigo":"CYCF"}},"caratula":"Recurso Queja Nº 1 - SANATORIO BRITANICO S.A. c/ ESTADO NACIONAL Y/O AFIP-DGI s/ACCION MERAMENTE DECLARATIVA DE INCONSTITUCIONALIDAD","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"93008124. "},"recurso":{"id":5148647,"expediente":{"id":30311218,"numeroExpediente":93008124,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":1942,"descripcion":"ACCION MERAMENTE DECLARATIVA DE INCONSTITUCIONALIDAD","idMateria":112,"tema":{"id":1,"codigo":"CYCF"}},"caratula":"Recurso Queja Nº 1 - SANATORIO BRITANICO S.A. c/ ESTADO NACIONAL Y/O AFIP-DGI s/ACCION MERAMENTE DECLARATIVA DE INCONSTITUCIONALIDAD","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpedien