[{"codigo":8002613,"analisisDocumental":{"id":800261,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"NATUSUR SA c/ AFIP-DGI s/CONTENCIOSO ADMINISTRATIVO-VARIOS","inconstitucional":false,"falloDestacado":{"id":7441,"titulo":"Requisitos para acceder al beneficio de la condonación de multas","cabecilla":"<p style=\"text-indent:2em\">La cámara rechazó el pedido de condonación de la multa discutida efectuado por la actora con fundamento en lo dispuesto por el art. 12, cuarto párrafo, de la ley 27.541. Sostuvo que, para acceder a ese beneficio, deben cumplirse los requisitos establecidos en el art. 9° de la misma ley, esto es, el desistimiento de la acción y del derecho por parte del contribuyente, así como la asunción de las costas y gastos causídicos, debiendo presentar también el formulario 408 (nuevo modelo). </p><p style=\"text-indent:2em\">La Corte revocó este pronunciamiento.</p><p style=\"text-indent:2em\">Sostuvo que la lectura de ambos preceptos mencionados permite concluir que los referidos requisitos se exigen respecto de las obligaciones vencidas al 31 de julio de 2020 (art. 9° y concordantes) pero que distinto es el supuesto regulado en el art. 12, que no se ocupa de la “regularización” de obligaciones vencidas, sino de la “condonación” de multas formales, materiales y de intereses resarcitorios.</p><p style=\"text-indent:2em\">La procedencia de la condonación prevista en el art. 12, cuarto párrafo, de la ley 27.541, entonces, no requiere de desistimiento por parte del contribuyente, ni tampoco de la asunción, por el responsable, del pago de las costas y gastos causídicos del proceso judicial en el que se impugna la infracción sustancial. Como lógica derivación de lo expuesto, tampoco puede requerirse la presentación del formulario de declaración jurada 408 (nuevo modelo).</p>","esNovedad":true,"fecha":1724727600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1724871203128,"usuarioCreacion":4,"fechaCreacion":1724848440369,"privado":false,"posicion":8,"resumen":null},"reciboEntrada":{"id":126058,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32349103,"numeroExpediente":58861,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contenc