[{"codigo":7921143,"analisisDocumental":{"id":792114,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"L., M. E. c/ PAMI (INSSJYP) s/ amparo ley 16.986.","alias":null,"caratula":"Recurso Queja Nº 2 - LAMAS, MARGARITA EUSEBIA c/ PAMI (INSSJYP) s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":6481,"titulo":"Las costas en la acción de amparo","cabecilla":"<p style=\"text-indent:2em\">La cámara confirmó el amparo en la que se reclamaban prestaciones médicas y modificó la decisión solo en lo atinente a la imposición de las costas, las que distribuyó por su orden en ambas instancias. </p><p style=\"text-indent:2em\">La demandada interpuso un recurso extraordinario invocando la afectación de sus derechos de propiedad y debido proceso.</p><p style=\"text-indent:2em\"><b>La Corte dejó sin efecto el pronunciamiento apelado que había impuesto las costas por su orden</b>. Consideró que el tribunal no tuvo en cuenta que el artículo 68 del Código Civil y Comercial de la Nación que citó resultaba inaplicable a este asunto, pues tratándose de un proceso de amparo las costas debían ser impuestas según lo normado en el artículo 14 de la ley 16.986 que establece la imposición de las costas a la parte vencida con la sola excepción de que, con anterioridad a la contestación del informe previsto en el artículo 8° de esa ley, se produzca el cese del acto u omisión en que se fundó el amparo, supuesto que no había ocurrido en las actuaciones.</p><p style=\"text-indent:2em\">Agregó que <em>la cámara no proporcionó una razón válida para justificar su apartamiento de la norma referida y que modificó la imposición de las costas sin que esa decisión atendiera al resultado del pleito</em> y utilizando como argumento decisivo el hecho de que la actora fue representada por la defensoría oficial, circunstancia que, además de no estar contemplada en la normativa aplicable al caso, carece de relevancia a los fines de la distribución de los gastos causídicos.</p>","esNovedad":true,"fecha":1709175600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1709308650887,"usuarioCreacion":4,"fechaCreacion":1709236074914,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":116393,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35095221,"numeroExpediente":28628,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 2 - CASSANI CAMARA OMAR DANIEL c/ SAPHIR JOSE HERMINIO Y O