[{"codigo":7916644,"analisisDocumental":{"id":791664,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - PEREZ CONDORI , TEODORA c/ PROVINCIA ASEGURADORA DE RIESGOS DEL TRABAJO SA Y OTRO s/INDEMNIZACION ART. 212","inconstitucional":false,"falloDestacado":{"id":6241,"titulo":"Exigencia de debida fundamentación en la reparación de daños padecidos con motivo de fallecimiento","cabecilla":"<p>La cámara hizo lugar a la demanda que entabló la actora con fundamento en el derecho civil para obtener la reparación integral de los daños padecidos con motivo del fallecimiento de su cónyuge, el que atribuyó a las insuficientes condiciones de salubridad del ambiente en el que desarrollaba su actividad de costurero. La Corte, por mayoría, revocó lo decidido con fundamento en la doctrina de la arbitrariedad. Consideró que las conclusiones del peritaje médico no otorgaban suficiente grado de certeza como para atribuir al ambiente laboral el carácter de causa determinante de la enfermedad multisistémica que llevó al operario a su deceso, máxime cuando no se había demostrado acabadamente que el ambiente de trabajo estuviere afectado por elementos químicos y careciese de ventilación y que realmente el trabajador, en su desempeño cotidiano, se encontrara expuesto a agentes tóxicos o nocivos. Concluyó así que las constancias obrantes en la causa no permitían establecer el eventual <em>nexo de causalidad entre el factor laboral y la enfermedad</em> que había afectado al trabajador, extremo que impedía atribuir a la empleadora y a la aseguradora responsabilidad civil por su muerte.</p>","esNovedad":true,"fecha":1701918000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1701976032357,"usuarioCreacion":11,"fechaCreacion":1701971358391,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":116147,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32505363,"numeroExpediente":52428,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9709,"descripcion":"INDEMNIZACION ART. 212","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - PEREZ CONDORI , TEODORA c/ MONTAGNE OUTDOORS SA Y OTRO s/INDEMNIZACION ART. 212","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":32517558,"numeroExpediente":52428,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcion