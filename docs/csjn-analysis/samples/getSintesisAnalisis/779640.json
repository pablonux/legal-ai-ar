 de Aduanas, la Corte confirmó la sentencia apelada. Para decidir de este modo, consideró que la conducta endilgada a la empresa actora resulta susceptible de ser condonada de acuerdo a lo normado por el <b>art. 55 de la ley 27.260</b>, en la medida en que la sanción reprochada no se encontraba firme a la fecha del acogimiento al régimen de regularización.</p>","esNovedad":true,"fecha":1667271600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1667325731417,"usuarioCreacion":11,"fechaCreacion":1667325689110,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":104897,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32150953,"numeroExpediente":49539,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2,"tema":null},"caratula":"YPF SA c/ ADMINISTRACION NACIONAL DE ADUANAS s/RECURSO DIRECTO DE ORGANISMO EXTERNO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"49539. "},"recurso":{"id":5508894,"expediente":{"id":32150953,"numeroExpediente":49539,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2