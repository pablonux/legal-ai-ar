[{"codigo":8086486,"analisisDocumental":{"id":808648,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"KIA ARGENTINA S.A. c/ DIRECCION GENERAL DE RENTAS DE LA PROVINCIA DE MISIONES s/DEMANDA CONTENCIOSO ADMINISTRATIVA","inconstitucional":false,"falloDestacado":{"id":8781,"titulo":"Impuesto de sellos: alcance e interpretación del principio de instrumentalidad","cabecilla":"<p style=\"text-indent:2em\">Un fabricante de autos promovió demanda contencioso administrativa contra la resolución de la Dirección General de Rentas de la Provincia de Misiones, que determinó el impuesto de sellos sobre diversas operaciones contractuales. En tal sentido, solicitó que se declare la inconstitucionalidad del último párrafo del artículo 174 del Código Fiscal de la Provincia de Misiones que grava con el impuesto de sellos a los contratos entre ausentes con cláusulas de aceptación ficta con fundamento en que dicha norma transgrede el compromiso de respetar el principio de instrumentalidad asumido por dicha provincia al  adherir a la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-23548-21108/actualizacion\">ley 23.548</a> de coparticipación federal de impuestos.</p><p style=\"text-indent:2em\">Ante el rechazo de la demanda por el Superior Tribunal de Justicia de Misiones se interpuso recurso extraordinario que rechazado dio lugar a la queja.</p><p style=\"text-indent:2em\">La Corte declaró procedente el recurso y revocó la sentencia apelada pues consideró que resulta descalificable en los términos de la doctrina sobre arbitrariedad de sentencias, pues ha convalidado la constitucionalidad de una norma local con un razonamiento que presenta groseras deficiencias lógicas del razonamiento y una total ausencia de fundamento normativo.</p><p style=\"text-indent:2em\">Para decidir de ese modo, consideró que la decisión impugnada se fundó en una norma local -el art. 174 del Código Fiscal de la provincia-, que se halla en contravención a lo dispuesto por el art. 9°, inc. b), de la ley 23.548, en cuanto exige que el “instrumento” gravado revista los caracteres de un título jurídico, con el que se pueda exigir el cumplimiento de las obligaciones, “sin necesidad de otro documento y con prescindencia de los actos que efectivamente realicen los contribuyentes”.</p>","esNovedad":true,"fecha":1748487600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1748629076549,"usuarioCreacion":11,"fechaCreacion":1748614018390,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":136879,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34925982,"numeroExpediente":806,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"cam