[{"codigo":7750634,"analisisDocumental":{"id":775063,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"GAUNA, WALTER GUSTAVO Y OTRO s/EXTRADICION","alias":null,"caratula":"REQUERIDO: GAUNA, WALTER GUSTAVO Y OTRO s/EXTRADICION","inconstitucional":false,"falloDestacado":{"id":4304,"titulo":"Extradición: inadmisibilidad de agravios ya debidamente considerados en otra instancia. ","cabecilla":"<p>Contra la sentencia de primera instancia que concedió la extradición a la República del Paraguay la defensa del requerido interpuso recurso de apelación ante la <b>Corte, quien confirmó, por unanimidad, dicha decisión</b>. Consideró para ello que la mayoría de los agravios en que se sustentaba la apelación constituían mera reiteración de los que ya habían sido ventilados y debidamente considerados por la jueza de la causa de forma ajustada a derecho y al tratado que rige la entrega. Recordó el Tribunal que no compete en este procedimiento la revisión de los aspectos probatorios valorados por el juez extranjero que habrían justificado la orden de detención que dio sustento al posterior pedido de extradición, ni tampoco la validez de la prueba incorporada al proceso extranjero y/o de los actos procesales allí celebrados, cuestión que debe ventilarse en la causa que se le sigue al requerido en el país requirente. También consideró inadmisible el agravio fundado en las condiciones de detención a las que quedaría expuesto el requerido en el país requirente al tener en cuenta que el temor esgrimido en ese sentido solo aparecía derivado de una situación general que no presentaba en el caso un riesgo \"cierto\" y \"actual\" que obstara a su extradición.</p>","esNovedad":true,"fecha":1660273200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1660671228314,"usuarioCreacion":4,"fechaCreacion":1660330567583,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":33988,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30997515,"numeroExpediente":12038,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":21,"codigo":"21","abreviatura":"FPO","descripcion":"Justicia Federal de Posadas","estado":0,"descripcionLarga":"FPO - Justicia Federal de Posadas"},"objetoJuicio":{"id":2401,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"REQUERIDO: GAUNA, WALTER GUSTAVO Y OTRO s/EXTRADICION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"12038. "},"recurso":{"id":5284920,"expediente":{"id":30997515,"numeroExpediente":12038,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":21,"codigo":"21","abreviatura":"FPO","descripcion":"Justicia Federal de Posadas","e