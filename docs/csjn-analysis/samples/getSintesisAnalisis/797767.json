[{"codigo":7977675,"analisisDocumental":{"id":797767,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - Incidente Nº 1 - ACTOR: BRONWAY TECHNOLOGY SA DEMANDADO: AFIP s/INC APELACION","inconstitucional":false,"falloDestacado":{"id":6961,"titulo":"Impuesto interno a los tabacos: contradicción que torna descalificable el fallo","cabecilla":"<p style=\"text-indent:2em\">La cámara confirmó el rechazo de la medida cautelar pero se apartó de lo resuelto en lo referido al pedido de suspensión de la versión 5 del programa aplicativo denominado “Impuesto interno y adicional de emergencia a los cigarrillos” -implementado por la resolución general (AFIP) 5290/2022- respecto de lo cual hizo lugar a la apelación deducida. Autorizó entonces a la actora a declarar el impuesto interno a los tabacos (IIT) conforme los arts. 13 y 14 de la ley 24.674 y 11 de la ley 11.683 por un plazo de tres meses.</p><p style=\"text-indent:2em\">La Corte revocó esta decisión.</p><p style=\"text-indent:2em\">Señaló que resultaba ostensible la inconsistencia en la que incurrió la sentencia al rechazar la apelación contra la denegatoria de la medida cautelar y, al mismo tiempo, hacer lugar a la suspensión mencionada pues, paradójicamente, permite que en la práctica se determine e ingrese el impuesto interno al tabaco sin aplicar el monto mínimo establecido en el artículo 15, segundo párrafo, de la ley 24.674 de impuestos internos.</p><p style=\"text-indent:2em\">Recordó que la sentencia debe ser una unidad lógico jurídica, cuya validez depende de que constituya un todo indivisible en el que la parte dispositiva no es sino la conclusión final y necesaria del análisis de los presupuestos fácticos y normativos efectuado en su fundamentación y que este criterio no autoriza a admitir antagonismos entre ambas partes del pronunciamiento, sino que, por el contrario, exige que ineludiblemente lo vertido en la primera aparezca como una razonable derivación de las argumentaciones que lo sustentan.</p>","esNovedad":true,"fecha":1717470000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1717604938694,"usuarioCreacion":11,"fechaCreacion":1717528519346,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":121920,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37602929,"numeroExpediente":14978,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviat