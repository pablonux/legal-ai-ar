[{"codigo":8134013,"analisisDocumental":{"id":813401,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":41,"codigoRelacion":80041,"valor":"DECLARA INEXISTENCIA","activo":"S","usuarioCreacion":"JURJ3F","usuarioMod":"JURJ3F","fechaCreacionLong":202509111053,"fechaModLong":202509111053,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - LI, RUHAI c/ DIRECCION NACIONAL DE MIGRACIONES s/CONTENCIOSO ADMINISTRATIVO-VARIOS","inconstitucional":false,"falloDestacado":{"id":9282,"titulo":"Inexistencia como pronunciamiento judicial del auto denegatorio del recurso extraordinario","cabecilla":"<p style=\"text-indent:2em\">Ante la decisión que declaró irregular su permanencia en el país y ordenó su expulsión un migrante interpuso un recurso judicial que fue rechazado en primera y segunda instancia.</p><p style=\"text-indent:2em\">El actor dedujo un recurso extraordinario que, sin ser sustanciado, fue declarado extemporáneo por uno de los vocales de la cámara. </p><p style=\"text-indent:2em\">La Corte declaró la inexistencia como pronunciamiento judicial de dicho auto.</p><p style=\"text-indent:2em\">Recordó en primer lugar que la adecuada notificación de las distintas etapas fundamentales del proceso, particularmente el traslado del recurso extraordinario federal que dispone el art. 257, segundo párrafo, del Código Procesal Civil y Comercial de la Nación, tiene por objeto proporcionar a los litigantes la oportunidad de ejercer sus defensas con la amplitud que exige el debido proceso y señaló que el rechazo del intentado por la actora se había dispuesto sin haberse dado cumplimento en forma previa al traslado que determina la norma citada.</p><p style=\"text-indent:2em\">Sin perjuicio de ello, el Tribunal también advirtió que la providencia que tuvo por extemporáneo el recurso extraordinario había sido firmada solo por un vocal de la sala de la cámara. En tanto se trata de un tribunal colegiado y la decisión importa una denegación implícita del remedio federal expresó que no correspondía entonces considerar a dicha resolución como pronunciamiento válido del tribunal de la causa en punto a la concesión o denegatoria del recurso extraordinario.</p>","esNovedad":true,"fecha":1756177200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1756489484867,"usuarioCreacion":11,"fechaCreacion":1756238163734,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":142020,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33340792,"numeroExpediente":265,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":2001,"descripcion":"CONTENCIOSO ADMINISTRATIVO-VARIOS","idMateria":112,"tema":{"id":6,"codigo":"CONTADM"}},"caratula":"Recurso Queja Nº 1 - LI, 