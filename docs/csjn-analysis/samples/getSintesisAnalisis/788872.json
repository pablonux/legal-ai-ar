[{"codigo":7888723,"analisisDocumental":{"id":788872,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ALVAREZ ARMANDO DAVID c/ EN-M° RREECI Y C-CANCILLERIA-RESOL 1702/05 s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":6021,"titulo":"Condena a reintegrar erogaciones efectuadas en dólares: valores reales al momento del pago","cabecilla":"<p>El Estado Nacional fue condenado a abonar una suma en dólares en concepto de reintegro por los gastos médicos realizados por el recurrente encontrándose en el extranjero prestando servicios diplomáticos. La cámara ordenó que la liquidación del crédito debía efectuarse “convirtiendo las sumas en dólares a pesos según el valor del dólar al tiempo en que ‘cada gasto fue efectuado’, con más los intereses calculados a la tasa pasiva aludida desde que esas erogaciones fueron efectuadas y hasta su efectivo pago”. Contra ello, el actor interpuso recurso extraordinario. <b>La Corte dejó sin efecto la decisión apelada.</b> Consideró que lo resuelto no se condecía con lo decidido en el pronunciamiento que se pretendía ejecutar (que había establecido un monto total y en dólares) pues sujetaba el cálculo del crédito a un tipo de cambio histórico prescindiendo, de ese modo, de los valores reales al momento del pago.</p>","esNovedad":true,"fecha":1697684400000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1697747197520,"usuarioCreacion":11,"fechaCreacion":1697743223031,"privado":false,"posicion":0,"resumen":null},"reciboEntrada":{"id":114271,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":10850480,"numeroExpediente":21819,"anioExpediente":2006,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"ALVAREZ ARMANDO DAVID c/ EN-M° RREECI Y C-CANCILLERIA-RESOL 1702/05 s/PROCESO DE CONOCIMIENTO","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"21819. "},"recurso":{"id":5952049,"expediente":{"id":10850480,"numeroExpediente":21819,"anioExpediente":2006,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuic