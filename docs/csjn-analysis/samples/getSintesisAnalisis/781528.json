[{"codigo":7815283,"analisisDocumental":{"id":781528,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":40,"codigoRelacion":80040,"valor":"PROCEDIMIENTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201512101503,"fechaModLong":201512101503,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"GOBIERNO DE LA CIUDAD DE BUENOS AIRES c/ ESTADO NACIONAL s/ ACCIÓN DECLARATIVA DE INCONSTITUCIONALIDAD - COBRO DE PESOS","alias":null,"caratula":"GOBIERNO DE LA CIUDAD DE BUENOS AIRES c/ ESTADO NACIONAL s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD - COBRO DE PESOS (EXPEDIENTE DIGITAL)","inconstitucional":false,"falloDestacado":{"id":4901,"titulo":"Transferencia de funciones de seguridad de la Nación a CABA y coparticipación federal","cabecilla":"<p>La Corte hizo lugar parcialmente a la medida cautelar formulada por el Gobierno de la Ciudad de la Ciudad de Buenos Aires y ordenó que durante la tramitación del proceso el Estado Nacional le entregue el 2,95% de la masa de fondos definida en el artículo 2° de la ley 23.548 y que, durante la tramitación del proceso, se abstenga de aplicar la ley 27.606. Dicha decisión fue tomada en el marco de una demanda promovida por el Gobierno de la Ciudad Autónoma de Buenos Aires contra el Estado Nacional, que tramita ante la instancia originaria del Tribunal y con el objeto de que se declare la inconstitucionalidad de esta última norma, de transferencia de funciones de seguridad de la Nación a la Ciudad Autónoma en materias no federales. La Corte expresó que hasta el presente no pudo llegarse a un consenso entre las jurisdicciones involucradas y que se encuentran pendientes de producción distintos medios de prueba ofrecidos. Aclaró que lo discutido no afecta la coparticipación de las provincias, sea cual fuere el resultado del pleito.  </p>","esNovedad":true,"fecha":1671591600000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1671730443322,"usuarioCreacion":11,"fechaCreacion":1671643620290,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":105997,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35229344,"numeroExpediente":1865,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10564,"descripcion":"ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","idMateria":0,"tema":null},"caratula":"GOBIERNO DE LA CIUDAD DE BUENOS AIRES c/ ESTADO NACIONAL s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD - COBRO DE PESOS (EXPEDIENTE DIGITAL)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1865. "},"recurso":{"id":5955220,"expediente":{"id":35229344,"numeroExpediente":1865,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10564,"descripcion":"ACCION DECLARATIVA DE INCONS