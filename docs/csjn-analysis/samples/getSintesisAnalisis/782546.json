[{"codigo":7825465,"analisisDocumental":{"id":782546,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"MOLINA, ALDO ANDRES s/ RECURSO DE QUEJA","alias":null,"caratula":"MOLINA, ALDO ANDRES s/RECURSO DE QUEJA - CAUSA N 84547","inconstitucional":false,"falloDestacado":{"id":5161,"titulo":"Defensa en juicio y debida notificación de la sentencia al condenado","cabecilla":"<p>Luego del rechazo de otros recursos en las anteriores instancias la defensa de un condenado interpuso recurso extraordinario. La Corte aclaró que dicho recurso es improcedente cuando se pretende revisar las decisiones de los tribunales de la causa en materia de admisibilidad de los recursos por tratarse de un aspecto procesal, pero consideró que en el caso se presentaba una excepción ya que se podría privar definitivamente al imputado del derecho a la revisión de la condena. Expresó que se había rechazado el recurso por considerarlo extemporáneo al considerar que el condenado había quedado notificado del fallo a partir del acto de su lectura a pesar de que no había constancia de que haya estado presente en ese momento. <b>El Tribunal dejó sin efecto la sentencia apelada </b>y señaló que ante la existencia de la única <b>constancia fehaciente de notificación del cómputo de la pena en el lugar de detención</b> y la manifestación de voluntad del condenado en el sentido de que se apartara a su abogado de confianza por no haber recurrido la condena, el superior tribunal provincial no podía omitir, sin incurrir en arbitrariedad, un pronunciamiento sobre el agravio introducido.</p>","esNovedad":true,"fecha":1678762800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1678880166775,"usuarioCreacion":11,"fechaCreacion":1678823679711,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":107582,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34816721,"numeroExpediente":408,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MOLINA, ALDO ANDRES s/RECURSO DE QUEJA - CAUSA N 84547","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"408. "},"recurso":{"id":5830447,"expediente":{"id":34816721,"numeroExpediente":408,"anioExpediente":2020,"tomoExpediente":