[{"codigo":8237375,"analisisDocumental":{"id":823737,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 2 - PILARBUS SA Y OTROS c/ EN-M TRANSPORTE DE LA NACION-RESOL 270/08 s/INC APELACION","inconstitucional":false,"falloDestacado":{"id":10341,"titulo":"Distribución de las compensaciones tarifarias - Ejercicio de potestades propias de una autoridad nacional","cabecilla":"<p style=\"text-indent:2em\">Un grupo de empresas prestadoras del servicio público de transporte de pasajeros por automotor promovió una acción declarativa de certeza contra el Estado Nacional a fin de que se declare que su estructura de costos se encuentra desactualizada y no refleja el valor real de los ítems que la componen desde el año 2016 y reclamaron el dictado de una medida cautelar de no innovar que impida al demandado modificar los criterios de distribución de compensaciones previstos en una resolución del año 2018 del Ministerio de Transporte. La cámara hizo lugar a esta medida.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia.</p><p style=\"text-indent:2em\">Consideró que, si bien se trataba de una resolución referida a una medida precautoria, frustraba la aplicación de disposiciones de carácter general dictadas por los organismos estatales con incumbencia específica en la materia, por lo que se configuraba un factor de perturbación y retardo en el desarrollo de una política económica.</p><p style=\"text-indent:2em\">Señaló que la actora no logró acreditar el peligro irreparable en la demora que insinuó, no aportó los cálculos necesarios para verificar la entidad concreta del perjuicio grave que podría derivar de la -en ese entonces eventual- modificación del criterio de distribución de las compensaciones y ni siquiera explicó cómo podría repercutir en la ecuación económico financiera de cada una de las empresas en función de los costos de la operatoria a su cargo.</p><p style=\"text-indent:2em\">El Tribunal expresó que la demandante no había demostrado –mediante una referencia precisa y fundamentada– que la modificación o el remplazo del régimen vigente al momento de la interposición de la demanda tornara imposible o improbable la continuación de sus actividades en el futuro, en la forma como lo había hecho hasta ahora, hasta obtener una sentencia final favorable a su derecho.</p><p style=\"text-indent:2em\">Concluyó así que los fundamentos expresados por la cámara para tener por acreditado el peligro irreparable en la demora resultaban dogmáticos e insuficientes para admitir la procedencia de la medida cautelar.</p><p style=\"text-indent:2em\">Finalmente, señaló que los jueces habían sustituido al Ministerio de Transporte en la determinación de las compensaciones tarifarias del servicio público del transporte automotor de pasajeros bajo jurisdicción nacional y que ello aparecía como un exceso de jurisdicción.</p>","esNovedad":true,"fecha":1772679600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1773145571783,"usuarioCreacion":11,"fechaCreacion":1772736872848,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":153119,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36823103,"numeroExpediente":20065,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 1 - Incidente Nº 2 - PILARBUS SA Y OTROS c/ EN-M TRANSPORTE DE LA NACION-RESOL 270/08 s/INC APELACION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"20065. "},"recurso":{"id":6363193,"expediente":{"id":36823103,"numeroExpediente":20065,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 1 - Incid