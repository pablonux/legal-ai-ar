[{"codigo":8239664,"analisisDocumental":{"id":823966,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 9 - AGENCIA DE ADMINISTRACION DE BIENES DEL ESTADO c/ OCUPANTES Y/O INTRUSOS INMUEBLE CAMINO DE CINTURA Y AUTOPISTA TENIENTE GENERAL PABLO RICHIERI CIUDAD, EVITA LA MATANZA PARCELAS 948, 949A Y 949B  s/LANZAMIENTO LEY 17.091","inconstitucional":false,"falloDestacado":{"id":10487,"titulo":"Lanzamiento de ocupantes de predios en litigio: necesidad de considerar la inclusión de los inmuebles en un ordenamiento especial","cabecilla":"<p style=\"text-indent:2em\">La cámara hizo lugar a la demanda promovida por la Agencia de Administración de Bienes del Estado (AABE) con el objeto de obtener el lanzamiento de los ocupantes de un inmueble ubicado en la Provincia de Buenos Aires. Dispuso la suspensión de aquél por el plazo de noventa (90) días y ordenó que la jueza de la causa ponga en conocimiento de las autoridades competentes la situación de los niños que pudieran verse afectados.</p><p style=\"text-indent:2em\">La Defensora Oficial interpuso un recurso extraordinario y la Corte revocó esta decisión.</p><p style=\"text-indent:2em\">Consideró que, al fundamentar su decisión en lo dispuesto por la ley <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-17091-194855/texto\">17.091</a>, la cámara prescindió de considerar la inclusión de los inmuebles reclamados en el Régimen de Regularización Dominial para la Integración Socio Urbana (ley <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-27453-315739/actualizacion\">27.453</a>) que suspende los desalojos. </p><p style=\"text-indent:2em\">Agregó también el Tribunal que se había omitido verificar si el predio a desalojar integraba el domino público del Estado Nacional, esto es, si estaba consagrado en forma “real y efectiva al uso público o servicio público” y añadió que tal ponderación resultaba indispensable, pues esa condición constituye uno de los presupuestos de viabilidad de la acción habilitada por la ley 17.091.</p>","esNovedad":true,"fecha":1774926000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1775040905412,"usuarioCreacion":4,"fechaCreacion":1774991168629,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":153458,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28045840,"numeroExpediente":3756,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpedi