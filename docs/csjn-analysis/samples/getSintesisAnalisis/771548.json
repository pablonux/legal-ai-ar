[{"codigo":7715483,"analisisDocumental":{"id":771548,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"SANTIAGO EDUARDO s/ INCIDENTE DE INCOMPETENCIA","alias":null,"caratula":"Incidente Nº 1 -  NN: SANTIAGO EDUARDO s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":5183,"titulo":"Defraudación y lugar donde se cometieron actos con relevancia típica","cabecilla":"<p>A raíz de la denuncia realizada por una persona que había solicitado un vehículo mediante la aplicación “Uber” para que transportara desde la Ciudad de  Buenos Aires hacia Avellaneda cierta mercancía, se originó un conflicto negativo de competencia entre un juzgado nacional en lo criminal y correccional de la ciudad y el juzgado de garantías de la localidad bonaerense mencionada. Llegadas las actuaciones a la Corte, ésta recordó que las cuestiones de  competencia en materia penal deben resolverse atendiendo a razones de economía procesal y teniendo en cuenta los distintos lugares donde se desarrollaron actos con relevancia típica. En ese entendimiento, resolvió que debía seguir interviniendo en la causa la justicia nacional en lo criminal y correccional de la Ciudad de Buenos Aires. Ello toda vez que era allí donde se había contratado y pagado el servicio de mensajería y donde se había entregado la mercadería que no llegó a destino; y además pertenecía a esa jurisdicción el juez que previno y que se encontraba en mejores condiciones para desarrollar la investigación.</p>","esNovedad":true,"fecha":1679367600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1679501644068,"usuarioCreacion":11,"fechaCreacion":1679431347313,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":32778,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33037542,"numeroExpediente":17005,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXPEDIENTES PENALES","idMateria":9,"tema":null},"caratula":"Incidente Nº 1 - DENUNCIANTE: FINKELSTEIN, ABRAHAM SILVIO NN: N.N. s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"17005. "},"recurso":{"id":5534857,"expediente":{"id":33037542,"numeroExpediente":17005,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXPEDIENTES PENALES","idMateria":9,"tema":null},"caratula":"Incidente Nº 1 - DENUNCIANTE: FINKELSTEIN, ABRAHAM SILVI