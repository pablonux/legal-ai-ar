[{"codigo":7717422,"analisisDocumental":{"id":771742,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"PERALTA CRISPIN ANTONIO c/ ESTADO NACIONAL - MINISTERIO DEL INTERIOR s/RECURSO DIRECTO","alias":null,"caratula":"PERALTA CRISPIN ANTONIO c/ EN-M§ INTERIOR-DNM-RESOL 111/12(EX 814477/06 80160/09) s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":3321,"titulo":"Tráfico de estupefacientes y permanencia de extranjeros en el país","cabecilla":"<p>La Direcci&oacute;n Nacional de Migraciones declar&oacute; irregular la permanencia de un extranjero en el pa&iacute;s, orden&oacute; su expulsi&oacute;n del territorio nacional y prohibi&oacute; su reingreso con car&aacute;cter permanente. Ante el rechazo del recurso judicial directo por la c&aacute;mara el migrante interpuso un recurso extraordinario cuestionando entre otros argumentos la interpretaci&oacute;n de la ley realizada. La Corte&nbsp;<strong>declar&oacute; admisible el recurso extraordinario y confirm&oacute; la sentencia apelada</strong>.&nbsp;Consider&oacute; que&nbsp;para la soluci&oacute;n de la controversia resultaba menester determinar si se configuraba la causal de impedimento para permanecer en el pa&iacute;s y para ello resultaba necesario dilucidar si el delito en el que se fund&oacute; la condena del recurrente, contrabando calificado de estupefacientes, en grado de tentativa y participaci&oacute;n secundaria, deb&iacute;a considerarse equivalente, a los fines migratorios, al de tr&aacute;fico de estupefacientes previsto en la norma que rige el caso. Record&oacute; el Tribunal que&nbsp;el tr&aacute;fico de estupefacientes representa una grave amenaza para la salud y el bienestar de los seres humanos, y menoscaba las bases econ&oacute;micas, culturales y pol&iacute;ticas de la sociedad, adem&aacute;s de involucrar compromisos internacionales asumidos por el Estado en materia de represi&oacute;n del narcotr&aacute;fico. Por ello concluy&oacute; que era&nbsp; razonable sostener una interpretaci&oacute;n del art&iacute;culo 29, inciso c, de la ley 25.871 seg&uacute;n la cual se configura la causal de impedimento para permanecer en el pa&iacute;s por la existencia de una condena por tr&aacute;fico de estupefacientes, m&aacute;s all&aacute; del monto de la pena, si el delito se refiere a uno de los eslabones de esa actividad, tomando como referencia para su definici&oacute;n a la Convenci&oacute;n de las Naciones Unidas contra el Tr&aacute;fico Il&iacute;cito de Estupefacientes y Sustancias Sicotr&oacute;picas de 1988.</p>","esNovedad":true,"fecha":1639623600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1640001188459,"usuarioCreacion":11,"fechaCreacion":1639742361880,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":32845,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":2500