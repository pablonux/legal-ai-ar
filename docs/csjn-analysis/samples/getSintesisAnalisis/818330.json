[{"codigo":8183303,"analisisDocumental":{"id":818330,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"NUÑEZ, VICTOR EDGARDO c/ SPINAZZE, ELIO Y OTRO s/EJECUCIÓN PRENDARIA","inconstitucional":false,"falloDestacado":{"id":9684,"titulo":"Plazo perentorio del recurso extraordinario: no se interrumpe ni suspende por una aclaratoria desestimada","cabecilla":"<p style=\"text-indent: 2em;\">El superior tribunal provincial confirmó la decisión que había hecho lugar a la excepción de pago opuesta por los ejecutados y, por ende, había rechazado la ejecución prendaria. El abogado apoderado del actor dedujo un recurso de aclaratoria en el entendimiento de que el tribunal no se había expedido en relación a sus honorarios. Después del rechazo del pedido de aclaratoria el ejecutante interpuso el recurso extraordinario federal en el cual se agravia de la cuestión de fondo y afirmó que el plazo para interponerlo había sido interrumpido por la interposición de un recurso de aclaratoria.</p><p style=\"text-indent: 2em;\">La Corte desestimó el recurso de queja intentado al considerar que el <b>recurso extraordinario deducido por el ejecutante resultaba extemporáneo</b>.</p><p style=\"text-indent: 2em;\">Recordó que el término para interponer el recurso extraordinario federal es perentorio y no se interrumpe ni suspende por una aclaratoria desestimada, que no altera la resolución impugnada por esa vía.</p><p style=\"text-indent: 2em;\">El Tribunal señaló que no había existido ningún pedido de aclaratoria contra lo decidido en cuanto al tema de fondo y que no podía obstar a dicha conclusión el recurso de aclaratoria rechazado al que aludía el recurrente, pues además de estar vinculado con una cuestión accesoria –honorarios–, había sido deducido por el letrado apoderado en su exclusivo interés.</p>","esNovedad":true,"fecha":1762225200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1762296835280,"usuarioCreacion":4,"fechaCreacion":1762296829534,"privado":false,"posicion":8,"resumen":null},"reciboEntrada":{"id":146840,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37282668,"numeroExpediente":3897,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":9481,"descripcion":"ORDINARIO","idMateria":4,"tema":{"id":501,"codigo":"JUIORD"}},"caratula":"Recurso Queja Nº 1 - ACCESO NORTE S.R.L. c/ PAMPA ENERGIA S.A. Y OTROS s/ORDINARIO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"3897