[{"codigo":7701705,"analisisDocumental":{"id":770170,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"ETCHEVERRY, JUAN BAUTISTA Y OTROS c/ ESTADO NACIONAL s/AMPARO LEY 16.986","alias":null,"caratula":"Recurso Queja Nº 1 - ETCHEVERRY, JUAN BAUTISTA Y OTROS c/ EN s/AMPARO LEY 16.986","inconstitucional":true,"falloDestacado":{"id":2881,"titulo":"Omisión del Poder Ejecutivo de reglamentar el artículo 179 de la Ley de Contrato de Trabajo","cabecilla":"<p>La C&aacute;mara Nacional de Apelaciones en lo Contencioso Administrativo Federal conden&oacute; al Poder Ejecutivo Nacional a reglamentar, en el plazo de noventa d&iacute;as h&aacute;biles, el art&iacute;culo 179 de la Ley de Contrato de Trabajo que dispone que en los establecimientos donde preste servicios el n&uacute;mero m&iacute;nimo de trabajadoras que determine la reglamentaci&oacute;n, el empleador deber&aacute; habilitar salas maternales y guarder&iacute;as para ni&ntilde;os hasta la edad y en las condiciones que oportunamente se establezcan. Contra dicho pronunciamiento, el Estado Nacional interpuso recurso extraordinario que, denegado, dio origen a la queja. La Corte declar&oacute;&nbsp; admisible el recurso extraordinario y confirm&oacute; la sentencia apelada. En su decisi&oacute;n, consider&oacute; que frente a la injustificable omisi&oacute;n de reglamentar una ley que expresamente impone el deber de hacerlo, corresponde ordenar al Poder Ejecutivo que subsane esa omisi&oacute;n en un plazo razonable. En sus fundamentos, sostuvo que la falta de reglamentaci&oacute;n conduce en la pr&aacute;ctica a privar de efectos jur&iacute;dicos a la disposici&oacute;n y relega el cumplimiento de la obligaci&oacute;n de los empleadores e impide el ejercicio de un derecho concreto de los trabajadores. Asimismo, consider&oacute; que la falta de reglamentaci&oacute;n es la causa que impide el ejercicio del derecho, porque no hay otro modo de obtener su satisfacci&oacute;n.</p>","esNovedad":true,"fecha":1634785200000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1634924984897,"usuarioCreacion":11,"fechaCreacion":1634844169978,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":32284,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29779668,"numeroExpediente":49220,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1099,"descripcion":"AMPARO LEY 16.986","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 1 