[{"codigo":8118634,"analisisDocumental":{"id":811863,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":80008,"valor":"RECHAZA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231243,"fechaModLong":201008231243,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"OLGUIN, LEONARDO ENRIQUE LUIS c/ SWISS MEDICAL ART S.A. s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":9202,"titulo":"Requisito de fundamentación autónoma: crítica concreta y razonada a los fundamentos desarrollados en la sentencia","cabecilla":"<p style=\"text-indent: 2em;\">La cámara confirmó la aptitud de los juzgados laborales para intervenir en la demanda, en la que el actor promovió acción contra la aseguradora de riesgos de trabajo en virtud de una enfermedad profesional. Señaló que, más allá de que el actor inició un trámite administrativo que carece de sustento práctico puesto que había acudido a la Jefatura de Gabinete de Ministros en lugar de a la comisión médica jurisdiccional (CMJ), las instancias administrativas previas deben permitir un acceso pleno a la vía judicial. Puntualizó además que las medidas excepcionales adoptadas por el Poder Ejecutivo para paliar la emergencia sanitaria derivada de la pandemia del Covid–19 impidieron a las CMJ ejercer sus funciones con las garantías debidas a los justiciables, ante la imposibilidad de revisar en forma presencial a los trabajadores.</p><p style=\"text-indent: 2em;\">La Corte rechazó el recurso intentado por la aseguradora demandada al considerar que no contaba con la fundamentación autónoma requerida por el artículo 15 de la ley 48.</p><p style=\"text-indent: 2em;\">Tuvo en cuenta que el único agravio por el que fue concedido el recurso se vinculaba con la constitucionalidad del procedimiento ante las Comisiones Médicas Jurisdiccionales respecto del que denunciaba falta de agotamiento  pero, sin embargo, la sentencia apelada, además de pronunciarse sobre la validez de la norma, argumentó que, en esta causa, era necesario apartarse de esa exigencia en virtud de las dificultades que le generó al actor el funcionamiento irregular del procedimiento ante las comisiones médicas, dadas las medidas decretadas en virtud de la pandemia del Covid–19. Este argumento, basado en cuestiones de hecho y de derecho común, ajenas a esta instancia, no fue siquiera mínimamente rebatido por la demandada en el recurso extraordinario.</p>","esNovedad":true,"fecha":1752721200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1752840829720,"usuarioCreacion":11,"fechaCreacion":1752840827844,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":140443,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcio