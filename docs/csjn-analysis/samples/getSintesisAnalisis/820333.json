[{"codigo":8203333,"analisisDocumental":{"id":820333,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"TELESISTEMA SRL c/ JUJUY, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA - (EXPEDIENTE DIGITAL)","inconstitucional":false,"falloDestacado":{"id":9901,"titulo":"Impuesto de sellos: causa ajena a la competencia originaria","cabecilla":"<p style=\"text-indent:2em\">Una empresa que presta el servicio interjurisdiccional de telecomunicaciones (TIC) -provisión de internet- promovió una acción declarativa de certeza contra la Provincia de Jujuy a fin de que se declare la invalidez e inconstitucionalidad de la pretensión fiscal por medio de la cual se le exigía el pago en concepto de impuesto de sellos. Solicitó también una medida cautelar de no innovar.</p><p style=\"text-indent:2em\">La Corte, por mayoría, entendió que la<b> causa </b><b>es ajena a su competencia originaria</b>.</p><p style=\"text-indent:2em\">Recordó, en primer lugar, que la apertura de la misma en razón de la materia cuando una provincia es parte solo procede cuando la acción entablada se funda directa y exclusivamente en prescripciones constitucionales de carácter nacional, leyes del Congreso, o tratados, de tal suerte que la cuestión federal sea la predominante en la causa y que quedan excluidos aquellos procesos en los que también se planteen cuestiones de índole local.  </p><p style=\"text-indent:2em\">También señaló que, más allá de la voluntad de los litigantes en sus expresiones formales, es necesario considerar la realidad jurídica de cada caso particular, ya que lo contrario importaría dejar librado al resorte de aquellos la determinación de la competencia originaria.</p><p style=\"text-indent:2em\">Expresó que la solución del asunto, además del examen de la violación a normativa federal, requerirá examinar normas provinciales dictadas en el marco del derecho público local, interpretándolas en su espíritu y en los efectos que la soberanía local ha querido darles, lo cual no resulta de resorte del Tribunal. Efectivamente, el planteo exige, de manera ineludible, interpretar y establecer el alcance de diferentes normas del código fiscal provincial vinculadas con la configuración del hecho imponible en el impuesto de sellos, con la conformación de instrumentos a los efectos del referido tributo, con la verificación de las condiciones necesarias para la existencia de actos entre ausentes y con la constatación de obligaciones accesorias.</p>","esNovedad":true,"fecha":1764212400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1764592042311,"usuarioCreacion":11,"fechaCreacion":1764278018764,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":148799,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35839085,"numeroExpediente":1828,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Sup