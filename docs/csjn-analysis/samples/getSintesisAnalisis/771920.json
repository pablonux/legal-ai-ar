[{"codigo":7719204,"analisisDocumental":{"id":771920,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"REYNAL, ALEJANDRO s/ INCIDENTE DE RECURSO EXTRAORDINARIO","alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - IMPUTADO: REYNAL, ALEJANDRO s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":3383,"titulo":"Arbitrariedad en el proceso penal: afirmaciones dogmáticas sin una mínima argumentación","cabecilla":"<p>La C&aacute;mara Federal de Casaci&oacute;n Penal anul&oacute; la resoluci&oacute;n del tribunal inferior que hab&iacute;a dejado firme el sobreseimiento definitivo por prescripci&oacute;n de la acci&oacute;n penal. Contra dicha decisi&oacute;n, la defensa interpuso recurso extraordinario. La Corte, por decisi&oacute;n un&aacute;nime, dej&oacute; sin efecto el pronunciamiento recurrido. Comenz&oacute; se&ntilde;alando que si bien las decisiones cuya consecuencia sea la obligaci&oacute;n de seguir sometido a proceso criminal no resultan, por regla, revisables en esta instancia extraordinaria el auto apelado configuraba una situaci&oacute;n excepcional, ya que de quedar firme lo resuelto, quedar&iacute;an sin efecto actuaciones regularmente realizadas en un juicio criminal en las que el imputado qued&oacute; desvinculado definitivamente con base en la causal de prescripci&oacute;n de la acci&oacute;n penal. Agreg&oacute; que, en tanto lo resuelto supuso admitir la configuraci&oacute;n en el caso del delito de lesa humanidad, el agravio del imputado aparec&iacute;a vinculado al respeto de la cosa juzgada con el fin de lograr la plena efectividad de la prohibici&oacute;n de la doble persecuci&oacute;n penal, cuyo rango constitucional ha sido reconocido por la Corte. Consider&oacute; el Tribunal que el reproche que le&nbsp;endilg&oacute;&nbsp;el a quo a la c&aacute;mara de apelaciones por tergiversar los t&eacute;rminos de la acusaci&oacute;n del querellante particular y omitir analizar las circunstancias all&iacute; planteadas, solo era producto de una lectura arbitraria de la resoluci&oacute;n sometida a su control. Decidi&oacute; entonces descalificar el pronunciamiento apelado por no cumplir con la exigencia que demanda que las sentencias constituyan una derivaci&oacute;n razonada del derecho vigente y devolver las actuaciones para que, por quien corresponda, y haciendo uso de las facultades de ordenaci&oacute;n del proceso, se d&eacute; cumplimiento en el menor plazo posible con lo dispuesto teniendo en cuenta la especial naturaleza y problem&aacute;tica que presentaba el caso. La Corte consider&oacute; importante aclarar que en modo alguno el fallo pod&iacute;a implicar tolerar o fomentar que se empleen subterfugios para amparar cualquier forma de impunidad, sino simplemente que resultaba indudable que la punici&oacute;n estatal -que en el caso conllevaba la obligaci&oacute;n de determinar si los hechos investigados&nbsp;pod&iacute;an&nbsp;ser calificados como de lesa humanidad-, ten&iacute;a que ser asegurada cumpliendo tambi&eacute;n con las normas constitucionales y convencionales que obligan al Tribunal a velar por el respeto de las garant&iacute;as judiciales establecidas en la Constituci&oacute;n Nacional.</p>","esNovedad":true,"fecha":1640660400000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1640779597132,"usuarioCreacion":11,"fechaCreacion":1640779593724,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":32903,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30985587,"numeroExpediente":1875,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Incidente Nº 2 - IMPUTADO: REYNAL, ALEJANDRO s/INCIDENTE DE RECURSO EXTRAORDINARIO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1875. "},"recurso":{"id":5228524,"expediente":{"id":30985587,"numeroExpediente":1875,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Incidente Nº 2 - IMPUTADO: REYNAL, ALEJANDRO s/INCIDENTE DE RECURSO EXTRAORDINARIO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"