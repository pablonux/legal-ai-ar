[{"codigo":8198512,"analisisDocumental":{"id":819851,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":24,"codigoRelacion":80024,"valor":"DECLARA NULIDAD","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201011041306,"fechaModLong":201011041306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"INSUA ANA MARIA LUJAN c/ ANSES s/REAJUSTES VARIOS","inconstitucional":false,"falloDestacado":{"id":9881,"titulo":"Concesión del recurso extraordinario que no aparece debidamente fundada","cabecilla":"<p style=\"text-indent: 2em;\">La cámara concedió el recurso extraordinario interpuesto por el beneficiario de la regulación de honorarios por entender que se encontraban involucradas cuestiones de naturaleza constitucional y que la decisión impugnada resultaría adversa a la validez de derechos de aquella naturaleza.</p><p style=\"text-indent: 2em;\">La Corte declaró la nulidad de esta resolución por considerar que sus términos sumamente genéricos evidenciaban que el tribunal no había examinado circunstanciadamente la apelación federal.</p><p style=\"text-indent: 2em;\">Recordó que los órganos judiciales llamados a expedirse sobre la concesión del recurso extraordinario federal deben resolver categórica y circunstanciadamente si tal apelación –prima facie valorada– satisface todos los recaudos formales y sustanciales que condicionan su admisibilidad y, entre ellos, la presencia de una cuestión federal.</p><p style=\"text-indent: 2em;\">Agregó que, de seguirse una orientación opuesta, el Tribunal debería admitir que su jurisdicción extraordinaria se viese, en principio, habilitada o denegada, sin razones que avalen uno u otro resultado, lo cual infligiría un claro perjuicio al derecho de defensa de los litigantes y al adecuado servicio de justicia de la Corte.</p>","esNovedad":true,"fecha":1763434800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1763556676296,"usuarioCreacion":4,"fechaCreacion":1763556640868,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":148359,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":25898129,"numeroExpediente":21839,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":5,"codigo":"5","abreviatura":"CSS","descripcion":"Camara Federal de la Seguridad Social","estado":0,"descripcionLarga":"CSS - Camara Federal de la Seguridad Social"},"objetoJuicio":{"id":10612,"descripcion":"REAJUSTES VARIOS","idMateria":6,"tema":{"id":540,"codigo":"PREV"}},"caratula":"INSUA ANA MARIA LUJAN c/ ANSES s/REAJUSTES VARIOS","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"21839. "},"recurso":{"id":7242641,"expediente":{"id":25898129,"numeroExpediente":21839,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":5,"codigo":"5","abreviatura":"CSS","descripcion":"Camara Fe