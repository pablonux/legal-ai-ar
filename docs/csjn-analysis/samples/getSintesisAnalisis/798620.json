[{"codigo":7986204,"analisisDocumental":{"id":798620,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"MIRANDA SORIA, LAUTARO GABRIEL s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":7261,"titulo":"Atribución de competencia en los delitos que se vinculan con un ilícito investigado por la justicia nacional ordinaria","cabecilla":"<p style=\"text-indent: 2em;\">A raíz de las actuaciones que se iniciaron en la Provincia de Buenos Aires con motivo del secuestro de una motocicleta que había sido sustraída en la Ciudad de Buenos Aires se suscitó una contienda de competencia entre la justicia de garantías y la justicia federal.  </p><p style=\"text-indent: 2em;\">La Corte, por unanimidad y siguiendo el criterio de su precedente <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7566181&amp;cache=1722978378178\">\"Galarza\"</a>, del 17 de diciembre de 2019, resolvió que no cabe asignar competencia al fuero federal para entender en delitos que se vinculen con un ilícito investigado por la justicia nacional ordinaria, los que quedarán sujetos a las normas de competencia pertinentes a la naturaleza del delito en cuestión.</p><p style=\"text-indent: 2em;\">Declaró por lo tanto competente para entender en las actuaciones respecto del encubrimiento y los delitos previstos en el art. 289, inc. 3 del Código Penal al Juzgado de Garantías n° 4 del Departamento Judicial de Avellaneda–Lanús.</p>","esNovedad":true,"fecha":1722913200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1722978406313,"usuarioCreacion":11,"fechaCreacion":1722978404165,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":122739,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36807584,"numeroExpediente":1434,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MIRANDA SORIA, LAUTARO GABRIEL s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1434. "},"recurso":{"id":6358700,"expediente":{"id":36807584,"numeroExpediente":1434,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":98