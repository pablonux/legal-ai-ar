[{"codigo":7868274,"analisisDocumental":{"id":786827,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"MAPFRE ARGENTINA SEGUROS S.A. c/ PEREZ GUZMAN, ALEJANDRA IRENE s/RECURSO DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":5684,"titulo":"Nulidad de actuaciones llevadas a cabo sin la debida intervención del Ministerio Público","cabecilla":"<p>La actora demandó, por sí y en representación de su hijo menor de edad por resarcimiento de los daños y perjuicios derivados del accidente de tránsito en el que perdió la vida su esposo y padre del niño. En el marco del incidente de caducidad promovido por la compañía de seguros, el superior tribunal provincial declaró la perención de la instancia. Contra dicho pronunciamiento, la actora dedujo recurso extraordinario. Como se encontraban en juego los derechos de un niño la Corte dio vista a la Defensoría Oficial, lo que originó un dictamen en el que se destacó la omisión de dar intervención a la defensora de menores durante el transcurso del proceso principal, a la que solo se le había corrido vista una vez planteado el incidente de caducidad. El Tribunal dejó sin efecto la sentencia apelada. Expresó que si bien había transcurrido un lapso de tiempo superior al estipulado en la legislación local sin que la demandante hubiera realizado actividad procesal útil, la omisión de dar intervención oportuna al Ministerio Público en la causa principal había ocasionado un menoscabo al derecho de defensa en juicio, debido proceso y lesión del interés superior del niño. </p>","esNovedad":true,"fecha":1691031600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1691171962543,"usuarioCreacion":4,"fechaCreacion":1691095133378,"privado":false,"posicion":-1,"resumen":null},"reciboEntrada":{"id":112120,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32328477,"numeroExpediente":1485,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MAPFRE ARGENTINA SEGUROS S.A. c/ PEREZ GUZMAN, ALEJANDRA IRENE s/RECURSO DE INCONSTITUCIONALIDAD","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1485. "},"recurso":{"id":5394448,"expediente":{"id":32328477,"numeroExpediente":1485,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","es