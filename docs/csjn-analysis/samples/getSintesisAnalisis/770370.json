[{"codigo":7703703,"analisisDocumental":{"id":770370,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":80013,"valor":"DECLARA INOFICIOSO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009221235,"fechaModLong":201009221235,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"MIRANDA CASTILLO, GLORIA TRINIDAD c/ ESTADO NACIONAL - MINISTERIO DE DESARROLLO SOCIAL DE LA NACIÓN s/ AMPARO LEY 16.986","alias":null,"caratula":"Recurso Queja Nº 1 - MIRANDA CASTILLO, GLORIA TRINIDAD c/ ESTADO NACIONAL- MINISTERIO DE DESARROLLO SOCIAL DE LA NACIÓN  s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":2984,"titulo":"Exigencia de residencia continua a los extranjeros para acceder a una pensión por invalidez","cabecilla":"<p>La actora promovi&oacute; acci&oacute;n de amparo contra el Poder Ejecutivo Nacional a fin de que se lo condene a tomar las medidas pertinentes para otorgar la pensi&oacute;n por invalidez regulada por la ley 13.478 y solicit&oacute; la declaraci&oacute;n de inconstitucionalidad del decreto reglamentario, en cuanto exige a los extranjeros acreditar una residencia m&iacute;nima continua en el pa&iacute;s de veinte&nbsp;a&ntilde;os. La c&aacute;mara hizo lugar a la acci&oacute;n y declar&oacute; la inconstitucionalidad de la norma cuestionada. Contra esta sentencia interpuso recurso extraordinario la demandada. La Corte, por mayor&iacute;a, record&oacute; que sus sentencias deben ce&ntilde;irse a las circunstancias existentes al momento de ser dictadas y se&ntilde;al&oacute; que la actora hab&iacute;a obtenido la ciudadan&iacute;a argentina por naturalizaci&oacute;n durante el transcurso del proceso, por lo que a la luz de su nueva condici&oacute;n de argentina naturalizada, el agravio hab&iacute;a perdido virtualidad.&nbsp;Por ello, declar&oacute; inoficioso emitir pronunciamiento en las actuaciones.&nbsp;&nbsp;El juez Rosatti, en disidencia, consider&oacute; que&nbsp;no obstaba a la intervenci&oacute;n del Tribunal el hecho de que la actora haya obtenido la ciudadan&iacute;a argentina por naturalizaci&oacute;n ya que subsist&iacute;a el inter&eacute;s en relaci&oacute;n al per&iacute;odo anterior a la adquisici&oacute;n de la nacionalidad durante el cual la actora manten&iacute;a la condici&oacute;n de extranjera y consider&oacute; que el plazo de 20 a&ntilde;os exigido a los extranjeros para poder gozar de los&nbsp;beneficios de la pensi&oacute;n luce manifiestamente irrazonable en los t&eacute;rminos del art. 28 de la Constituci&oacute;n Nacional.</p>","esNovedad":true,"fecha":1635390000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1635529820045,"usuarioCreacion":11,"fechaCreacion":1635511967292,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":32358,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":27884638,"numeroExpediente":31334,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"ti