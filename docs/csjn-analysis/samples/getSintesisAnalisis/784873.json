[{"codigo":7848736,"analisisDocumental":{"id":784873,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"ALFONSO, EDUARDO s/INCIDENTE DE RECURSO EXTRAORDINARIO","alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - IMPUTADO: ALFONSO, EDUARDO s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":6467,"titulo":"Detención domiciliaria y delitos de lesa humanidad","cabecilla":"<p style=\"text-indent:2em\">Un tribunal oral concedió la detención cautelar domiciliara a un condenado – con sentencia que aún no estaba firme– a la pena de prisión perpetua por delitos calificados como de lesa humanidad.</p><p style=\"text-indent:2em\">A raíz del rechazo de su recurso por parte de la cámara, el fiscal interpuso un recurso extraordinario que fue mantenido por el Procurador General ante la Corte.</p><p style=\"text-indent:2em\"><b>El Tribunal hizo lugar al recurso y dejó sin efecto el pronunciamiento</b>. Expresó que no existían razones humanitarias que justificaran la concesión de la medida y que la sentencia se había limitado a señalar cuáles eran las patologías que sufría el condenado, <em>sin demostrar que no habían recibido la atención médica necesaria por parte del Servicio Penitenciario Federal, ni explicar por qué serían mejor atendidas en el domicilio de aquél.</em></p><p style=\"text-indent:2em\">Recordó al respecto la Corte su jurisprudencia en el sentido de que en relación a la detención domiciliaria, los jueces deben ponderar tanto si, en función de las particulares circunstancias de salud que registra el interesado, además de su avanzada edad, la privación de libertad en un establecimiento penitenciario puede comprometer o agravar su estado, como también si la unidad carcelaria correspondiente resulta apta para alojarlo, resguardarlo y tratarlo de forma adecuada.</p><p style=\"text-indent:2em\">Agregó también que se había omitido tener en cuenta que el condenado había demostrado que contaba con la capacidad suficiente para eludir la acción de la justicia, dado que se había mantenido prófugo durante cuatro años cuando la causa todavía estaba en la etapa de instrucción.</p>","esNovedad":true,"fecha":1709175600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1709308068555,"usuarioCreacion":4,"fechaCreacion":1709296452766,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":110160,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35952045,"numeroExpediente":27004012,"anioExpediente":2003,"tomoExpediente":nu