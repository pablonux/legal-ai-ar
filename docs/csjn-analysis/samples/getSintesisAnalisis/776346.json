[{"codigo":7763462,"analisisDocumental":{"id":776346,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"FERNÁNDEZ DE KIRCHNER, CRISTINA ELISABET s/ABUSO DE AUTORIDAD Y VIOL. DEB.FUNC.PUBL. (ART.248)","alias":null,"caratula":"Recurso Queja Nº 1 - IMPUTADO: FERNADEZ DE KIRCHNER, CRISTINA ELISABET s/ABUSO DE AUTORIDAD Y VIOL. DEB.FUNC.PUBL.(ART.248), NEGOCIACIONES INCOMPATIBLES (ART.265), MALVERSACION DE CAUDALES PUBLICOS (ART.260), ENRIQUECIMIENTO ILICITO (ART.268 INC.1) y DEFRAUDACION CONTRA LA ADMINISTRACION PUBLICA QUERELLANTE: UNIDAD DE INFORMACION FINANCIERA Y OTROS","inconstitucional":false,"falloDestacado":{"id":4126,"titulo":"Las decisiones en materia de prueba en el proceso penal no constituyen sentencia definitiva","cabecilla":"<p>Ante el pedido de la defensa solicitando que se realizaran diversas medidas de prueba, los jueces de la causa aceptaron la realizaci&oacute;n de algunas y rechazaron otras. Apelada esta decisi&oacute;n, la Corte desestim&oacute; la queja al considerar que las decisiones adoptadas en materia de prueba no constituyen sentencia definitiva, aun cuando se invoque la garant&iacute;a constitucional de la defensa en juicio o la doctrina de la arbitrariedad. Se&ntilde;al&oacute; que su intervenci&oacute;n reci&eacute;n podr&aacute; quedar habilitada luego de dictada la sentencia final por parte del superior tribunal de la causa. Agreg&oacute; adem&aacute;s que no se hab&iacute;a demostrado que se hubiera configurado una situaci&oacute;n excepcional por medio de la cual se hubiera suprimido el derecho de ofrecer y producir prueba de descargo y que, por el contrario, el tribunal de juicio hab&iacute;a accedido a realizar numerosas medidas probatorias solicitadas por la recurrente.</p>","esNovedad":true,"fecha":1655780400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1655906792620,"usuarioCreacion":4,"fechaCreacion":1655843063720,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":34468,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32866416,"numeroExpediente":5048,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - IMPUTADO: FERNADEZ DE KIRCHNER, CRISTINA ELISABET s/ABUSO DE AUTORIDAD Y VIOL. DEB.FUNC.PUBL.(ART.248), NEGOCIACIONES INCOMPATIBLES (ART.265), MALVERSACION DE CAUDALES PUBLICOS (ART.260), ENRIQUECIMIENTO ILICITO (ART.268 INC.1) y DEFRAUDACION CONTRA LA ADMINISTRACION PUBLICA ACTOR CIVIL: IGUACEL, JAV