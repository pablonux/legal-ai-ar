[{"codigo":7796002,"analisisDocumental":{"id":779600,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"G., M.E. c/ CAJA DE SEGURIDAD SOCIAL PARA ESCRIBANOS DE LA PROVINCIA DE BUENOS AIRES s/ AMPARO DE SALUD","alias":null,"caratula":"Recurso Queja Nº 2 - G., M.E. c/ CAJA DE SEGURIDAD SOCIAL PARA ESCRIBANOS DE LA PROVINCIA DE BUENOS AIRES s/AMPARO  DE SALUD","inconstitucional":false,"falloDestacado":{"id":4704,"titulo":"Adjudicación de responsabilidad a una caja de seguridad social basada en afirmaciones dogmáticas","cabecilla":"<p>La cámara hizo lugar al amparo deducido con el fin de que la Caja de Seguridad Social para Escribanos de la Provincia de Buenos Aires le otorgase a la actora la cobertura de la internación con fundamento en que, si bien dicha entidad no adhirió al sistema establecido por las leyes que regulan las obras sociales y las prestaciones a favor de las personas con discapacidad por ser una persona jurídica de derecho público no estatal, ello no la relevaba de la carga de adoptar las medidas razonables a su alcance para otorgar a sus afiliados los derechos de la seguridad social con el alcance integral. La demandada interpuso recurso extraordinario y l<b>a Corte, por mayoría, dejó sin efecto este pronunciamiento</b>. Consideró que luego de afirmar que la condenada no era una obra social ni una entidad de medicina prepaga le había adjudicado dogmáticamente responsabilidad en el marco de ese sistema enfatizando que no había norma que la eximiera de ella, lo que traducía un claro desconocimiento de garantías constitucionales. Agregó que el tribunal tampoco había abordado las serias y relevantes alegaciones de la apelante, fundadas en las disposiciones de la ley provincial que regla su actuación y determina el alcance de las prestaciones que reconoce a sus afiliados, entre las que estaría regulado un subsidio especial por geriatría.</p>","esNovedad":true,"fecha":1666666800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1666726951036,"usuarioCreacion":11,"fechaCreacion":1666726942744,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":104857,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33462671,"numeroExpediente":1301,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":3,"codigo":"3","abreviatura":"CCF","descripcion":"Cámara Nacional de Apelaciones en lo Civil y Comercial Federal","estado":0,"descripcionLarga":"CCF - Cámara Nacional de Apelaciones en lo Civil y Comercial Federal"},"objetoJuicio":{"id":1432,"descripcion":"AMPARO  DE SALUD","idMateria":3,"tema":{"id":460,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 2 - G., M.E. c/ CAJA DE SEGURIDAD SOCIAL PARA ESCRIBANOS DE LA PROVINCIA DE BUENOS 