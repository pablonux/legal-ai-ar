[{"codigo":7978694,"analisisDocumental":{"id":797869,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"Reta, Miguel Ángel c/ Universidad Nacional de San Juan s/ civil y comercial –varios","alias":null,"caratula":"Recurso Queja Nº 1 - DEMANDADO: UNIVERSIDAD NACIONAL DE SAN JUAN s/CIVIL y COMERCIAL-VARIOS ACTOR: RETA, MIGUEL ÁNGEL","inconstitucional":false,"falloDestacado":{"id":7141,"titulo":"La motivación del acto administrativo","cabecilla":"<p style=\"text-indent:2em\">La Cámara Federal de Apelaciones de Mendoza revocó las resoluciones dictadas por el rector de la Universidad Nacional de San Juan y dispuso que se reponga al actor en el cargo interino de director administrativo, hasta que se reintegre su titular, con el consiguiente ajuste de las retribuciones que dejó de percibir.</p><p style=\"text-indent:2em\">La cuestión a dilucidar era determinar si el acto que dispuso el cese del interinato debía cumplir con el requisito de motivación que prevé la ley 19.549.</p><p style=\"text-indent:2em\">La Corte declaró procedente el recurso extraordinario interpuesto y confirmó la sentencia apelada pues consideró que no puede sostenerse válidamente que el ejercicio de facultades discrecionales por parte de un órgano administrativo para remover a una persona del cargo para el cual había sido designada, aun con carácter transitorio o precario, lo exima de cumplir los recaudos que para todo acto administrativo exige el artículo 7° de la ley 19.549.</p>","esNovedad":true,"fecha":1719889200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1720029295002,"usuarioCreacion":4,"fechaCreacion":1720011895446,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":122018,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29383932,"numeroExpediente":82194343,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":20,"codigo":"20","abreviatura":"FMZ","descripcion":"Justicia Federal de Mendoza","estado":0,"descripcionLarga":"FMZ - Justicia Federal de Mendoza"},"objetoJuicio":{"id":4084,"descripcion":"CIVIL y COMERCIAL-VARIOS","idMateria":112,"tema":{"id":261,"codigo":"CYCF"}},"caratula":"Recurso Queja Nº 1 - DEMANDADO: UNIVERSIDAD NACIONAL DE SAN JUAN s/CIVIL y COMERCIAL-VARIOS ACTOR: RETA, MIGUEL ÁNGEL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"82194343. "},"recurso":{"id":5022343,"expediente":{"id":29383932,"numeroExpediente":82194343,"anioExpediente":2011,"tomoExpedien