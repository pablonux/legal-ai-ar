[{"codigo":8186796,"analisisDocumental":{"id":818679,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - SOLIS JUAN ANTONIO  c/ LIBERTY  ART S.A.  s/RECURSO DE APELACION LEY 24557","inconstitucional":false,"falloDestacado":{"id":9721,"titulo":"Acceso a la justicia del trabajador y certeza que debe adquirir el procedimiento laboral","cabecilla":"<p style=\"text-indent:2em\">La cámara federal confirmó la decisión que rechazó la demanda de ejecución de la sentencia y manifestó que la sentencia declarativa de la justicia federal de la seguridad social, que había admitido la apelación contra el dictamen de la comisión médica y determinado la incapacidad del actor, no era ejecutable y que había adquirido firmeza la decisión que ordenó devolver las actuaciones a la sede administrativa.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia. </p><p style=\"text-indent:2em\">Consideró que esta falta de aptitud jurisdiccional del fuero federal producía un agravio de imposible o inoportuna reparación ulterior pues clausuraba la vía procesal y denegaba al trabajador el acceso a la justicia con sustento en que debía volver a la comisión médica, restringiendo sustancialmente su derecho de defensa. Y que, más allá de las razones formales alegadas por la alzada federal, la decisión sobre su aptitud jurisdiccional, adoptada luego de casi veinte años de trámite y de haberse dictado sentencia sobre el fondo del asunto, tampoco resultaba acorde con la certeza, rapidez y eficacia que debe adquirir el procedimiento laboral.</p><p style=\"text-indent:2em\">Recordó el Tribunal que entre los propósitos del trámite previo ante las comisiones médicas figura agilizar la evaluación sanitaria de la persona accidentada, para lograr el acceso eficaz a la reparación económica y a las prestaciones dispuestas en el régimen y que la validez de esa instancia administrativa depende de que el trabajador cuente, en todos los casos, con una revisión amplia y plena ante un tribunal independiente e imparcial, con jurisdicción para controlar lo actuado en orden a la determinación de los hechos y el derecho aplicable.</p><p style=\"text-indent:2em\">Concluyó así que la decisión que retrotraía el proceso a una instancia administrativa precluida privaba de manera injustificada al actor de la vía judicial establecida y que correspondía que la causa sea restituida al juzgado federal quien deberá determinar el importe indemnizatorio correspondiente a la incapacidad establecida, examinando para ello los planteos constitucionales del actor y, definido el monto de la condena, en caso de incumplimiento por parte de la compañía de seguros, llevar adelante la ejecución.</p>","esNovedad":true,"fecha":1762225200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1762368156004,"usuarioCreacion":11,"fechaCreacion":1762343085871,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":147091,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36196733,"numeroExpediente":22017556,"anioExpediente":2003,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":9162,"descripcion":"RECURSO DE APELACION LEY 24557","idMateria":112,"tema":null},"caratula":"Recurso Queja Nº 1 - SOLIS JUAN ANTONIO  c/ LIBERTY  ART S.A.  s/RECURSO DE APELACION LEY 24557","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"22017556. "},"recurso":{"id":6234253,"expediente":{"id":36196733,"numeroExpediente":22017556,"anioExpediente":2003,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":9162,"descripcion":"RECURSO DE APELACION LEY 24557","idMateria":112,"tema":null},"caratula":"Recurso Queja Nº 1 - SOLIS JUAN ANTONIO  c/ LIBERTY  ART S.A.  s/RECURSO DE APELACION LEY 24557","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"22017556. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"FMP 022017556/2003/1/RH001","identificacionExpediente":"FMP 022017556/2003/1/RH001"},"piezas":null,"urgente":null,"observacio