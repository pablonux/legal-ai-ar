[{"codigo":7782084,"analisisDocumental":{"id":778208,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"G., A.C. Y OTRO s/GUARDA CON FINES DE ADOPCION","inconstitucional":false,"falloDestacado":{"id":5303,"titulo":"Guarda con fines de adopción. Interés superior del niño","cabecilla":"<p>En el marco de un proceso de guarda con fines de adopción, la Cámara confirmó el rechazo de la demanda deducida por el matrimonio guardador de una niña, con quien convive desde su nacimiento ocurrido el 21 de marzo de 2012 por decisión de su madre biológica y dispuso que, de conformidad con lo previsto en el art. 28 de la ley local XII n° 20, se procediera a citar a los postulantes inscriptos en el Registro Único de Aspirantes a la Adopción en el orden de la lista correspondiente para definir la situación de la infante. Ante el rechazo de los recursos provinciales, el matrimonio guardador dedujo recurso extraordinario. La Corte lo declaró formalmente admisible y revocó el pronunciamiento apelado dejando sin efecto la sentencia que rechazó in limine la demanda. Para ello, consideró que, dado el tiempo transcurrido desde el comienzo de las actuaciones, mantener en la actualidad una decisión adoptada en un momento y contexto determinado de manera preliminar y sin mayor sustanciación, que desestimó la pretensión inicial del matrimonio guardador, compartida por la madre biológica, por cuestiones estrictamente formales y dispuso la elección de nuevos postulantes para asumir la guarda y, en su caso, la adopción de la niña, importaría <em>hoy una evaluación del asunto alejada de las directrices constitucionales que deben guiar el caso</em> (artículo 75, inciso 22, de la Ley Fundamental, artículo 3° de la Convención sobre los Derechos del Niño). Solución que se refuerza frente a la ausencia de elementos que aseguren –o cuando menos indiquen- que su mantenimiento resulta más beneficioso para el sujeto que requiere de una protección especial.</p>","esNovedad":true,"fecha":1681959600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1682089046896,"usuarioCreacion":4,"fechaCreacion":1682022187670,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":35143,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34305536,"numeroExpediente":2517,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"G., A.C. Y OTRO s/GUARDA CON FINES DE ADOPCION","verificacionMesa":"N",