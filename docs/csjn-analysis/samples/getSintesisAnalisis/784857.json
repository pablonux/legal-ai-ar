[{"codigo":7848574,"analisisDocumental":{"id":784857,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"A., S. H. c/ OSFATLYF – Obra Social de la Federación Argentina de Trabajadores de Luz y Fuerza s/ amparo ley 16.986.\r\n","alias":null,"caratula":"Recurso Queja Nº 2 - ARIAS, SEBASTIAN HERNAN c/ OSFATLYF - OBRA SOCIAL DE LOS TRABAJADORES DE LUZ Y FUERZA- s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":5623,"titulo":"Omisión de considerar un planteo oportunamente introducido en un amparo de salud","cabecilla":"<p>En el marco de un amparo iniciado contra una obra social tendiente a obtener la cobertura de los tratamientos de una niña con discapacidad la cámara decidió que la misma debía limitarse a los valores establecidos por el Ministerio de Salud. El Defensor Oficial interpuso un recurso contra dicha sentencia y la Corte la dejó sin efecto. Expresó que la cámara consideró central determinar el impacto que produciría en la economía familiar el tener que afrontar los gastos médicos de la menor, y juzgó necesario comprobar si –a la luz de dichas constancias- el derecho a la salud de la niña estaba en peligro pero que, sin embargo, no tuvo en cuenta dicha incidencia en modo alguno. Además, señaló que los importes por cada sesión de acompañante terapéutico habían quedado reducidos al haber encuadrado la cámara dicha prestación en el “Módulo Integral Simple” del nomenclador del ministerio lo que implicaba que la alzada había colocado a la única apelante en una peor situación que la resultante del pronunciamiento de primera instancia, violando el límite de su competencia, circunscripto a las cuestiones controvertidas.</p>","esNovedad":true,"fecha":1688439600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1688564601098,"usuarioCreacion":11,"fechaCreacion":1688505814818,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":110144,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32139485,"numeroExpediente":4440,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":14,"codigo":"14","abreviatura":"FCR","descripcion":"Justicia Federal de Comodoro Rivadavia","estado":0,"descripcionLarga":"FCR - Justicia Federal de Comodoro Rivadavia"},"objetoJuicio":{"id":4565,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":300,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 2 - A., S. H. c/ OSFATLYF - OBRA SOCIAL DE LA  FEDERACION ARGENTINA DE TRABAJADORES DE LUZ Y FUERZA- s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"4440. "},"recurso":{"id":5371593,"expediente":{"id":32139485,"numeroExpediente":4440,"anioExpediente":2017,"tomoExpediente":null,"letraExped