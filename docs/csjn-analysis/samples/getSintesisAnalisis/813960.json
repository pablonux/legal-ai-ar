[{"codigo":8139603,"analisisDocumental":{"id":813960,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - MENDOZA ALVARADO, RAFAEL TEOFILO c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":9385,"titulo":"Migraciones - Cancelación de la residencia: condena impuesta en el caso concreto","cabecilla":"<p style=\"text-indent:2em\">La cámara confirmó la expulsión de un migrante por encontrarse incurso en la causal establecida en el art. 62, inciso b, de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/92016/actualizacion\">ley 25.871</a> (redacción original), que ordena la cancelación de la residencia concedida a quien \"hubiese sido condenado judicialmente en la República por delito doloso que merezca pena privativa de libertad mayor de cinco (5) años”. La decisión había sido motivada en una condena a tres (3) años de prisión en suspenso por el delito de robo agravado por haber sido cometido en poblado y en banda pero la decisión se basaba en que el tipo penal de dicho delito conlleva, en su máximo, una pena mayor a la de cinco años.</p><p style=\"text-indent:2em\">Ante el recurso intentado por el migrante la Corte revocó la decisión apelada. </p><p style=\"text-indent:2em\">Señaló que la cuestión federal a decidir consistía en determinar si la norma mencionada <b>se refiere al máximo de la escala penal o la condena impuesta en el caso concreto</b> y que en tanto el texto de la norma alude a una decisión judicial <b>condenatoria concreta</b> - “condena judicial en la República”- los jueces no pueden apartarse del parámetro fijado por el legislador y quedan relevados de indagar en alternativas hermenéuticas más complejas.</p><p style=\"text-indent:2em\">Así, y teniendo en cuenta que en el caso no se había alcanzado el límite de cinco años de pena privativa de la libertad previsto, no se configuraba el supuesto de cancelación de la residencia permanente en el país.</p>","esNovedad":true,"fecha":1757991600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1758203930649,"usuarioCreacion":11,"fechaCreacion":1758059230923,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":142542,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33421988,"numeroExpediente":50997,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"t