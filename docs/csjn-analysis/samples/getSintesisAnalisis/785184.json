[{"codigo":7851844,"analisisDocumental":{"id":785184,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"REQUERIDO: GLAVIC, TOMISLAV s/EXTRADICION","inconstitucional":false,"falloDestacado":{"id":5642,"titulo":"Cómputo de la pena en un proceso de extradición","cabecilla":"<p>La justicia federal de Córdoba denegó la extradición del requerido a la República de Croacia para el cumplimiento de la pena de 1 año de prisión a la cual se lo había condenado en el país requirente. Contra esa decisión, el Ministerio Público Fiscal dedujo recurso ordinario de apelación que fue concedido. La Corte, por unanimidad, dejó sin efecto el pronunciamiento apelado y resolvió conceder la extradición. Recordó que la normativa aplicable establece para la procedencia de la extradición que la pena que faltare cumplir sea no menor de un año de privación de libertad en el momento en que se presente la solicitud y esa circunstancia se encontraba cumplida en el caso. Sostuvo que no podía considerarse, como había hecho el juez de la causa, que el monto de la pena hubiese sido alterado por el hecho de que el requerido había estado sometido a detención preventiva en nuestro país. Asimismo, explicó que son las autoridades judiciales extranjeras las legitimadas para confeccionar el cómputo final del cual se deduciría el tiempo que el requerido estuvo privado de libertad en argentina en el marco del proceso de extradición, y no el juez de la cooperación.</p>","esNovedad":true,"fecha":1688439600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1700076873747,"usuarioCreacion":11,"fechaCreacion":1688504106418,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":110566,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33790929,"numeroExpediente":11663,"anioExpediente":2000,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Recurso Queja Nº 18 - IMPUTADO: AUGUSTE , ERNESTO s/DEFRAUDACION CONTRA LA ADMINISTRACION PUBLICA ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"11663. "},"recurso":{"id":5635025,"expediente":{"id":33790929,"numeroExpediente":11663,"anioExpediente":2000,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuici