[{"codigo":7698115,"analisisDocumental":{"id":769811,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"COLEGIO DE MANDATARIOS Y GESTORES DE LA PROVINCIA DE ENTRE RIOS c/ MINISTERIO DE JUSTICIA - DIREC NAC REG NAC PROPIEDAD AUTOMOTOR Y CREDITOS PRENDARIOS s/ACCION MERAMENTE DECLARATIVA DE INCONSTITUCIONALIDAD","alias":null,"caratula":"COLEGIO DE MANDATARIOS Y GESTORES DE LA PROVINCIA DE ENTRE RIOS c/ MINISTERIO DE JUSTICIA - DIREC NAC REG NAC PROPIEDAD AUTOMOTOR Y CREDITOS PRENDARIOS s/ACCION MERAMENTE DECLARATIVA DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":2843,"titulo":"Actividad de mandatarios ante los Registros Nacionales de la Propiedad Automotor: potestades nacionales y provinciales","cabecilla":"<p>Cuestionamiento constitucional por parte del Colegio de Martilleros y Gestores de la Provincia de Entre R&iacute;os de la disposici&oacute;n 128/2014 de la Direcci&oacute;n Nacional de los Registros Nacionales de la Propiedad Automotor por medio de la cual se exige a los gestores y mandatarios de la Provincia de Entre R&iacute;os que se &quot;reempadronen&quot; en el registro de mandatarios que tiene a su cargo, como condici&oacute;n para la realizaci&oacute;n de tr&aacute;mites ante sus dependencias -&nbsp;Impugnaci&oacute;n de la norma sobre la base de que tal conducta invade las facultades que le corresponden al Colegio de Martilleros y Gestores de la Provincia de Entre R&iacute;os -&nbsp;Sentencia de la c&aacute;mara que declar&oacute; la inconstitucionalidad de la disposici&oacute;n -&nbsp;Interpretaci&oacute;n de la Corte en el sentido que&nbsp;<strong>la regulaci&oacute;n del derecho de dominio de los automotores de manera uniforme para todo el pa&iacute;s, establecida en el decreto-ley 6582/58, fue dictada en ejercicio de las atribuciones conferidas en el art&iacute;culo 75, inciso&nbsp;12 de la Constituci&oacute;n Nacional <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=75551&amp;cache=1634301932397\">(Fallos: 334:902)</a></strong>&nbsp;- Las atribuciones conferidas por el legislador provincial a la entidad accionante se encuentran circunscriptas a las cuestiones referidas al gobierno de la matr&iacute;cula local y a desempe&ntilde;ar la actividad de gestores y mandatarios realizada en la provincia, en cuanto &eacute;stas se encuentren reguladas por normas de ese orden - La disposici&oacute;n cuestionada alcanza a los colegiados &uacute;nicamente cuando tales sujetos realicen tr&aacute;mites ante las dependencias nacionales reguladas por el decreto-ley 6582/58 - El Estado Nacional no desconoce o invade las potestades provinciales en la regulaci&oacute;n de la matr&iacute;cula local ya que se trata de exigencias adicionales que &uacute;nicamente deben cumplirse cuando se realicen tr&aacute;mites ante las propias dependencias del estado emisor -&nbsp;<strong>Se revoca la sentencia apelada</strong>.</p>","esNovedad":true,"fecha":1634180400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1634845877098,"usuarioCreacion":11,"fechaCreacion":1634301964226,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":32158,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":10638232,"numeroExpediente":31518,"anioExpediente":2008,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1116,"descripcion":"PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"GARCIA LUIS ALBERTO Y OTROS c/ EN-M§ DEFENSA-EJERCITO-DTOS 1104/05 1053/08 s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"31518. "},"recurso":{"id":6072249,"expediente":{"id":10638232,"numeroExpediente":31518,"anioExpediente":2008,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1116,"descripcion":"PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","idMateria":2,"te