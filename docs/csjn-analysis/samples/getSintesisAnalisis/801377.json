[{"codigo":8013776,"analisisDocumental":{"id":801377,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"PAEZ, ANGEL s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":7643,"titulo":"Atribución de competencia para la investigación de la publicación de imágenes de explotación sexual infantil","cabecilla":"<p style=\"text-indent: 2em;\">En la causa en la que se investiga la presunta infracción al artículo 128 del Código Penal, iniciada a raíz de un reporte de la ONG “National Center of Missing and Exploited Children” (NCMEC), sobre la publicación de imágenes de explotación sexual infantil a través de la red social “Facebook\" se suscitó un conflicto negativo de competencia entre un juzgado en lo penal, contravencional y de faltas de la Ciudad de Buenos Aires y un juzgado de garantías de la Provincia de Buenos Aires.</p><p style=\"text-indent: 2em;\">La Corte tuvo en cuenta que este último no había desconocido su competencia provincial y del informe elaborado por los expertos surgía que todas las conexiones se realizaron desde distintas IP ubicadas en el territorio bonaerense.</p><p style=\"text-indent: 2em;\">Decidió así que corresponde al juzgado provincial continuar con el conocimiento de las actuaciones, sin perjuicio de que si entiende que debe intervenir otro juez provincial, se las remita de conformidad con las normas del derecho procesal local.</p>","esNovedad":true,"fecha":1727751600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1727815290803,"usuarioCreacion":4,"fechaCreacion":1727815288630,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":128086,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35805714,"numeroExpediente":1745,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"AIELLO, MELINA SOLEDAD c/ SEGUROS RIVADAVIA COOPERATIVA LIMITADA s/demanda derecho de consumo daños y perjuicios ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1745. "},"recurso":{"id":6124230,"expediente":{"id":35805714,"numeroExpediente":1745,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINA