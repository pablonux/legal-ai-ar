[{"codigo":7817733,"analisisDocumental":{"id":781773,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Y.P.F. S.A. c/ SANTA FE, PROVINCIA DE s/ ACCIÓN DECLARATIVA DE CERTEZA","alias":null,"caratula":"Y.P.F. S.A. c/ SANTA FE, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","inconstitucional":false,"falloDestacado":{"id":4941,"titulo":"Alcance de la medida cautelar ordenada contra una provincia","cabecilla":"<p>En el marco de la jurisdicción originaria de la Corte, la provincia demandada solicitó el levantamiento parcial de la medida cautelar ordenada por la Corte mediante un pronunciamiento anterior. Afirmó que ello paraliza la totalidad del reclamo administrativo desplegado por el fisco provincial, y que esa circunstancia le genera perjuicio por no permitir culminar con el procedimiento de determinación tributaria con relación a otros conceptos sobre los cuales el Tribunal no tendrá que decidir porque no forman parte del reclamo. La Corte desestimó el planteo. Recordó que las medidas cautelares no deben obstaculizar los trámites administrativos que el Estado provincial se considere con derecho a llevar a cabo para poner las actuaciones en condiciones de ejecutar el crédito si la petición esgrimida en el proceso es finalmente rechazada, sino que importan la abstención de perseguir su cobro como así también de disponer o impulsar medidas que importen inmovilizar fondos o bienes pertenecientes al beneficiario de la cautela. Consideró entonces que la paralización del procedimiento administrativo determinativo a la que se refiere el Estado provincial demandado no puede ser atribuida a la anterior decisión del Tribunal.</p>","esNovedad":true,"fecha":1675911600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1675966087295,"usuarioCreacion":11,"fechaCreacion":1675966075222,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":106361,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31496397,"numeroExpediente":440,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION DECLARATIVA DE CERTEZA","idMateria":0,"tema":null},"caratula":"Y.P.F. S.A. c/ SANTA FE, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"440. "},"recurso":{"id":5295344,"expediente":{"id":31496397,"numeroExpediente":440,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION DECLARATIVA DE CERTEZA","idMateria":0,"tema":null},"caratula":"Y.