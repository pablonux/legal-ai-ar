[{"codigo":8091974,"analisisDocumental":{"id":809197,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":24,"codigoRelacion":80024,"valor":"DECLARA NULIDAD","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201011041306,"fechaModLong":201011041306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ROSENBROCK EDUARDO BAUTISTA c/ ANSES s/REAJUSTES VARIOS","inconstitucional":false,"falloDestacado":{"id":8701,"titulo":"Nulidad de la concesión del recurso extraordinario que no aparece debidamente fundada","cabecilla":"<p style=\"text-indent: 2em;\">La cámara concedió el recurso extraordinario interpuesto por la beneficiaria de la regulación de honorarios, al entender que se encontraban involucradas cuestiones de naturaleza constitucional.</p><p style=\"text-indent: 2em;\">La Corte declaró la nulidad de dicha resolución y dispuso que los autos vuelvan al tribunal de origen para que se dicte una nueva decisión sobre el punto.</p><p style=\"text-indent: 2em;\">Recordó que los órganos judiciales llamados a expedirse sobre la concesión del recurso extraordinario deben resolver categórica y circunstanciadamente si tal apelación –<em>prima facie</em> valorada- satisface todos los recaudos formales y sustanciales que condicionan su admisibilidad, entre ellos la presencia de una cuestión federal.</p><p style=\"text-indent: 2em;\">Agregó que, de seguirse una orientación opuesta, el Tribunal debería admitir que su jurisdicción extraordinaria se viese, en principio, habilitada o denegada, sin razones que avalen uno u otro resultado, lo cual infringiría un claro perjuicio al derecho de defensa de los litigantes y al adecuado servicio de justicia.</p><p style=\"text-indent: 2em;\">Señaló que los términos del auto de concesión del recurso evidenciaban que la cámara no había examinado circunstanciadamente la apelación federal pues se había basado en que las cuestiones y derechos involucrados eran de naturaleza constitucional, cuando los cuestionamientos de la apelante se sustentan en la doctrina de la arbitrariedad al entender que se regularon sus honorarios en violación de mínimos legales que son de orden público.</p>","esNovedad":true,"fecha":1747796400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1747854093157,"usuarioCreacion":4,"fechaCreacion":1747850712353,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":137559,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":21270536,"numeroExpediente":23325,"anioExpediente":1992,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":9481,"descripcion":"ORDINARIO","idMateria":4,"tema":{"id":501,"codigo":"JUIORD"}},"caratula":"BANCO PEÑA S.