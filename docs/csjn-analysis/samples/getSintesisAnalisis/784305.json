[{"codigo":7843054,"analisisDocumental":{"id":784305,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"COMUNIDAD MAPUCHE TRYPAY ANTU Y OTRA c/ EN - INAI Y OTRO s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":5466,"titulo":"Validez de la prórroga de la competencia originaria de la Corte cuando dicha jurisdicción nace en razón de las personas","cabecilla":"<p>En un proceso iniciado por la Comunidad Mapuche Trypay Antú tendiente a que se ordene otorgar la escritura traslativa de dominio de las tierras comunitarias que reclama, la cámara ordenó que se integrara la litis con la Provincia de Río Negro, que se presentó y contestó la demanda. Posteriormente, el juez de primera instancia dispuso de oficio remitir las actuaciones a la Corte por resultar el supuesto de competencia originaria. El Tribunal declaró su incompetencia para entender por esa vía. Expresó que cuando dicha jurisdicción originaria nace <em>rationae personae </em>se trata de una prerrogativa de carácter personal que, como tal, puede ser renunciada expresa o tácitamente y que la conducta asumida por la provincia al presentarse en su carácter de demandada ante el juzgado en lo contencioso administrativo federal sin invocar dicha prerrogativa que ostenta por mandato constitucional y sin efectuar reserva alguna al respecto debe ser considerada como una clara renuncia a la misma y como una prórroga a favor de la justicia referida. </p>","esNovedad":true,"fecha":1684810800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1684943241332,"usuarioCreacion":11,"fechaCreacion":1684935300947,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":109543,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28201205,"numeroExpediente":20801,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"COMUNIDAD MAPUCHE TRYPAY ANTU Y OTRA c/ EN - INAI Y OTRO s/PROCESO DE CONOCIMIENTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"20801. "},"recurso":{"id":5715322,"expediente":{"id":28201205,"numeroExpediente":20801,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"