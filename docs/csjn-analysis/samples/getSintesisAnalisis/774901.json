[{"codigo":7749014,"analisisDocumental":{"id":774901,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"AAGESEN, HAYDEE MARGARITA Y OTRO s/ QUERELLA","alias":null,"caratula":"Recurso Queja Nº 1 - Recurso Queja Nº 4 - PROCESADO: AAGESEN , HAYDEE MARGARITA Y OTRO s/QUERELLA","inconstitucional":false,"falloDestacado":{"id":3963,"titulo":"Excepcionalidad de la doctrina de la arbitrariedad de sentencias","cabecilla":"<p>La c&aacute;mara de casaci&oacute;n desestim&oacute; el recurso con el que el querellante hab&iacute;a impugnado la sentencia que confirm&oacute; un sobreseimiento. Declar&oacute; luego inadmisible el recurso extraordinario por considerar que no hab&iacute;a planteado cuesti&oacute;n federal alguna, lo que motiv&oacute; la presentaci&oacute;n de un recurso de queja ante la Corte que fue desestimado. El Tribunal consider&oacute; que no se presentaba dicha cuesti&oacute;n federal sino que las cr&iacute;ticas del recurrente expresaban su desacuerdo con la actividad probatoria producida en el proceso, su valoraci&oacute;n por parte de los magistrados que intervinieron en &eacute;l, y la interpretaci&oacute;n del derecho com&uacute;n en la que fundaron sus pronunciamientos.&nbsp;Record&oacute; la Corte que&nbsp;el recurso extraordinario por arbitrariedad de sentencia es de naturaleza excepcional y&nbsp; no tiene por objeto corregir fallos equivocados, sino que s&oacute;lo pretende suplir defectos realmente graves de fundamentaci&oacute;n o razonamiento.</p>","esNovedad":true,"fecha":1652151600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1652271014470,"usuarioCreacion":11,"fechaCreacion":1652271005482,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":33930,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30222486,"numeroExpediente":9548,"anioExpediente":2008,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Recurso Queja Nº 4 - PROCESADO: AAGESEN , HAYDEE MARGARITA Y OTRO s/QUERELLA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"9548. "},"recurso":{"id":5135859,"expediente":{"id":30222486,"numeroExpediente":9548,"anioExpediente":2008,"tomoExpediente":null,"letraExpediente":null,"t