[{"codigo":7977593,"analisisDocumental":{"id":797759,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ENEQUE DE LA CRUZ, GIANCARLOS HECTOR c/ DIRECCION NACIONAL DE MIGRACIONES s/RECURSO DIRECTO A JUZGADO","inconstitucional":false,"falloDestacado":{"id":7143,"titulo":"Permanencia de migrantes: debido proceso en el procedimiento administrativo","cabecilla":"<p style=\"text-indent: 2em;\">La Dirección Nacional de Migraciones declaró irregular la permanencia en el país de un migrante de nacionalidad peruana y ordenó su expulsión del territorio nacional  por haber sido condenado por el delito de comercialización de estupefacientes.</p><p style=\"text-indent: 2em;\">La cámara declaró la nulidad de estas disposiciones y sostuvo que el acto había sido nulo por vulneración de las normas del debido proceso ya que la Dirección mencionada, luego de recaída la sentencia penal en contra del migrante, había dictado el acto de expulsión sin haber dado intervención previa al interesado para ejercer el derecho a ser oído y producir prueba, en total violación de lo dispuesto por el art. 61 de la ley 25.871.</p><p style=\"text-indent: 2em;\">La Corte revocó esta sentencia.</p><p style=\"text-indent: 2em;\">Señaló que no se encontraba controvertido que el migrante había contado con asistencia jurídica luego del dictado del acto por el que se dispuso su expulsión y que pudo cuestionarlo en las instancias administrativas y judiciales correspondientes.</p><p style=\"text-indent: 2em;\">Concluyó, por lo tanto, que no se había vulnerado el derecho al debido proceso en el procedimiento administrativo que culminó con el dictado del acto de expulsión. </p>","esNovedad":true,"fecha":1719889200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1720012205957,"usuarioCreacion":11,"fechaCreacion":1720012203907,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":121899,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31179654,"numeroExpediente":678,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":20,"codigo":"20","abreviatura":"FMZ","descripcion":"Justicia Federal de Mendoza","estado":0,"descripcionLarga":"FMZ - Justicia Federal de Mendoza"},"objetoJuicio":{"id":4188,"descripcion":"RECURSO DIRECTO A JUZGADO","idMateria":112,"tema":{"id":273,"codigo":"RDJ"}},"caratula":"FERNANDEZ GAMEZ, CARLOS c/ DIRECCION NACIONAL DE MIGRACIONES s/RECURSO DIRECTO A JUZGADO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"678. "},"recurso":{"id":5842284,"expediente":{"id":31179654,"numeroExpediente":678,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpedi