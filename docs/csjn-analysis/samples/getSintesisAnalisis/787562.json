azó el recurso por falta de fundamentación suficiente. Sostuvo, que a lo largo de su recurso, el Estado asevera que el límite de la edad previsto en el reglamento discutido resulta un recaudo objetivo y que se presume legítimo. Sin embargo, dicha afirmación se comprueba dogmática en la medida en que no brinda mayores argumentos y precisiones para refutar la inconstitucionalidad, por exceso reglamentario, que fue decidido en las anteriores instancias.</p>","esNovedad":true,"fecha":1695092400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1695233585886,"usuarioCreacion":11,"fechaCreacion":1695151832603,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":113604,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30098392,"numeroExpediente":41639,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"ALIAS, GUILLERMO HORACIO c/ EN-M JUSTICIA DDHH-DNRPA s/PROCESO DE CONOCIMIENTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"41639. "},"recurso":{"id":6186052,"expediente":{"id":30098392,"numeroExpediente":41639,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"}