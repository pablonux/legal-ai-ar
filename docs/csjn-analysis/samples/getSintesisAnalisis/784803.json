[{"codigo":7848035,"analisisDocumental":{"id":784803,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"REQUERIDO: MANSILLA, NESTOR EZEQUIEL Y OTROS s/EXTRADICION","inconstitucional":false,"falloDestacado":{"id":5581,"titulo":"Extradición y menores de edad","cabecilla":"<p>En un proceso de extradición, la defensa se agravió en esta instancia porque los intereses de los hijos menores a cargo de los requeridos se verían gravemente afectados ante la separación que implica la concesión de la extradición de sus progenitores sin contemplación alguna a sus necesidades, endilgándole al a quo la omisión de ponderar cuestiones humanitarias que consideró presentes en el caso y que ameritaban la denegatoria del pedido o, cuanto menos, su aplazamiento. Para la Corte, el agravio es infundado ya que, al así argumentar, quienes recurrieron soslayaron tener en cuenta que en <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=339&amp;pagina=94\">Fallos: 339:94 (“Caballero López”)</a> el Tribunal ya desestimó un agravio sustancialmente análogo. Ello, al señalar que el correspondiente instrumento internacional no contempla, entre las causales para \"no conceder\" (artículos 5°, 9°, 10 y 12), \"rehusar\" (artículo 7°) o \"denegar\" (artículo 11) la extradición, razones de índole humanitaria como las que se invocan sino sólo la posibilidad de \"aplazar la entrega del reclamado\" si existieran \"circunstancias excepcionales de carácter personal y suficientemente serias\". En virtud de ello, entre otras consideraciones, el Tribunal confirmó la procedencia de la extradición.</p>","esNovedad":true,"fecha":1687402800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1700076882997,"usuarioCreacion":11,"fechaCreacion":1687459236434,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":110058,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30278739,"numeroExpediente":10597,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":14,"codigo":"14","abreviatura":"FCR","descripcion":"Justicia Federal de Comodoro Rivadavia","estado":0,"descripcionLarga":"FCR - Justicia Federal de Comodoro Rivadavia"},"objetoJuicio":{"id":4561,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"REQUERIDO: MANSILLA, NESTOR EZEQUIEL Y OTROS s/EXTRADICION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10597. "},"recurso":{"id":5448629,"expediente":{"id":30278739,"numeroExpediente":10597,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":14,"codigo":"14","abreviatura":"FCR","descripcion":"Justicia Federa