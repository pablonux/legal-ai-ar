[{"codigo":8153545,"analisisDocumental":{"id":815354,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"FERNANDEZ PASTOR MIGUEL ANGEL c/ ANSES s/AMPAROS Y SUMARISIMOS","inconstitucional":false,"falloDestacado":{"id":9961,"titulo":"Movilidad de las jubilaciones y pensiones: facultades del legislador","cabecilla":"<p style=\"text-indent: 2em;\">El actor promovió una acción de amparo dirigida a que se declare la inconstitucionalidad de los artículos 1°, 2° y 3° de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-27426-305214/texto\">ley 27.426</a>, que habían modificado el régimen para el cálculo del nivel inicial de las prestaciones jubilatorias y su posterior movilidad.</p><p style=\"text-indent: 2em;\"> La cámara hizo lugar al cuestionamiento con respecto al artículo 2° y las partes interpusieron recurso extraordinario.</p><p style=\"text-indent: 2em;\">La Corte revocó este pronunciamiento.</p><p style=\"text-indent: 2em;\">Por un lado, sostuvo que la ley cuestionada <b>no había vulnerado un derecho adquirido</b> por los beneficiarios pues, para ese entonces, el derecho a obtener o percibir el aumento de la ley anterior aún no había nacido ni se contaba con los elementos necesarios para ello, dado que no se había completado el semestre al que hacía referencia la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-26417-145867/actualizacion\">ley 26.417</a> para el cálculo de las variaciones necesarias para obtener el coeficiente de reajuste a aplicar. Los autores de dicha ley habían elegido dos épocas del año para reajustar los haberes y decidieron utilizar la frase “para los haberes que se devenguen en los meses de marzo y septiembre” por lo que el reajuste previsto para marzo de 2018 era un efecto pendiente del anterior régimen que podía ser modificado antes de esa fecha, sin que pudieran invocarse a su respecto derechos adquiridos.</p><p style=\"text-indent: 2em;\">Afirmó que no existía una aplicación retroactiva de la ley 27.426 cuando dispuso una nueva fórmula de movilidad que consideraba un período en el cual regía la ley 26.417 ya que aquella regló las consecuencias aún no cumplidas de la anterior legislación.  </p><p style=\"text-indent: 2em;\">Por otro lado, en cuanto a la validez constitucional de la variable de reajuste establecida por el artículo 1° de la ley 27.426, el Tribunal señaló que las <b>objeciones planteadas por el actor constituían meras discrepancias</b> con los argumentos expresados por la cámara. Efectivamente, los agravios invocados no bastaban para demostrar el gravamen que consideraba le ocasionaba la norma impugnada cuya nueva fórmula de movilidad no generó un congelamiento del haber previsional.</p><p style=\"text-indent: 2em;\">La Corte aclaró que la decisión se enrola dentro de los criterios jurisprudenciales que ella ha fijado, aplicado y mantenido a lo largo de diferentes precedentes en relación con las distintas modificaciones que se producen en los métodos de movilidad previstos para los haberes previsionales. Ratifica así la garantía constitucional de jubilaciones y pensiones móviles, reafirma que constituye una facultad del Congreso de la Nación efectuar modificaciones al régimen de movilidad que no hieran de modo sustancial su contenido económico, y reitera, por ende, la inexistencia de un derecho adquirido a mantener determinado régimen de movilidad.</p>","esNovedad":true,"fecha":1764817200000,"relevancia":3,"usuarioModificacion":11,"fechaModificacion":1764873916250,"usuarioCreacion":11,"fechaCreacion":1764873910257,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":143718,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31095924,"numeroExpediente":138932,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":5,"codigo":"5","abreviatura":"CSS","descripcion":"Camara Federal de la Seguridad Social","estado":0,"descripcionLarga":"CSS - Camara Federal de la Seguridad Social"},"objetoJuicio":{"id":10614,"descripcion":"AMPAROS Y SUMARISIMOS","idMateria":6,"tema":{"id":540,"codigo":"PREV"}},"caratula":"FERNANDEZ PASTOR MIGUEL ANGEL c/ ANSES s/AMPAROS Y SUMARISIMOS","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":32504379,"numeroExpediente":138932,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":5,"codigo":"5","abreviatura":"CSS","descripcion":"Camara Federal de la Seguridad Social","estado":0,"descripcionLarga":"CSS - Camara Federal de la Seguridad Social"},"objetoJuicio":{"id":10614,"descripcion":"AMPAROS Y SUMARISIMOS","idMateria":6,"tema":{"id":540,"codigo":"PREV"}},"caratula":"Recurso Queja Nº 2 - FERNANDEZ PASTOR MIGUEL ANGEL c/