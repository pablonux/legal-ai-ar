[{"codigo":7835885,"analisisDocumental":{"id":783588,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"CELLO MARIA MONICA c/ EN-M° SEGURIDAD-DISP 268/09 212/10 s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":5342,"titulo":"Sobre el carácter remunerativo de los suplementos salariales","cabecilla":"<p>La actora promovió demanda contra el Estado Nacional –Ministerio de Seguridad, Justicia y Derechos Humanos-, con el objeto de que se incorporen al rubro sueldo las sumas de dinero que percibía, desde el año 1991, bajo el rubro “Estímulo, Contracción al Trabajo, Presentismo, Incentivo”. Rechazado su planteo, recurrió por la vía extraordinaria. La Corte falló a favor de la accionante ordenando dictar un nuevo pronunciamiento. Entre los argumentos vertidos para resolver la cuestión, recordó que según la jurisprudencia del Tribunal poseen carácter remunerativo aquellos adicionales cuyo pago no reconoce otra causa que la retribución por tareas desempeñadas genéricamente por el personal, en la medida en que se dispuso su pago habitual y general juntamente con los haberes mensuales. Sobre dicha base, consideró el Tribunal, que <em>la naturaleza jurídica de un suplemento salarial se determina objetivamente, de acuerdo al modo implementado, la contraprestación que retribuye y la finalidad que persigue su concreción, sin depender de las necesidades presupuestarias</em> (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=326&amp;pagina=4076\">326:4076</a>).</p>","esNovedad":true,"fecha":1682391600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1682449756660,"usuarioCreacion":4,"fechaCreacion":1682448080494,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":108717,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":11145224,"numeroExpediente":12077,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"CELLO MARIA MONICA c/ EN-M° SEGURIDAD-DISP 268/09 212/10 s/PROCESO DE CONOCIMIENTO","verificacionMesa":"M","etiqueta":null,"hijos":[{"id":28221190,"numeroExpediente":12077,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en 