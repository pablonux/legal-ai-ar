[{"codigo":7958063,"analisisDocumental":{"id":795806,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":80008,"valor":"RECHAZA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231243,"fechaModLong":201008231243,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"LA RIOJA, PROVINCIA DE c/ ESTADO NACIONAL s/ACCION DECLARATIVA DE CERTEZA","inconstitucional":false,"falloDestacado":{"id":6681,"titulo":"Rechazo de la acción declarativa de certeza de la Provincia de La Rioja por inexistencia de un “caso”","cabecilla":"<p style=\"text-indent:2em\">La Provincia de La Rioja promovió una demanda declarativa de certeza contra el Estado Nacional con el objeto de poner fin al estado de incertidumbre derivado –según alegó– de la manifiesta inconstitucionalidad del decreto de necesidad y urgencia 70 /2023, publicado en el Boletín Oficial el 21 de diciembre de 2023.</p><p style=\"text-indent:2em\">La Corte rechazó <em>in limine</em> la demanda promovida.  Para resolver de ese modo consideró, entre otras razones, que el control encomendado a la justicia sobre las actividades ejecutiva y legislativa requiere inexorablemente de la existencia de un \"caso\" donde se debata la determinación de un derecho entre partes adversas, fundado en un interés específico, concreto y atribuible en forma determinada al litigante.</p><p style=\"text-indent:2em\">En tal sentido recordó que una demanda declarativa solo da lugar a una causa o caso contencioso si la parte actora pone a decisión de la Corte una controversia de intereses actual y concreta, no meramente posible o hipotética.</p><p style=\"text-indent:2em\">En concreto, consideró el Tribunal que, en la causa, la demanda no ha definido ningún interés propio de la provincia (como persona jurídica diferenciada de sus vecinos) que se encuentre afectado de manera actual y concreta.</p><p style=\"text-indent:2em\">Por  último también desestimó por improcedente el intento de fundar la legitimación activa en el artículo 128 de la Constitución. A tal fin consideró que, cualquiera sea la interpretación que se adopte de dicha norma, ella no puede conducir a una disolución de los presupuestos establecidos en la misma Constitución para habilitar el ejercicio de la atribución jurisdiccional de la Corte y de los demás tribunales federales.</p>","esNovedad":true,"fecha":1713236400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1713379213793,"usuarioCreacion":11,"fechaCreacion":1713291279634,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":119598,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38580141,"numeroExpediente":2847,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION DECLARATIVA DE CERTEZA","idMateria":0,"tema":null},"caratula":"LA RIOJA, PROVINCIA DE c/ ESTADO NACIONAL s/ACCION DECLARATIVA DE CERTEZA","verificacionMesa":"N","etiqueta":