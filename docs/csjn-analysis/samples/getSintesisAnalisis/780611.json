[{"codigo":7806113,"analisisDocumental":{"id":780611,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"LASO JOSE LUIS Y OTROS c/ TRANSPORTES METROPOLITANOS GENERAL SAN MARTIN S.A. Y OTROS s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","alias":null,"caratula":"Recurso Queja Nº 1 - LASO JOSE LUIS Y OTRO Y OTROS c/ TRANSPORTES METROPOLITANOS GENERAL ROCA SA  Y OTROS s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","inconstitucional":false,"falloDestacado":{"id":4882,"titulo":"Responsabilidad del concesionario ferroviario ante la rescisión del contrato","cabecilla":"<p>La cámara rechazó la demanda planteada en contra del Estado Nacional y de la Comisión Nacional Reguladora del Transporte (CNRT) por los daños causados en el accidente en el que uno de los demandantes fue despedido de la formación ferroviaria en la que viajaba pero mantuvo la condena en contra de la ex concesionaria. Basó su decisión en que, según el contrato de concesión, los daños como los reclamados eran responsabilidad exclusiva del concesionario que, como transportista, había incurrido en el supuesto de responsabilidad objetiva. La Corte dejó sin efecto este pronunciamiento. Señaló que había omitido considerar que el accidente fue posterior a la sanción del decreto que daba por terminada la concesión ferroviaria. Expresó que, cualquiera fuera el alcance de las cláusulas sobre responsabilidad previstas en el contrato de concesión, para decidir la cuestión, la cámara no pudo obviar que al momento del accidente el propio Estado Nacional ya había decretado su rescisión y que por ese entonces la prestación del servicio todavía no había sido transferida a Unidad de Gestión Operativa (UGOFE)</p>","esNovedad":true,"fecha":1671073200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1671129787933,"usuarioCreacion":11,"fechaCreacion":1671129479970,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":105558,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33862864,"numeroExpediente":55459,"anioExpediente":2006,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":9189,"descripcion":"DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 1 - LASO JOSE LUIS Y OTROS c/ TRANSPORTES METROPOLITANOS GENERAL SAN MARTIN S.A. Y OTROS s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"55459. "},"recurso":{"id":5647965,"expediente":{"id":33862864,