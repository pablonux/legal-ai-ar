[{"codigo":8005023,"analisisDocumental":{"id":800502,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"CHIEMENA, UHIARA c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO PARA JUZGADOS","inconstitucional":false,"falloDestacado":{"id":7542,"titulo":"Notificación de la disposición que ordena la expulsión del migrante","cabecilla":"<p style=\"text-indent:2em\">La cámara declaró la nulidad de todo lo actuado y dispuso que la Dirección Nacional de Migraciones debía arbitrar los medios necesarios para notificar personalmente al actor de lo resuelto en la disposición que ordenaba su expulsión del territorio nacional. Entendió que había quedado acreditado que el mandato otorgado por el migrante a la Comisión del Migrante de la Defensoría General de la Nación había sido conferido expresamente a fin de que pudiera ejercer su defensa ante la Dirección mencionada y en los términos del art. 32 del Reglamento de Procedimientos Administrativos pero que dicha defensoría carecía de facultades para cuestionar judicialmente la expulsión del migrante.</p><p style=\"text-indent:2em\">La Corte revocó este pronunciamiento.</p><p style=\"text-indent:2em\">Señaló que el art. 54 de la Ley de Migraciones establece en forma categórica no solo la obligación del migrante de informar su domicilio en la República Argentina sino que también dispone que, en toda presentación ante las autoridades de la Dirección Nacional de Migraciones, se debe constituir domicilio. A su vez, a partir del ordenamiento jurídico aplicable en la materia se considera válida la notificación cursada en el último domicilio constituido o aquella efectuada mediante alguna de las formas previstas en la reglamentación supletoria. No surge entonces del mencionado artículo, ni de ningún otro de los contenidos por la ley migratoria que actos como los impugnados en autos deban ser notificados en forma personal al migrante.</p><p style=\"text-indent:2em\">Concluyó así el Tribunal que la expulsión había sido notificada de acuerdo a lo establecido en el ordenamiento jurídico migratorio y que no se habían acompañado elementos objetivos suficientes para demostrar una lesión a la garantía del debido proceso y al derecho de defensa en juicio, por lo que no resultaba ajustado a las normas aplicables al caso ordenar una nueva notificación de esa decisión.</p>","esNovedad":true,"fecha":1725937200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1726080246940,"usuarioCreacion":4,"fechaCreacion":1725999000010,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":126682,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30079749,"numeroExpediente":40988,"anioExpediente":2017,"tomoExpediente":null,"letraExped