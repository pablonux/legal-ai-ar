[{"codigo":8034175,"analisisDocumental":{"id":803417,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":40,"codigoRelacion":80040,"valor":"PROCEDIMIENTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201512101503,"fechaModLong":201512101503,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"SOCOLINSKY MARIO BERNARDO Y OTROS c/ AMAIZON BEATRIZ Y OTROS s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":7842,"titulo":"Expresiones amparadas por la libertad de expresión en un informe periodístico","cabecilla":"<p style=\"text-indent: 2em;\">La cámara hizo lugar al reclamo de daños y perjuicios derivados de la emisión de unos informes de investigación periodística que giraban en torno a la presunta aparición de médicos sin títulos habilitantes en un programa de la televisión pública conducido por un conocido pediatra, como también acerca de la adquisición del predio en el que funcionaba la sede principal de la fundación a cargo de dicho profesional.</p><p style=\"text-indent: 2em;\">La Corte revocó esta sentencia y, en uso de las atribuciones conferidas por el artículo 16, segundo párrafo, de la ley 48, <b>rechazó la demanda</b>.</p><p style=\"text-indent: 2em;\">Comenzó expresando que resultaba de aplicación la <b>doctrina de la real malicia</b> por lo que correspondía a la parte actora demostrar que la información difundida era falsa y que el emisor de esa información conocía la falsedad de la noticia, o bien había obrado con notoria despreocupación por comprobar su veracidad.</p><p style=\"text-indent: 2em;\">Ante el cuestionamiento de la metodología empleada  - con la participación de una productora que simuló el rol de médica- , el Tribunal expresó que ello obstaba a la calificación de la noticia como falsa ya que dicho mecanismo había sido exhibido en forma pormenorizada en el programa cuestionado. </p><p>     Concluyó la Corte que todas las expresiones críticas guardaban razonable vinculación con los asuntos de interés público investigados y buscaban brindar elementos de juicio a la audiencia y no agraviar gratuitamente la figura del actor. Se trataba, en definitiva, de puntos de vista y conjeturas sobre el rigor de los procedimientos internos para seleccionar a los profesionales invitados a brindar información a la comunidad sobre temas de salud en un medio de comunicación social.</p><p>     Finalmente, con respecto a la transferencia del inmueble y la actividad de la fundación afirmó que tampoco podía afirmarse que los demandados hubieran difundido información inexacta con conocimiento de su falsedad o con evidente desinterés por su veracidad.</p>","esNovedad":true,"fecha":1730775600000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1730847611766,"usuarioCreacion":11,"fechaCreacion":1730847609085,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":130038,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":15033931,"numeroExpediente":16814,"anioExpediente":2005,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":8520,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"SOCOLINSKY MARIO BERNARDO Y OTROS c/ AMAIZON BEATRIZ Y OTROS s/DAÑOS Y PERJUICIOS","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"16814. "},"recurso":{"id":5918818,"expediente":{"id":15033931,"numeroExpediente":16814,"anioExpediente":2005,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":8520,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"SOCOLINSKY MARIO BERNARDO Y OTROS c/ AMAIZON BEATRIZ Y OTROS s/DAÑOS Y PERJUICIOS","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"16814. "},"tipoRecurso":{"id":1166,"codigo":"REX","descripcion":"RECURSO EXTRAORDINARIO"},"claveRecurso":"CIV 016814/2005/CS001","identificacionExpediente":"CIV 016814/2005/CS001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":10,"nombreUsuario":"27179020438","apellido":"Messuti","nombre":"Mariana","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583843772000,"nombreUsuarioMigrado":null,"codigo":"JURW6J","mail":"