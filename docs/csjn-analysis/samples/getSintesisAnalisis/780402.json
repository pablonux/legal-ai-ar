[{"codigo":7804023,"analisisDocumental":{"id":780402,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"GUIZZO, RICARDO A. Y OTS c/ YPF S,E P/ ORD- s/Proceso de Conocimiento - Ordinarios","alias":null,"caratula":"Recurso Queja Nº 2 - GUIZZO, RICARDO A. Y OTS c/ YPF S,E P/ ORD- s/Proceso de Conocimiento - Ordinarios","inconstitucional":false,"falloDestacado":{"id":4845,"titulo":"Fijación de intereses y límites de la jurisdicción de la  cámara","cabecilla":"<p>La cámara de apelaciones consideró que atento a que en la sentencia de primera instancia, que había pasado en autoridad de cosa juzgada, no se había determinado el interés que devengaba el capital, entendió que era obligatorio, en uso del art. 622 del código civil anterior, aplicar en el caso el plenario de la cámara  y estableció un interés igual a la tasa activa del Banco de la Nación Argentina para las operaciones de descuento en documentos comerciales. <em>La Corte, por mayoría, dejó sin efecto este pronunciamiento</em>. Recordó que la jurisdicción de los tribunales de segunda instancia está <em>limitada por el alcance de los recursos concedidos</em> que determinan el ámbito de su competencia decisoria, y que la prescindencia de tal limitación causa agravio a la garantía constitucional de la defensa en juicio. Señaló que al expedirse respecto de la tasa de interés aplicable, el tribunal de alzada abordó una cuestión que no le había sido planteada, lo que se encuentra vedado por el ordenamiento procesal.</p>","esNovedad":true,"fecha":1669258800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1669389880003,"usuarioCreacion":11,"fechaCreacion":1669316744742,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":105281,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32099688,"numeroExpediente":48618,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":1999,"descripcion":"IMPUGNACION de ACTO ADMINISTRATIVO","idMateria":112,"tema":{"id":6,"codigo":"CONTADM"}},"caratula":"XU, ZHENZHEN c/ DIRECCION NACIONAL DE MIGRACIONES s/IMPUGNACION de ACTO ADMINISTRATIVO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"48618. "},"recurso":{"id":5614234,"expediente":{"id":32099688,"numeroExpediente":48618,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":