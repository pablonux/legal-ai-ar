[{"codigo":7848723,"analisisDocumental":{"id":784872,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 3 - ALARCON JUAN ESTEBAN c/ GONCALVEZ NESTOR ABEL Y OTRO s/ACCIDENTE - ACCION CIVIL","inconstitucional":false,"falloDestacado":{"id":5541,"titulo":"La imprescindible acreditación del nexo causal para atribuir responsabilidad a la ART","cabecilla":"<p>La cámara hizo lugar a la acción que, con fundamento en el derecho civil, entabló el conductor de un taxi contra su empleador a raíz de la incapacidad que padece con motivo de un accidente vial. Condenó también en forma solidaria a la ART, quien interpuso un recurso extraordinario. <b>La Corte revocó el pronunciamiento invocando la doctrina de la arbitrariedad</b> y la exigencia de la debida fundamentación. Señaló que la sentencia se limitaba a formular elucubraciones genéricas acerca de las obligaciones de las aseguradoras de riesgos del trabajo sin precisar cuál sería el nexo de causalidad adecuado entre el siniestro y la conducta de la recurrente. Recordó que si la acción pretende la reparación integral de los daños producidos a raíz de un accidente, resulta esencial dilucidar su modo de ocurrencia a los efectos de determinar su adecuado nexo de causalidad con los presuntos incumplimientos de la demandada para poder atribuirle, eventualmente, responsabilidad civil. Agregó que la sola circunstancia de que el trabajador hubiera sufrido daños como consecuencia de su labor no autoriza a concluir sin más que la aseguradora incumplió con sus deberes de prevención y vigilancia a los efectos de la eventual imputación de responsabilidad.</p>","esNovedad":true,"fecha":1686625200000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1686681769142,"usuarioCreacion":11,"fechaCreacion":1686680207609,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":110124,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33943401,"numeroExpediente":42404,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9702,"descripcion":"ACCIDENTE - ACCION CIVIL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 3 - ALARCON JUAN ESTEBAN c/ GONCALVEZ NESTOR ABEL Y OTRO s/ACCIDENTE - ACCION CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"42404. "},"recurso":{"id":5657721,"expediente":{"id":33943401,"numeroExpediente":42404,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","a