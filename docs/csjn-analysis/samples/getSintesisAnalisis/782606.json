[{"codigo":7826065,"analisisDocumental":{"id":782606,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":80003,"valor":"REVOCA PARCIALMENTE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051034,"fechaModLong":201008181300,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"ZARATE, ENRIQUE AUGUSTO c/ SENASA s/AMPARO AMBIENTAL","alias":null,"caratula":"ZARATE, ENRIQUE AUGUSTO c/ SENASA s/AMPARO AMBIENTAL","inconstitucional":false,"falloDestacado":{"id":5181,"titulo":"Determinación de las políticas relativas al control sanitario de los alimentos","cabecilla":"<p>Se promovió un amparo contra el Servicio Nacional de Sanidad y Calidad Agroalimentaria para que se instrumenten controles períodicos en el Mercado de Concentración Fisherton y el Mercado de Productores de Rosario sobre frutas, verduras y hortalizas provenientes de otras provincias argentinas, a efectos de detectar la presencia de biocidas, plaguicidas u otros agrotóxicos. La cámara hizo lugar al pedido pero, disconforme con este pronunciamiento, la demandada interpuso el recurso extraordinario. <b>La Corte revocó la sentencia en cuanto ordenó realizar un mínimo de seis inspecciones y veinticuatro monitoreos al año</b>.  Para ello, consideró que no corresponde a los magistrados de la causa establecer el alcance del control, lo que ocurre con la indicación de las condiciones que debe reunir el plan a llevar a cabo por el SENASA, incluyendo específicamente una cantidad mínima de seis inspecciones y veinticuatro monitoreos al año. En ese sentido entendió que, si bien es cierto que, una vez verificada la omisión de un deber legal, la sentencia puede condenar a la demandada a poner fin a dicha situación , tal circunstancia no justifica que se ordene el modo preciso en que debe realizar su tarea de control sobre los alimentos de origen vegetal en los mercados antes mencionados.</p>","esNovedad":true,"fecha":1679367600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1679501584664,"usuarioCreacion":4,"fechaCreacion":1679431077582,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":107603,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28618522,"numeroExpediente":26209,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":1924,"descripcion":"AMPARO AMBIENTAL","idMateria":112,"tema":{"id":0,"codigo":"AMPAROS"}},"caratula":"ZARATE, ENRIQUE AUGUSTO c/ SENASA s/AMPARO AMBIENTAL","verificacionMesa":"N","etiqueta":n