[{"codigo":7979524,"analisisDocumental":{"id":797952,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"RODRIGUEZ, JONATHAN DAVID c/ SECRETARIA DE ESTADO DE LA NIÑEZ, ADOLESCENCIA Y FAMILIA s/APELACION","inconstitucional":false,"falloDestacado":{"id":7062,"titulo":"Omisión de cuestiones conducentes para la correcta solución del litigio","cabecilla":"<p style=\"text-indent:2em\">El actor - beneficiario de un programa de becas- promovió acción de amparo contra la Provincia de Río Negro –Secretaría de Estado de la Niñez, Adolescencia y Familia- con el objeto de volver a prestar funciones en la administración pública y que se declare la inconstitucionalidad del art. 4°, inc. c, del Estatuto General y Básico para el Personal de la Administración Pública de la demandada, aprobado mediante la ley provincial 3487, en tanto establece que “no podrá ingresar [...] c) El que haya sido condenado por delito doloso o por delito en perjuicio de la administración pública nacional, provincial, municipal o del Gobierno de la Ciudad de Buenos Aires”.</p><p style=\"text-indent:2em\">Planteó que la norma impugnada resulta contraria a la garantía de igualdad, conculca los derechos a trabajar, a la estabilidad, de propiedad y a la integridad personal, y se opone al principio de separación de poderes y funciones de gobierno.</p><p style=\"text-indent:2em\">El Superior Tribunal de Justicia de la Provincia rechazó la demanda. Contra esta decisión la parte actora interpuso el recurso extraordinario cuya denegación motivó la presente queja.</p><p style=\"text-indent:2em\">La Corte declaró procedente la queja y dejó sin efecto la sentencia por considerar que el Superior Tribunal local, al decidir mediante una simple remisión a los argumentos de un precedente propio, omitió examinar los planteos del actor relacionados con el alcance del art. 50 de la Constitución local y la inconstitucionalidad de la ley local en relación con sus circunstancias particulares.</p><p style=\"text-indent:2em\">La respuesta a esos planteos resultaba necesaria, según la Corte, a poco que se repare en las diferencias que presenta el caso en examen con el precedente en cuestión. En efecto, en este último, el máximo tribunal provincial motivó la decisión de convalidar la separación del cargo del actor en la existencia de una condena por comisión de delitos contra la administración pública -supuesto previsto constitucional y legalmente en el ámbito provincial como impedimento para acceder a un cargo público-. Mientras que en esta causa, por el contrario, la decisión administrativa que se cuestiona fue causada por las condenas a veinte (20) días de prisión en suspenso y a tres (3) años de prisión en suspenso por los delitos de robo en grado de tentativa y de robo con arma de fuego no apta para el disparo, en concurso ideal con robo en poblado y en banda y lesiones leves, respectivamente.</p><p style=\"text-indent:2em\">En consecuencia, según el Tribunal, la existencia de condenas por delitos dolosos distintos de los crímenes contra la administración pública obligaba al tribunal a expedirse expresamente respecto de los planteos del actor –en particular el relativo a la inconstitucionalidad de la ley 3487- pues los delitos por él cometidos no encuadran en el impedimento para la función pública previsto expresamente en la Constitución local.</p>","esNovedad":true,"fecha":1719284400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1719420470237,"usuarioCreacion":4,"fechaCreacion":1719343377338,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":122100,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34118355,"numeroExpediente":2066,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"RODRIGUEZ, JONATHAN DAVID c/ SECRETARIA DE ESTADO DE LA NIÑEZ, ADOLESCENCIA Y FAMILIA s/APELACION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2066. "},"recurso":{"id":5695850,"expediente":{"id":34118355,"numeroExpediente":2066,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"RODRIGUEZ, JONATHAN DAVID c/ SECRETARIA DE