[{"codigo":7964913,"analisisDocumental":{"id":796491,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"FROMETA ULLOA, MARCO DOROTEO c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":6843,"titulo":"Migraciones: oportunidad para la invocación de la dispensa por razones de reunificación familiar","cabecilla":"<p style=\"text-indent: 2em;\">La cámara declaró la nulidad de la expulsión del actor del territorio nacional por considerar que las autoridades administrativas habían omitido expedirse acerca de la afectación que esa medida de expulsión podría provocar en los hijos de su pareja, menores de edad.</p><p style=\"text-indent: 2em;\">La Corte revocó la sentencia. Señaló que del examen del expediente administrativo no se desprendía que el migrante hubiera peticionado el otorgamiento de la dispensa por razones 