[{"codigo":7794994,"analisisDocumental":{"id":779499,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"RIZZO, CARLOS ADRIAN c/ MINISTERIO DE HACIENDA s/JUICIO SUMARISIMO","alias":null,"caratula":"Recurso Queja Nº 2 - RIZZO, CARLOS ADRIAN c/ MINISTERIO DE HACIENDA s/JUICIO SUMARISIMO","inconstitucional":false,"falloDestacado":{"id":4702,"titulo":"Denegatoria del fuero federal y cuestionamiento de la reinstalación dispuesta en una relación de empleo público","cabecilla":"<p>La Cámara Nacional del Trabajo hizo lugar a la medida cautelar solicitada para que se disponga la reinstalación del actor a su puesto de trabajo al entender que se había demostrado que gozaba de tutela sindical dada su condición de candidato a cargos gremiales. El Estado Nacional dedujo recursos extraordinarios y sostuvo que se había desconocido su prerrogativa de acceder al fuero contencioso administrativo en razón de la persona. La Corte consideró que existía denegación del fuero federal teniendo en cuenta que no corresponde equiparar a los tribunales nacionales ordinarios con los federales para dirimir cuestiones de competencia ya que no puede soslayarse que el carácter nacional de los tribunales ordinarios de la Capital Federal es meramente transitorio. Resolvió que la causa debía tramitar ante la Justicia Nacional en lo Contencioso Administrativo Federal al considerar determinantes que el Estado Nacional tiene derecho a litigar en jurisdicción federal, que no existe en la jurisdicción federal de la Ciudad Autónoma de Buenos Aires un tribunal con específica competencia en asuntos laborales y la condición del actor de agente contratado “con relación de empleo público”. Además, consideró el Tribunal que, al admitir y ordenar la inmediata reinstalación del accionante en su puesto, la cámara omitió considerar otras situaciones cuya ponderación resultaba conducente para resolver el punto.</p>","esNovedad":true,"fecha":1666666800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1666874599501,"usuarioCreacion":11,"fechaCreacion":1666723720667,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":104823,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33461979,"numeroExpediente":38185,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":1