[{"codigo":7888774,"analisisDocumental":{"id":788877,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"S., S. S c/ EN-M INTERIOR OP Y V-DNM S7 RECURSO DIRECTO DNM","alias":"S., S. S c/ EN-M INTERIOR OP Y V-DNM S7 RECURSO DIRECTO DNM","caratula":"SALDAÑA SHUPINGAHUA, SALOME c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":5964,"titulo":"Arbitrariedad de la sentencia que declaró la nulidad de una expulsión del país","cabecilla":"<p>La Dirección Nacional de Migraciones declaró irregular la permanencia de la actora en el país y ordenó su expulsión al tener en cuenta que había sido condenada, en su país de procedencia, a la pena de quince años de prisión al ser hallada responsable del delito de homicidio agravado. La cámara declaró la nulidad de estas disposiciones ya que consideró que la autoridad mencionada había omitido expedirse respecto de la dispensa por razones humanitarias invocada por la migrante - mujer trans- con sustento en el artículo 29, in fine, de la ley 25.871 y respecto al riesgo inminente que podría correr su vida, su integridad física y su seguridad personal si se la expulsaba del territorio nacional. La Corte revocó esta sentencia y expresó que los argumentos defensivos se habían orientado exclusivamente a sostener que el acto de expulsión afectaba su derecho a trabajar, el fin resocializador de la pena y que desconocía el principio <em>ne bis in idem</em>. No tuvo en cuenta entonces el pronunciamiento apelado que se trataba de alegaciones cronológicamente posteriores al dictado de los actos cuestionados, por lo que no era posible endilgar a la autoridad administrativa la falta de consideración de razones respecto de las cuales carecía de conocimiento al momento de resolver la situación de la migrante.</p>","esNovedad":true,"fecha":1696302000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1696420872539,"usuarioCreacion":11,"fechaCreacion":1696420857366,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":114299,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32215620,"numeroExpediente":53674,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"S. S., S. c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":