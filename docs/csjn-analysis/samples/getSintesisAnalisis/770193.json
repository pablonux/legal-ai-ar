[{"codigo":7701933,"analisisDocumental":{"id":770193,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"ARTIGAS, VALENTíN c/ ESTADO NACIONAL PREFECTURA NAVAL ARGENTINA s/ ACCIDENTE EN EL ÁMBITO MILITAR Y FUERZAS DE SEGURIDAD","alias":null,"caratula":"ARTIGAS, VALENTIN c/ ESTADO NACIONAL PREFECTURA NAVAL ARGENTINA s/ACCIDENTE EN EL AMBITO MILITAR Y FZAS DE SEG","inconstitucional":false,"falloDestacado":{"id":2941,"titulo":"Fuerzas de seguridad: reclamo por daños y perjuicios fundado en las normas del derecho común por lesiones no provenientes de riesgos característicos de la función","cabecilla":"<p>La c&aacute;mara rechaz&oacute; el reclamo indemnizatorio fundado en las normas del derecho com&uacute;n contra el Estado Nacional promovido por un agente que cumpl&iacute;a funciones en la Prefectura Naval Argentina por los da&ntilde;os y perjuicios padecidos en dos intentos de asalto, uno ocurrido mientras cumpl&iacute;a con sus tareas y otro cuando se dirig&iacute;a a prestar servicio. Para as&iacute; decidir, consider&oacute; que no era procedente el reclamo indemnizatorio fundado en normas de derecho com&uacute;n pues los da&ntilde;os sufridos eran consecuencia de episodios ocurridos en cumplimiento de funciones atinentes a la fuerza a la que perteneci&oacute;. Contra dicha sentencia el agente interpuso el recurso extraordinario. La Corte declar&oacute; admisible el recurso,&nbsp;revoc&oacute; la sentencia y orden&oacute; dictar un nuevo pronunciamiento. En sus fundamentos, expres&oacute; que la c&aacute;mara hab&iacute;a omitido considerar que se hab&iacute;a probado que las lesiones sufridas a manos de terceras personas no fueron consecuencia de los riesgos caracter&iacute;sticos de la funci&oacute;n de polic&iacute;a de seguridad, sino que se&nbsp;derivaron&nbsp;de hechos delictivos comunes de los cuales el actor fue v&iacute;ctima, lo que resultaba insoslayable para decidir si correspond&iacute;a la aplicaci&oacute;n del criterio de la mayor&iacute;a de la Corte en el precedente &ldquo;<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verUnicoDocumentoLink.html?idAnalisis=637481&amp;cache=1634910245548\">Leston</a>&rdquo;. A&ntilde;adi&oacute; que ello llevaba a la descalificaci&oacute;n del pronunciamiento impugnado con arreglo a su doctrina de la arbitrariedad de sentencias.</p>","esNovedad":true,"fecha":1634785200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1634924761661,"usuarioCreacion":11,"fechaCreacion":1634910252511,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":32290,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":16048619,"numeroExpediente":9980,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"t