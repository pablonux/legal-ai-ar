[{"codigo":8098392,"analisisDocumental":{"id":809839,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":80013,"valor":"DECLARA INOFICIOSO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009221235,"fechaModLong":201009221235,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - EXPLORA SA c/ EN-SECRETARIA DE GOBIERNO DE ENERGIA s/INC APELACION","inconstitucional":false,"falloDestacado":{"id":8821,"titulo":"Derogación expresa de un régimen promocional y pronunciamiento inoficioso","cabecilla":"<p style=\"text-indent:2em\">La cámara reconoció a la empresa actora el derecho a recibir, precautoriamente, un cupo mínimo de biodiésel a partir de asignársele el carácter de “sujeto promocionado”, en los términos del art. 13 y siguientes de la <a target=\"_blank\" href=\"http://www.argentina.gob.ar/normativa/nacional/ley-26093-116299/texto\">ley 26.093</a>.</p><p style=\"text-indent:2em\">Ante el recurso interpuesto por el Estado demandado la Corte declaró inoficioso emitir pronunciamiento en la causa ya que, con posterioridad a la interposición del recurso de queja ante el Tribunal, se sancionó la <a target=\"_blank\" href=\"http://www.argentina.gob.ar/normativa/nacional/ley-27640-352587/texto\">ley 27.640</a> que aprobó el nuevo “Marco Regulatorio de Biocombustibles” y dejó sin efecto la ley 26.093 antes mencionada y sus normas reglamentarias.</p><p style=\"text-indent:2em\">Recordó que sus sentencias deben ajustarse a las condiciones existentes al momento en que se dictan, incluso si estas son sobrevinientes al recurso extraordinario y también que la subsistencia de los requisitos jurisdiccionales es comprobable de oficio y su desaparición importa la de poder juzgar.</p>","esNovedad":true,"fecha":1748919600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1748993720564,"usuarioCreacion":4,"fechaCreacion":1748975050889,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":138298,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35002236,"numeroExpediente":2755,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1106,"descripcion":"MEDIDA CAUTELAR (AUTONOMA)","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - EXPLORA SA c/ EN-SECRETARIA DE GOBIERNO DE ENERGIA s/INC APELACION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2755. "},"recurso":{"id":5876870,"expediente":{"id":35002236,"numeroExpediente":2755,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpedient