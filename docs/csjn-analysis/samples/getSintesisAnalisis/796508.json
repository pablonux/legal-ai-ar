[{"codigo":7965084,"analisisDocumental":{"id":796508,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 6 - QUERELLANTE: PUPATO, SILVIA ROSA Y OTROS IMPUTADO: PUPATO , MARIELA Y OTROS s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":6981,"titulo":"Confección del balance falso y presunta defraudación por administración infiel: conflicto de competencia","cabecilla":"<p style=\"text-indent:2em\">A partir de la denuncia de hechos en orden a los delitos de administración infiel y balance falso y, eventualmente, evasión tributaria, se suscitó un conflicto de competencia entre la justicia nacional en lo criminal y correccional y la justicia en lo penal económico. </p><p style=\"text-indent:2em\">La Corte resolvió que sea el juzgado nacional ordinario quien continúe conociendo en las actuaciones.</p><p style=\"text-indent:2em\">Recordó su doctrina de Fallos: <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=308&amp;pagina=705\">308:705</a> y expresó que, tanto en el caso en que pueda considerase que el balance falso hubiera sido confeccionado como medio para llevar a cabo la presunta defraudación, como en el que aparece cometido para ocultar el delito contra la propiedad, corresponde su investigación a la justicia nacional ordinaria , desde que ésta posee más amplia competencia que la que ejerce el fuero en lo penal económico.</p>","esNovedad":true,"fecha":1717470000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1717605019208,"usuarioCreacion":11,"fechaCreacion":1717591450085,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":120389,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35246576,"numeroExpediente":30644,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXPEDIENTES PENALES","idMateria":9,"tema":null},"caratula":"Incidente Nº 1 - DENUNCIANTE: MAMANI PRIETO, ELIZABETH Y OTROS IMPUTADO: MIRANDA, LUIS ANTONIO s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"30644. "},"recurso":{"id":5959051,"expediente":{"id":35246576,"numeroExpediente":30644,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correcci