[{"codigo":7710313,"analisisDocumental":{"id":771031,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"TINO, LUIS ALBERTO Y OTROS s/INCIDENTE DE INCOMPETENCIA","alias":null,"caratula":"Incidente Nº 5 - QUERELLANTE: DIRITO, ROQUE EDUARDO Y OTRO IMPUTADO: TINO, LUIS ALBERTO Y OTROS s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":3921,"titulo":"Conflictos de competencia en materia penal y facultades excepcionales por razones de economía procesal","cabecilla":"<p>A ra&iacute;z de la causa promovida con motivo del hallazgo de varias obras de arte robadas que se encontraban expuestas en diversas galer&iacute;as del rubro, se suscit&oacute; un conflicto de competencia entre dos c&aacute;maras criminales.&nbsp;La Corte lo resolvi&oacute; asignando la causa a la c&aacute;mara federal pero, adem&aacute;s, consider&oacute; que, por razones de econom&iacute;a procesal, era conveniente hacer uso excepcional de la facultad de anular el sobreseimiento que hab&iacute;a sido dictado en primera instancia.&nbsp;Aclar&oacute; que si bien corresponder&iacute;a que la c&aacute;mara, que era el tribunal de alzada del juez de instrucci&oacute;n que dict&oacute; el sobreseimiento, se pronuncie respecto de la apelaci&oacute;n pendiente por dicho tema,&nbsp;con el objeto de evitar una demora in&uacute;til derivada de la nueva intervenci&oacute;n de aquella c&aacute;mara, que con anterioridad hab&iacute;a declinado la competencia a favor del fuero federal, aconsejaba el uso excepcional de la facultad de anular el sobreseimiento y remitir la causa a la justicia federal que oportunamente acept&oacute; la competencia.</p>","esNovedad":true,"fecha":1651546800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1651681028902,"usuarioCreacion":11,"fechaCreacion":1651665847779,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":32600,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30035476,"numeroExpediente":12409,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Incidente Nº 5 - QUERELLANTE: DIRITO, ROQUE EDUARDO Y OTRO IMPUTADO: TINO, LUIS ALBERTO Y OTROS s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"12409. "},"recurso":{"id":5108923,"expediente":{"id":30035476,"numeroExpediente":12409,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal 