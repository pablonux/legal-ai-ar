[{"codigo":7705183,"analisisDocumental":{"id":770518,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"A.C.U.D.E.N. c/ BANCO PROVINCIA DEL NEUQUEN s/DAÑOS Y PERJUICIOS POR RESPONSABILIDAD EXTRACONTRACTUAL","alias":null,"caratula":"A.C.U.D.E.N. c/ BANCO PROVINCIA DEL NEUQUEN s/DAÑOS Y PERJUICIOS POR RESPONSABILIDAD EXTRACONTRACTUAL","inconstitucional":false,"falloDestacado":{"id":2987,"titulo":"La existencia de una relación de consumo como requisito para la aplicación del artículo 55 de la ley 24.240","cabecilla":"<p>Una asociaci&oacute;n de consumidores plante&oacute; una acci&oacute;n colectiva en contra de una entidad bancaria a fin de que dejara de cobrar una comisi&oacute;n por el diligenciamiento de oficios judiciales. El Tribunal Superior de Justicia de la Provincia del Neuqu&eacute;n rechaz&oacute; la acci&oacute;n colectiva por entender que en el caso no se configuraba una relaci&oacute;n de consumo en los t&eacute;rminos de la ley 24.240 e impuso las costas a la actora vencida. Agraviada por el fallo, la asociaci&oacute;n interpuso un recurso ante la Corte con base en la imposici&oacute;n de costas por no ajustarse, a su criterio, a lo previsto en el art&iacute;culo 55 de la ley 24.240.&nbsp;<strong>La Corte, por mayor&iacute;a, rechaz&oacute; el recurso extraordinario.</strong>&nbsp;Entre otros fundamentos expres&oacute; que, a&uacute;n bajo la interpretaci&oacute;n amplia del beneficio de justicia gratuita del art&iacute;culo 55 de la ley 24.240 que sustenta el recurrente, no resulta descalificable la imposici&oacute;n de costas decidida en la instancia provincial pues no se configura el presupuesto legal que justifica la aplicaci&oacute;n de la norma citada. Del mismo modo, en su voto concurrente, el Juez Rosatti expres&oacute; que el derecho concedido en el art. 42 de la Constituci&oacute;n Nacional &nbsp;no importa un reconocimiento en abstracto que prescinda del contexto en el que dichos derechos se encuentran inmersos, por lo que la determinaci&oacute;n de la presencia de un v&iacute;nculo jur&iacute;dico de consumo constituye el punto de partida a partir del cual s&oacute;lo puede entrar en juego la tutela preferencial. Por su lado, el Juez Maqueda vot&oacute; en disidencia considerando que el recurso extraordinario era inadmisible (art. 280 del C&oacute;digo Procesal Civil y Comercial de la Naci&oacute;n).</p>","esNovedad":true,"fecha":1635390000000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1635518142210,"usuarioCreacion":11,"fechaCreacion":1635518136733,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":32419,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31095031,"numeroExpediente":2585,"anioExpediente":2017,"