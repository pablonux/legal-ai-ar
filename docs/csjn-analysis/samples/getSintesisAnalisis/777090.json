[{"codigo":7770905,"analisisDocumental":{"id":777090,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"ARANCIBIA, CARLOS IGNACIO Y OTRO s/ INCIDENTE DE RECURSO EXTRAORDINARIO","alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 2 - IMPUTADO: ARANCIBIA, CARLOS IGNACIO Y OTRO s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":4261,"titulo":"Derecho al doble conforme y agravios sin respuesta jurisdiccional","cabecilla":"<p>Luego del reenvío al dejar sin efecto la imposición de una pena menor, el recurrente fue condenado a la pena de prisión perpetua e interpuso un recurso de casación e inconstitucionalidad que fue rechazado. Esto motivó que recurriera a la Corte, que dejó sin efecto este pronunciamiento. Consideró para ello que la denegatoria al pedido de reconducir el recurso extraordinario como recurso de casación por no presentar ninguna crítica sustantiva concreta a la sentencia que reformó la calificación jurídica resultaba arbitraria por apartarse de las constancias de la causa, con menoscabo del derecho a la revisión de la condena. Recordó que en el precedente \"Duarte\" (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=337&amp;pagina=901\">Fallos: 337:901</a>) se estableció que el derecho al doble conforme no podía ser cumplido a través del recurso extraordinario federal ante el escaso margen revisor del Tribunal y que dejaría afuera una cantidad de aspectos esenciales que no podrían ser abordados, por lo que correspondía remitir las actuaciones a la cámara de casación para que una nueva sala procediera a la revisión de la condena dictada en esa sede. Resaltó además la Corte, con cita de <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=342&amp;pagina=2389\">Fallos: 342:2389</a> (\"P., S. M\") que ante el dictado de una condena en sede casatoria, la garantía de la doble instancia debe ser salvaguardada en dicho ámbito mediante la interposición de un recurso de casación que deberán resolver otros magistrados que integren ese tribunal.</p>","esNovedad":true,"fecha":1659409200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1659546607930,"usuarioCreacion":11,"fechaCreacion":1659466509559,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":34741,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31591088,"numeroExpediente":530,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DET