[{"codigo":8123603,"analisisDocumental":{"id":812360,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":80013,"valor":"DECLARA INOFICIOSO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009221235,"fechaModLong":201009221235,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - CAROL MARIA LUISA Y OTROS c/ HARAS EL MORO S.A. Y OTRO s/NULIDAD DE ESCRITURA/INSTRUMENTO","inconstitucional":false,"falloDestacado":{"id":9161,"titulo":"Tribunal superior de la causa y pronunciamiento inoficioso","cabecilla":"<p style=\"text-indent:2em\">La Cámara Nacional de Apelaciones en lo Civil condenó a la demandada a otorgar la escritura traslativa de dominio a la parte actora.</p><p style=\"text-indent:2em\">Contra esa decisión, la condenada interpuso recurso extraordinario federal cuya denegación motivó una queja. Simultáneamente y contra la misma resolución, también planteó un recurso de inconstitucionalidad que fue rechazado y que derivó en un conflicto jurisdiccional suscitado entre la cámara referida y el Superior Tribunal de Justicia de la Ciudad Autónoma de Buenos Aires que fue resuelto por la Corte en forma simultánea al presente, declarando a este último competente para revisar la sentencia de aquella (<a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=8123591&amp;cache=1752775092320\"><b>Competencia CSJ 432/2024/CS1 “Haras El Moro SA\"</b></a>).</p><p style=\"text-indent:2em\">A partir de tal decisión el Tribunal declaró que resultaba inoficioso un pronunciamiento sobre la queja por haber devenido abstracta la cuestión planteada.</p>","esNovedad":true,"fecha":1752721200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1752853965265,"usuarioCreacion":11,"fechaCreacion":1752772622825,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":140922,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38304378,"numeroExpediente":16057,"anioExpediente":2004,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":641,"descripcion":"NULIDAD DE ESCRITURA/INSTRUMENTO","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 1 - CAROL MARIA LUISA Y OTROS c/ HARAS EL MORO S.A. Y OTRO s/NULIDAD DE ESCRITURA/INSTRUMENTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"16057. "},"recurso":{"id":6699395,"expediente":{"id":38304378,"numeroExpediente":16057,"anioExpediente":2004,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":