[{"codigo":8086943,"analisisDocumental":{"id":808694,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":230004,"valor":"RECURSO DE REVOCATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - EN - DNM c/ MARTINEZ ALVITE, MANUEL s/EJECUCION FISCAL","inconstitucional":false,"falloDestacado":{"id":8681,"titulo":"Corresponde el pago del depósito previo del recurso de queja interpuesto en defensa de honorarios profesionales","cabecilla":"<p style=\"text-indent:2em\">El recurrente cuestionó a través de una revocatoria la intimación a efectuar el depósito previsto en el artículo 286 del Código Procesal Civil y Comercial de la Nación dispuesta por el Secretario de la Corte. Argumentó para ello que no se encuentra alcanzado por dicha carga porque la queja fue interpuesta en defensa de sus honorarios profesionales, respecto de los cuales destaca su carácter alimentario.</p><p style=\"text-indent:2em\">La Corte desestimó el planteo y reiteró la intimación efectuada. </p><p style=\"text-indent:2em\">Señaló que la obligación que impone el artículo mencionado solo cede respecto de las personas que están exentas de pagar sellado o tasa judicial, según las disposiciones de las leyes nacionales respectivas, esto es, de aquellos que se encuentran comprendidos en el artículo 13 de la <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-23898-298/actualizacion\">ley 23.898</a> y en las normas especiales que contemplan excepciones a tales tributos, inclusión que debe ser expresa e interpretada con criterio restrictivo. </p><p style=\"text-indent:2em\">Recordó el Tribunal que ya ha establecido que la ley 23.898 no dispensa a los profesionales de dicha carga cuando se trata de una queja relativa a sus honorarios, a pesar de las connotaciones atribuibles a su trabajo.</p>","esNovedad":true,"fecha":1747278000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1747335974373,"usuarioCreacion":4,"fechaCreacion":1747335831269,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":136900,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38138517,"numeroExpediente":1569,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"GLOBAL COLLECTION ARGENTINA S.A. c/ ELECTRICIDAD DE MISIONES S.A. s/cobro de pesos ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1569. "},"recurso":{"id":6656094,"expediente":{"id":38138517,"numeroExpediente":1569,"anioExpediente":202