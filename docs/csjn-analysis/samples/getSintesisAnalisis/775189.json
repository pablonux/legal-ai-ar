astreintes. Posteriormente, tras un nuevo pedido de intimaci&oacute;n, el juez federal declin&oacute; seguir entendiendo en el litigio haciendo hincapi&eacute; en que la provincia hab&iacute;a adherido al r&eacute;gimen instituido por el Ministerio de Salud de la Naci&oacute;n. La Corte expres&oacute; que no se encontraba habilitado para reexaminar su competencia pues ya mediaba un pronunciamiento sobre el fondo del asunto. Record&oacute; que las causas en que ha reca&iacute;do&nbsp;un acto jurisdiccional definitorio deben seguir su tr&aacute;mite hasta concluir ante el fuero que lo dict&oacute;. Agreg&oacute; que lo decidido favorec&iacute;a la seguridad jur&iacute;dica y la econom&iacute;a y concentraci&oacute;n procesal, m&aacute;s aun, trat&aacute;ndose de un amparo en el que se debatieron prestaciones de salud para un menor con discapacidad.</p>","esNovedad":true,"fecha":1652756400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1652975445145,"usuarioCreacion":11,"fechaCreacion":1652814098143,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":34042,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32602738,"numeroExpediente":28963,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":24,"codigo":"24","abreviatura":"FSA","descripcion":"Justicia Federal de Salta","estado":0,"descripcionLarga":"FSA - Justicia Federal de Salta"},"objetoJuicio":{"id":3105,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":180,"codigo":"AMPAROS"}},"caratula":"L., A. E. c/ ESTADO NACIONAL - PROGRAMA FEDERAL DE SALUD - DIRECCION NACIONAL DE PRESTACIONES MEDICAS Y OTRO s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"28963. "},"recurso":{"id":6106364,"expediente":{"id