[{"codigo":7814674,"analisisDocumental":{"id":781467,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"BANCO DE SAN JUAN S.A. Y OTROS s/INFRACCION LEY 19.359","alias":null,"caratula":"RECURRENTE: BANCO DE SAN JUAN S.A. Y OTROS s/INFRACCION LEY 19.359 ","inconstitucional":false,"falloDestacado":{"id":4903,"titulo":"Derecho a ser juzgado dentro de un plazo razonable y falta de fundamentación","cabecilla":"<p>Ante la condena a un banco y a sus funcionarios jerárquicos por la comisión de infracciones cambiarias, las defensas presentaron recursos extraordinarios donde, entre otros agravios, cuestionaron que se haya desechado el planteo de que el procedimiento habría violado el derecho de las partes acusadas a ser juzgadas dentro de un plazo razonable. La Corte descalificó por arbitraria la sentencia. Expresó que si bien la evaluación de una eventual violación al derecho a ser juzgados en un plazo razonable depende no sólo de las características de los hechos investigados sino del comportamiento de las partes y los tribunales en el propio proceso, la identidad contextual entre dos de los sumarios - que incluyeron imputaciones homogéneas respecto de operaciones cambiarias de la misma entidad financiera, ocurridas durante un período de tiempo semejante - obligaba al a quo a brindar una explicación que diera cuenta de por qué la misma demora implicaba, en uno de ellos, una violación al derecho invocado, mientras que en el otro no tendría ese carácter. Consideró que la total ausencia de una argumentación capaz de tornar comprensible para las partes el rechazo de su petición frente a la concesión de idéntico reclamo en el otro, privaba a lo decidido del fundamento mínimo necesario para que pueda contar como un acto jurisdiccional válido.</p>","esNovedad":true,"fecha":1671591600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1671647433605,"usuarioCreacion":11,"fechaCreacion":1671647405111,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":105954,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":19732697,"numeroExpediente":14418,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":20,"codigo":"20","abreviatura":"FMZ","descripcion":"Justicia Federal de Mendoza","estado":0,"descripcionLarga":"FMZ - Justicia Federal de Mendoza"},"objetoJuicio":{"id":9421,"descripcion":"Varios - Medida Cautelar","idMateria":11,"tema":null},"caratula":"RECURRENTE: BANCO DE SAN JUAN S.A. Y OTROS s/INFRACCI