[{"codigo":7979815,"analisisDocumental":{"id":797981,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - CAMBREA, JUAN RODOLFO c/ CEAMSE s/ESCRITURACION","inconstitucional":false,"falloDestacado":{"id":7061,"titulo":"Honorarios profesionales: valor del bien inmueble para la determinación del monto del proceso","cabecilla":"<p style=\"text-indent:2em\">La cámara dejó sin efecto la base regulatoria según el monto fijado en el boleto de compraventa, y fijó la base regulatoria en la valuación acompañada por los letrados, pues interpretó que la demandada no había formulado su propia estimación del valor de los inmuebles en los términos de la ley de honorarios.</p><p style=\"text-indent:2em\">La Corte consideró que ésta era una interpretación arbitraria de la normativa arancelaria aplicable y <b>dejó sin efecto la sentencia. </b></p><p style=\"text-indent:2em\">Según la Corte, resultó excesivo considerar que la demandada no había efectuado su propio cálculo del valor de los inmuebles.</p><p style=\"text-indent:2em\">Así - sostuvo - mientras los letrados solicitaron la fijación del monto del proceso a los fines arancelarios en la tasación que acompañaron, la demandada había impugnado esa tasación manifestando que debía considerarse el valor del inmueble contenido en el boleto de compraventa, y, en subsidio,  la designación de un perito tasador en los términos del artículo 23, segunda parte, de la ley 21.839.</p><p style=\"text-indent:2em\">Según el Tribunal la ley arancelaria no exige ninguna formalidad en el modo de valuar los bienes y que no obliga a tasar el bien, sino que invita a las partes a que manifiesten en tal sentido.</p><p style=\"text-indent:2em\">Concluyó entonces que se había impuesto a la accionada una carga procesal desmedida que excedía la finalidad de la norma, q<em>ue no es otra que evidenciar el disenso con la estimación de la otra parte en el proceso y establecer los valores de referencia para discernir quién cargará con las costas de la tasación judicial a practicar.</em></p><p style=\"text-indent:2em\">Agregó que, ante la disconformidad de la recurrente con la estimación efectuada por los letrados, no correspondía que la cámara estableciera la base regulatoria sino que ordenara que se cumpliera con el trámite previsto en la segunda parte del artículo 23 ya mencionado.</p>","esNovedad":true,"fecha":1719284400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1719420338971,"usuarioCreacion":4,"fechaCreacion":1719342794427,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":122139,"secretaria":{"id":8,"tipo":"S","descripcion":"