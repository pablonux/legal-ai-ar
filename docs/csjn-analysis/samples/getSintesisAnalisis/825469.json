[{"codigo":8254693,"analisisDocumental":{"id":825469,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"COL-VEN SA c/ GCBA-AGIP s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":10561,"titulo":"Prórroga de la competencia originaria de la Corte","cabecilla":"<p style=\"text-indent: 2em;\">La actora dedujo una acción en los términos del artículo 322 del Código Procesal Civil y Comercial de la Nación contra la Ciudad Autónoma de Buenos Aires (AGIP), a fin de que se declare la inconstitucionalidad de las leyes locales que establecieron una alícuota más gravosa en el impuesto sobre los ingresos brutos a la actividad industrial realizada por los contribuyentes que no poseían establecimiento radicado en su jurisdicción.</p><p style=\"text-indent: 2em;\">Con motivo del planteo de incompetencia efectuado por la demandada el juez ante quien se inició el proceso se declaró incompetente y remitió las actuaciones a la Corte.</p><p style=\"text-indent: 2em;\">El Tribunal declaró su incompetencia para entender en las actuaciones por la vía de su instancia originaria.</p><p style=\"text-indent: 2em;\">Expresó que si bien la Ciudad Autónoma de Buenos Aires tiene derecho a dicha competencia con el mismo alcance que el reconocido a las provincias aquella no había hecho valer ese privilegio. Por el contrario, efectuó un planteo de inhibitoria ante el fuero en lo contencioso administrativo y tributario local, que fue desestimado en primera instancia y cuyo rechazo quedó firme.</p><p style=\"text-indent: 2em;\">Recordó la Corte su doctrina en el sentido de reconocer la validez de la prórroga de su competencia originaria, en favor de los tribunales federales de primera instancia, en los casos en los que no se advierta la concurrencia de un interés federal o de razones institucionales de tal magnitud que hagan impostergable su intervención. </p>","esNovedad":true,"fecha":1776308400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1776371863245,"usuarioCreacion":4,"fechaCreacion":1776370936613,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":155619,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31857531,"numeroExpediente":35134,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"COL-VEN SA c/ GCBA-AGIP s/PROCESO DE CONOCIMIENTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"35134. "},"recurso":{"id":5799100,"expediente":{"id":31857531,"numeroExpediente":35134,"anioExpediente":2018,"tomoExpediente":null,"letraEx