[{"codigo":8020333,"analisisDocumental":{"id":802033,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - MACHADO , JUAN CARLOS c/ LA SEGUNDA A.R.T. S.A. Y OTROS s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":7722,"titulo":"Atribución dogmática de responsabilidad a una aseguradora de riesgo de trabajo","cabecilla":"<p style=\"text-indent:2em\">La cámara hizo lugar a la acción que, con fundamento en el derecho civil, entabló el actor a fin de obtener la reparación integral de los daños que padece a raíz de las lesiones que sufrió en su espalda como consecuencia de un accidente laboral. </p><p style=\"text-indent:2em\">Ante el recurso de la ART condenada la Corte, por mayoría, dejó sin efecto el pronunciamiento.</p><p style=\"text-indent:2em\">Sostuvo que la cámara no había proporcionado ningún fundamento para atribuir responsabilidad civil a la demandada y que no señaló ningún elemento o constancia obrante en el expediente que acreditase el incumplimiento de la aseguradora de los deberes legales en materia de control y prevención de riesgos.</p><p style=\"text-indent:2em\">Agregó que el actor desistió de la realización del peritaje técnico ofrecido como prueba a la par que se le dio por decaído el derecho a producir la testifical y que el tribunal solo sustentó la responsabilidad en “el resultado” adverso a la salud del trabajador, extremo que atribuyó dogmáticamente a presuntas inobservancias pero sin examinar la existencia de vinculación causal con el siniestro denunciado.</p><p style=\"text-indent:2em\">Recordó el Tribunal que la sola circunstancia de que el trabajador haya sufrido daños como consecuencia de su labor no autoriza a concluir sin más que la aseguradora de riesgos del trabajo ha incumplido con los deberes de prevención y vigilancia a su cargo a los efectos de la eventual imputación de responsabilidad en los términos del art. 1074 del Código Civil entonces vigente.</p>","esNovedad":true,"fecha":1728961200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1729253228577,"usuarioCreacion":4,"fechaCreacion":1729020666466,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":128600,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33086705,"numeroExpediente":2032,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":3,"codigo":"3","abreviatura":"CCF","descripcion":"Cámara Nacional de Apelaciones en lo Civil y Comercial Federal","estado":0,"descripcionLarga":"CCF - Cámara Nacional de Apelaciones en lo Civil y Comercial Federal"},"objetoJuicio":{"id":1432,"descripcion":"AMPARO  DE SALUD","idMateria":3,"tema":{"id":460,"codigo":"AMPAROS"}},"ca