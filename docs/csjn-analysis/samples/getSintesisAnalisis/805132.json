[{"codigo":8051322,"analisisDocumental":{"id":805132,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - SEOANE MANUEL c/ BANCO DE LA NACION ARGENTINA s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":8101,"titulo":"Arbitrariedad respecto de la distribución de las costas del proceso","cabecilla":"<p style=\"text-indent:2em\">En el marco de una demanda tendiente a obtener el cobro de las sumas adeudadas con motivo de la pesificación de los depósitos en dólares estadounidenses la cámara distribuyó las costas en el orden causado. </p><p style=\"text-indent:2em\">La Corte dejó sin efecto este pronunciamiento al considerarlo arbitrario. </p><p style=\"text-indent:2em\">Señaló que el artículo 68 del Código Procesal Civil y Comercial de la Nación consagra el principio rector en materia de costas y que ello encuentra su razón de ser en el hecho objetivo de la derrota, de modo que quien pretenda exceptuarse de esa regla debe demostrar acabadamente las circunstancias que justificarían el apartamiento de ella, lo que debe admitirse restrictivamente.</p><p style=\"text-indent:2em\">Consideró que la decisión adolecía de fundamentación aparente pues para ordenar la distribución de las costas por su orden se basó en fundamentos dogmáticos referidos a “la novedad y complejidad de las cuestiones debatidas al momento de iniciarse la acción que ha llevado a líneas jurisprudenciales encontradas” cuando, más allá de la discusión jurisprudencial previa, al momento de iniciarse la acción resultaba clara la solución jurídica que los tribunales debían aplicar al caso en tanto ya existían los precedentes de la Corte en que se basó la decisión.</p><p style=\"text-indent:2em\">Agregó el Tribunal que, por otra parte, la mera existencia de jurisprudencia o doctrina discrepante no resulta ser razón suficiente para apartarse del principio objetivo de la derrota establecido en la ley.</p>","esNovedad":true,"fecha":1734577200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1734705500431,"usuarioCreacion":4,"fechaCreacion":1734703468164,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":131668,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36158908,"numeroExpediente":9758,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":9481,"descripcion":"ORDINARIO","idMateria":4,"tema":{"id":501,"codigo":"JUIORD"}},"caratula":"Recurso Queja Nº 1 - GRAHAM, MARTA HAYDE