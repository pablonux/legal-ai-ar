[{"codigo":8225736,"analisisDocumental":{"id":822573,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ARIAS, ALAN NICOLAS c/ ASOCIART SA ART  s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":10162,"titulo":"Falta de coincidencia sustancial de opiniones en los tribunales colegiados ","cabecilla":"<p style=\"text-indent:2em\">La cámara revocó la sentencia de primera instancia que había desestimado los planteos de inconstitucionalidad de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-27348-272119/texto\">ley 27.348</a> y declaró habilitada la instancia para entender en las actuaciones. La demandada interpuso un recurso extraordinario y se agravió porque el actor no cumplió con la instancia administrativa obligatoria prevista en la ley mencionada.</p><p style=\"text-indent:2em\">La Corte revocó la decisión apelada. Comenzó señalando que, aun cuando sus decisiones deben limitarse a lo peticionado por las partes en los recursos extraordinarios, resulta insoslayable declarar la inexistencia de aquellas sentencias que carecen de los requisitos indispensables para ser consideradas un acto judicial válido.</p><p style=\"text-indent:2em\">Consideró que la inconsistencia entre los fundamentos brindados por los tres camaristas impedía considerar la sentencia como un acto jurisdiccional en sentido estricto y la dejó sin efecto.</p><p style=\"text-indent:2em\">Señaló que una vocal tuvo por acreditado que el actor acudió a la comisión médica jurisdiccional pero consideró que no correspondía habilitar la jurisdicción porque interpuso una demanda directa que no se encuentra prevista en la ley 27.348 mientras que los otros dos vocales declararon la aptitud jurisdiccional sobre la base de argumentos disímiles y, a su vez, contradictorios. Uno de ellos en el entendimiento de que el procedimiento establecido en la mencionada ley es inconstitucional y el segundo sobre la base de que, si bien el actor transitó el procedimiento administrativo previo y ese recaudo resultaba constitucionalmente válido, no prevé un control judicial suficiente y, además, el plazo fijado para la interposición del recurso judicial es inconstitucional.</p><p style=\"text-indent:2em\">El Tribunal recordó que las sentencias de los tribunales colegiados no pueden concebirse como una colección o sumatoria de opiniones individuales o aisladas de sus integrantes, sino como el producto de un intercambio racional de ideas.</p>","esNovedad":true,"fecha":1770692400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1770836431509,"usuarioCreacion":11,"fechaCreacion":1770749093669,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":151258,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37265103,"numeroExpediente":31631,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9702,"descripcion":"ACCIDENTE - ACCION CIVIL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - BALADA, IRMA ESTHER Y OTRO c/ CLUB CIUDAD DE BOLIVAR Y OTRO s/ACCIDENTE - ACCION CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"31631. "},"recurso":{"id":6459671,"expediente":{"id":37265103,"numeroExpediente":31631,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9702,"descripcion":"ACCIDENTE - ACCION CIVIL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - BALADA, IRMA ESTHER Y OTRO c/ CLUB CIUDAD DE BOLIVAR Y OTRO s/ACCIDENTE - ACCION CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"31631. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CNT 031631/2016/1/RH001","identificacionExpediente":"CNT 031631/2016/1/RH001"},"piezas":null,"urgente":null,"observaciones":"fórmula es la que se indica en las firmas  - 2-2-26  se pone cartel de verificar. hay dic nada se dice en la fórmula, se deja como esta y se envía con cartel de verificar.","usuarioCreacion":{"id":10,"no