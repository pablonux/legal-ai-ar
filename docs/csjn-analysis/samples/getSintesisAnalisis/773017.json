[{"codigo":7730174,"analisisDocumental":{"id":773017,"competencia":null,"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ESTADO NACIONAL-FUERZA AEREA ARGENTINA c/ OLIVA, NORMA DEL VALLE s/LANZAMIENTO LEY 17.091","inconstitucional":false,"falloDestacado":{"id":5602,"titulo":"Principio de congruencia y cosa juzgada","cabecilla":"<p>La Fuerza Aérea Argentina promovió demanda de lanzamiento, en los términos de la ley 17.091, por una vivienda que había asignado en tenencia precaria, transitoria y de excepción a la demandada bajo la modalidad de permiso de uso, por ser personal civil en actividad de las Fuerzas Armadas. La Cámara Federal de Apelaciones de Córdoba declaró improcedente el lanzamiento, en los términos de la ley 17.091 sobre la base de que  las constancias aportadas a la causa no demostraban ni la titularidad ni la propiedad por parte de la Fuerza Aérea Argentina, por lo que no concurría uno de los requisitos para la viabilidad de la acción. <b>La Corte dejó sin efecto la sentencia </b>pues consideró que la cámara, sin exponer razón alguna que lo justificara, ingresó en el examen de los planteos relacionados con la titularidad del inmueble por parte de la Fuerza Aérea Argentina pese a que el juez de primera instancia había cerrado el debate sobre la cuestión -por considerar que el planteo de la señora Oliva era extemporáneo- y la demandada no había impugnado de manera precisa y acabada tal aspecto del fallo. La decisión de la cámara implicó una inobservancia del principio de congruencia y de la cosa juzgada, cuya raigambre constitucional ha sido reconocida por la  Corte y su respeto se ha entendido como una exigencia del orden jurídico con jerarquía superior.</p>","esNovedad":true,"fecha":1687834800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1687896125247,"usuarioCreacion":11,"fechaCreacion":1687892992043,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":33259,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":8337770,"numeroExpediente":31011030,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":16,"codigo":"16","abreviatura":"FCT","descripcion":"Justicia Federal de Corrientes","estado":0,"descripcionLarga":"FCT - Justicia Federal de Corrientes"},"objetoJuicio":{"id":3667,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":112,"tema":{"id":222,"codigo":"DAÑOS"}},"caratula":"PEREYRA, RAMÓN HORACIO c/ GENDARMERIA NACIONAL-ESCUADRON 7-P.LIBRES Y OTROS s/DAÑOS Y PERJUICIOS","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"31011030. "},"recurso":{"id":5638146,"expediente":{"id":8337770,"numeroExpediente":31011030,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":16,"codigo":"16","abreviatura":"FCT","descripcion":"Justicia Federal de Corrientes","estado":0,"descripcionLarga":"FCT - Justicia Federal de Corrientes"},"objeto