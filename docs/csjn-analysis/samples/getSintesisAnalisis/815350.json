[{"codigo":8153504,"analisisDocumental":{"id":815350,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"AUSTRAL CONSTRUCCIONES S.A. S/ QUIEBRA S/ INCIDENTE DE COMPETENCIA","alias":null,"caratula":"Incidente Nº 118 - INCIDENTISTA: CONFLICTO DE COMPETENCIA  s/INCIDENTE","inconstitucional":false,"falloDestacado":{"id":9401,"titulo":"Conflicto de competencia: subasta de bienes en la quiebra y pretensión de asegurar activos sujetos a eventual decomiso","cabecilla":"<p style=\"text-indent:2em\">Un tribunal oral en lo criminal federal exhortó a un juez comercial a que se abstuviera de subastar los bienes de una quiebra, invocando la vigencia de medidas cautelares ordenadas en la causa penal con el fin de asegurar activos sujetos a eventual decomiso. El juez comercial consideró improcedente esa solicitud y solicitó a la Corte que dirimiera la competencia. </p><p style=\"text-indent:2em\">El Tribunal <b>rechazó la solicitud formulada por el tribunal en lo criminal y ordenó devolver las actuaciones a la justicia comercial</b>.</p><p style=\"text-indent:2em\">Señaló que toda pretensión de injerencia de otro tribunal respecto del patrimonio del fallido afectaría la competencia atribuida por cuestiones de orden público por la ley concursal y podría establecer prerrogativas supralegales sobre el resto de la masa de los acreedores. </p><p style=\"text-indent:2em\">Agregó que en las convenciones internacionales y recomendaciones de organismos multilaterales -citadas por el tribunal federal en apoyo de su postura- no se aprecia norma alguna que establezca una prioridad de la pretensión penal vinculada a la recuperación de activos producto o instrumento del delito, en detrimento del derecho crediticio de terceros ajenos al proceso, reclamado de conformidad con las normas de derecho interno.</p><p style=\"text-indent:2em\">Finalmente destacó que no advertía que la solución propuesta comprometiera el curso regular del proceso penal, que ya ha llegado a la etapa de juico, y cuya celebración se encuentra sujeta al resultado eventual de las apelaciones pendientes contra la sentencia que revocó el sobreseimiento dictado por el órgano que originó la contienda.</p>","esNovedad":true,"fecha":1757991600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1758203761373,"usuarioCreacion":11,"fechaCreacion":1758114025986,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":143700,"secretaria":{"id":209,"tipo":"S","descripcion":"Sec. Penal Especial","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal Especial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38788469,"numeroExpediente":22216,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga"