[{"codigo":8053643,"analisisDocumental":{"id":805364,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"COSANI, CARMEN ESTHER c/ PROVINCIA DE SANTA FE s/AMPARO","inconstitucional":true,"falloDestacado":{"id":8083,"titulo":"Concurso docente y discriminación por género y por edad","cabecilla":"<p style=\"text-indent: 2em;\">Una docente de nivel primario de sesenta y un años de edad promovió una acción de amparo contra la Provincia de Santa Fe con el objeto de que se declare la inconstitucionalidad de una norma de un decreto provincial y se le permita participar en un concurso docente sin aplicar el límite de edad allí previsto,que era el impuesto por el régimen jubilatorio. </p><p style=\"text-indent: 2em;\">La corte provincial rechazó la demanda y la Corte dejó sin efecto este pronunciamiento. </p><p style=\"text-indent: 2em;\">Recordó para ello que cuando se impugna una norma basada en ciertas categorías puntuales como la raza, la religión, el género o nacionalidad, corresponde considerarla sospechosa de discriminación y portadora de una presunción de inconstitucionalidad que corresponde a la demandada desvirtuar y que esta presunción conlleva un escrutinio de razonabilidad más severo.</p><p style=\"text-indent: 2em;\">Señaló que la norma provincial cuestionada establece una distinción por la edad al excluir de los concursos a todas las personas que superen determinado límite etario pero, indirectamente, esa edad varía de acuerdo al género en la medida que se remite a las normas previsionales que fijan a las mujeres una edad jubilatoria inferior a los hombres. </p><p style=\"text-indent: 2em;\">También observó que la demandada no había expresado, siquiera mínimamente, el motivo que justificara la introducción –por vía reglamentaria– de un requisito que impide a las mujeres de entre sesenta a sesenta y cinco años de edad acceder a un cargo docente y, al mismo tiempo, confiere ese derecho a los varones de idéntica edad.</p><p style=\"text-indent: 2em;\">Señaló que la Constitución y la jurisprudencia de la Corte descalifican las distinciones por la edad a personas mayores basadas en presunciones que no admiten prueba en contrario y sustentadas en meros prejuicios sobre la vejez.</p><p style=\"text-indent: 2em;\">Concluyó el Tribunal que la norma cuestionada es inconstitucional ya que confronta con los derechos a trabajar y enseñar, al efectuar una discriminación inválida que intersecta dos factores, sexo y edad. El estado provincial no superó así el estándar de razonabilidad singular que cabe exigir a normas con discriminaciones como la cuestionada en el caso.</p><p style=\"text-indent: 2em;\">Agregó finalmente que el interés vital del Estado por la educación no podría justificar una discriminación de las características señaladas, sin incurrir en una interpretación que tensiona el sistema educativo con los derechos de las personas mayores a participar activamente en él ya que el enfoque correcto es el inverso, que busca la complementariedad entre la vejez y la educación. </p>","esNovedad":true,"fecha":1734577200000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1734639406347,"usuarioCreacion":11,"fechaCreacion":1734639383154,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":131958,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33719762,"numeroExpediente":1258,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"COSANI, CARMEN ESTHER c/ PROVINCIA DE SANTA FE s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1258. "},"recurso":{"id":5622068,"expediente":{"id":33719762,"numeroExpediente":1258,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"COSANI, CARMEN ESTHER c/ PROVINCIA DE SANTA FE s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1258. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CSJ 001258/2019/RH001","identificacionExpediente":"CSJ 001258/2019/RH001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":11