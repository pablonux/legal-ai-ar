[{"codigo":7940315,"analisisDocumental":{"id":794031,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - BAYER ARGENTINA SA c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","inconstitucional":false,"falloDestacado":{"id":6541,"titulo":"Determinación de oficio del impuesto a las ganancias: empleo de la mediana y el rango intercuartil","cabecilla":"<p style=\"text-indent: 2em;\">La Cámara confirmó el pronunciamiento del Tribunal Fiscal de la Nación que había revocado la determinación de oficio del impuesto a las ganancias de la actora.</p><p style=\"text-indent: 2em;\">Ante el recurso del Fisco la Corte confirmó el pronunciamiento apelado.</p><p style=\"text-indent: 2em;\">Con respecto a los agravios dirigidos a defender la aplicación de la mediana y el rango intercuartil como sustento del ajuste practicado, señaló que no resultaban de aplicación al período fiscal 1999 y que dichas herramientas fueron consagradas recién por una resolución general del año 2001. Agregó que permitir el empleo de las mismas cuando su utilización no estaba legalmente habilitada, implicaría sustituir al legislador en su tarea, aspecto vedado a los tribunales.</p><p style=\"text-indent: 2em;\">Recordó además el Tribunal que el artículo 86, inciso b, de la ley 11. 683 otorga carácter limitado a la revisión de la cámara y, en principio, queda excluido de ella el juicio del Tribunal Fiscal respecto de los extremos de hecho y que, bien no se trata de una regla absoluta y la cámara debe apartarse de dichas conclusiones cuando éstas presentan deficiencias manifiestas lo resuelto por la cámara no excedía el marco de sus facultades ni exhibía una manifiesta arbitrariedad que permitiera descalificarlo como acto jurisdiccional.</p>","esNovedad":true,"fecha":1710212400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1710272565570,"usuarioCreacion":4,"fechaCreacion":1710269721377,"privado":false,"posicion":0,"resumen":null},"reciboEntrada":{"id":117845,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34013838,"numeroExpediente":56807,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descr