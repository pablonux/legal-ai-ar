[{"codigo":8070636,"analisisDocumental":{"id":807063,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"BLINDAJE SEGURIDAD SRL c/ PONCE DE LEON, ALEJANDRO Y OTRO s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":8581,"titulo":"Competencia federal en un reclamo de daños y perjuicios ocasionados por actos de competencia desleal","cabecilla":"<p style=\"text-indent:2em\">Una empresa dedicada a prestar servicios de seguridad, vigilancia e información entabló una demanda de daños y perjuicios contra un ex empleado y un ex proveedor, que constituyeron una compañía y a quienes reprocha actos presuntamente contrarios a la lealtad comercial. Les imputa desviar en provecho propio o de un tercero la clientela del establecimiento y, más tarde, competir deslealmente con él. Ello originó un conflicto negativo de competencia entre la justicia provincial y la justicia federal. </p><p style=\"text-indent:2em\">La Corte, tras mencionar los artículos 61, 65 y 66 del decreto <a href=\"https://www.argentina.gob.ar/normativa/nacional/decreto-274-2019-322236/texto\">DNU 274/2019</a> resolvió que resultaba competente para conocer en el pleito el fuero federal de Rosario pues se reclamaba el resarcimiento de los daños y perjuicios ocasionados por supuestos actos de competencia desleal con fundamento preponderante en la normativa sobre lealtad comercial.</p>","esNovedad":true,"fecha":1744686000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1745239504061,"usuarioCreacion":11,"fechaCreacion":1744734785490,"privado":false,"posicion":1,"resumen":{"idResumen":141,"resumen":"La Corte resolvió que el fuero federal de Rosario es competente en la demanda por actos de competencia desleal. Se reclamaba resarcimiento por daños y perjuicios ocasionados, con fundamento en la normativa sobre lealtad comercial (DNU 274/2019).","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":134587,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36729348,"numeroExpediente":1267,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"JARA PINO, JEAN JEFFERSON s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1267. "},"recurso":{"id":6342597,"expediente":{"id":36729348,"numeroExpediente":1267,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara"