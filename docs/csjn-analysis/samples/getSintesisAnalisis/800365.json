[{"codigo":8003652,"analisisDocumental":{"id":800365,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GONZALEZ MARIA NORMA c/ ANSES s/REAJUSTES VARIOS","inconstitucional":false,"falloDestacado":{"id":7425,"titulo":"Convenio de transferencia de previsión social y derechos adquiridos de los retirados y pensionados","cabecilla":"<p style=\"text-indent: 2em;\">La cámara dejó sin efecto el reajuste de la pensión de la actora según una ley provincial. Tuvo en cuenta para ello que la cláusula tercera del Convenio de Transferencia del Sistema de Previsión Social de la Provincia de San Luis que preveía que el Estado Nacional tomaba a su cargo el pago de las prestaciones de jubilados y pensionados transferidos y consideró que la prestación de la actora, a partir de la entrada en vigencia del referido convenio, había quedado sometida a las disposiciones de las leyes nacionales.</p><p style=\"text-indent: 2em;\">Ante esta decisión la recurrente sostiene que la sentencia es arbitraria pues, al no permitir que se le otorgue al beneficio obtenido al amparo de la ley provincial el 82% móvil que la normativa dispone, se estaba afectando discrecionalmente un derecho adquirido y protegido por el ordenamiento constitucional.</p><p style=\"text-indent: 2em;\"><b>La Corte revocó la sentencia apelada.</b></p><p style=\"text-indent: 2em;\">Afirmó que si bien eran ciertos los argumentos dados por la cámara en cuanto a que el acuerdo referido trajo aparejada la derogación de todas las normas locales de naturaleza previsional y su sustitución por la movilidad establecida en el sistema de las leyes nacionales 24.241, 24.463 y 26.417, pasó por alto el hecho de que en el convenio se incluyó un apartado específico referido a la transferencia de beneficios relativos al Régimen de Retiros del Personal Policial bajo el cual se hallaba la recurrente.</p>","esNovedad":true,"fecha":1724727600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1724787152014,"usuarioCreacion":4,"fechaCreacion":1724787149901,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":126378,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23382628,"numeroExpediente":677,"anioExpediente":2014,"tomoExpediente":50,"letraExpediente":"G","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"GONZALEZ MARIA NORMA c/ ANSES s/REAJUSTES VARIOS","verificacionMesa":"M","etiqueta":"99009","hijos":[],"oldIdentificadorExpediente":"G. 677. L. "},"recurso":{"id":31226