[{"codigo":8157493,"analisisDocumental":{"id":815749,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":24,"codigoRelacion":80024,"valor":"DECLARA NULIDAD","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201011041306,"fechaModLong":201011041306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 3 - SALVATO FERNANDO RAUL Y OTRO Y OTROS c/ INVERSORA MAYFORD S.A. Y OTROS Y OTROS s/ORDINARIO","inconstitucional":false,"falloDestacado":{"id":9482,"titulo":"Conformación de la mayoría en un tribunal colegiado","cabecilla":"<p style=\"text-indent: 2em;\">A raíz de una demanda tendiente a que se declare la nulidad por simulación de una sociedad anónima el juez de primera instancia admitió parcialmente el planteo y condenó a una de las demandadas a rendir cuentas a los actores por la administración del inmueble rural.</p><p style=\"text-indent: 2em;\">La cámara, integrada por cinco magistrados en atención a la imposibilidad de reunir mayoría entre los tres miembros que la componen por ley, revocó la decisión de grado y rechazó la demanda promovida.</p><p style=\"text-indent: 2em;\">La Corte declaró la nulidad de esta sentencia y ordenó que vuelvan los autos al tribunal de origen para que, por intermedio de quien corresponda, dicte un nuevo pronunciamiento con arreglo a lo expresado.</p><p style=\"text-indent: 2em;\">Señaló que los términos en que fue dictada ponen en evidencia que no quedó conformada la mayoría que se requiere cuando se trata de decisiones adoptadas por un tribunal colegiado, defecto que afecta la validez misma de la sentencia, circunstancia que debe ser atendida y declarada con antelación al tratamiento de las cuestiones planteadas por el recurrente.</p><p style=\"text-indent: 2em;\">Tuvo en cuenta para así decidir que dos de los jueces –al hacer lugar al recurso de apelación– revocaron la decisión de grado y rechazaron la demanda. Por su parte, otros dos magistrados declararon la nulidad de la sentencia de primera instancia. Uno de ellos reenvió la causa a la instancia de grado para que allí fuera fallada nuevamente, mientras el otro resolvió la cuestión de fondo en el sentido de hacer lugar a la demanda y condenar a la codemandada a rendir cuentas. Por último, la restante jueza rechazó el recurso de apelación, confirmando de ese modo la sentencia de grado.</p><p style=\"text-indent: 2em;\">Recordó el Tribunal que si bien sus sentencias deben limitarse a lo peticionado por las partes en los recursos extraordinarios, constituye un requisito previo emanado de su función jurisdiccional el control -aun de oficio- del desarrollo del procedimiento cuando se encuentran involucrados aspectos que atañen al orden público, toda vez que la existencia de un vicio capaz de provocar la nulidad absoluta del fallo, no podría ser confirmada por sentencias ulteriores.</p>","esNovedad":true,"fecha":1759201200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1759271310901,"usuarioCreacion":11,"fechaCreacion":1759271306017,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id"