[{"codigo":7695005,"analisisDocumental":{"id":769500,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"ROCCA, ALEJANDRO CARLOS c/ UNLP s/ACCION MERE DECLARATIVA DE DERECHO","alias":null,"caratula":"ROCCA, ALEJANDRO CARLOS c/ UNLP s/ACCION MERE DECLARATIVA DE DERECHO","inconstitucional":false,"falloDestacado":{"id":2804,"titulo":"Edad jubilatoria y opción para permanecer en actividad de los docentes de universidades nacionales (ley 26.508)","cabecilla":"<p>Sentencia que admiti&oacute; la demanda interpuesta por un docente universitario y orden&oacute; a la Facultad demandada que se abstuviera de aplicar la resoluci&oacute;n dictada por el Consejo Directivo y que lo reincorporara en su cargo - Interposici&oacute;n del recurso por parte de la casa de estudios - Tanto la ley como el estatuto universitario establecen, como principio, el derecho a la jubilaci&oacute;n ordinaria docente a la edad de 65 a&ntilde;os pero la ley 26.508 &nbsp;le otorga la posibilidad de permanecer en actividad hasta los 70 a&ntilde;os, siempre que haya manifestado su voluntad en tal sentido, lo que desplaza la aplicaci&oacute;n del mecanismo de pr&oacute;rroga que se prev&eacute; en los preceptos dictados en el &aacute;mbito de la demandada en tanto ellos requieren una decisi&oacute;n del Consejo Superior o del Consejo Directivo - La interpretaci&oacute;n efectuada por la universidad en el sentido de que, una vez cumplidos los sesenta y cinco a&ntilde;os, el docente debe cesar en sus funciones seg&uacute;n lo establecido por el art. 137 del estatuto universitario, aunque puede optar por permanecer en la actividad por cinco a&ntilde;os m&aacute;s siempre que obtenga la pr&oacute;rroga de su designaci&oacute;n en los t&eacute;rminos de la ordenanza 174/86, no se ajusta a las disposiciones de la ley 26.508 - No modifica la suerte del planteo de la demandada el hecho de que, al momento de efectuar la opci&oacute;n, el concurso del actor se encontrase vencido - En efecto, tal circunstancia fue expresamente contemplada por el juez de primera instancia quien concluy&oacute; en que en esa casa de estudios los docentes ordinarios se manten&iacute;an en su cargo mientras no se resolviera el nuevo concurso -&nbsp;Las universidades deben disponer de las potestades necesarias para llevar a cabo su gesti&oacute;n pero la facultad de dictar sus normas de funcionamiento interno no puede en modo alguno convertirse en un obst&aacute;culo al ejercicio de las potestades que la Constituci&oacute;n confiere al Congreso para sancionar el r&eacute;gimen jubilatorio del personal docente de universidades nacionales - Se confirma la sentencia apelada - Disidencia del juez Rosenkrantz: recurso extraordinario inadmisible (art. 280 CPCCN).&nbsp;</p>","esNovedad":true,"fecha":1632970800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1633457473588,"usuarioCreacion":11,"fechaCreacion":16