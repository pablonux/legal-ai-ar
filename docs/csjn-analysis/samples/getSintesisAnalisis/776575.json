[{"codigo":7765755,"analisisDocumental":{"id":776575,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"DENEGRI, NATALIA RUTH c/ GOOGLE INC s/DERECHOS PERSONALISIMOS:ACCIONES RELACIONADAS","alias":null,"caratula":"DENEGRI, NATALIA RUTH c/ GOOGLE INC s/DERECHOS PERSONALISIMOS:ACCIONES RELACIONADAS","inconstitucional":false,"falloDestacado":{"id":4161,"titulo":"Libertad de expresión y derecho al olvido","cabecilla":"<p>La actora demand&oacute; a Google con el objeto de que se le ordene &ldquo;desindexar&rdquo; ciertos links a sitios web en los que se expon&iacute;a informaci&oacute;n suya relativa a hechos ocurridos hace m&aacute;s de 20 a&ntilde;os que inclu&iacute;a videos en programas de televisi&oacute;n y noticias period&iacute;sticas y sustent&oacute; su pedido en el llamado &quot;derecho al olvido&quot;. Se&ntilde;al&oacute; que, aunque se trataba de informaci&oacute;n real sobre hechos de los que form&oacute; parte, el mero paso del tiempo hab&iacute;a generado que en la actualidad no revistiera ninguna importancia informativa, adem&aacute;s de que la avergonzaba, ya que formaba parte de un pasado que no deseaba recordar. La c&aacute;mara de apelaciones hab&iacute;a admitido el reclamo. Sin embargo llevado el caso a la m&aacute;xima instancia por la demandada, la Corte, por unanimidad, rechaz&oacute; la demanda al considerar que no se advert&iacute;a fundamento constitucional ni legal alguno que sustente la pretensi&oacute;n. Resalt&oacute; que la Constituci&oacute;n Nacional garantiza una amplia protecci&oacute;n a la libertad de expresi&oacute;n, la cual tiene un lugar preeminente en el marco de nuestras libertades constitucionales y que comprende el derecho de transmitir ideas, hechos y opiniones a trav&eacute;s de internet. Por ello, consider&oacute; que toda restricci&oacute;n, sanci&oacute;n o limitaci&oacute;n a dicha libertad debe ser de interpretaci&oacute;n restrictiva y que una eventual decisi&oacute;n judicial de &ldquo;desindexar&rdquo; ciertas direcciones respecto de un resultado, implicar&iacute;a una limitaci&oacute;n que interrumpir&iacute;a el proceso comunicacional. Record&oacute; el Tribunal que la actora cobr&oacute; notoriedad por su vinculaci&oacute;n con el denominado &ldquo;caso Coppola&rdquo; y que contin&uacute;a siendo una persona p&uacute;blica y se&ntilde;al&oacute; que concluir que por el mero paso del tiempo la informaci&oacute;n que form&oacute; parte de nuestro debate p&uacute;blico pierde ese atributo, pone en serio riesgo la historia como tambi&eacute;n el ejercicio de la memoria social. Agreg&oacute; que el cariz desagradable o desmesurado de ciertas expresiones del debate p&uacute;blico no podr&iacute;a despojarlas de protecci&oacute;n constitucional sin incurrir en criterios que, en &uacute;ltima instancia, depender&iacute;an de los subjetivos gustos o sensibilidades del tribunal de justicia llamado a ponderarlas. En otro orden, el Tribunal tambi&eacute;n dej&oacute; abierta la v&iacute;a a una posible &ldquo;tutela preventiva&rdquo; en materia de solicitudes de bloqueo, con car&aacute;cter absolutamente excepcional, en los cuales el da&ntilde;o, una vez producido, contin&uacute;a gener&aacute;ndose obligando a la v&iacute;ctima a realizar constantemente nuevos reclamos reparatorios. La Corte dej&oacute; finalmente planteada la necesidad de asumir hacia el futuro la problem&aacute;tica de ciertos aspectos del funcionamiento de los algoritmos de los que se sirven los motores de b&uacute;squeda, para que resulten m&aacute;s entendibles y transparentes para los usuarios, hoy sujetos a la decisi&oacute;n de aquellos.</p>","esNovedad":true,"fecha":1656385200000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1656523495424,"usuarioCreacion":4,"fechaCreacion":1656432394550,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":34557,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28711079,"numeroExpediente":50016,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":668,"descripcion":"DERECHOS PERSONALISIMOS:ACCIONES RELACIONADAS","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"DENEGRI, NATALIA RUTH c/ GOOGLE INC s/DERECHOS PERSONALISIMOS:ACCIONES RELACIONADAS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"50016. "},"recurso":{"id":5883671,"expediente":{"id":28711079,"numeroExpediente":50016,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camar