[{"codigo":7706335,"analisisDocumental":{"id":770633,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":19,"codigoRelacion":80019,"valor":"CONFIRMA PARCIALMENTE","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009281029,"fechaModLong":201009281029,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"MINERA SAN JORGE S.A. c/ GOBIERNO DE LA PROVINCIA DE MENDOZA s/ ACCIÓN DE INCONSTITUCIONALIDAD","alias":null,"caratula":"MINERA SAN JORGE S.A. c/ GOBIERNO DE LA PROVINCIA DE MENDOZA s/ACCION DE INSCONTITUCIONALIDAD","inconstitucional":true,"falloDestacado":{"id":2986,"titulo":"Protección de los recursos hídricos y alta toxicidad de la minería a cielo abierto","cabecilla":"<p>Una empresa titular de derechos mineros promovi&oacute; una acci&oacute;n impugnando la ley 7.722 de la Provincia de Mendoza en cuanto dispone prohibir el uso de cianuro, mercurio, &aacute;cido sulf&uacute;rico y otras sustancias t&oacute;xicas similares en los procesos mineros metal&iacute;feros. Ante el rechazo por parte del superior tribunal provincial, la empresa interpuso recurso extraordinario fundado en que esta prohibici&oacute;n implicaba lisa y llanamente la restricci&oacute;n absoluta de sus derechos de propiedad y a ejercer una industria l&iacute;cita, violando el principio de igualdad ante la ley y de igualdad de trato. La Corte, en primer lugar, se&ntilde;al&oacute; que la provincia, mediante la ley cuestionada, hab&iacute;a ejercido sus competencias constitucionales sin avanzar sobre las facultades exclusivas del Congreso de la Naci&oacute;n para dictar el C&oacute;digo de Miner&iacute;a sino complementando y estableciendo mayores exigencias o requisitos en materia ambiental&nbsp; y, por otro lado, que de la confrontaci&oacute;n de la ley provincial atacada con las finalidades perseguidas por el ordenamiento jur&iacute;dico no surg&iacute;a que haya sancionado, en t&eacute;rminos generales, una ley irrazonable. Afirm&oacute; que la actora no se hab&iacute;a hecho cargo de rebatir los s&oacute;lidos fundamentos de la sentencia plenaria que daban cuenta de la peligrosidad de las sustancias prohibidas por la ley y consider&oacute; improcedente tambi&eacute;n el agravio referido a haberse omitido evaluar prueba esencial y relevante para resolver la causa. El Tribunal descart&oacute; que resultara violatoria del principio de igualdad la prohibici&oacute;n de emplear el uso de tales sustancias para la actividad minera metal&iacute;fera y no para el resto de las actividades mineras e industriales, en la medida en que aquella actividad no es equiparable, en su desarrollo y consecuencias ambientales, a cualquier otra. Por otro lado, en sentido contrario, el Tribunal advirti&oacute; que la ley cuestionada, al prohibir en los procesos mineros metal&iacute;feros el empleo de &quot;otras sustancias t&oacute;xicas similares&quot;, se apartaba del principio de legalidad y adolec&iacute;a de una gran indeterminaci&oacute;n. Por ello, la Corte, por unanimidad, declar&oacute; admisible el recurso extraordinario y confirm&oacute; parcialmente la sentencia apelada.</p>","esNovedad":true,"fecha":1635390000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1635525558408,"usuarioCreacion":11,"fechaCreacion":1635515456052,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":32462,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31916823,"numeroExpediente":916,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MINERA SAN JORGE S.A. c/ GOBIERNO DE LA PROVINCIA DE MENDOZA s/ACCION DE INSCONTITUCIONALIDAD","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"916. "},"recurso":{"id":5339806,"expediente":{"id":31916823,"numeroExpediente":916,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MINERA SAN JORGE S.A. c/ GOBIERNO DE LA PROVINCIA DE MENDOZA s/ACCION DE INSCONTITUCIONALIDAD","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"916. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecu