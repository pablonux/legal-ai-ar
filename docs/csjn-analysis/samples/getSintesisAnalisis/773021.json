[{"codigo":7730213,"analisisDocumental":{"id":773021,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"PEREYRA, RAMÓN HORACIO c/ GENDARMERIA NACIONAL  Y OTROS s/DAÑOS Y PERJUICIOS","alias":null,"caratula":"PEREYRA, RAMÓN HORACIO c/ GENDARMERIA NACIONAL-ESCUADRON 7-P.LIBRES Y OTROS s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":3524,"titulo":"Indemnización de lucro cesante, diferencias salariales y el límite del objeto de la litis","cabecilla":"<p>En el marco de una demanda iniciada con fundamento en la responsabilidad objetiva de la Gendarmer&iacute;a Nacional por el hecho il&iacute;cito de sus dependientes, la C&aacute;mara incluy&oacute; en la indemnizaci&oacute;n, como integrante del lucro cesante, diferencias salariales provenientes del decreto 1490/02 que ten&iacute;an car&aacute;cter remunerativo y bonificable. Ante el recurso del Estado demandado&nbsp;<strong>la Corte, por unanimidad, revoc&oacute; el pronunciamiento</strong>&nbsp;al considerar que se hab&iacute;a omitido considerar que el objeto de la demanda no era obtener un reajuste de haberes sino la reparaci&oacute;n de da&ntilde;os y perjuicios. Agreg&oacute; que las diferencias salariales pretendidas no constitu&iacute;an un da&ntilde;o patrimonial derivado de los hechos imputados a la demandada y resultaban independientes de la conducta juzgada en la causa. Por ello, al no existir una relaci&oacute;n entre el objeto y las circunstancias f&aacute;cticas del presente proceso y el rubro reclamado, no correspond&iacute;a en el sub lite expedirse respecto de las sumas reconocidas en el decreto 1490/02.</p>","esNovedad":true,"fecha":1646276400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1646407019147,"usuarioCreacion":11,"fechaCreacion":1646397522695,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":33259,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":8337770,"numeroExpediente":31011030,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":16,"codigo":"16","abreviatura":"FCT","descripcion":"Justicia Federal de Corrientes","estado":0,"descripcionLarga":"FCT - Justicia Federal de Corrientes"},"objetoJuicio":{"id":3667,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":112,"tema":{"id":222,"codigo":"DAÑOS"}},"caratula":"PEREYRA, RAMÓN HORACIO c/ GENDARMERIA NACIONAL-ESCUADRON 7-P.LIBRES Y OTROS s/DAÑOS Y PERJUICIOS","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"31011030. "},"recurso":{"id":5638146,"expediente":{"id":8337770,"numeroExpediente":31011030,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":16,"codigo":"16","abreviatura