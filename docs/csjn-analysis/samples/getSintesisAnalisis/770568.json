[{"codigo":7705683,"analisisDocumental":{"id":770568,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"CÁMARA ARGENTINA DE ESPECIALIDADES MEDICINALES Y OTRO c/ ESTADO NACIONAL MINISTERIO DE INDUSTRIA DE LA NACIÓN Y OTROS s/ NULIDAD DE ACTO ADMINISTRATIVO","alias":null,"caratula":"Recurso Queja Nº 2 - CAMARA ARGENTINA DE ESPECIALIDADES MEDICINALES Y OTRO c/ ESTADO NACIONAL MINISTERIO DE INDUSTRIA DE LA NACION Y OTROS s/NULIDAD DE ACTO ADMINISTRATIVO","inconstitucional":false,"falloDestacado":{"id":2963,"titulo":"Alcance de la participación de \"Amigos del Tribunal\" en temas de interés general","cabecilla":"<p>El Centro de Estudios Legales y Sociales (CELS) solicit&oacute; su intervenci&oacute;n como Amigo del Tribunal en el marco de un proceso donde se debat&iacute;an cuestiones relacionadas con los criterios de patentabilidad de las invenciones qu&iacute;mico farmac&eacute;uticas. La intervenci&oacute;n fue rechazada por la c&aacute;mara con fundamento en que carec&iacute;a de apoyo normativo, al no estar reglamentada en el C&oacute;digo Procesal Civil y Comercial de la Naci&oacute;n y advirtiendo que el presentante no cumpl&iacute;a con el requisito de reconocida competencia sobre la cuesti&oacute;n debatida en el pleito. La Corte declar&oacute; procedente el recurso extraordinario interpuesto por la amparista y revoc&oacute; la sentencia apelada. Luego de recordar las consideraciones que inspiraron e impulsaron el instituto de &quot;Amigos del Tribunal&quot; expresadas en diversas Acordadas, la Corte consider&oacute; que negar la participaci&oacute;n de la recurrente con apoyo en la inexistencia de sustento normativo que lo reglamente hab&iacute;a devenido en un argumento irrazonable y contrario a las garant&iacute;as constitucionales que impulsan y dan fundamento a la actuaci&oacute;n de los amicus curiae en un proceso judicial en el que se examinan cuestiones que podr&iacute;an suscitar el inter&eacute;s general. Agreg&oacute; que&nbsp;exigir como recaudo para la intervenci&oacute;n como amicus una especializaci&oacute;n en patentamiento de invenciones farmac&eacute;uticas sin efectuar un examen de los argumentos que sustentaban la presentaci&oacute;n del recurrente, ni de los derechos humanos que podr&iacute;an encontrarse comprometidos en la cuesti&oacute;n a resolver en la causa, resultaba una decisi&oacute;n arbitraria que se apartaba de los fines y de la amplitud del debate que en temas de inter&eacute;s general persigue la instituci&oacute;n en cuesti&oacute;n.</p>","esNovedad":true,"fecha":1635390000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1635531485852,"usuarioCreacion":11,"fechaCreacion":1635453669342,"privado":false,"posicion":9,"resumen":null},"reciboEntrada":{"id":32432,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial"