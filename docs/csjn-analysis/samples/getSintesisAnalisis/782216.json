[{"codigo":7822164,"analisisDocumental":{"id":782216,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"MARINI, OSVALDO OSCAR c/ EN-PEN s/AMPARO LEY 16.986","alias":null,"caratula":"Recurso Queja Nº 4 - MARINI, OSVALDO OSCAR c/ EN-PEN s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":5122,"titulo":"Bonos emitidos en dólares","cabecilla":"<p>En el marco de una causa en la cual se discutía el monto a abonar por el Estado Nacional al actor tenedor de bonos emitidos en dólares estadounidenses, la cámara ordenó a la demandada a que abonara al actor la totalidad del monto original de los mismos, convertidos a pesos a la relación de $1,40 por cada dólar, importe que debería ajustarse por el coeficiente de estabilización de referencia (CER). Recurrida la sentencia, la Corte indicó que asistía razón a la demandada en cuanto a que los títulos públicos en cuestión eran Bonos del Tesoro 2002 8,75% y no préstamos garantizados como había concluido la cámara. En consecuencia, los mismos no estaban exceptuados del diferimiento de los pagos de la deuda pública del Gobierno Nacional contraída con anterioridad al 31 de diciembre de 2001. Por otra parte, al pronunciarse sobre el recurso extraordinario interpuesto por la actora, hizo lugar al mismo parcialmente y señaló que los bonos de titularidad de aquella emitidos bajo la ley argentina no se encontraban excluidos de la ley 27.249. De ese modo, ésta podría acogerse al régimen de cancelación delineado en el art. 6° de dicha norma. Finalmente, el Tribunal indicó que, contrariamente a lo alegado por la actora, el decreto 471/02 continuaba vigente y resultaba aplicable la tasa de interés prevista en su art. 2° a los bonos de la actora.</p>","esNovedad":true,"fecha":1678158000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1678298553845,"usuarioCreacion":4,"fechaCreacion":1678215376127,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":107197,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32835114,"numeroExpediente":665,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1099,"descripcion":"AMPARO LEY 16.986","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula"