[{"codigo":8030693,"analisisDocumental":{"id":803069,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"TOYOTA ARGENTINA S.A. c/ PROVINCIA DE MISIONES DIRECCION GENERAL DE RENTAS s/demanda contencioso administativa ","inconstitucional":false,"falloDestacado":{"id":7923,"titulo":"Requisito de la instrumentación de los actos jurídicos como exigencia elemental del impuesto de sellos","cabecilla":"<p style=\"text-indent:2em\">La empresa actora interpuso una demanda contra la Provincia de Misiones a efectos de que se deje sin efecto la determinación de oficio en concepto de impuesto de sellos respecto de los contratos de concesión comercial suscriptos con el concesionario oficial. El superior tribunal provincial rechazó la demanda y confirmó la determinación de oficio recurrida.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia. </p><p style=\"text-indent:2em\">Consideró que resultaba arbitraria pues se sustentaba únicamente en el carácter oneroso del contrato de concesión, sin tener en consideración el requisito de la instrumentación establecido en el art. 167 del Código Fiscal y en la ley de coparticipación federal de impuestos, y de ese modo desvirtuaba y volvía inoperantes las normas de derecho local.</p><p style=\"text-indent:2em\">Señaló que el requisito de la instrumentación determina que no existe el hecho imponible por el impuesto de sellos si el acto en cuestión no se encuentra instrumentado, no pudiendo presumirse la existencia del instrumento aun cuando se pruebe que el contrato existe. </p><p style=\"text-indent:2em\">Según las cláusulas de los contratos de concesión involucrados, el concesionario solo tenía “derecho a comprar” los productos comercializados por la actora, “sujeto a disponibilidad de abastecimiento”, por lo que al no encontrarse instrumentadas las operaciones de compraventa de vehículos, repuestos y accesorios, ni las de prestación de servicios, no resultaba posible exigir el impuesto de sellos respecto de ellas.</p><p style=\"text-indent:2em\">Agregó el Tribunal que la ausencia de instrumentación de tales operaciones no podía ser salvada mediante su inclusión en la base imponible presunta del impuesto de sellos con el cual se pretendía gravar a los contratos de concesión en virtud de los cuales se realizaron aquellas.</p>","esNovedad":true,"fecha":1732158000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1732287900851,"usuarioCreacion":4,"fechaCreacion":1732225268612,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":129659,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35576048,"numeroExpediente":1051,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":