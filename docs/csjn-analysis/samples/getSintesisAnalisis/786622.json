[{"codigo":7866224,"analisisDocumental":{"id":786622,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GRANJA TRES ARROYOS SACAFEI c/ MUNICIPALIDAD DE RIO CUARTO s/ACCION MERAMENTE DECLARATIVA DE DERECHO","inconstitucional":true,"falloDestacado":{"id":5683,"titulo":"Potestades tributarias municipales: validez de la contribución que incide sobre los servicios de protección sanitaria","cabecilla":"<p>Una empresa cuestionó la constitucionalidad de las normas del Código Tributario de la Municipalidad de Río Cuarto que regulan la contribución que incide sobre los servicios de protección sanitaria por considerar que esas disposiciones crearon un impuesto y no una tasa municipal. <b>La cámara resolvió que se trataba de un tributo inconstitucional</b> por constituir un derecho aduanero sobre mercaderías en tránsito, vulnerando la cláusula comercial del artículo 75, inciso 13 y los artículos 9°, 10 y 11 de la Constitución Nacional que establecen la libre circulación en el territorio argentino y prohíben las aduanas interiores. El municipio demandado interpuso un recurso extraordinario en el que invoca la autonomía municipal y que  los controles establecidos no reglan el comercio, ni establecen una aduana interior sino que  configuran el ejercicio del poder de policía en materia de salubridad y sanidad alimentaria. <b>La Corte confirmó la sentencia apelada.</b></p>","esNovedad":true,"fecha":1691031600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1691171915298,"usuarioCreacion":11,"fechaCreacion":1691093241042,"privado":false,"posicion":-2,"resumen":null},"reciboEntrada":{"id":111971,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28913630,"numeroExpediente":34667,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":15,"codigo":"15","abreviatura":"FCB","descripcion":"Justicia Federal de Córdoba","estado":0,"descripcionLarga":"FCB - Justicia Federal de Córdoba"},"objetoJuicio":{"id":2602,"descripcion":"ACCION MERAMENTE DECLARATIVA DE DERECHO","idMateria":112,"tema":{"id":81,"codigo":"CYCF"}},"caratula":"GRANJA TRES ARROYOS SACAFEI c/ MUNICIPALIDAD DE RIO CUARTO s/ACCION MERAMENTE DECLARATIVA DE DERECHO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"34667. "},"recurso":{"id":5709013,"expediente":{"id":28913630,"numeroExpediente":34667,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":15,"codigo":"15","abreviatura":"FCB","descripcion":"Justicia Federal de Córdoba","estado":0,"descripcionLarga":"FCB - Justicia Federal de Córdoba"},"objetoJuicio":{"id":2602,"descripcion":"ACCION MERAMENTE DECLARATIVA DE DERECHO","idMateria":112,"tema":{"id":81,"codigo":"CYCF"}},"caratula":"GRANJA TRES ARROYOS SACAFEI c/ MUNICIPALIDAD DE RIO CUARTO s/ACCION MERAMENTE DECLARATIVA DE DERECHO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"34667. "},"tipoRecurso":{"id":1166,"codigo":"REX","descripcion":"RECURSO EXTRAORDINARIO"},"claveRecurso":"FCB 034667/2016/CS001","identificacionExpediente":"FCB 034667/2016/CS001"},"piezas":3,"urgente":null,"observaciones":"4-2023 Vino a CHE  recibo 108926: eso no salió.\r\n14-7-23 vuelve a CHE p/ Copiar c/ 3 proyectos. \r\nSe pide el que  falta por mail y en el mail se envían  las consultas a voc 3 rtti.\r\n14-7-23 vino letrado (Azte) voc 3b, indicó dejar los  art y los consid como estan, excepto cuestiones de redacción y citas completas y poner puntos suspensivos en citas textuales donde el texto sigue .\r\nEn la fecha confirmó el Dr Els voc4b de rtz: indica x Casares  que queda como está. Dijo que si a las correcciones de redacción, ya vistas personalmente con el consid 11  indicó poner art 36 en vez de 37 del dec 815/99 y en el consid 12 poner titulo VI en vez de título  IV, etc.\r\nEn la fecha se hizo consulta a Sec 7 sobre cómo poner en el proyecto de Rosenkrantz, indica poner  Voto (así vino impreso en el proyecto de la vocalía. Piden de la sec que se pase en limpio asi como esta.\r\n","usuarioCreacion":{"id":10,"nombreUsuario":"27179020438","apellido":"Messuti","nombre":"Mariana","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583843772000,"nombreUsuarioMigrado":null,"codigo":"JURW6J","mail":"mmessuti@csjn.gov.ar","intentos":0,"notificacion":false},"usuarioCreacionOld":"JURW6J","usuarioModificacion":{"id":10,"nombreUsuario":"27179020438","apellido":"Messuti","nombre":"Mariana","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583843772000,"nombreUsuarioMigrado":null,"codigo":"JURW6J","mail":"mmessuti@csjn.gov.ar","intentos":0,"not