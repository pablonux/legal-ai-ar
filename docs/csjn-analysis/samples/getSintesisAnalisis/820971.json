[{"codigo":8209716,"analisisDocumental":{"id":820971,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"TABOADA, MARIELA EUGENIA s/SUMARIO - JUICIO POLITICO","inconstitucional":false,"falloDestacado":{"id":10081,"titulo":"Enjuiciamientos de magistrados y funcionarios judiciales: límites a la revisión judicial","cabecilla":"<p style=\"text-indent: 2em;\">La titular de una secretaría de un juzgado de instrucción penal fue destituida e inhabilitada por el término de cinco años para ocupar otro cargo judicial, por considerársela incursa en la causal de mal desempeño en la función.</p><p style=\"text-indent: 2em;\">Ante el rechazo del recurso interpuesto ante el superior tribunal la funcionaria recurrió a la Corte, quien desestimó el planteo por considerar que los agravios no eran suficientes para demostrar una afectación al debido proceso. </p><p style=\"text-indent: 2em;\">Consideró que el escrito no constituía una crítica concreta y razonada de la sentencia apelada, sino que se limitaba a cuestionarla mediante afirmaciones escuetas y absolutamente dogmáticas, que resultaban claramente insuficientes para rebatir los fundamentos utilizados por el a quo para sostener su decisión.</p><p style=\"text-indent: 2em;\">Recordó el Tribunal que solo patentes violaciones a las reglas del debido proceso y a la garantía de defensa en juicio podrán tener acogida ante sus estrados, y siempre y cuando sea acreditado por el recurrente no solo ello, sino también que la reparación de dichas transgresiones es conducente para variar la suerte del proceso en función de la directa e inmediata relación que debe tener la cuestión federal invocada con la materia del juicio.</p><p style=\"text-indent: 2em;\">Señaló que las objeciones de la apelante tendientes a cuestionar los argumentos del tribunal en cuanto sostuvo que los cambios en la estructura del Poder Judicial no restaban entidad a los hechos investigados y que las funciones desempeñadas por la actora habían mutado pero el cargo no había desaparecido, sólo trasuntaban una mera discrepancia con el criterio adoptado por el <em>a quo</em> al respecto con fundamentos que no fueron debidamente rebatidos.</p><p style=\"text-indent: 2em;\">Lo mismo ocurría con la supuesta omisión del análisis de las conductas de violencia de género que habría denunciado la actora, puesto que la sentencia apelada advirtió que se trataba de agravios introducidos en forma tardía al haber cuestionado en el recurso de casación únicamente el modo en que fue valorado el material probatorio.</p><p style=\"text-indent: 2em;\">Por último, la Corte no admitió el argumento relativo al planteo de inconstitucionalidad del art. 222 de la Constitución de Río Negro, pues la apelante se limitó a insistir en que las provincias no tienen competencia para disponer la pena de inhabilitación, sin efectuar un adecuado desarrollo de la invalidez que propugnó, como hubiera sido menester. </p>","esNovedad":true,"fecha":1766026800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1766146704081,"usuarioCreacion":11,"fechaCreacion":1766146698795,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":149558,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34319864,"numeroExpediente":2558,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9484,"descripcion":"SUMARIO","idMateria":4,"tema":{"id":502,"codigo":"AMPAROS"}},"caratula":"TABOADA, MARIELA EUGENIA s/SUMARIO - JUICIO POLITICO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2558. "},"recurso":{"id":5737648,"expediente":{"id":34319864,"numeroExpediente":2558,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9484,"descripcion":"SUMARIO","idMateria":4,"tema":{"id":502,"codigo":"AMPAROS"}},"caratula":"TABOADA, MARIELA EUGENIA s/SUMARIO - JUICIO POLITICO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2558. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DE