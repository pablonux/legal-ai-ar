[{"codigo":7853164,"analisisDocumental":{"id":785316,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 3 - DOMINGUEZ, DORVALINA Y OTROS c/ UGOFE SA Y OTROS s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":5701,"titulo":"Daños y perjuicios: arbitrariedad por incongruencia de la sentencia","cabecilla":"<p>En el caso, la sentencia de primera instancia hizo lugar a la demanda de daños y perjuicios derivados de la muerte del esposo y padre de los actores al caer de una formación de tren. A tal fin condenó a abonar en concepto de valor vida la suma de $ 600.000 monto que ponderaba los importes recibidos anteriormente en sede laboral. Interpuesto el recurso de apelación, la cámara confirmó, en su parte dispositiva, la sentencia de primera instancia mientras que, en los considerandos afirmó que correspondía deducir el monto pagado en el fuero laboral por la aseguradora de riesgos del trabajo. Ello motivó que la actora presentara un recurso extraordinario. <b>La Corte, dejó sin efecto este pronunciamiento.</b> Recordó el Tribunal que la sentencia constituye una unidad lógico-jurídica en que la parte dispositiva no es sino la conclusión final y necesaria del análisis de los presupuestos fácticos y normativos efectuados en su fundamentación y que, si bien es cierto que para establecer los límites de la cosa juzgada ha de atenderse primordialmente a la parte dispositiva, no lo es menos que, a esos fines, no puede prescindirse de sus motivaciones. Consideró que existía una incongruencia entre la parte dispositiva de la sentencia de cámara, que confirmaba la decisión de primera instancia que había condenado a las demandadas a pagar una suma de dinero luego de ponderar el monto percibido en sede laboral, con los fundamentos de la decisión, según los cuales debía efectuarse la deducción de los montos cobrados en el marco del expediente tramitado en dicha sede. Señaló que ese grave defecto de fundamentación provocaba un agravio tangible a la actora pues en los hechos implicaba una reducción sustancial del monto reconocido en primera instancia</p>","esNovedad":true,"fecha":1691031600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1691171996584,"usuarioCreacion":11,"fechaCreacion":1691095076635,"privado":false,"posicion":0,"resumen":null},"reciboEntrada":{"id":110877,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34147399,"numeroExpediente":105932,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civi