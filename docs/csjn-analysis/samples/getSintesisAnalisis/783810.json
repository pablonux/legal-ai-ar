[{"codigo":7838105,"analisisDocumental":{"id":783810,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"RUIZ JUAN CARLOS Y , OTROS INTERNOS PAB, B2, C1 Y C2 COMP. FED V Y OTROS s/INCIDENTE DE RECURSO EXTRAORDINARIO","alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - PRESENTANTE: RUIZ JUAN CARLOS Y , OTROS INTERNOS PAB, B2, C1 Y C2 COMP. FED V  Y OTROS s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":6421,"titulo":"Agravamiento de las condiciones de detención: insuficiente remisión a un precedente anterior","cabecilla":"<p style=\"text-indent:2em\">En respuesta a una acción de hábeas corpus en beneficio de los internos alojados en las celdas unipersonales de un complejo federal penitenciario el juez prohibió el alojamiento compartido en ellas y los trabajos de colocación de cuchetas dobles que se estaban realizando al considerar que ello constituía una amenaza actual de agravamiento de las condiciones de detención.</p><p style=\"text-indent:2em\">Por su parte, la cámara declaró la nulidad de esta sentencia y reconoció al Servicio Penitenciario Federal la facultad de fijar el cupo de los diversos establecimientos.</p><p style=\"text-indent:2em\"><b>La Corte dejó sin efecto la decisión de la cámara</b>. Consideró que, si bien la remisión a lo resuelto en pronunciamientos anteriores, en principio, no importa de por sí la arbitrariedad de una sentencia, ello puede resultar insuficiente si con ello quedan sin responder cuestiones oportunamente debatidas y conducentes o se omiten tratar aspectos del hecho relevantes. Tuvo en cuenta que el precedente al que se había remitido también trataba sobre el cupo de un establecimiento y la colocación de cuchetas dobles pero no se había probado que la medida hubiera implicado un agravamiento de las condiciones de detención mientras que en este caso la conclusión del juez había sido la contraria.</p>","esNovedad":true,"fecha":1708398000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1708610690892,"usuarioCreacion":11,"fechaCreacion":1708460621561,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":108933,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34303196,"numeroExpediente":39487,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":17,"codigo":"17","abreviatura":"FGR","descripcion":"Justicia Federal de General Roca","estado":0,"descripcionLarga":"FGR - Justicia Federal de General Roca"},"objetoJuicio":{