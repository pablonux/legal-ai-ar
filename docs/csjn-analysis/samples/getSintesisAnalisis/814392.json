[{"codigo":8143924,"analisisDocumental":{"id":814392,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"PRIETO ALICIA LILIANA c/ ANSES s/PRESTACIONES VARIAS","inconstitucional":false,"falloDestacado":{"id":9361,"titulo":"Jubilación de magistrados y funcionarios judiciales: diferenciación entre interinos y efectivos","cabecilla":"<p style=\"text-indent: 2em;\">La cámara hizo lugar a la demanda promovida con el objeto de obtener el otorgamiento de la jubilación ordinaria de conformidad con lo dispuesto en la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-24018-417/actualizacion\">ley 24.018</a>. La Administración Nacional de la Seguridad Social (ANSeS) interpuso un recurso extraordinario argumentando que la actora no había alcanzado el mínimo de cinco años en el cargo de prosecretaria administrativa de manera efectiva ya que durante cierto lapso lo había hecho con carácter interino. </p><p style=\"text-indent: 2em;\">La Corte declaró admisible el recurso y confirmó la sentencia apelada. </p><p style=\"text-indent: 2em;\">Señaló que el legislador no efectuó distinción alguna según el carácter -efectivo o interino- en que se desempeñó el magistrado o funcionario que solicita el beneficio previsional, sino que solamente aludió a la prestación de servicios por un tiempo determinado (cinco o diez años según el caso). </p><p style=\"text-indent: 2em;\">Agregó que se advertía que, desde el momento en que la actora comenzó a prestar servicios en el cargo de prosecretaria administrativa, se retuvieron los aporte jubilatorios del 12% de sus haberes con destino al organismo demandado, quien los recibió en el marco del régimen establecido por la ley 24.018 por lo que la postura de la recurrente -en tanto omitía considerar el período en que la actora se desempeñó con carácter interino- importaba el desconocimiento de uno de los contenidos esenciales del principio cardinal de la buena fe, con arreglo al cual nadie puede ponerse en contradicción con sus propios actos, ejerciendo una conducta incompatible  con otra anterior deliberada, jurídicamente relevante y plenamente eficaz.</p>","esNovedad":true,"fecha":1757991600000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1758051621378,"usuarioCreacion":11,"fechaCreacion":1758047276694,"privado":false,"posicion":9,"resumen":null},"reciboEntrada":{"id":142825,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34029265,"numeroExpediente":23606,"anioExpediente":2018,"t