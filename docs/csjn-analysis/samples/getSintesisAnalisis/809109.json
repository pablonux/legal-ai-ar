[{"codigo":8091094,"analisisDocumental":{"id":809109,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - RAMIREZ BALBUENA, CELIA c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":8723,"titulo":"Migraciones: variaciones en la regulación normativa y resguardo de la defensa en juicio","cabecilla":"<p style=\"text-indent:2em\">La cámara confirmó la decisión que rechazó el recurso deducido contra la disposición mediante la que la Dirección Nacional de Migraciones declaró irregular la permanencia en el país de una migrante de nacionalidad paraguaya y ordenó su expulsión del territorio nacional. Entendió que la decisión adoptada se ajustaba a lo dispuesto en el artículo 29, inciso c, de la<a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-25871-92016/actualizacion\"> ley 25.871</a>, conforme el texto modificado por el <a href=\"https://www.argentina.gob.ar/normativa/nacional/decreto-70-2017-271245/texto\">decreto 70/2017</a>, pues se encontraba firme el auto que había dispuesto el procesamiento de la migrante por el delito de transporte de estupefacientes.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto este pronunciamiento.</p><p style=\"text-indent:2em\">Señaló que, con posterioridad a que la actora dedujera el recurso extraordinario, fue promulgado el decreto <a href=\"https://www.argentina.gob.ar/normativa/nacional/decreto-138-2021-347595/texto\">138/2021</a>, que derogó su par 70/2017 y, al restituir la vigencia de las normas modificadas, sustituidas o derogadas por este último, varió sustancialmente el encuadramiento normativo bajo el cual debe examinarse la situación de la actora.</p><p style=\"text-indent:2em\">     El Tribunal agregó que tuvo oportunidad de expedirse con relación a la exigencia de condena como causal de impedimento de ingreso y permanencia en “Zhang Hang” (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=330&amp;pagina=4554\">330:4554</a>) y con respecto a las garantías mínimas judiciales consagradas en el artículo 8.2 de la Convención Americana sobre Derechos Humanos -entre las que se encuentra la presunción de inocencia- en \"<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarSumariosFallo.html?idSumario=170531\">Alcaraz Páez, Jésica Lorena c/ EN - DNM</a>\", sentencia del 19 de diciembre de 2024.</p><p style=\"text-indent:2em\">     Por ello, atento a la variación de la regulación normativa en aspectos que fueron objeto de cuestionamientos en el recurso extraordinario, la Corte resolvió devolver las actuaciones a los jueces de la causa para que examinen el asunto a la luz de las nuevas disposiciones vigentes. Añadió que, a tal fin, deberán resguardar la garantía de la defensa en juicio permitiendo a las partes ejercer los derechos que les asisten y resolver los planteos de inconstitucionalidad introducidos por la migrante.</p>","esNovedad":true,"fecha":1747796400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1747935266112,"usuarioCreacion":11,"fechaCreacion":1747858029362,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":137402,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35148654,"numeroExpediente":21698,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 2 - CHIQUILLAN SECCE, AMELIA c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"21698. "},"recurso":{"id":5927651,"expediente":{"id":35148654,"numeroExpediente":21698,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 2 - CHIQUILLAN SECCE, AMELIA c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"21698. "},"tipoRecurso":{"id":1182,"codigo":"RHX","d