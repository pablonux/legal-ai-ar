[{"codigo":8054204,"analisisDocumental":{"id":805420,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - USUARIOS Y CONSUMIDORES UNIDOS c/ DG MEDIOS Y ESPECTACULOS S.A. s/SUMARISIMO","inconstitucional":false,"falloDestacado":{"id":8142,"titulo":"Proceso de consumo: gratuidad prevista en el art. 55 de la ley 24.240","cabecilla":"<p style=\"text-indent:2em\">La Corte reiteró su jurisprudencia en el sentido que el beneficio de justicia gratuito previsto por el art. 55 de la ley 24.240, se rige por la doctrina de la causa “ADDUC y otros” (Fallos: <a href=\"https://webvpn.csjn.gov.ar/proxy/4234bfb9/https/sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=344&amp;pagina=2835\">344:2835</a>) en la cual se entendió que una razonable interpretación armónica de los artículos 53 y 55 de la ley <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-24240-638/actualizacion\">24.240</a> (con las modificaciones introducidas por la ley 26.361) permite sostener que el Congreso Nacional ha tenido la voluntad de eximir a quienes inician una acción en los términos de la Ley de Defensa del Consumidor del pago de las costas del proceso, en tanto la norma no requiere a quien demanda en el marco de sus prescripciones la demostración de una situación de pobreza para otorgar el beneficio, sino que se lo concede automáticamente y solo en determinados supuestos, esto es en acciones iniciadas en defensa de intereses individuales, se admite que la contraparte acredite la solvencia del actor para hacer cesar la eximición.</p><p style=\"text-indent:2em\">Asimismo, señaló el Tribunal que la efectiva vigencia del mandato constitucional del art. 42, requiere que dicha protección no quede limitada sólo al reconocimiento de ciertos derechos y garantías, sino que, además, asegure a los consumidores la posibilidad de obtener su eficaz defensa en las instancias judiciales. Y que la gratuidad del proceso judicial encuentra su razón de ser en la condición de debilidad estructural en la que se encuentra el consumidor/usuario en el marco de la relación de consumo con el objeto de facilitar su defensa y de evitar que obstáculos de índole económica puedan comprometer su acceso a la justicia y, en consecuencia, privarlos de la efectiva tutela de los derechos consagrados en el texto constitucional (Fallos: <a href=\"https://webvpn.csjn.gov.ar/proxy/4234bfb9/https/sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=338&amp;pagina=1344\">338:1344</a>).</p>","esNovedad":true,"fecha":1735268400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1735564359478,"usuarioCreacion":11,"fechaCreacion":1735333003562,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":131973,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden"