[{"codigo":7723343,"analisisDocumental":{"id":772334,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"PAOLI, GASTON ALEJANDRO s/ INCIDENTE DE INCOMPETENCIA","alias":null,"caratula":"PAOLI, GASTON ALEJANDRO s/VIOLACION DE MEDIDAS-PROPAGACION EPIDEMIA(ART.205)","inconstitucional":false,"falloDestacado":{"id":3341,"titulo":"Competencia para juzgar sobre infracciones a las medidas de aislamiento social","cabecilla":"<p>A ra&iacute;z de la detenci&oacute;n por la polic&iacute;a local de una persona que se hallaba supuestamente circulando por la v&iacute;a p&uacute;blica&nbsp;<strong>en infracci&oacute;n a las medidas de aislamiento social, preventivo y obligatorio,&nbsp;</strong>se origin&oacute; un conflicto negativo de competencia entre un juzgado de garant&iacute;as provincial y un juzgado federal, que a la Corte le correspondi&oacute; dirimir. El Tribunal record&oacute; que el dise&ntilde;o institucional en materia jurisdiccional se erige sobre el principio de que la competencia federal se encuentra acotada y definida a los poderes que las provincias delegaron en el Estado Federal y, por ello, la competencia de los tribunales federales es restrictiva. Agreg&oacute; que el juzgamiento del delito imputado -previsto en el art&iacute;culo 205 del C&oacute;digo Penal- no se haya atribuido a la justicia federal en las diversas normas que determinan la competencia del fuero de excepci&oacute;n, por lo que se encuentra a cargo de las autoridades locales conocer, como principio, de los hechos que en esta materia cayeron bajo sus respectivas jurisdicciones.&nbsp;<strong>Concluy&oacute; as&iacute; el Tribunal que correspond&iacute;a que sea la justicia local</strong>&nbsp;la que investigue el hecho, sin perjuicio de lo que resulte de la investigaci&oacute;n posterior.</p>","esNovedad":true,"fecha":1640055600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1640274145676,"usuarioCreacion":4,"fechaCreacion":1640113515851,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":33037,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35053175,"numeroExpediente":1237,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10579,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"PAOLI, GASTON ALEJANDRO s/VIOLACION DE MEDIDAS-PROPAGACION EPIDEMIA(ART.205)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1237. "},"recurso":{"id":5892773,"expediente":{"id":35053175,"numeroExpediente":1237,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CS