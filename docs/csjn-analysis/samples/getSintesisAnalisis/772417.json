[{"codigo":7724173,"analisisDocumental":{"id":772417,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"DIEZ, HORACIO PEDRO Y OTRO s/LEGAJO DE APELACION","alias":null,"caratula":"Recurso Queja Nº 1 - DENUNCIADO: DIEZ, HORACIO PEDRO s/MALVERSACION DE CAUDALES PUBLICOS (ART.261)","inconstitucional":false,"falloDestacado":{"id":3382,"titulo":"Debido proceso legal y derecho al doble conforme del auto de procesamiento","cabecilla":"<p>Ante la decisi&oacute;n de c&aacute;mara que revoc&oacute; el sobreseimiento del imputado y dispuso su procesamiento sin prisi&oacute;n preventiva la defensa interpuso un recurso de casaci&oacute;n invocando la necesidad de obtener el doble conforme, que fue declarado inadmisible por la C&aacute;mara Federal de Casaci&oacute;n Penal.&nbsp;<strong>La Corte dej&oacute; sin efecto la decisi&oacute;n recurrida</strong>&nbsp;al considerar que se estaba ante un supuesto de arbitrariedad en tanto no se hab&iacute;a hecho&nbsp;cargo de evaluar y abordar debidamente los planteos oportunamente formulados por el recurrente.&nbsp;Destac&oacute; que&nbsp; la importancia que para la parte ten&iacute;a contar con esa instancia de revisi&oacute;n no pod&iacute;a entenderse como prescindible y que el reclamo de la defensa no constitu&iacute;a una caprichosa ocurrencia&nbsp;sino que se fundaba en previsiones claras y expresas establecidas por el legislador al dise&ntilde;ar el esquema de enjuiciamiento penal y que, en consecuencia, no pod&iacute;an ser relativizadas ni dejadas de lado sin raz&oacute;n suficiente.&nbsp;Agreg&oacute; que las cuestiones planteadas se vinculaban con la operatividad de la instancia revisora&nbsp;en un determinado momento procesal previsto por la ley a los fines de asegurar la tutela eficaz del derecho de defensa y el debido proceso legal.</p>","esNovedad":true,"fecha":1640660400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1640778961477,"usuarioCreacion":11,"fechaCreacion":1640778958718,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":33072,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30495946,"numeroExpediente":1610,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - DENUNCIADO: DIEZ, HORACIO PEDRO s/MALVERSACION DE CAUDALES PUBLICOS (ART.261) ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1610. "},"recurso":{"id":5177408,"expediente":{"id":30495946,"num