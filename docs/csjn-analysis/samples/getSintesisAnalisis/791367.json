[{"codigo":7913674,"analisisDocumental":{"id":791367,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"LLANOS, ERMINDO EDGARDO MARCELO s/RECURSO DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":6182,"titulo":"Arbitrariedad en la aplicación de la nulidad por cosa juzgada írrita","cabecilla":"<p>Ante la sentencia que anuló el sobreseimiento del acusado (por prescripción de la acción penal) la defensa interpuso recurso extraordinario. <b>La Corte dejó sin efecto este pronunciamiento con fundamento en su arbitrariedad</b>. Consideró que la sentencia cuestionada había omitido argumentos y que tampoco justificaba adecuadamente de qué manera el supuesto “palmario error de derecho” habilitaba la anulación de una sentencia pasada en autoridad de cosa juzgada sin afectación de la garantía de <em>ne bis in idem</em> planteada por el recurrente. Agregó que l