[{"codigo":7820133,"analisisDocumental":{"id":782013,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"ALPHA SHIPPING S.A. c/ PROVINCIA DE T.D.F. A E I A S s/contencioso administrativo - medida cautelar","alias":null,"caratula":"ALPHA SHIPPING S.A. c/ PROVINCIA DE T.D.F. A E I A S s/contencioso administrativo - medida cautelar ","inconstitucional":false,"falloDestacado":{"id":5141,"titulo":"Prescripción de las obligaciones tributarias locales","cabecilla":"<p>La empresa actora cuestionó las multas impuestas por la dirección general de rentas provincial, entre otras cuestiones, por entender que las mismas se encontraban prescriptas. La justicia provincial rechazó la defensa de prescripción articulada por el contribuyente y declaró la nulidad parcial de una de las multas. Recurrida esa decisión ante la Corte, esta revocó la sentencia apelada. Señaló que los principios y reglas del derecho penal son aplicables en el ámbito de las sanciones administrativas, siempre que la solución no esté prevista en el ordenamiento jurídico específico y en tanto resulten compatibles con el régimen jurídico estructurado por las normas especiales de que se trate. De ese modo, resolvió que correspondía aplicar el plazo establecido en el inc. 4° del art. 65 del Código Penal, pues es a ese cuerpo normativo a quien le incumbe legislar sobre la extinción de acciones y penas, sin perjuicio del derecho de las provincias al establecimiento de particulares infracciones y penas en asuntos de interés puramente local. Al respecto, indicó que la prescripción no es un instituto propio del derecho público local, sino un instituto general del derecho, por lo cual las legislaturas locales no se hallan habilitadas para dictar leyes incompatibles con las previsiones que al respecto contienen los códigos de fondo, dictados por el legislador nacional en ejercicio de la habilitación conferida al legislador nacional por el art. 75, inc. 12, de la Constitución Nacional.</p>","esNovedad":true,"fecha":1678158000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1678368145046,"usuarioCreacion":4,"fechaCreacion":1678368124551,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":106851,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32575536,"numeroExpediente":1897,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ALPHA SHIPPING S.A. c/ PROVINCIA DE T.D.F. A E I A S s/contencioso administrati