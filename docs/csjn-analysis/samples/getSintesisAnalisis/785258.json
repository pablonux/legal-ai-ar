[{"codigo":7852585,"analisisDocumental":{"id":785258,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Legajo Nº 1 - MARASCALCHI MUÑIZ MARCOS LEANDRO Y OTROS s/LEGAJO DE CASACION","inconstitucional":false,"falloDestacado":{"id":5621,"titulo":"Afectación al derecho a ser juzgado en un plazo razonable ","cabecilla":"<p>En un nuevo pronunciamiento dictado a partir de una sentencia anterior de la Corte, la cámara de casación rechazó el recurso planteado por uno de los acusados lo que originó otro recurso extraordinario. La Corte dejó sin efecto la sentencia por considerar que se había apartado de su previa decisión, en la que había señalado el alcance que debe darse al derecho a obtener un pronunciamiento sin dilaciones indebidas. Destacó que la duración de la causa no podía ser atribuida al imputado ni a la complejidad del caso, y por lo tanto se configuraba la afectación al derecho a ser juzgado en un plazo razonable que nuevamente reclamaba la recurrente. En respuesta al argumento relativo a que el imputado no había demostrado el perjuicio concreto al no haber sido privado de su libertad el Tribunal señaló que no obstante que el enjuiciamiento penal comporta una situación de incertidumbre y de restricción de aquella, las referidas son dos garantías diferentes cuya lesión podría acarrear consecuencias distintas. Agregó que resultaba un contrasentido que al rechazar el recurso de casación la cámara haya admitido que se había verificado una considerable demora causada en gran medida por la dilación de la etapa de juicio y, a la vez, haya objetado a la defensa que omitiera indicar los actos que habrían dado lugar a dilaciones indebidas. </p>","esNovedad":true,"fecha":1688439600000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1688502579082,"usuarioCreacion":11,"fechaCreacion":1688498040603,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":110758,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30693962,"numeroExpediente":500000816,"anioExpediente":2004,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXPEDIENTES PENALES","idMateria":9,"tema":null},"caratula":"Recurso Queja Nº 1 - Legajo Nº 1 - MARASCALCHI MUÑIZ M