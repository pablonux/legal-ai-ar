[{"codigo":8032012,"analisisDocumental":{"id":803201,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"VILLEGAS, TITO c/ SOCIEDAD TIRO GIMNASIA Y ESGRIMA JUJUY s/ recurso de inconstitucionalidad","inconstitucional":false,"falloDestacado":{"id":7882,"titulo":"Usucapión: arbitrariedad en la evaluación de las pruebas","cabecilla":"<p style=\"text-indent: 2em;\">La actora inició una acción por usucapión al considerar cumplidos los veinte años continuos exigidos para adquirir el dominio de un inmueble. El reclamo fue rechazado en las instancias provinciales con fundamento en el contenido de una copia de una nota en la cual la accionante habría solicitado al club demandado una constancia escrita sobre su situación de ocupantes precarios de un inmueble perteneciente a dicha institución. Consideró entonces que del contenido de la nota surgía de forma indubitable que la actora había reconocido en otro la propiedad de la fracción de terreno que ocupaba.</p><p style=\"text-indent: 2em;\">La Corte dejó sin efecto la sentencia.</p><p style=\"text-indent: 2em;\">Consideró que había otorgado un alcance irrazonable tanto a la certificación de la copia como a la falta de impugnación del auto de apertura a prueba, la que relacionó directamente con dicha certificación. Efectivamente, la certificación del prosecretario de cámara solo dio fe de que la fotocopia respectiva coincidía con la copia de la nota que le fue exhibida, y no de su contenido o de las firmas insertas dado que el documento no había sido extendido ni suscripto en su presencia. Carecía así de sustento el fundamento del tribunal en el sentido de que la actora había omitido redargüir de falsedad el referido documento, ya que el artículo 993 del Código Civil -entonces vigente- disponía que el instrumento público hacía plena fe solo de la existencia material de los hechos que el oficial público hubiese anunciado como cumplidos por él mismo, o que han pasado en su presencia.</p><p style=\"text-indent: 2em;\">Concluyó el Tribunal que no habían sido evaluadas tampoco el resto de las pruebas producidas en la causa, lo cual llevaba a la descalificación de la sentencia como acto jurisdiccional.</p>","esNovedad":true,"fecha":1730775600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1730904234478,"usuarioCreacion":4,"fechaCreacion":1730904232656,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":129802,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32505533,"numeroExpediente":78241,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","esta