[{"codigo":7807353,"analisisDocumental":{"id":780735,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"ASOCIACIÓN DEL PERSONAL DE ORGANISMOS DE CONTROL - APOC c/ TRIBUNAL DE CUENTAS DE LA PROVINCIA DE MISIONES s/ ACCIÓN CONTENCIOSO ADMINISTRATIVA","alias":null,"caratula":"ASOCIACION DEL TRIBUNAL DE ORGANISMOS DEL CONTROL - APOC c/ TRIBUNAL DE CUENTAS DE LA PROVINCIA DE MISIONES s/ACCION CONTENCIOSO ADMINISTRATIVA","inconstitucional":false,"falloDestacado":{"id":4907,"titulo":"Interpretación del consentimiento otorgado en las actas poder en favor de un sindicato","cabecilla":"<p>Un sindicato reclamó el reconocimiento para sus afiliados de los adicionales por \"Compensación Funcional\" y \"Pasajes\". La cámara rechazó el pedido por considerar que no tenía legitimación procesal dado que las actas poder habían sido otorgadas para otros reclamos. La Corte dejó sin efecto la sentencia apelada. Tuvo en cuenta que si bien en las actas poder acompañadas se había aludido a un adicional por antigüedad, también se había aclarado que el consentimiento se prestaba para llevar a sede judicial el reclamo del pago de los adicionales mencionados. Consideró entonces que la decisión que se sustentó solo en ciertos pasajes de dichas actas, ignorando otras de sus partes que resultaban relevantes a los fines de decidir la legitimación de la actora, incurrió en un injustificado rigor formal y comportó una valoración de las constancias de la causa contraria al principio \"in dubio pro actione\", que resulta rector en materia de acceso a la justicia.</p>","esNovedad":true,"fecha":1671591600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1671711358334,"usuarioCreacion":11,"fechaCreacion":1671711349540,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":105627,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33438751,"numeroExpediente":7451,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7321,"descripcion":"MARCO DE REGULACION DEL EMPLEO PUBLICO NACIONAL - LEY 25164 - ART 40","idMateria":2,"tema":null},"caratula":"Recurso Queja Nº 1 - RAMOS VILLAVERDE, JAVIER MARCELO c/ EN-M JUSTICIA Y DDHH s/MARCO DE REGULACION DEL EMPLEO PUBLICO NACIONAL - LEY 25164 - ART 40","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"7451. "},"recurso":{"id":5577009,"expediente":{"id":33438751,"numeroExpediente":7451,"anioExpediente":2015,"tomoExpediente":null,"letraEx