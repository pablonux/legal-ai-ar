[{"codigo":7958093,"analisisDocumental":{"id":795809,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - RIZZO, JORGE GABRIEL Y OTRO c/ EN-DNU 70/23 s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":6701,"titulo":"Rechazo de una acción de amparo contra el DNU 70/2023 por inexistencia de un “caso”\r\n","cabecilla":"<p style=\"text-indent:2em\">El actor, por derecho propio y en representación de una asociación, promovió acción de amparo a fin de que se declare la inconstitucionalidad \"integral\" del decreto 70/2023. Luego de su rechazo en las anteriores instancias interpuso un recurso extraordinario que <em>fue desestimado por la Corte</em>.</p><p style=\"text-indent:2em\">El Tribunal entendió que el apelante no cumplió con el requisito de fundamentación autónoma por no refutar la conclusión central del pronunciamiento recurrido referido a que ni él personalmente, ni la asociación que preside, poseen un <em>interés concreto o sustancial en la declaración de inconstitucionalidad</em> del DNU. Consideró que el recurso no explicó de qué modo la aplicación de ese decreto les causa una afectación personal, diferenciada de la que, por hipótesis, podría recaer sobre el resto de la población.</p><p style=\"text-indent:2em\">Recordó que la existencia de \"caso\" presupone la de \"parte\", esto es la de quien reclama o se defiende y, por ende, la de quien se beneficia o perjudica con la resolución adoptada al cabo del proceso. Es decir, para que exista un caso es imprescindible que quien reclama tenga un interés suficientemente directo, concreto y personal —diferenciado del que tienen el resto de los ciudadanos— en el resultado del pleito que propone, de manera que los agravios que se invocan lo afecten de forma \"suficientemente directa\" o \"substancial\".</p><p style=\"text-indent:2em\">Agregó que los tribunales federales no han sido investidos por la Constitución de la facultad de analizar la constitucionalidad de normas o formular interpretaciones de ellas en abstracto, lo que impide pronunciamientos meramente teóricos o consultivos.</p>","esNovedad":true,"fecha":1713236400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1713379221931,"usuarioCreacion":11,"fechaCreacion":1713291964400,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":119600,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38744189,"numeroExpediente":48194,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacion