[{"codigo":7832456,"analisisDocumental":{"id":783245,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Principal en Tribunal Oral TO01 - QUERELLANTE: PASSAGLIA, MANUEL Y OTRO s/QUERELLA","inconstitucional":false,"falloDestacado":{"id":5381,"titulo":"Competencia federal para hechos vinculados al desempeño de un funcionario federal ","cabecilla":"<p>La justicia en lo criminal y correccional y la justicia en lo criminal y correccional federal se declararon incompetentes para intervenir en la causa iniciada con motivo de la querella deducida por el Intendente de San Nicolás contra el Ministro de Ambiente y Desarrollo Sostenible a raíz de las afirmaciones formuladas por éste último acusando, entre otros, al citado intendente por los incendios intencionales acaecidos en el Delta del Paraná. La Corte recordó que en los casos que involucran a un funcionario federal la competencia del <b>fuero de excepción</b> solo se halla justificada <b>cuando los hechos aparecen vinculados al desempeño de sus funciones</b>. Teniendo en cuenta que atento el tenor de las afirmaciones que el querellante le atribuye al imputado no puede descartarse que se vinculen con el desempeño de sus funciones como ministro, resolvió que <b>debe intervenir en la causa la justicia federal</b>. </p>","esNovedad":true,"fecha":1683082800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1683218470298,"usuarioCreacion":11,"fechaCreacion":1683208428976,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":108319,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35222774,"numeroExpediente":54567,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Principal en Tribunal Oral TO01 - QUERELLANTE: PASSAGLIA, MANUEL Y OTRO s/QUERELLA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"54567. "},"recurso":{"id":5996072,"expediente":{"id":35222774,"numeroExpediente":54567,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Principa