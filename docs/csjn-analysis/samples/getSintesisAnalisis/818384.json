[{"codigo":8183843,"analisisDocumental":{"id":818384,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":230004,"valor":"RECURSO DE REVOCATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - SOCIEDAD ITALIANA DE BENEFICENCIA EN BUENOS AIRES c/ EN-M SALUD DE LA NACION- Y OTRO s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":10463,"titulo":"Acordada 4/2007: requisito de \"carátula\"","cabecilla":"<p style=\"text-indent: 2em;\">La Corte desestimó un planteo de revocatoria al recordar que sus decisiones en los recursos de queja por apelación denegada no son, como principio, susceptibles de recurso alguno y que no se configuraba un supuesto estrictamente excepcional que justificara apartarse de tal doctrina.</p><p style=\"text-indent: 2em;\">Expresó que el incumplimiento del recaudo establecido en el artículo 5° del reglamento aprobado por la acordada 4/2007 -que había determinado la desestimación de la presentación directa- resultaba ostensible si se tenía en cuenta que tal norma exige la presentación en hoja aparte de una \"carátula\" -o \"formulario\" (confr. punto II de la acordada)- en la que, según se indica en ese artículo deben consignarse \"exclusivamente\" los datos allí requeridos.</p><p style=\"text-indent: 2em;\">En lugar de ello, la apelante había efectuado una presentación de ocho páginas, de apretada escritura, en la que se extendía en el desarrollo de diversos argumentos, alegatos, críticas a la decisión del a quo y transcripciones de fallos.</p><p style=\"text-indent: 2em;\">Concluyó, pues, que resultaba indudable que una presentación de tales características no constituía la \"carátula\" que debe acompañar al recurso de hecho según el claro texto del referido artículo 5°.</p>","esNovedad":true,"fecha":1774494000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1774554622112,"usuarioCreacion":11,"fechaCreacion":1774554601727,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":146860,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38935646,"numeroExpediente":11625,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 1 - SOCIEDAD ITALIANA DE BENEFICENCIA EN BUENOS AIRES c/ EN-M SALUD DE LA NACION- Y OTRO s/PROCESO DE CONOCIMIENTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"11625. "