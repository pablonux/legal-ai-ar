[{"codigo":8010445,"analisisDocumental":{"id":801044,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"SINDICATO UNIDO DE TRABAJADORES Y EMPLEADOS DEL PAMI SUTEPA c/ INSTITUTO NACIONAL DE SERVICIOS SOCIALES PARA JUBILADOS Y PENSIONADOS s/JUICIO SUMARISIMO","inconstitucional":false,"falloDestacado":{"id":7582,"titulo":"Libertad sindical y asociación sindical simplemente inscripta","cabecilla":"<p style=\"text-indent:2em\">La actora, entidad de primer grado simplemente inscripta, solicita que se permita la realización de elecciones de representantes en el ámbito de las instalaciones del INSSJP, que se ordene que las autoridades electas de la organización integren la mesa de negociaciones colectivas de la Comisión Paritaria Permanente y que se garantice la igualdad de trato respecto de otras asociaciones sindicales.</p><p style=\"text-indent:2em\">La cuestión federal por lo tanto consistió en determinar si, a la luz de las normas de rango constitucional que tutelan la libertad sindical y el derecho de sindicación, puede condicionarse la designación de delegados de una asociación sindical simplemente inscripta -como la actora- a la celebración de una elección de representantes convocada con carácter general por la entidad más representativa.</p><p style=\"text-indent:2em\">La Corte consideró que otorgar un derecho exclusivo a la entidad con personería gremial para convocar, organizar y fiscalizar las elecciones de delegados sindicales, permitiéndole únicamente a las entidades simplemente inscriptas -como la recurrente- participar de esa elección general, <em>vulnera la libertad sindical prevista en el artículo 14 bis de la Constitución Nacional y en el Convenio 87 de la OIT.</em></p><p style=\"text-indent:2em\">Según la Corte ello implica conferirle a la organización más representativa privilegios que no son compatibles con la libertad sindical en cuanto exceden de una prioridad en materia de representación en las negociaciones colectivas, consultas con los gobiernos, o incluso en materia de designación de los delegados ante organismos internacionales.</p><p style=\"text-indent:2em\">En esos términos, entendió que la condición impuesta por la sentencia apelada priva a las organizaciones sindicales simplemente inscriptas del derecho de elegir libremente a sus representantes, de organizar su gestión y su actividad y de formular su programa de acción (art. 3.1, Convenio 87 de la OIT) y, en definitiva, de contar con los medios esenciales para defender los intereses profesionales de sus miembros, lo que configura una injerencia injustificada en la libertad sindical, en franca contradicción con el deber del Estado de evitar toda intervención que limite o entorpezca el ejercicio legal de ese derecho (art. 3.2, convenio cit.) y de asegurar, en definitiva, la organización sindical libre y democrática (art. 14 bis, Constitución Nacional).</p><p style=\"text-indent:2em\">En conclusión, entendió el Tribunal, que la invalidez constitucional del artículo 41, inciso a, de la ley 23.551 comprende la exclusividad de los sindicatos con personería gremial para organizar las elecciones de delegados del personal e integrantes de las comisiones internas y organismos similares. Ese monopolio – consideró -  viola la libertad sindical de la entidad actora al interferir en su proceso de designación de representantes, y afecta el ejercicio de sus funciones esenciales de promoción, defensa, fomento y protección de los intereses legítimos de orden gremial.</p>","esNovedad":true,"fecha":1726542000000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1726601656040,"usuarioCreacion":11,"fechaCreacion":1726598126674,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":127598,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":26825711,"numeroExpediente":19155,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9715,"descripcion":"JUICIO SUMARISIMO","idMateria":5,"tema":null},"caratula":"SINDICATO UNIDO DE TRABAJADORES Y EMPLEADOS DEL PAMI SUTEPA c/ INSTITUTO NACIONAL DE SERVICIOS SOCIALES PARA JUBILADOS Y PENSIONADOS s/JUICIO SUMARISIMO","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":30919291,"numeroExpediente":19155,"anioExpediente":2015,"tomoEx