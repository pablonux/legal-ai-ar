[{"codigo":7977764,"analisisDocumental":{"id":797776,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"CORREO OFICIAL DE LA REPUBLICA ARGENTINA S.A. c/ ENTRE RIOS, PROVINCIA DE s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":7041,"titulo":"Ingresos brutos e impuesto de sellos: competencia originaria del Tribunal","cabecilla":"<p style=\"text-indent:2em\">El Correo Oficial de la República Argentina S.A. promovió una acción contra la Provincia de Entre Ríos a fin de que se declare inconstitucional la pretensión de gravar con los impuestos de sellos, inmobiliario y sobre los ingresos brutos la actividad que despliega en ella.</p><p style=\"text-indent:2em\">La Corte entendió que el juicio es de su competencia originaria.</p><p style=\"text-indent:2em\">Tuvo en cuenta que es parte una provincia en una causa de manifiesto contenido federal, pues el planteo exige dilucidar si la potestad tributaria que pretende ejercer la provincia demandada interfiere el ámbito que le es propio a la Nación en torno al Servicio Oficial de Correo que fue reasumido transitoriamente por el Estado Nacional, por lo que la cuestión se encuentre entre aquellas especialmente regidas por la Constitución Nacional, a las que alude el art. 2°, inc. 1° de la ley 48.</p><p style=\"text-indent:2em\">El Tribunal decretó parcialmente la prohibición de innovar solicitada ya que, si bien por vía de principio dichas medidas no proceden respecto de actos administrativos o legislativos habida cuenta de la presunción de validez que ostentan, tal doctrina debe ceder cuando se los impugna sobre bases <em>prima facie</em> verosímiles.</p><p style=\"text-indent:2em\">En cambio, no hizo lugar a la medida cautelar pedida con relación al impuesto inmobiliario, en tanto no corresponde que la Corte interfiera por esta vía en procesos judiciales ya existentes, con afectación del adecuado respeto que merecen las decisiones judiciales.</p>","esNovedad":true,"fecha":1718247600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1718370127674,"usuarioCreacion":11,"fechaCreacion":1718307500859,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":121922,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23327589,"numeroExpediente":1109,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"C","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"Cayetano Caruso S.A. c/ Buenos Aires, provincia de s/acción declarativa de certeza","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"C. 1109. XLIX. "},"recurso":{"id":3135608,"expediente":{"id":23327589,"numeroExpediente":1109,"anioExpediente":2013,"tomo