[{"codigo":7773774,"analisisDocumental":{"id":777377,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"ESCALANTE, ESTEBAN IVAN Y OTROS s/ HOMICIDIO","alias":null,"caratula":"ESCALANTE, ESTEBAN IVAN Y OTROS s/homicidio triplemente calificado por haberse cometido con ensañamiento, alevosia y con el concurso de dos o mas personas en concurso real con el abuso sexual con acceso carnal y con el delito de privacion ilegitima de la libertad","inconstitucional":false,"falloDestacado":{"id":4302,"titulo":"Alcance de lo resuelto por la Corte Interamericana de Derechos Humanos y decisión de la cuestión federal por el superior tribunal de la causa.","cabecilla":"<p>La defensa de un menor condenado a prisión perpetua reclamó la aplicación de lo resuelto por la Corte Interamericana de Derechos Humanos en el caso “<a href=\"https://www.corteidh.or.cr/docs/casos/articulos/seriec_260_esp.pdf\"><u>Mendoza</u></a>”, en el cual  se declaró la responsabilidad internacional del Estado argentino y se consideró que la imposición de penas de prisión y reclusión perpetuas a personas que eran menores de edad al momento de la comisión de delitos vulnera la prohibición de detenciones arbitrarias o ilegales y de sometimiento a torturas, penas o tratos crueles, inhumanos o degradantes. El superior tribunal local declaró inadmisible el recurso de revisión interpuesto. La <b>Corte, sin adelantar criterio alguno sobre la solución de la cuestión federal planteada,</b> <b>dejó sin efecto la sentencia</b> al considerar que, frente al planteo de la defensa, correspondía dilucidar si es constitucionalmente válido para el orden jurídico argentino el cumplimiento obligatorio de lo ordenado por la Corte Interamericana como medida de reparación. Recordó para ello la jurisprudencia sentada en los precedentes \"Strada\" (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=308&amp;pagina=490\">Fallos: 308:490</a>) y \"Di Mascio\" (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=311&amp;pagina=2478\">Fallos: 311:2478</a>) según la cual los máximos tribunales provinciales no pueden invocar limitaciones de orden local para rehusar el abordaje de las cuestiones federales sometidas a su conocimiento.</p>","esNovedad":true,"fecha":1660273200000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1660325788924,"usuarioCreacion":11,"fechaCreacion":1660325761270,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":34826,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30313450,"numeroExpediente":1487,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","desc