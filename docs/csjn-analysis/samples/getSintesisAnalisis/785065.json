[{"codigo":7850653,"analisisDocumental":{"id":785065,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ORTIZ MARISA LILIANA c/ GARCIA NIMO COBAS Y CIA S.R.L. Y OTRO s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":5583,"titulo":"Ley de Riesgos del Trabajo y daño moral","cabecilla":"<p>La cámara hizo lugar a la demanda entablada por la actora a fin de obtener las prestaciones dinerarias propias de la Ley de Riesgos del Trabajo a raíz del accidente <em>in itinere</em> sufrido y confirmó también la asignación de una partida especial para atender el daño moral de la demandante ponderando los detalles perturbadores del siniestro. Ante el recurso extraordinario interpuesto por la aseguradora la Corte dejó sin efecto la sentencia impugnada. Señaló que el  sistema especial contemplado en la ley mencionada (ley 24.557) no prevé el otorgamiento de partidas especiales para indemnizar el perjuicio en cuestión, sin que obste a ello que el daño moral pueda ser reclamado contra el sujeto responsable de su producción mediante una acción fundada en el ordenamiento civil.</p>","esNovedad":true,"fecha":1687402800000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1687459721461,"usuarioCreacion":11,"fechaCreacion":1687459674408,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":110387,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34113960,"numeroExpediente":56326,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9701,"descripcion":"ACCIDENTE - LEY ESPECIAL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - ORTIZ MARISA LILIANA c/ GARCIA NIMO COBAS Y CIA S.R.L. Y OTRO s/ACCIDENTE - LEY ESPECIAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"56326. "},"recurso":{"id":5694760,"expediente":{"id":34113960,"numeroExpediente":56326,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9701,"descripcion":"ACCIDENTE - LEY ESPECIAL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - ORTIZ MARISA LILIANA c/ GARCIA NIMO COBAS Y CIA S.R.L. Y OTRO s/ACCIDENTE - LEY ESPECIAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"56326. "},"tipoRecurso":{"id":