[{"codigo":7767253,"analisisDocumental":{"id":776725,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"BALDWIN ELINA DOROTEA c/ METROVIAS SA Y OTROS s/ DAÑOS Y PERJUICIOS","alias":null,"caratula":"Recurso Queja Nº 1 - BALDWIN ELINA DOROTEA c/ METROVIAS SA Y OTROS s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":4262,"titulo":"No procede la caducidad de instancia cuando la actividad le corresponde al Tribunal","cabecilla":"<p>La Corte, por unanimidad, revocó la sentencia de la Cámara que no tuvo en  cuenta el planteo de la recurrente que resultaba conducente para dirimir la cuestión. En tal sentido, según el Tribunal, al fundar su decisión la cámara omitió las consideraciones prescriptas en los arts. 313, inc. 3º, y 482 del Código Procesal Civil y Comercial de la Nación, de las que surge que la clausura de la etapa probatoria <em>es una actividad que le corresponde al tribunal de oficio, precisamente, al prosecretario administrativo</em>  motivo por el cual, la eventual pasividad de la parte no puede ser presumida como abandono de la instancia cuando se encuentra exenta de la carga procesal de impulso, pues ello implicaría imputarle las consecuencias del incumplimiento de las obligaciones de los funcionarios judiciales responsables.</p>","esNovedad":true,"fecha":1659409200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1659466826331,"usuarioCreacion":11,"fechaCreacion":1659466789944,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":34612,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33011752,"numeroExpediente":70861,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":567,"descripcion":"EJECUCION HIPOTECARIA","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 1 - NICOLETTI FRANCISCO c/ CIPRIANO AMBROSIO BARTOLOME s/EJECUCION HIPOTECARIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"70861. "},"recurso":{"id":5504841,"expediente":{"id":33011752,"numeroExpediente":70861,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":567,"descripcion":"EJECUCION HIPOTECARIA","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 1 - NICOLETTI FRANCISCO c/ CIPRIANO AMBRO