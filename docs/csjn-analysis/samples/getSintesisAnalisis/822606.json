[{"codigo":8226064,"analisisDocumental":{"id":822606,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"OBRA SOCIAL PARA LA ACTIVIDAD DOCENTE (OSPLAD) c/ SALTA, PROVINCIA DE s/EJECUCION FISCAL","inconstitucional":false,"falloDestacado":{"id":10164,"titulo":"Oportunidad para pedir la declaración de caducidad de la instancia","cabecilla":"<p style=\"text-indent: 2em;\">En el marco de la competencia originaria de la Corte la provincia demandada solicitó que se declare la caducidad de la instancia sobre la base de considerar que había transcurrido el plazo previsto por el artículo 310, inciso 2°, del Código Procesal Civil y Comercial de la Nación, sin que la ejecutante haya impulsado el procedimiento. </p><p style=\"text-indent: 2em;\">La Corte desestimó el planteo.</p><p style=\"text-indent: 2em;\">Señaló que, según lo dispuesto por el artículo 315, segunda parte, del código mencionado, el planteo debe formularse antes de consentir el solicitante cualquier actuación del Tribunal o de la parte posterior al vencimiento del plazo legal. Es decir que la perención queda purgada cuando se consiente una actuación útil para impulsar el procedimiento pero que fue realizada con posterioridad a dicho vencimiento, conformidad que tácitamente se produce una vez pasados cinco días del conocimiento de dicho acto y de la ampliación correspondiente en su caso en razón de la distancia, sin formular objeción por parte del sujeto legitimado para pretender una declaración de esta naturaleza, por aplicación analógica del artículo 170, segundo párrafo, de la ley ritual.</p>","esNovedad":true,"fecha":1770692400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1770755059092,"usuarioCreacion":11,"fechaCreacion":1770755057123,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":151319,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34314346,"numeroExpediente":2544,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"OBRA SOCIAL PARA LA ACTIVIDAD DOCENTE (OSPLAD) c/ SALTA, PROVINCIA DE s/EJECUCION FISCAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2544. "},"recurso":{"id":5736163,"expediente":{"id":34314346,"numeroExpediente":2544,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"OBRA SOCIAL PARA LA ACTIVIDAD DOCENTE (OSPLAD) c/ SALTA, 