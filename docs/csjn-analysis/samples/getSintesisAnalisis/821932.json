[{"codigo":8219326,"analisisDocumental":{"id":821932,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - MERLANI, PATRICIO EZEQUIEL c/ FONDO FINANCIERO PARA EL DESARROLLO DE LA CUENCA DEL PLATA s/DESPIDO","inconstitucional":false,"falloDestacado":{"id":10102,"titulo":"Inmunidad de jurisdicción y falta de sentencia definitiva: agravios conjeturales","cabecilla":"<p style=\"text-indent:2em\">La Cámara Nacional del Trabajo confirmó la decisión que declinó intervenir en el reclamo por despido en virtud de la inmunidad de jurisdicción de la demandada –Fondo Financiero para el Desarrollo de la Cuenca del Plata o “FONPLATA”-.</p><p style=\"text-indent:2em\">Contra ese pronunciamiento el actor dedujo recurso extraordinario, que fue denegado y dio origen a la queja.</p><p style=\"text-indent:2em\">La Corte desestimó el recurso intentado.</p><p style=\"text-indent:2em\">Señaló que la sentencia apelada no era definitiva ni equiparable a tal en la medida en que los planteos destinados a cuestionar la validez del trámite ante dicho tribunal administrativo, que aún no había intervenido, se basaban en agravios futuros o meramente conjeturales. Consideró que no existía aún una afectación concreta de las garantías constitucionales que el recurrente aseveraba vulneradas, por lo que resultaba prematuro pronunciarse sobre el particular antes de que el tribunal referido no escuchara o desestimara el reclamo.</p><p style=\"text-indent:2em\">El Tribunal agregó que el actor podrá en el futuro, luego de agotar el procedimiento alternativo previsto en el ámbito del Fondo, acudir a la instancia judicial pertinente para que se estudien eventuales afectaciones al debido proceso suscitadas en el marco de aquel trámite. A tal fin, cuenta como reserva suficiente el hecho de que el actor haya promovido el litigo en sede argentina y planteado la inconstitucionalidad de la inmunidad de jurisdicción.</p>","esNovedad":true,"fecha":1766458800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1766765937679,"usuarioCreacion":11,"fechaCreacion":1766513401000,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":150552,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35182549,"numeroExpediente":32770,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cá