[{"codigo":7728094,"analisisDocumental":{"id":772809,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":80006,"valor":"HACE LUGAR A  LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008251405,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"OUTOKUMPU FORTINOX S.A. c/ CÓRDOBA, PROVINCIA DE s/ ACCIÓN DECLARATIVA DE CERTEZA","alias":null,"caratula":"OUTOKUMPU FORTINOX S.A. c/ CORDOBA, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","inconstitucional":true,"falloDestacado":{"id":3463,"titulo":"Impuesto sobre los ingresos brutos y obstaculización del comercio entre las provincias","cabecilla":"<p>La empresa actora, con domicilio legal en la Ciudad de Buenos Aires, inici&oacute; acci&oacute;n declarativa contra la Provincia de C&oacute;rdoba cuestionando la pretensi&oacute;n de gravar la actividad que realiza en su jurisdicci&oacute;n con una al&iacute;cuota diferencial (m&aacute;s alta) para el pago del impuesto sobre los ingresos brutos en raz&oacute;n de no poseer su establecimiento productivo en esa provincia.<strong> La Corte </strong>entendi&oacute; en la causa por la v&iacute;a originaria haciendo lugar a la demanda y declar&oacute; la inconstitucionalidad de la norma provincial cuestionada y de la pretensi&oacute;n fiscal fundada en ella. Sostuvo que la aplicaci&oacute;n de dicha ley impositiva obstaculizaba el desenvolvimiento del comercio entre las provincias. Expres&oacute; que&nbsp;quedaba en evidencia la discriminaci&oacute;n que genera la legislaci&oacute;n provincial en funci&oacute;n del lugar de radicaci&oacute;n del establecimiento productivo del contribuyente, en tanto lesiona el principio de igualdad y altera la corriente natural del comercio instaurando as&iacute; una suerte de &ldquo;aduana interior&rdquo; vedada por la Constituci&oacute;n Nacional. Se&ntilde;al&oacute; que al perjudicar a los productos for&aacute;neos en beneficio de los manufacturados en su territorio ello conduc&iacute;a a la declaraci&oacute;n de invalidez de la pretensi&oacute;n fiscal de la demandada.&nbsp;</p>","esNovedad":true,"fecha":1645066800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1645202271737,"usuarioCreacion":11,"fechaCreacion":1645132526459,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":33181,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23513322,"numeroExpediente":161,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"E","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"Estado Nacional c/ San Juan, provincia de y otros s/ordinario.","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"E. 161. XLIX. "},"recurso":{"id":3088882,"expediente":{"id":23513322,"numeroExpediente":161,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"E","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descr