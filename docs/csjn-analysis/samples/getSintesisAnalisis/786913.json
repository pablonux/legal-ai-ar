[{"codigo":7869135,"analisisDocumental":{"id":786913,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":80006,"valor":"HACE LUGAR A  LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008251405,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"BICE FIDEICOMISOS S.A. -BFSA- (EX NACION FIDEICOMISOS S.A.) c/ SALTA, PROVINCIA DE s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":5681,"titulo":"Imposición del impuesto de sellos respecto de contratos celebrados para la distribución de gas natural","cabecilla":"<p>Una sociedad fiduciaria de una serie de fideicomisos establecidos con la finalidad de hacer una obra de expansión de gasoductos promovió acción declarativa contra la Provincia de Salta, a fin de que se declare la inconstitucionalidad de los actos administrativos que tenían por objeto la determinación y cobro del impuesto de sellos respecto de los contratos. La Corte, en el marco de su competencia originaria, hizo lugar a la demanda y declaró la improcedencia de la pretensión fiscal. Señaló que la propia ley 23.548 de coparticipación federal, al referirse a la imposición del gravamen la limita cuando media interferencia con el interés nacional. Señaló que el Estado Nacional, en el marco de la situación de emergencia imperante, tomó la decisión de encarar esa política en materia energética, vinculada con el transporte y distribución de gas mediante la creación de un patrimonio de afectación y que las provincias carecen de atribuciones para gravar los medios o instrumentos empleados por el Gobierno de la Nación para ejecutar sus poderes constitucionales. Concluyó, finalmente, que estos instrumentos de gobierno, destinados a efectivizar una alta política nacional en materia energética no pueden ser incididos directamente por el impuesto de sellos provincial, sin representar ello una palmaria interferencia del poder local sobre el nacional, junto a una inadmisible limitación de su independencia.</p>","esNovedad":true,"fecha":1691031600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1691095464796,"usuarioCreacion":11,"fechaCreacion":1691090547153,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":112382,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23445068,"numeroExpediente":240,"anioExpediente":2011,"tomoExpediente":47,"letraExpediente":"N","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"BICE FIDEICOMISOS S.A. -BFSA- (EX NACION FIDEICOMISOS S.A.) c/ SALTA, PROVINCIA DE s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","verificacionMesa":"M","etiqueta":"99014","hijos":[],"oldIdentificadorExpediente":"N. 240. XLVII. "},"recurso":{"id":3129872,"expediente":{"id":23445068,"numeroExpediente":240,"anioExpediente":2011,"tomoExpediente":47,"letraExpediente":"N","tipoExpediente":null,"camara":{"id":0,"cod