[{"codigo":8005653,"analisisDocumental":{"id":800565,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 5 - IMPUTADO: AGÜERO, JULIO CESAR s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":7421,"titulo":"Condena por tentativa de contrabando de estupefacientes: apartamiento de la solución legal aplicable al caso","cabecilla":"<p style=\"text-indent:2em\">La cámara de casación dejó sin efecto la pena “de cumplimiento efectivo” impuesta por la tentativa de contrabando de estupefacientes destinados a ser comercializados. Entendió que los años transcurridos entre el momento en que se dictó la sentencia que declaró su culpabilidad y aquel en el que la pena finalmente determinada en el caso estuvo en condiciones de ser ejecutada, así como el modo en que aquél habría llevado adelante su vida durante ese tiempo, darían razones para apartarse de la rigidez de la ley aplicable que obliga al cumplimiento efectivo de las sanciones de prisión que exceden los tres años de privación de la libertad.</p><p style=\"text-indent:2em\"><b>La Corte dejó sin efecto este pronunciamiento.</b></p><p style=\"text-indent:2em\">Consideró que los argumentos esgrimidos a fin de habilitar la ejecución condicional de la pena no autorizaban a soslayar lo reglado por el art. 26 del Código Penal ni a modificar el monto mínimo de la escala penal correspondiente, sin que mediara excepción legal expresamente prevista a esos fines ni declaración de inconstitucionalidad de la ley aplicable al caso concreto, porque ello supondría prescindir de lo estipulado por el legislador.</p><p style=\"text-indent:2em\">Recordaron que el principio constitucional de la separación de poderes no consiente a los jueces el poder prescindir de lo dispuesto por la ley respecto al caso, so color de su posible injusticia o desacierto.</p>","esNovedad":true,"fecha":1724727600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1724871086896,"usuarioCreacion":4,"fechaCreacion":1724785223893,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":126800,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36881246,"numeroExpediente":518,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":6,"codigo":"6","abreviatura":"CPE","descripcion":"Cámara Nacional de Apelaciones en lo Penal Económico","estado":0,"descripcionLarga":"CPE - Cámara Nacional de Apelaciones en lo Penal Económico"},"objetoJuicio":{"id":8141,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - IMPUTADO: AGÜERO, JULIO CESAR s/INFRACCION LEY 22.415 ","verificacionMesa":"N","etiqueta":null,"hijos":[