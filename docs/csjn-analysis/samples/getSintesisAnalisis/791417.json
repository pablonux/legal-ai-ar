[{"codigo":7914174,"analisisDocumental":{"id":791417,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"POGGIO MARIA MARTA c/ PROCURACION GRAL. DE LA NACION Y OTRO Y OTRO s/VARIOS","inconstitucional":false,"falloDestacado":{"id":6244,"titulo":"Retribución adicional por subrogancia y facultades discrecionales del Procurador General de la Nación","cabecilla":"<p>Una secretaria subrogante de una fiscal reclamó percibir las diferencias de remuneración por su desempeño como fiscal subrogante mientras cumplió esas tareas. Luego del rechazo de su pedido por el Procurador General de la Nación, la cámara hizo lugar en forma parcial a la demanda, haciendo lugar al cobro de la diferencia de haberes solicitada. Ante el recurso extraordinario interpuesto por el funcionario mencionado la Corte dejó sin efecto la sentencia apelada. Señaló que al momento de los hechos, la liquidación de adicionales por subrogancia, en los supuestos en que no concurriera alguna de las circunstancias enumeradas en la resolución correspondiente, constituía una excepción a la regla allí establecida y solo procedía cuando fundadamente se demostrara la existencia de necesidades cuya cobertura beneficiara la eficiencia del servicio, situación que no se consideró suficientemente acreditada en la causa. El Tribunal sostuvo que se trataba de una decisión discrecional para el Procurador General y que solo puede ser admitida de modo excepcional y mediante una decisión que lo justifique, circunstancia que no se había verificado en el caso. Recordó que el control judicial no puede traducirse en la sustitución de los criterios de oportunidad, mérito y conveniencia adoptados por el órgano competente, de conformidad con las pautas definidas en la normativa aplicable al caso. </p>","esNovedad":true,"fecha":1701918000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1702309970284,"usuarioCreacion":11,"fechaCreacion":1701981153180,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":115952,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":2823116,"numeroExpediente":73023477,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":2038,"descripcion":"VARIOS","idMateria":112,"tema":{"id":11,"codigo":"PREV"}},"caratula":"POGGIO MARIA MARTA c/ PROCURACION GRAL. DE LA NACION Y OTRO s/VARIOS","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"73023477. "},"recurso":{"id":5157159,"expediente":{"id":2823116,"numeroExpediente":73023477