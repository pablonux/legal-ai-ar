[{"codigo":8018134,"analisisDocumental":{"id":801813,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - MEDINA PABLO EZEQUIEL c/ GESTION BUENOS AIRES S.A. Y OTRO s/ACCIDENTE - ACCION CIVIL","inconstitucional":false,"falloDestacado":{"id":7681,"titulo":"Responsabilidad de la empleadora por un accidente de trabajo. Falta de fundamentación","cabecilla":"<p style=\"text-indent:2em\">La Sala I de la Cámara Nacional de Apelaciones del Trabajo condenó a la demandada al pago de la suma de $750.000 en forma concurrente con La Segunda Aseguradora de Riesgos del Trabajo S.A. por $603.000, más intereses a la tasa de interés nominal anual para préstamos personales libre destino que otorga el Banco de la Nación Argentina con plazo de 49 a 60 meses, conforme punto 2 del Acta Acuerdo 2601 CNAT. </p><p style=\"text-indent:2em\">En lo pertinente, el tribunal estimó acreditado que el demandante, se encontraba desarrollando su jornada laboral habitual de <b>mensajería a bordo de su motocicleta</b>, cuando fue impactado por una rueda que se desprendió de otro vehículo que estaba circulando, lo que le produjo una minusvalía del 85% de la total obrera.</p><p style=\"text-indent:2em\">La cámara atribuyó la responsabilidad objetiva a la empleadora, de acuerdo con el artículo 1113 del código vigente al momento de los hechos. Para ello, consideró que la tarea de mensajero llevadas a cabo a bordo de su motocicleta implica una actividad riesgosa, sin que la demandada haya acreditado la culpa de la víctima ni de un tercero por el cual la empleadora no debiera responder para lograr quebrar el nexo de causalidad.</p><p style=\"text-indent:2em\"><b>Recurrida la sentencia ante la Corte, ésta desestimó los recursos interpuestos por las demandadas</b>.</p><p style=\"text-indent:2em\">Los agravios de la empleadora fueron rechazados, mientras que, con relación a los agravios de la aseguradora los consideró como sin una adecuada fundamentación. En efecto, la recurrente planteó que, correspondía que se aplique el límite previsto en el decreto 1278/2000, en razón de que la derogación de ese tope fue establecida por un decreto posterior al accidente (dec. 1694/2009), conforme surge de la doctrina de Fallos: 339:781, “<a target=\"_blank\" href=\"http://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7311992&amp;cache=1728416411125\">Espósito</a>”. Sin embargo, precisó el Tribunal, ese agravio resulta ineficaz toda vez que la cámara no aplicó retroactivamente el decreto 1694/2009, sino que declaró inconstitucional el tope indemnizatorio previsto por decreto 1278/2000 con sustento en consideraciones que no fueron refutadas por el recurrente.</p>","esNovedad":true,"fecha":1728356400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1728420570493,"usuarioCreacion":4,"fechaCreacion":1728416433727,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":128423,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32795739,"numeroExpediente":14860,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9702,"descripcion":"ACCIDENTE - ACCION CIVIL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 2 - MEDINA PABLO EZEQUIEL c/ GESTION BUENOS AIRES S.A. Y OTRO s/ACCIDENTE - ACCION CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":32794076,"numeroExpediente":14860,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9702,"descripcion":"ACCIDENTE - ACCION CIVIL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - MEDINA PABLO EZEQUIEL c/ LA SEGUNDA A.R.T. S.A. Y OTRO s/ACCIDENTE - ACCION CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"14860. "}],"oldIdentificadorExpediente":"14860. "},"recurso":{"id":5469081,"expediente":{"id":32795739,"numeroExpediente":14860,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional d