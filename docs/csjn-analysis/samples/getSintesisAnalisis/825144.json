[{"codigo":8251444,"analisisDocumental":{"id":825144,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GAITAN, CARLOS ALEJANDRO c/ SANTIAGO DEL ESTERO, PROVINCIA DE s/USUCAPION","inconstitucional":false,"falloDestacado":{"id":10523,"titulo":"Demanda de usucapión: competencia originaria de la Corte","cabecilla":"<p style=\"text-indent:2em\">Un vecino de la Provincia de Córdoba promovió demanda de usucapión contra la Provincia de Santiago del Estero a fin de que se declare adquirido el dominio por prescripción adquisitiva de un inmueble. </p><p style=\"text-indent:2em\">Señaló que es poseedor con ánimo de dueño desde hace aproximadamente más de treinta años, por lo que solicitó que se declare adquirida la propiedad de tal bien por la vía de la prescripción adquisitiva veinteñal, por haberlo poseído de manera pública, pacífica, continua, e ininterrumpida, y de buena fe, en cumplimiento de todos los demás recaudos legales a tal fin.</p><p style=\"text-indent:2em\">La Corte declaró que la causa corresponde a su competencia originaria. </p><p style=\"text-indent:2em\">Señaló que dentro del limitado marco cognoscitivo propio de la cuestión de competencia en examen, cabe asignar naturaleza civil a la materia del pleito ya que para solucionar el conflicto deberá aplicar, sustancialmente lo dispuesto en el Libro Cuarto “Derechos Reales”, a partir del artículo 1941 y siguientes y concordantes del Código Civil y Comercial de la Nación, con respecto al derecho de dominio, como así también los artículos 1897, 1898, 1900, 1905, 1907 y 2119 de dicho código sobre prescripción adquisitiva, lo cual confirma la naturaleza civil de la materia en debate.</p><p style=\"text-indent:2em\">Recordó que su competencia originaria, conferida por el art. 117 de la Constitución Nacional y reglamentada por el artículo 24, inc. 1°, del <a href=\"https://www.argentina.gob.ar/normativa/nacional/decreto_ley-1285-1958-37915/actualizacion\">decreto-ley 1285/58</a> procede en los juicios en que una provincia es parte si a la distinta vecindad de la contraria se une el carácter civil de la materia en debate.</p>","esNovedad":true,"fecha":1775703600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1775765827544,"usuarioCreacion":4,"fechaCreacion":1775765816663,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":155339,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38580906,"numeroExpediente":2851,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nació