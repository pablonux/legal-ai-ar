[{"codigo":8064104,"analisisDocumental":{"id":806410,"competencia":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":190009,"valor":"PRESENTACIONES VARIAS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"PIUMATO, JULIO Y OTRO c/ GUERRERO, MIGUEL ANGEL s/expte 106/2021","inconstitucional":false,"falloDestacado":{"id":8301,"titulo":"Sanciones disciplinarias a magistrados - Inexistencia de arbitrariedad en el ejercicio de las facultades sancionatorias","cabecilla":"<p style=\"text-indent:2em\">Un juez federal de la Provincia de Misiones dedujo recurso contra la resolución del Plenario del Consejo de la Magistratura del Poder Judicial de la Nación que aplicó una sanción de multa del 30% de sus haberes, por única vez por encontrar su conducta inmersa en las faltas disciplinarias previstas en la Ley 24.937. El Consejo consideró acreditado un patrón de conducta en el que el juez propiciaba malos tratos y hostigamiento a sus subordinados y, en particular, ejercía violencia de género contra las empleadas y funcionarias mujeres.</p><p style=\"text-indent:2em\">La Corte consideró que no se había demostrado arbitrariedad o manifiesta extralimitación en el ejercicio de facultades sancionatorias y que, por ello, correspondía no hacer lugar al recurso deducido y confirmar lo decidido. </p><p style=\"text-indent:2em\">Señaló que no existía lesión al principio de legalidad, pues la multa había sido impuesta con base en la ley antes mencionada, que estaba vigente al momento de los hechos, describía con suficiente precisión la conducta reprochada y preveía específicamente la sanción que se aplicó.</p><p style=\"text-indent:2em\">El Tribunal concluyó que el Consejo tuvo por acreditadas las conductas reprochadas con base en una valoración razonable de la prueba obrante en el expediente, que las encuadró en normas que se referían claramente a ese tipo de comportamientos, habilitaban una sanción como la que se impuso y, además, se encontraban vigentes al momento en que ocurrieron los hechos y que respondió en forma concreta a cada una de las defensas del apelante, quien no refutó ninguno de esos argumentos.</p>","esNovedad":true,"fecha":1740625200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1740750672248,"usuarioCreacion":4,"fechaCreacion":1740685657862,"privado":false,"posicion":2,"resumen":{"idResumen":104,"resumen":"La Corte Suprema confirmó la sanción de multa al juez por violencia de género y maltrato laboral. Consideró que la sanción se basó en una valoración razonable de la prueba y no vulneró el principio de legalidad.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":133480,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":39183443,"numeroExpediente":1504,"anioExpediente":2024,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DET