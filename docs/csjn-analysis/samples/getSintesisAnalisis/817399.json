[{"codigo":8173993,"analisisDocumental":{"id":817399,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - BROLLO, NORA ELENA c/ NUEVO BANCO DE ENTRE RIOS SA s/COBRO DE PESOS/SUMAS DE DINERO","inconstitucional":false,"falloDestacado":{"id":9645,"titulo":"Principio de congruencia: sentencia que revisa un aspecto que se hallaba firme y fuera de su potestad de revisión","cabecilla":"<p style=\"text-indent: 2em;\">La actora promovió demanda ordinaria contra una entidad bancaria reclamando diferencias como consecuencia de la desafectación y pesificación de un certificado de depósito a plazo fijo en dólares estadounidenses y explicando que era  cotitular del mismo junto a su madre, por entonces mayor de setenta y cinco (75) años y ya fallecida. El juez desestimó la acción por considerar que el régimen de excepción encuadraba solamente para mayores de esa edad por lo que el reclamo lo podía hacer la madre de la actora pero no ella. La decisión fue apelada solo por la demandante y confirmada por la cámara, que señaló que no obraba en autos documentación alguna que logre acreditar los dichos de la actora, por cuanto no surgía que hubiera constituido el depósito de plazo fijo en carácter de cotitular a la orden conjunta, recíproca e indistinta con su madre. </p><p style=\"text-indent: 2em;\">La Corte dejó sin efecto este pronunciamiento.</p><p style=\"text-indent: 2em;\">Señaló que la cámara, al revisar la cuestión de si la actora era cotitular o no del depósito que daba base al reclamo había avanzado sobre un aspecto de la sentencia de primera instancia que se encontraba fuera de su potestad de revisión pues se hallaba firme, al no haber un planteo en la apelación que le confiriese jurisdicción a ese respecto. Al proceder de ese modo, además, modificó la sentencia en perjuicio de la única recurrente, incurriendo en una <em>reformatio in pejus</em> que resulta vedada por principios de raigambre constitucional.</p><p style=\"text-indent: 2em;\">Recordó que  la jurisdicción de las cámaras está limitada por los términos en que quedó trabada la relación procesal y el alcance de los recursos concedidos, que determinan el ámbito de su facultad decisoria, de modo que la prescindencia de tal limitación -resolviendo cuestiones que han quedado firmes- infringe el principio de congruencia que se sustenta en los artículos 17 y 18 de la Constitución Nacional.</p><p style=\"text-indent: 2em;\">Agregó el Tribunal que la sentencia apelada omitió toda consideración del agravio de la actora referido a su legitimación para promover la demanda no ya como cotitular del depósito a plazo fijo, sino en su condición de heredera de su madre, cuestión que era conducente para la correcta solución del litigio y debió haber sido abordada por el a quo.</p>","esNovedad":true,"fecha":1761620400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1761686726269,"usuarioCreacion":11,"fechaCreacion":1761686721476,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":145938,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35386454,"numeroExpediente":6822,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":2841,"descripcion":"COBRO DE PESOS/SUMAS DE DINERO","idMateria":112,"tema":{"id":161,"codigo":"CYCF"}},"caratula":"Recurso Queja Nº 1 - BROLLO, NORA ELENA c/ NUEVO BANCO DE ENTRE RIOS SA s/COBRO DE PESOS/SUMAS DE DINERO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"6822. "},"recurso":{"id":6000066,"expediente":{"id":35386454,"numeroExpediente":6822,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":2841,"descripcion":"COBRO DE PESOS/SUMAS DE DINERO","idMateria":112,"tema":{"id":161,"codigo":"CYCF"}},"caratula":"Recurso Queja Nº 1 - BROLLO, NORA ELENA c/ NUEVO BANCO DE ENTRE RIOS SA s/COBRO DE PESOS/SUMAS DE DINERO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"6822. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"FPA 006822/2013/1/RH001","identificacionExpediente":"FPA 006822/2013/1/RH001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":16,"nombreUsuario":"27209880461","apellido":"Slaibe","nombre":"Eugenia","estado":"A","tiene