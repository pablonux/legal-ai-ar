[{"codigo":8235234,"analisisDocumental":{"id":823523,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GENERACION ZOE, . s/INCIDENTE DE COMPETENCIA","inconstitucional":false,"falloDestacado":{"id":10281,"titulo":"Delito de intermediación financiera no autorizada y competencia de la justicia federal","cabecilla":"<p style=\"text-indent: 2em;\">En el marco de actuaciones relacionadas con la presunta actividad financiera de las empresas dirigidas por la organización investigada, que habría sido el medio para cometer las defraudaciones denunciadas se originó un conflicto negativo de competencia entre el fuero ordinario y el fuero federal.</p><p style=\"text-indent: 2em;\">La Corte señaló que mantener y promover la competencia del fuero federal para investigar la posible comisión del delito de intermediación financiera no autorizada resulta de fundamental importancia para asegurar la eficacia de la norma que lo reprime, y que eso determina que, ante la existencia de alguno de los extremos inherentes al delito en cuestión, la justicia federal no puede declinar su competencia ni rechazar la que se le pretende atribuir, sin antes realizar las medidas necesarias para establecer si éste se halla configurado.</p><p style=\"text-indent: 2em;\">Añadió que, más allá de que no estarían determinados los pormenores de la maniobra, las constancias incorporadas al incidente permiten establecer la existencia de elementos de cargo que dan cuenta de extremos constitutivos del aludido delito federal y que surge de las actuaciones que las presuntas víctimas de las maniobras defraudatorias habrían dispuesto de su patrimonio en favor de las empresas a modo de inversión. </p><p style=\"text-indent: 2em;\">Finalmente, expresó que le corresponde al fuero federal que interviene en la presunta intermediación financiera no autorizada investigar, además, si esa infracción constituyó el medio para cometer las defraudaciones sufridas por los damnificados en su patrimonio.</p>","esNovedad":true,"fecha":1772074800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1772195639448,"usuarioCreacion":4,"fechaCreacion":1772195637165,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":152738,"secretaria":{"id":209,"tipo":"S","descripcion":"Sec. Penal Especial","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal Especial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37624466,"numeroExpediente":1174,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":6,"codigo":"6","abreviatura":"CPE","descripcion":"Cámara Nacional de Apelaciones en lo Penal Económico","estado":0,"descripcionLarga":"CPE - Cámara Nacional de Apelaciones en lo Penal Económico"},"objetoJuicio":{"id":8141,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"GENER