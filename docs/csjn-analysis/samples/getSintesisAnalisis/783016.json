[{"codigo":7830164,"analisisDocumental":{"id":783016,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - DON MARCELINO SA c/ FISCO NACIONAL - DGI s/CONTENCIOSO ADMINISTRATIVO-VARIOS","inconstitucional":false,"falloDestacado":{"id":5306,"titulo":"Impuesto a las ganancias: requisitos para gozar de los beneficios del régimen de reorganización de sociedades","cabecilla":"<p>La cámara rechazó la solicitud de reorganización efectuada por una empresa en los términos del art. 77 de la ley del impuesto a las ganancias respecto de su fusión por absorción por considerar que de la documental acompañada no se desprendía que la empresa absorbida hubiese desarrollado actividad económica en el período requerido por la norma para considerarla como empresa en marcha. Si bien la cámara reconoció que había celebrado asambleas, presentado declaración jurada del impuesto a la ganancia mínima presunta, pagado el impuesto inmobiliario, presentado estados contables y realizado gastos que no estaban identificados, a su entender dichas actividades no eran “actividades objeto de la empresa\". La Corte dejó sin efecto la sentencia y consideró que, al interpretar el requisito de empresa en marcha de la manera en que lo hizo había privado de autonomía a la condición de realizar “actividades objeto de la empresa” establecida en el apartado I) del art. 105 del decreto reglamentario de la ley de impuesto a las ganancias para reemplazarla por la condición de realizar las “actividades económicas” de producción y comercialización de bienes y servicios a las que se refiere el apartado II) de dicho artículo. De esta manera, al establecer dicho alcance al requisito en función de otro requisito contemplado por la misma norma, la cámara desatendió al hecho de que se trata de dos requisitos diferentes cuya razón de ser estriba justamente en imponer distintas condiciones.</p>","esNovedad":true,"fecha":1681959600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1682351842132,"usuarioCreacion":11,"fechaCreacion":1682085748419,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":107958,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32574785,"numeroExpediente":50063,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":15,"codigo":"15","abreviatura":"FCB","descripcion":"Justicia Federal de Córdoba","estado":0,"descripcionLarga":"FCB - Justicia Federal de Córdoba"},"objetoJuicio":{"id":2662,"descripcion":"CONTENCIOSO ADMINISTRATIVO-VARIOS","idMateria":112,"tema":{"id":86,"codigo":"CONTADM"}},"caratula":"Recurso Queja Nº 1 - DON MARCELINO SA c/ FISCO NACIONAL - DGI s/CONTENCIOSO ADMINISTRATIVO-