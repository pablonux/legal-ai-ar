[{"codigo":8006862,"analisisDocumental":{"id":800686,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"L., C. c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":7543,"titulo":"Aplicación del régimen de migraciones a quien tiene la condición de refugiado","cabecilla":"<p style=\"text-indent:2em\">La cámara declaró irregular la permanencia de un migrante y ordenó su expulsión. Consideró que la condición de refugiado no condicionaba el trámite propio de la ley migratoria.</p><p style=\"text-indent:2em\">La Corte revocó este pronunciamiento.</p><p style=\"text-indent:2em\">Consideró que un examen de las normas involucradas permitía sostener que los regímenes de las leyes 25.871 - de Migraciones- y 26.165 -de protección al refugiado- se encuentran interrelacionados y no es posible afirmar que la autoridad migratoria pueda expedirse respecto del ingreso o la permanencia en el país de un extranjero que ostente la condición de refugiado con abstracción de tal condición y de lo decidido sobre el punto por la Comisión Nacional para Refugiados (CONARE), autoridad de aplicación de la última ley mencionada.</p><p style=\"text-indent:2em\">Expresó que el proceso migratorio queda condicionado por la protección que con sentido humanitario se otorgó a una persona dada su calidad de refugiado y que el examen de tales cuestiones y circunstancias resultaba de ineludible consideración por la Dirección Nacional de Migraciones a los efectos de evaluar la procedencia de la medida de expulsión.</p>","esNovedad":true,"fecha":1725937200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1726080253170,"usuarioCreacion":4,"fechaCreacion":1725999717445,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":126981,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30663805,"numeroExpediente":72651,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"L., C. c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"72651. "},"recurso":{"id":5551114,"expediente":{"id":30663805,"numeroExpediente":72651,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","des