[{"codigo":8055084,"analisisDocumental":{"id":805508,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"SOTO, JOAQUÍN S/HOMICIDIO AGRAVADO","alias":null,"caratula":"SOTO, JOAQUIN c/  s/Soto Joaquin s/Homicidio Agravado","inconstitucional":false,"falloDestacado":{"id":8163,"titulo":"Actualidad del agravio relacionado con la imposibilidad de acceder a la libertad condicional en los supuestos de prisión perpetua","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal provincial rechazó el planteo de inconstitucionalidad del art. 14 del Código Penal que impide al condenado a prisión perpetua la posibilidad de acceder a la libertad condicional. Argumentó que el planteo era precoz y abstracto y que debía ser interpuesto en el momento en que pudiera gozar de los beneficios penitenciarios. </p><p style=\"text-indent:2em\">La Corte dejó sin efecto este pronunciamiento señalando que resultaba evidente que la defensa contaba con un agravio actual y concreto al cuestionar dicha constitucionalidad.</p><p style=\"text-indent:2em\">Destacó que <b>ningún habitante de la Nación puede ser privado de su dignidad humana, aunque su conducta haya sido reprobada y se encuentre cumpliendo una pena privativa de la libertad y que el principio de humanidad de las penas se integra con la prohibición de penas crueles y con el mandato de resocialización.</b></p><p style=\"text-indent:2em\">También señaló que las normas de los tratados internacionales que gozan de jerarquía constitucional exigen que toda pena privativa de la libertad, sea temporal o perpetua, tienda a la reinserción social del condenado, lo que supone, necesariamente, la posibilidad de volver a vivir en libertad.</p><p style=\"text-indent:2em\">Agregó el Tribunal que el principio de legalidad en materia penal, aunado con el mandato resocializador de las penas privativas de la libertad y la interdicción de la imposición de penas crueles, inhumanas y degradantes, exige que la ley defina, de modo explícito y con carácter previo, la conducta delictiva, la extensión temporal de la pena aplicable y, en el caso de las penas privativas de la libertad perpetuas, las condiciones que debe cumplir el condenado para su reinserción social, lo que supone establecer el plazo de revisión del cumplimiento de tal pena y sus requisitos, de modo que el condenado pueda saber qué debe hacer, en términos de cumplimiento del tratamiento penitenciario, para recuperar su libertad.</p><p style=\"text-indent:2em\">Concluyó así que el tribunal se había negado a tratar el planteo de inconstitucionalidad con base en meras afirmaciones dogmáticas referidas  a la falta de actualidad del agravio lo que descalifica la sentencia recurrida con base en la doctrina de la arbitrariedad.</p>","esNovedad":true,"fecha":1735268400000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1735563478421,"usuarioCreacion":11,"fechaCreacion":1735560476681,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":132064,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38526920,"numeroExpediente":2701,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"SOTO, JOAQUIN c/  s/Soto Joaquin s/Homicidio Agravado","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2701. "},"recurso":{"id":6769932,"expediente":{"id":38526920,"numeroExpediente":2701,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"SOTO, JOAQUIN c/  s/Soto Joaquin s/Homicidio Agravado","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2701. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CSJ 002701/2023/RH001","identificacionExpediente":"CSJ 002701/2023/RH001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":10,"nombreUsuario":"27179020438","apellido":"Messuti","nombre":"Mariana","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583843772000,"nombreUsuarioMigrado":null,"codigo":"JURW6J","mail":"mmessuti@csjn.gov.ar","intentos":0,"notificacion":false},"usuarioCreacionOld":"JURW6J","usuarioModificac