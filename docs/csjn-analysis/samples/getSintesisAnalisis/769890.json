[{"codigo":7698905,"analisisDocumental":{"id":769890,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"NEMEC, CARLOS GUILLERMO s/IMPUGNACION EXTRAORDINARIA","alias":null,"caratula":"NEMEC, CARLOS GUILLERMO s/IMPUGNACION EXTRAORDINARIA","inconstitucional":false,"falloDestacado":{"id":2923,"titulo":"Condena por el delito de homicidio y apreciación de pericias médicas","cabecilla":"<p>Rechazo de los recursos interpuestos contra la condena a prisi&oacute;n e inhabilitaci&oacute;n especial para el ejercicio de la medicina por el delito de homicidio imprudente. Contra ello, la defensa interpuso recurso un extraordinario. La Corte, por unanimidad, admiti&oacute; el recurso y dej&oacute; sin efecto la sentencia apelada. Para decidir de ese modo, consider&oacute; que la c&aacute;mara de casaci&oacute;n omiti&oacute; valorar la prueba y los argumentos de &iacute;ndole cient&iacute;fica y l&oacute;gica que fueron desarrollados durante el juicio para poner en crisis lo afirmado en el informe de los forenses sobre la causa de muerte de la damnificada.&nbsp;El an&aacute;lisis de argumentos que se refieren a una cuesti&oacute;n decisiva para la soluci&oacute;n del caso, se afirma en la sentencia, fue omitido por la c&aacute;mara de casaci&oacute;n. La parte acierta al tachar de arbitraria la decisi&oacute;n en la medida en que ha omitido analizar agravios conducentes para la correcta resoluci&oacute;n del asunto, lo que implic&oacute;, en definitiva, que no se cumpliera con la revisi&oacute;n integral y exhaustiva del fallo condenatorio. La respuesta del&nbsp;<em>a quo</em>&nbsp;en cuanto a que la c&aacute;mara de casaci&oacute;n hab&iacute;a efectuado un estudio integral de la cuesti&oacute;n sometida a su consideraci&oacute;n y que el recurrente se hab&iacute;a limitado&nbsp; a expresar su disconformidad con el pronunciamiento impugnado no satisface el est&aacute;ndar constitucional de los precedentes &ldquo;Strada&rdquo; (<a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoSumario.html?idDocumentoSumario=31450\">Fallos: 308:490</a>) y &ldquo;Di Mascio&rdquo; (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoSumario.html?idDocumentoSumario=1151\">Fallos: 311:2478</a>).</p>","esNovedad":true,"fecha":1634785200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1634925024413,"usuarioCreacion":11,"fechaCreacion":1634907744131,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":32189,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVaci