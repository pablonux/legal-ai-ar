[{"codigo":8201704,"analisisDocumental":{"id":820170,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Recurso Queja Nº 1 - P., F. c/ P., L. D. s/NULIDAD ","inconstitucional":false,"falloDestacado":{"id":9821,"titulo":"Principio de congruencia: tribunal que excedió los límites de su jurisdicción","cabecilla":"<p style=\"text-indent:2em\">Después de confirmar en lo sustancial la sentencia que había admitido la demanda que tenía como objeto que se declarara la nulidad de los convenios a los que arribaron las partes y que habían sido homologados, la cámara revocó la forma en que se había dispuesto la liquidación de la sociedad conyugal y mandó a dividir el activo conyugal mediante el procedimiento previsto para las sucesiones. </p><p style=\"text-indent:2em\">La Corte <b>dejó sin efecto</b> esta decisión.</p><p style=\"text-indent:2em\">Señaló que en los recursos de apelación deducidos por las partes no fue objeto de agravio la manera en que se dispuso la división de condominio del bien propio de ambas partes ni cómo se decidió la forma en que se partiría el activo de la sociedad conyugal, incluso este último punto fue consentido por ambos contendientes. Es decir, el modo en que había sido articulada la impugnación excluía la posibilidad de que el tribunal examinara lo decidido sobre dichos puntos.</p><p style=\"text-indent:2em\">Recordó el Tribunal que la jurisdicción de las cámaras está limitada por los términos en que quedó trabada la relación procesal y el alcance de los recursos concedidos, que determinan el ámbito de su facultad decisoria (artículos 271 y 277 del Código Procesal Civil y Comercial de la Nación), y que la prescindencia de tal limitación infringe el principio de congruencia que se sustenta en los derechos de propiedad y defensa en juicio previstos en los artículos 17 y 18 de la Constitución Nacional.</p>","esNovedad":true,"fecha":1763434800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1763645766193,"usuarioCreacion":11,"fechaCreacion":1763493535016,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":148619,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35008054,"numeroExpediente":48341,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":520,"descripcion":"NULIDAD ","idMateria":1,"tema":{"id":400,"codigo":"FAM"}},"caratula":"Recurso Queja Nº 1 - Recurso Queja Nº 1 - P., F. c/ P., L. D. s/NULIDAD ","verificacionMesa":"N","etiqueta":null