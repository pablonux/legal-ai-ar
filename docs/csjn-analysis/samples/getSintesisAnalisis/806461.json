[{"codigo":8064616,"analisisDocumental":{"id":806461,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - CARTELLONE, JOSE c/ AFIP s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":8341,"titulo":"Contribuyentes cumplidores: improcedencia de crear requisitos no previstos en la ley","cabecilla":"<p style=\"text-indent:2em\">El actor solicitó a la Administración Federal de Ingresos Públicos (AFIP) el reconocimiento de los beneficios para “contribuyentes cumplidores” establecidos en la <a target=\"_blank\" href=\"https://www.boletinoficial.gob.ar/detalleAviso/primera/148428/null\">ley 27.260</a>, consistentes en la exención del impuesto sobre los bienes personales de los períodos fiscales 2016 a 2018. La solicitud fue rechazada en virtud de que la declaración jurada del impuesto sobre los bienes personales correspondiente al período fiscal 2015 había sido presentada  con posterioridad a la fecha de su vencimiento y de la entrada en vigencia de la ley 27.260.</p><p style=\"text-indent:2em\">La cámara le dio la razón al contribuyente y ordenó a la AFIP que lo inscribiera como contribuyente cumplidor.</p><p style=\"text-indent:2em\">La Corte, por su parte, confirmó esta decisión. </p><p style=\"text-indent:2em\">Señaló que del tenor literal de la expresión “obligaciones tributarias” empleada por el art. 63 de la ley 27.260 no surge la obligación de presentar de modo tempestivo las declaraciones juradas determinativas del impuesto como condición para gozar del beneficio, sino únicamente la obligación de haber cancelado el impuesto adeudado.</p><p>     Agregó que el texto del art. 18 del decreto 895/2016 presupone que el art. 63 de la ley 27.260 se refiere a obligaciones tributarias que se cancelan con el pago de sumas de dinero por lo que no resultaba posible exigir requisitos adicionales que, como la presentación temporánea de las declaraciones juradas, no constituyen en sí mismos una obligación de pagar sumas de dinero. Consideró que admitir una tesitura distinta significaría habilitar la creación por vía interpretativa de requisitos no previstos en la legislación, lo que resulta jurídicamente inaceptable.</p><p style=\"text-indent:2em\">Destacó además el Tribunal que cuando el legislador quiso establecer la obligación de presentar las declaraciones juradas determinativas del impuesto como condición específica para otorgar beneficios a contribuyentes cumplidores lo hizo expresamente en la letra de la ley, como cuando la <a target=\"_blank\" href=\"https://www.boletinoficial.gob.ar/detalleAviso/primera/234082/20200826\">ley 27.562</a>, norma que dispuso la ampliación de la moratoria establecida por la <a target=\"_blank\" href=\"https://s3.arsat.com.ar/cdn-bo-001/suplementos/2019/12/23/primera-seccion_23-12-2019_suplemento-1.pdf\">ley 27.541</a> a los fines de paliar los efectos de la pandemia generada por el COVID-19, incorporó el art. 17.1 a esta última.</p>","esNovedad":true,"fecha":1741748400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1741890670946,"usuarioCreacion":11,"fechaCreacion":1741803712545,"privado":false,"posicion":2,"resumen":{"idResumen":125,"resumen":"La Corte confirmó la decisión de la cámara, señalando que la ley 27.260 no exige la presentación tempestiva de las DDJJ para ser \"contribuyente cumplidor\", sino solo la cancelación del impuesto adeudado.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":133618,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30575469,"numeroExpediente":5415,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":20,"codigo":"20","abreviatura":"FMZ","descripcion":"Justicia Federal de Mendoza","estado":0,"descripcionLarga":"FMZ - Justicia Federal de Mendoza"},"objetoJuicio":{"id":4045,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":260,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 2 - CARTELLONE, JOSE c/ AFIP s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"5415. "},"recurso":{"id":5191480,"expediente":{"id":30575469,"numeroExpediente":5415,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":20,"codigo":"20","abreviatura":"FMZ","descripcion":"Justicia Federal de Mendoza","estado":0,"descripcionLarga":"FMZ - Justicia Federal de Mendoza"},"objetoJuicio":{"id":4045,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":260,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 2 - CARTELLONE, JOSE c/ AFIP s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"5415. "},"tipoRecurso":{"i