[{"codigo":7841184,"analisisDocumental":{"id":784118,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":34,"codigoRelacion":80034,"valor":"ADMITE MEDIDA CAUTELAR ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201203261255,"fechaModLong":201203261255,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"PARTIDO POR LA JUSTICIA SOCIAL c/ TUCUMAN, PROVINCIA DE s/AMPARO","inconstitucional":false,"falloDestacado":{"id":5402,"titulo":"Elecciones provinciales: disposiciones constitucionales que hacen a la esencia de la forma republicana de gobierno","cabecilla":"<p>El consejero de la mesa ejecutiva de una agrupación política promovió una acción contra la Provincia de Tucumán para que se declare la inconstitucionalidad de la habilitación de Juan Luis Manzur como candidato al cargo de vicegobernador en las próximas elecciones. Observa que dicha pretensión resulta violatoria de la regla fijada por el artículo 90 de la Constitución provincial cuyo sentido es hacer respetar el principio republicano de alternancia en el poder, de manera que solo se puede ser reelegido una sola vez. La Corte entendió que al ser demandada una provincia y tratarse de una cuestión federal predominante el proceso corresponde a su competencia originaria y admitió la medida cautelar requerida disponiendo la suspensión de la convocatoria y remitiendo a las razones expresadas en la causa \"Evolución Liberal y otro c/ San Juan, Provincia de\", del día de la fecha. </p>","esNovedad":true,"fecha":1683601200000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1720189440939,"usuarioCreacion":4,"fechaCreacion":1683660716590,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":109277,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37758896,"numeroExpediente":687,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9875,"descripcion":"AMPARO","idMateria":0,"tema":null},"caratula":"PARTIDO POR LA JUSTICIA SOCIAL c/ TUCUMAN, PROVINCIA DE s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"687. "},"recurso":{"id":6563002,"expediente":{"id":37758896,"numeroExpediente":687,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9875,"descripcion":"AMPARO","idMateria":0,"tema":null},"caratula":"PARTIDO POR LA JUSTICIA SOCIAL c/ TUCUMAN, PROVINCIA DE s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"687. "},"tipoRecurso":{"id":1243,"codigo":"CIR","descripcion":"CIRCULACION DEL EXPEDIENTE"},"claveRecurso":null,"identificacionExpediente":"CSJ 687/2023"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":6,"nombreUsuario":"20179988705"