[{"codigo":8250023,"analisisDocumental":{"id":825002,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Recurso Queja Nº 1 - ASOCIACION GREMIAL DE COMPUTACION c/ PODER EJECUTIVO NACIONAL s/ACCION DECLARATIVA","inconstitucional":false,"falloDestacado":{"id":10488,"titulo":"Naturaleza federal de las medidas de fomento nacional","cabecilla":"<p style=\"text-indent:2em\">La Asociación Gremial de Computación dedujo una acción declarativa de certeza contra el Estado Nacional con el fin de que se esclarezca el alcance del <a href=\"https://www.argentina.gob.ar/normativa/nacional/decreto-1034-2020-345431/texto\">decreto 1034/2020</a> pues, a su criterio, lo establecido en el artículo 2°, párrafo quinto, de su anexo, importa un exceso reglamentario respecto de las disposiciones de la Ley de Promoción de la Economía del Conocimiento <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-27506-324101/actualizacion\">n° 27.506</a> y su modificatoria <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-27570-343520/texto\">n° 27.570</a>. El demandado opuso la excepción de incompetencia y la cámara la rechazó. Afirmó que la materia de controversia encuadraba en lo normado por el artículo 21, inciso a, de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-18345-45628/actualizacion\">ley 18.345</a> que dispone la competencia de la Justicia Nacional del Trabajo en las causas en las que tenga influencia decisiva la determinación de cuestiones directamente vinculadas con aspectos individuales o colectivos del derecho del trabajo.</p><p style=\"text-indent:2em\">Ante el recurso interpuesto por el Estado demandado la Corte revocó la sentencia apelada y declaró competente a la Justicia Nacional en lo Contencioso Administrativo Federal.</p><p style=\"text-indent:2em\">Señaló que las disposiciones del régimen de fomento tienen como objetivo promocionar actividades económicas que apliquen el uso del conocimiento y la digitalización de la información y constituyen medidas de carácter nacional que tienen fundamento en la llamada \"cláusula del progreso\" (<a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-24430-804/texto\">artículo 75, inciso 18, de la Constitución Nacional</a>) y, por ende, revisten naturaleza federal.</p><p style=\"text-indent:2em\">Recordó así  el Tribunal su doctrina según la cual si la solución de la causa depende esencialmente de la aplicación e interpretación de normas de derecho federal debe tramitar en la justicia federal.</p>","esNovedad":true,"fecha":1774926000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1775067599095,"usuarioCreacion":11,"fechaCreacion":1774992762976,"privado":false,"posicion":8,"resumen":null},"reciboEntrada":{"id":154984,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion"