[{"codigo":8014914,"analisisDocumental":{"id":801491,"competencia":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":190013,"valor":"QUEJA POR RETARDO DE JUSTICIA","activo":"S","usuarioCreacion":"CYCJ3F","usuarioMod":"CYCJ3F","fechaCreacionLong":202603171152,"fechaModLong":202603171152,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":80013,"valor":"DECLARA INOFICIOSO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009221235,"fechaModLong":201009221235,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Presentaciones Varias con Retardo de Justicia Nº 1 - DUEÑAS GARCIA, JUAN PABLO c/ GALENO ART S.A. s/RECURSO LEY 27348","inconstitucional":false,"falloDestacado":{"id":7642,"titulo":"Queja por retardo de justicia","cabecilla":"<p style=\"text-indent:2em\">El presentante promovió queja por retardo de justicia y solicitó la intervención de la Corte con motivo de la demora de la cámara en expedirse en una causa.  Requerido por Secretaría el informe pertinente y librado el correspondiente oficio electrónico, se señaló que ya se había dictado resolución en las actuaciones respectivas.</p><p style=\"text-indent:2em\">Por ello, con arreglo al deber de considerar las circunstancias sobrevinientes a la presentación de la queja, la Corte declaró que resultaba inoficioso el dictado de un pronunciamiento en el caso.</p><p style=\"text-indent:2em\">Recordó que la denuncia por retardo de justicia tiene por objeto exclusivo promover una decisión judicial pendiente y no obtener la revisión de pronunciamientos ya dictados, por lo que la cuestión planteada se había tornado abstracta.</p>","esNovedad":true,"fecha":1727751600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1727873610118,"usuarioCreacion":11,"fechaCreacion":1727813027349,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":128140,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38708765,"numeroExpediente":66385,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9701,"descripcion":"ACCIDENTE - LEY ESPECIAL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - AGUIRRE, JAVIER c/ GALENO ART S.A. s/ACCIDENTE - LEY ESPECIAL","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":38981365,"numeroExpediente":23218,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9701,"descripcion":"ACCIDENTE - LEY ESPECIAL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - CALIXTO, GABRIEL ALEJANDRO c/ GALENO ART S.A. s/ACCIDENTE - LEY ESPECIAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"23218. "},{"id":38751791,"numeroExpediente":26179,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de A