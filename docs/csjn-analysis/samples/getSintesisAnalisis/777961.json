[{"codigo":7779615,"analisisDocumental":{"id":777961,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":80013,"valor":"DECLARA INOFICIOSO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009221235,"fechaModLong":201009221235,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"CORREO OFICIAL DE LA REPUBLICA ARGENTINA SA DEMANDADO: DIRECCION GENERAL IMPOSITIVA s/BENEF. DE LITIGAR S/G","alias":null,"caratula":"Incidente Nº 1 - ACTOR: CORREO OFICIAL DE LA REPUBLICA ARGENTINA SA DEMANDADO: DIRECCION GENERAL IMPOSITIVA s/BENEF. DE LITIGAR S/G","inconstitucional":false,"falloDestacado":{"id":4565,"titulo":"Conflicto de competencia en un reclamo entre organismos administrativos del Estado Nacional","cabecilla":"<p>El Correo Oficial de la República Argentina S.A. dedujo ante el Tribunal Fiscal de la Nación recursos contra las resoluciones de la AFIP por medio de las cuales se le habían determinado diversas deudas y solicitó el beneficio de litigar sin gastos. Ello originó un conflicto de competencia entre la Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal y la Procuración del Tesoro de la Nación que la Corte debió resolver. Se trataba de determinar si dicho beneficio debía ser resuelto de acuerdo a las previsiones correspondientes a los conflictos interadministrativos o si, por el contrario, su conocimiento debía permanecer en la órbita del Poder Judicial de la Nación, por lo que debía determinarse antes cual era el juez competente que debía conocer en el juicio en que el beneficio se haría valer. La Corte, por mayoría, resolvió que las actuaciones principales debían ser sometidas al régimen de resolución de conflictos interadministrativos y que, por ello, devenía inoficioso pronunciarse acerca de la contienda negativa de competencia suscitada. Tuvo en cuenta para ello que el Correo Oficial es una sociedad anónima cuya composición accionaria es íntegramente propiedad del Estado Nacional por lo que es uno de los sujetos alcanzados por dicho régimen (sin que obste a ello el hecho de que se trate de una sociedad regida predominantemente por el derecho privado) y también que se hallaba cumplido el requisito esencial de tratarse de un conflicto pecuniario dada la naturaleza de la pretensión de la AFIP. </p>","esNovedad":true,"fecha":1664247600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1664387960486,"usuarioCreacion":4,"fechaCreacion":1664309065603,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":35047,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32240211,"numeroExpediente":54920,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2,"tema":null},"caratula":"Incidente Nº 1 - ACTOR: CORREO OFICIAL DE LA REPUBLICA ARGENTINA SA DEMANDADO: DIRECCION GENERA