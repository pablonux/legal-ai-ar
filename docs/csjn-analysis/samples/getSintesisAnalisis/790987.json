[{"codigo":7909874,"analisisDocumental":{"id":790987,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ARANDA, RAUL EDUARDO c/ ENA (MIN DE DEF. EJERCITO ARGENTINO) Y/O Q.R.R s/IMPUGNACION de ACTO ADMINISTRATIVO","inconstitucional":false,"falloDestacado":{"id":6221,"titulo":"Caducidad de la instancia: no cabe extender al justiciable una actividad que no le es exigible","cabecilla":"<p>La cámara declaró de oficio la caducidad de la segunda instancia respecto del recurso de apelación deducido por la actora por considerar que, si bien la elevación de los autos a la cámara era una actividad que incumbía al oficial primero del juzgado, subsistía sobre el apelante la carga del impulso procesal, que le imponía instar la realización de los actos omitidos por aquel funcionario. Ante el recurso interpuesto por el actor la Corte dejó sin efecto este pronunciamiento. Consideró que había soslayado lo dispuesto en el art. 251 del Código Procesal Civil y Comercial de la Nación que coloca en cabeza del oficial primero del juzgado de primera instancia la obligación de remitir los expedientes a la alzada una vez contestado el traslado previsto en el art. 246, como así también, lo establecido en el art. 313, inc. 3°, del aludido código, en cuanto excluye la ocurrencia de la caducidad cuando la prosecución del trámite dependiere de una actividad que dicho código o las reglamentaciones de superintendencia imponen al secretario o al oficial primero. Agregó que  el fallo no había explicado por qué trasladaba a la actora una responsabilidad atribuida explícitamente al funcionario mencionado y que  si la parte estaba exenta de la carga procesal de impulso, su pasividad no podía ser presumida como abandono de la instancia.</p>","esNovedad":true,"fecha":1701313200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1701692890810,"usuarioCreacion":11,"fechaCreacion":1701370852240,"privado":false,"posicion":0,"resumen":null},"reciboEntrada":{"id":115677,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36260203,"numeroExpediente":6333,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":21,"codigo":"21","abreviatura":"FPO","descripcion":"Justicia Federal de Posadas","estado":0,"descripcionLarga":"FPO - Justicia Federal de Posadas"},"objetoJuicio":{"id":2480,"descripcion":"IMPUGNACION de ACTO ADMINISTRATIVO","idMateria":112,"tema":{"id":66,"codigo":"CONTADM"}},"caratula":"Recurso Queja Nº 1 - ARANDA, RAUL EDUARDO c/ ENA (MIN DE DEF. EJERCITO ARGENTINO) Y/O Q.R.R s/IMPUGNACION de ACTO ADMINISTRATIVO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"6333. "},"recurso":{"id":62