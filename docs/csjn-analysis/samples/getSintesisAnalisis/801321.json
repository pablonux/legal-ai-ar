[{"codigo":8013213,"analisisDocumental":{"id":801321,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 3 - K., G. E. c/ O.S.D.E. Y OTRO s/LEY DE MEDICINA PREPAGA","inconstitucional":false,"falloDestacado":{"id":7602,"titulo":"Imposición de costas que  afecta la garantía de defensa en juicio","cabecilla":"<p style=\"text-indent:2em\">La cámara hizo lugar a la acción de amparo promovida a fin de que le garantizara al hijo de los accionantes la cobertura de su tratamiento e impuso las costas de la segunda instancia en el orden causado, con cita del art. 71 del Código Procesal Civil y Comercial de la Nación.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto este pronunciamiento al considerar que no constitutía una derivación razonada del derecho vigente de conformidad con las circunstancias de la causa</p><p style=\"text-indent:2em\">Señaló que la cámara había distribuido las costas de la segunda instancia en el orden causado con la sola cita del artículo mencionado pese a que había rechazado —sin costas— la apelación del letrado de la actora por sus honorarios y desestimado íntegramente la apelación de la accionada, confirmando el fallo de la instancia anterior que había hecho lugar a la demanda.</p><p style=\"text-indent:2em\">Sostuvo que la aplicación del referido artículo 71 no se ajustó al presupuesto fáctico previsto en la norma, desde que el resultado del incidente no fue “parcialmente favorable a ambos litigantes”.</p>","esNovedad":true,"fecha":1727146800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1727273876755,"usuarioCreacion":11,"fechaCreacion":1727203419592,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":128061,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34991128,"numeroExpediente":110600,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":8540,"descripcion":"DAÑOS Y PERJUICIOS - RESP.PROF.MEDICOS Y AUX.","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 1 - CARBALLUDE GISELLE MELINA c/ OSDE Y OTRO s/DAÑOS Y PERJUICIOS - RESP.PROF.MEDICOS Y AUX.","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"110600. "},"recurso":{"id":5873532,"expediente":{"id":34991128,"numeroExpediente":110600,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil