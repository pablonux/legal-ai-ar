[{"codigo":7852714,"analisisDocumental":{"id":785271,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":230004,"valor":"RECURSO DE REVOCATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - PEREYRA, ADRIANA PRISCILA c/ ORGANIZACION DE SERVICIOS DIRECTOS EMPRESARIOS (OSDE) s/AMPARO CONTRA ACTOS DE PARTICULARES","inconstitucional":false,"falloDestacado":{"id":5761,"titulo":"Exención del pago del depósito previo para obras sociales y no para entidades de medicina prepaga","cabecilla":"<p>Ante la intimación a efectuar el depósito previsto por el artículo 286 del Código Procesal Civil y Comercial de la Nación, OSDE (Organización de Servicios Directos Empresarios) solicitó que se deje sin efecto el proveído argumentando que, en su carácter de agente del seguro de salud, correspondía la exención contemplada en el art. 39 de la ley 23.661. La Corte desestimó el planteo y reiteró la intimación dispuesta en la providencia. Señaló que la recurrente es agente natural del seguro de salud y, a la vez, es una entidad de medicina prepaga y que solo se encuentra exenta del pago de la tasa de justicia y, consecuentemente, del depósito mencionado, cuando se  debaten sus derechos y obligaciones en su carácter de obra social. Agregó que un criterio contrario consagraría un indebido privilegio en favor de la demandada respecto del resto de las empresas de dicho sector.</p>","esNovedad":true,"fecha":1692241200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1692375515370,"usuarioCreacion":11,"fechaCreacion":1692296750255,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":110764,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35552937,"numeroExpediente":8312,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":14,"codigo":"14","abreviatura":"FCR","descripcion":"Justicia Federal de Comodoro Rivadavia","estado":0,"descripcionLarga":"FCR - Justicia Federal de Comodoro Rivadavia"},"objetoJuicio":{"id":4564,"descripcion":"AMPARO CONTRA ACTOS DE PARTICULARES","idMateria":112,"tema":{"id":300,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 1 - PEREYRA, ADRIANA PRISCILA c/ ORGANIZACION DE SERVICIOS DIRECTOS EMPRESARIOS (OSDE) s/AMPARO CONTRA ACTOS DE PARTICULARES","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"8312. "},"recurso":{"id":6050502,"expediente":{"id":35552937,"numeroExpediente":8312,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":14,"codigo":"14","abreviatura":"FCR","descripcion":"Justicia Federal de Comodoro Rivadavia","estado":0,"descripcionLarga":"FCR - Justicia Federal de Comodoro Rivadavia"},"objetoJuicio":{"id":4564,"descripcion":"AMPARO CONTRA ACTOS DE PARTICULARES","idMate