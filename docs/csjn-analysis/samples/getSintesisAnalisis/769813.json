[{"codigo":7698135,"analisisDocumental":{"id":769813,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"Marisi, Leandro y otros c/ Poder Ejecutivo Nacional – PEN – Ministerio de Transporte de la Nación y otro s/ inc. apelación.","alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 12 - MARISI, LEANDRO Y OTROS c/ PODER EJECUTIVO NACIONAL - PEN- MINISTERIO DE TRANSPORTE DE LA NACION Y OTRO s/INC APELACION","inconstitucional":false,"falloDestacado":{"id":2781,"titulo":"Medio ambiente: requisito de estudio de impacto ambiental previo al inicio de actividades","cabecilla":"<p>Acci&oacute;n de amparo ambiental contra el Poder Ejecutivo Nacional y la Administraci&oacute;n Nacional de Aviaci&oacute;n Civil con el objeto que se le impida a cualquier aerol&iacute;nea operar vuelos comerciales desde la pista del aer&oacute;dromo de la Base A&eacute;rea Militar El Palomar y pedido de medida cautelar - Sentencia de c&aacute;mara que consider&oacute; acreditada, prima facie, la inexistencia de da&ntilde;o ambiental con el inicio de la operatoria aerocomercial y confirm&oacute; el levantamiento total de la medida cautelar dispuesta en primera instancia - Sentencia arbitraria y descalificable como acto jurisdiccional ya que se ha apartado de la norma adecuada para la correcta soluci&oacute;n del caso y ha incurrido en un excesivo rigor formal - El a quo valor&oacute; en la sentencia apelada dos estudios de impacto ambiental en el entendimiento de que reun&iacute;an los requisitos m&iacute;nimos exigidos por la ley 25.675 pero no tuvo en cuenta que dicha ley requiere, en forma previa al inicio de una obra o actividad que pueda comprometer al medio ambiente, una declaraci&oacute;n de impacto ambiental por parte de las autoridades competentes, cuesti&oacute;n que fue invocada por la recurrente desde la primera presentaci&oacute;n en el juicio - De la documentaci&oacute;n valorada por los jueces de la causa no surge una declaraci&oacute;n de impacto ambiental emitida por las autoridades competentes previa al inicio de la actividad exigida por la ley - La realizaci&oacute;n de un estudio de impacto ambiental previo al inicio de las actividades no significa una decisi&oacute;n prohibitiva del emprendimiento en cuesti&oacute;n, sino una instancia de an&aacute;lisis reflexivo, realizado sobre bases cient&iacute;ficas y con participaci&oacute;n ciudadana - En cuestiones de medio ambiente, cuando se persigue la tutela del bien colectivo, tiene prioridad absoluta la prevenci&oacute;n del da&ntilde;o futuro - Principios de sustentabilidad y prevenci&oacute;n - Se deja sin efecto el pronunciamiento apelado.</p>","esNovedad":true,"fecha":1632970