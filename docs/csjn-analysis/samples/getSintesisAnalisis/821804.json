[{"codigo":8218043,"analisisDocumental":{"id":821804,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - FERNADEZ DE KIRCHNER, CRISTINA ELISABET Y OTRO s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":10043,"titulo":"Colocación de un dispositivo de monitoreo electrónico: falta de fundamentación autónoma el recurso","cabecilla":"<p style=\"text-indent:2em\">La cámara ordenó la colocación de un dispositivo de monitoreo electrónico e impuso la necesidad de peticionar motivadamente al tribunal oral la autorización de las visitas que no se encontrasen incluidas en la nómina de familiares, médicos y abogados, como condiciones para el cumplimiento de la modalidad de arresto domiciliario.</p><p style=\"text-indent:2em\">Ante el recurso intentado por la defensa la Corte entendió que en lo relativo a la colocación del dispositivo de monitoreo electrónico, el recurso carecía de fundamentación autónoma (artículo 15 de la ley 48). </p><p style=\"text-indent:2em\">Consideró que, si bien la defensa invoca que la colocación de dicho dispositivo resulta una medida arbitraria e irracional pues en esta clase de supuestos no resultaría \"indispensable para asegurar el estricto cumplimiento de la pena\", la parte no ha logrado fundar suficientemente tales alegaciones. En efecto, consideró que no explicó cómo sometió ese planteo ante el tribunal revisor, ni cuál fue su apoyo normativo.</p><p style=\"text-indent:2em\">Afirmó que el apelante tampoco formuló una crítica concreta y razonada a los fundamentos expresados por la mayoría del <em>a quo</em> en este aspecto para descartar sus agravios, sino que, por el contrario, se limitó a transcribir las consideraciones vertidas por el juez disidente en este aspecto, sin mayor desarrollo argumental propio. Precisamente, el dispositivo de monitoreo electrónico, conforme el artículo 33, último párrafo, de la<a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-24660-37872/texto\"> ley 24.660</a>, resulta, por regla, una exigencia normativa, cuya inconstitucionalidad no fue planteada y que, justamente, al decir del <em>a quo</em>, tiende a coadyuvar al control judicial sobre la restricción ambulatoria que pesa sobre quienes cumplen una pena privativa de la libertad en la modalidad de prisión domiciliaria.</p><p style=\"text-indent:2em\">Con respecto al régimen de visitas y ante la remisión de nuevos decretos que dispusieron modificaciones en el mismo, el Tribunal, de acuerdo a su doctrina según la cual sus fallos deben atender a las circunstancias existentes al momento en que se los dicta, consideró que la cuestión se había tornado abstracta.</p>","esNovedad":true,"fecha":1766026800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1766146561847,"usuarioCreacion":11,"fechaCreacion":1766088226393,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":150460,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":40404927,"numeroExpediente":5048,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - FERNADEZ DE KIRCHNER, CRISTINA ELISABET Y OTRO s/INCIDENTE DE RECURSO EXTRAORDINARIO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"5048. "},"recurso":{"id":7361452,"expediente":{"id":40404927,"numeroExpediente":5048,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - FERNADEZ DE KIRCHNER, CRISTINA ELISABET Y OTRO s/INCIDENTE DE RECURSO EXTRAORDINARIO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"5048. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CFP 005048/2016/TO01/55/1/1/1/RH091","identificacionExpediente":"CFP 005048/2016/TO01/55/1/1/1/RH091"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":4,"nombreUsuario":"20346628686","apellido":"Marquez","nombre":"Juan Santiago","estado":"A","tieneToken":"N","cargo":"ESCRIBIENTE AUXILIAR","fechaModifi