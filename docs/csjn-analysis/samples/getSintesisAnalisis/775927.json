[{"codigo":7759275,"analisisDocumental":{"id":775927,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"RINA IBERIA SL SUC ARGENTINA c/ AFIP-DGI s/DIRECCION GENERAL IMPOSITIVA","alias":null,"caratula":"RINA IBERIA SL SUC ARGENTINA c/ AFIP-DGI s/DIRECCION GENERAL IMPOSITIVA","inconstitucional":true,"falloDestacado":{"id":4164,"titulo":"Impuesto a las ganancias: facultades de la AFIP para incorporar el requisito de publicidad e inscripción de las transferencias de fondos de comercio.","cabecilla":"<p>La actora comunic&oacute; a la AFIP haber realizado un procedimiento de reorganizacion de empresas consistente en la transferencia de un fondo de comercio, lo que origin&oacute; el rechazo del beneficio fiscal relativo al impuesto a las ganancias por parte del organismo. La Corte, al confirmar la decisi&oacute;n de la c&aacute;mara que declar&oacute; la inconstitucionalidad de dichas resoluciones administrativas, consider&oacute; necesario estudiar si la AFIP,&nbsp;como consecuencia de su potestad reglamentaria y en uso de sus facultades de fiscalizaci&oacute;n y verificaci&oacute;n, se encontraba investida de atribuciones para incorporar el requisito de publicidad e inscripci&oacute;n de las transferencias de fondos de comercio establecidos en la ley 11.867. Luego de recordar que la&nbsp;primera fuente de interpretaci&oacute;n de la ley es su letra concluy&oacute; que de la lectura de las normas aplicables surg&iacute;a que dichos recaudos no estaban&nbsp;previstos para el caso y que se hab&iacute;a agregado una condici&oacute;n que no est&aacute; prevista en la ley. A&ntilde;adi&oacute; que el requisito de publicidad e inscripci&oacute;n de las transferencias tiene por finalidad la protecci&oacute;n de terceros ajenos a la relaci&oacute;n jur&iacute;dica de las partes intervinientes, circunstancia que no parecer&iacute;a operar toda vez que, al ser los mismos titulares los de ambas empresas, no cab&iacute;a posibilidad de ocasionar perjuicios a terceras personas.</p>","esNovedad":true,"fecha":1656385200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1656523553877,"usuarioCreacion":11,"fechaCreacion":1656442098963,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":34305,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":11628124,"numeroExpediente":37697,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1117,"descripcion":"DIRECCION GENE