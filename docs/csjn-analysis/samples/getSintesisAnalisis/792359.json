[{"codigo":7923594,"analisisDocumental":{"id":792359,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ALVAREZ, MARTIN LUCERO c/ MOSCATELLI, EMANUEL GUILLERMO Y OTRO s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","inconstitucional":false,"falloDestacado":{"id":6283,"titulo":"Seguro: ratificación de la oponibilidad del límite de cobertura pactado entre asegurador y asegurado","cabecilla":"<p> </p><p>   En un caso en que se debatía la inoponibilidad del límite de cobertura en <b>un seguro de obligatorio de responsabilidad civil</b>, la Corte, por mayoría, con remisión a la doctrina de su precedente \"Flores\" (<a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7378892&amp;cache=1702585567518\">Fallos: 340:765</a>) <b>resolvió que el  límite de cobertura previsto en el contrato de seguro es oponible al tercero damnificado y que la sentencia no podrá ser ejecutada contra la aseguradora sino en los límites de la contratación </b>(conf. art. 16, segunda parte, de la ley 48).</p><p>  Cabe recordar, que en aquel precedente, la Corte se había pronunciado en favor de la oponibilidad a la víctima del siniestro de las cláusulas contractuales del seguro, sin que obste a ello la modificación introducida por la ley 26.361 a la Ley de Defensa del Consumidor.</p><p>   Asimismo, en aquella oportunidad, había señalado que la función social que debe cumplir el seguro no implica que deban repararse todos los daños producidos al tercero víctima sin consideración a las pautas del contrato que se invoca y que el contrato de seguro rige la relación jurídica entre los otorgantes (artículos 957, 959 y 1021 del Código Civil y Comercial de la Nación) pues los damnificados revisten la condición de terceros frente a aquellos que no participaron de su realización, por lo que si pretenden invocarlo, deben circunscribirse a sus términos (artículo 1022 del Código Civil y Comercial de la Nación).</p><p>   En síntesis, en el precedente “Flores” se especificó que la obligación del asegurador de reparar el daño tiene naturaleza meramente \"contractual\" por lo que si su finalidad es indemnizar al asegurado de los perjuicios sufridos por la producción del riesgo asegurado, su origen no es el daño sino el contrato de seguro. </p>","esNovedad":true,"fecha":1702522800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1702663224590,"usuarioCreacion":4,"fechaCreacion":1702585598285,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":116557,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29344930,"numeroExpediente":1728,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"t