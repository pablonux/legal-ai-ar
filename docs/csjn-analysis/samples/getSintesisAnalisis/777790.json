[{"codigo":7777904,"analisisDocumental":{"id":777790,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"SALVINI, MARCELO DANIEL Y OTRO s/ INCIDENTE DE RECURSO EXTRAORDINARIO","alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - IMPUTADO: SALVINI, MARCELO DANIEL Y OTRO s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":true,"falloDestacado":{"id":4421,"titulo":"Tenencia de estupefacientes para consumo personal y establecimientos carcelarios","cabecilla":"<p>Ante la condena por la casación por el delito de tenencia de estupefacientes para consumo personal en una unidad penitenciaria el encartado promovió un recurso de queja ante la Corte. El Tribunal, por mayoría que se integró con un conjuez, modificando el anterior criterio fallado en la causa “Rodríguez, Héctor Ismael” (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=344&amp;pagina=2409\">Fallos: 344:2409</a>), revocó la condena y ordenó dictar un nuevo pronunciamiento remitiendo para ello a los fundamentos de los dos votos que se habían pronunciado en minoría en el precedente referido. En aquella ocasión, valer recordar, en los mencionados votos, se consideró que los internos no pierden todos sus derechos por el hecho de haber sido privados de su libertad sino que pueden reclamar, como cualquier otro ciudadano, que su derecho a la privacidad sea reconocido.  A lo que se añadió que correspondía respetar el ámbito de ejercicio de la libertad personal cuando no hay daño o peligro concreto para terceros.</p>","esNovedad":true,"fecha":1661828400000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1661889063873,"usuarioCreacion":11,"fechaCreacion":1661888942301,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":34997,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30935878,"numeroExpediente":2330,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"DOMINGUEZ, JOSE LUIS Y OTROS s/ABUSO SEXUAL AGRAVADO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2330. "},"recurso":{"id":5220140,"expediente":{"id":30935878,"numeroExpediente":2330,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripci