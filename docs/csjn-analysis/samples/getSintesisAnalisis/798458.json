[{"codigo":7984582,"analisisDocumental":{"id":798458,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":80003,"valor":"REVOCA PARCIALMENTE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051034,"fechaModLong":201008181300,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - KECHIYAN, INES SILVIA Y OTRO c/ HEREDIA, SERGIO OSVALDO Y OTROS s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","inconstitucional":false,"falloDestacado":{"id":7144,"titulo":"Honorarios profesionales: ley aplicable","cabecilla":"<p style=\"text-indent:2em\">En la causa la Corte consideró que en el caso de los trabajos profesionales el derecho se constituye en la oportunidad en que se los realiza, más allá de la época en que se practique la regulación (Fallos: <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=321&amp;pagina=146\">321:146</a>; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=328&amp;pagina=1381\">328:1381</a>; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=329&amp;pagina=1066\">329:1066</a>, entre muchos otros). Por ello – sostuvo - el nuevo régimen de la ley 27.423  no es aplicable a los procesos fenecidos o en trámite, en lo que respecta a la labor desarrollada durante las etapas procesales concluidas durante la vigencia de la ley 21.839 y su modificatoria ley 24.432, o que hubieran tenido principio de ejecución (arg. art. 7° del decreto 1077/2017, considerandos referidos al art. 64 de la ley 27.423 y doctrina de Fallos: <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=268&amp;pagina=352\">268:352</a>; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=318&amp;pagina=445\">318:445</a> -en especial considerando 7°entre otros y en las causas “Establecimiento Las Marías\",<a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=341&amp;pagina=1063\"> Fallos: 341:1063</a> y “All, Jorge Emilio, y otros”, <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=345&amp;pagina=220\">Fallos: 345:220</a> )</p>","esNovedad":true,"fecha":1719889200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1720029526780,"usuarioCreacion":4,"fechaCreacion":1720016187302,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":122518,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34194454,"numeroExpediente":42047,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nac