[{"codigo":8030473,"analisisDocumental":{"id":803047,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":210003,"valor":"PRECEDENTES CSJN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201009301210,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - BEHRENS, ROBERTO OSCAR c/ ASOCIART ART S.A. s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":7841,"titulo":"Riesgos del trabajo: constitucionalidad de la instancia previa ante comisiones médicas creadas por la ley 27.348","cabecilla":"<p style=\"text-indent:2em\">La cámara declaró la inconstitucionalidad de la atribución de competencias decisorias a las comisiones médicas en materia de riesgos del trabajo dispuesta por la ley 27.348. Ante el recurso interpuesto por la demandada la Corte dejó sin efecto la decisión al remitir a su precedente  <b>“Pogonza” (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=344&amp;pagina=2307\">344 :2307</a>)</b>.</p><p style=\"text-indent:2em\">En esa oportunidad había expresado que resulta acorde a las características de la materia de los riesgos del trabajo, y a los objetivos públicos definidos por la ley 26.773, la disposición en la esfera de la administración del Estado de un mecanismo institucional de respuesta ágil, organizado en base a parámetros estandarizados, que procure asegurar el acceso inmediato y automático a las prestaciones del seguro, y que evite el costo y el tiempo del litigio.</p><p style=\"text-indent:2em\">Recordó que la validez constitucional de la atribución de competencias jurisdiccionales a órganos administrativos había sido reconocida en reiteradas ocasiones siempre que se cumplieran ciertas condiciones y señaló que el sistema cuestionado que establece la ley 27.348 cumple con todos los recaudos fijados en su jurisprudencia.</p><p style=\"text-indent:2em\">Agregó que las comisiones médicas han sido creadas por ley formal, y satisfacen las exigencias de independencia e imparcialidad. Los profesionales de la salud que las integran se eligen por concurso público de oposición y antecedentes, el sistema incorpora resguardos del debido proceso que contribuyen a la participación de las partes en el procedimiento y el trabajador cuenta con patrocinio letrado gratuito y obligatorio durante la instancia administrativa. De ese modo, se da un mecanismo institucional de respuesta ágil, organizado con base en parámetros estandarizados, que procura asegurar el acceso inmediato y automático a las prestaciones del seguro, y que evita el costo y el tiempo del litigio.</p><p style=\"text-indent:2em\">En el precedente mencionado el Tribunal desestimó el cuestionamiento sobre el alegado carácter regresivo que tendría la norma en análisis, así como también el agravio dirigido a demostrar que la aplicación del régimen impugnado colocaría al trabajador accidentado en inferioridad de condiciones respecto de cualquier otro damnificado en ámbitos no laborales. Sobre este último punto recordó que “la garantía de igualdad solo exige un trato igual en igualdad de circunstancias” y destacó que no se constataba “igualdad de circunstancias” entre un reclamo de resarcimiento de daños basado en regímenes indemnizatorios no laborales y el fundado en el sistema especial de reparación de accidentes y enfermedades del trabajo.</p>","esNovedad":true,"fecha":1730775600000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1730847623111,"usuarioCreacion":11,"fechaCreacion":1730845141295,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":129618,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35839576,"numeroExpediente":45559,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9701,"descripcion":"ACCIDENTE - LEY ESPECIAL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - BEHRENS, ROBERTO OSCAR c/ ASOCIART ART S.A. s/ACCIDENTE - LEY ESPECIAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"45559. "},"recurso":{"id":6131680,"expediente":{"id":35839576,"numeroExpediente":45559,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":970