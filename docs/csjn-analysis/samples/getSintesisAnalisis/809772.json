[{"codigo":8097722,"analisisDocumental":{"id":809772,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":230004,"valor":"RECURSO DE REVOCATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 4 - LABORDA, EDUARDO s/SUCESION AB-INTESTATO","inconstitucional":false,"falloDestacado":{"id":8822,"titulo":"Depósito previo y beneficio de litigar sin gastos: planteo extemporáneo e inadmisible","cabecilla":"<p style=\"text-indent:2em\">El recurrente solicita que se revoque la providencia que dispuso diferir el estudio del recurso de queja hasta tanto le fuera concedido el beneficio de litigar sin gastos. Sostiene que la revocatoria se presenta dentro del término establecido por el art. 158 del <a target=\"_blank\" href=\"https://webvpn.csjn.gov.ar/proxy/3f306edc/http/www.argentina.gob.ar/normativa/nacional/ley-17454-16547/actualizacion\">Código Procesal Civil y Comercial de la Nación </a>y la <a target=\"_blank\" href=\"https://webvpn.csjn.gov.ar/proxy/3f306edc/http/www.csjn.gov.ar/documentos/descargar?ID=41817\">acordada 5/2010</a> ya que se encuentra residiendo en la Provincia de Misiones, lo que haría aplicable la extensión de 11 días.</p><p style=\"text-indent:2em\">La Corte desestimó este pedido y ordenó que la parte informe periódicamente acerca del trámite y resolución del beneficio de litigar sin gastos invocado, bajo apercibimiento de declarar la caducidad de la instancia.</p><p style=\"text-indent:2em\">Expresó que la ampliación solicitada no se verifica pues el auto denegatorio del recurso extraordinario fue dictado por la Cámara Nacional de Apelaciones en lo Civil de la Capital Federal. Además, en lo que respecta a los ulteriores actos procesales de la presentación directa, dicho supuesto tampoco se constata, en tanto al ocurrir en queja ante la Corte, el recurrente tenía la carga –que de hecho fue cumplida- de constituir domicilio legal dentro del perímetro de la ciudad en la que tiene asiento el Tribunal y tenía, asimismo, la carga de constituir domicilio electrónico, extremo que también resultó cumplido.</p><p style=\"text-indent:2em\">Concluyó así que lo dispuesto en el art. 158 del código de rito no resultaba aplicable al plazo para formular un planteo de revocatoria.</p><p style=\"text-indent:2em\">Si bien lo señalado resultaba suficiente para desestimar el planteo por extemporáneo, la Corte agregó que el pedido de revocatoria era inadmisible en tanto la obligación que impone el art. 286 del código de rito solo cede respecto de quienes se encuentran exentos de pagar sellado o tasa judicial y que la petición formulada no se hallaba incluida en ninguna de las exenciones previstas en la <a target=\"_blank\" href=\"http://www.argentina.gob.ar/normativa/nacional/ley-23898-298/actualizacion\">ley 23.898</a>.</p>","esNovedad":true,"fecha":1748919600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1748994098078,"usuarioCreacion":4,"fechaCreacion":1748979030658,"privado":f