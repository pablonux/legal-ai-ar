[{"codigo":7838844,"analisisDocumental":{"id":783884,"competencia":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":190013,"valor":"QUEJA POR RETARDO DE JUSTICIA","activo":"S","usuarioCreacion":"CYCJ3F","usuarioMod":"CYCJ3F","fechaCreacionLong":202603171152,"fechaModLong":202603171152,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":80009,"valor":"ADMITE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231243,"fechaModLong":201008231243,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"M. S., M. G. c/ F., M. V. s/RESTITUCION INTERNACIONAL DE MENORES","inconstitucional":false,"falloDestacado":{"id":5362,"titulo":"Queja por retardo de justicia en el marco de una restitución internacional de un niño","cabecilla":"<p>El progenitor de un niño dedujo una <b>queja por retardo de justicia</b> con motivo de la demora que atribuye a la corte provincial en expedirse en un proceso de restitución internacional por retención indebida. Luego de una decisión de cámara que confirmó la orden de restitución y de un recurso de inaplicabilidad de ley interpuesto por la demandada la causa se halla en la actualidad a estudio del superior tribunal local. La Corte, luego de recordar que se trata de una medida extrema que fue utilizada en otras ocasiones como ultima ratio para evitar una efectiva privación de justicia, señaló que correspondía admitir la presentación formulada. Expresó que en materia de restitución internacional de niñas, niños y adolescentes la <b>celeridad en la resolución del conflicto</b> constituye un mandato central que compromete la <b>responsabilidad del Estado argentino</b> y que la <b>excesiva demora</b> –casi tres años- en resolver el recurso no se condice con la urgencia que debe otorgarse a este tipo de procesos, máxime cuando no se han señalado razones y/o motivos de entidad que hubieran impedido el dictado de un pronunciamiento. Por ello, hizo lugar al reclamo y dispuso que el tribunal provincial se expida sin dilación alguna sobre el recurso extraordinario interpuesto ante sus estrados, debiendo adoptar idéntica premura frente a eventuales planteos y/o recursos que puedan deducirse con posterioridad, en consonancia con la celeridad que el caso exige y con el fin de evitar que su retardo injustificado pueda comprometer la responsabilidad internacional del Estado argentino.</p>","esNovedad":true,"fecha":1683082800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1683139050946,"usuarioCreacion":4,"fechaCreacion":1683139030914,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":109023,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37531232,"numeroExpediente":224,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"M. S., M. G. c/ F., M. V. s/RESTITUCION INTERNACIONAL DE MENORES","verificacion