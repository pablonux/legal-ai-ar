[{"codigo":8117003,"analisisDocumental":{"id":811700,"competencia":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":190013,"valor":"QUEJA POR RETARDO DE JUSTICIA","activo":"S","usuarioCreacion":"CYCJ3F","usuarioMod":"CYCJ3F","fechaCreacionLong":202603171152,"fechaModLong":202603171152,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":80009,"valor":"ADMITE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231243,"fechaModLong":201008231243,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"AGROPECUARIA CERRO DEL AGUILA S. A. Y OTRO c/ FISCO DE LA PROVINCIA DE BUENOS AIRES s/RETRDO Y DENEGACIÓN DE JUSTICIA","inconstitucional":false,"falloDestacado":{"id":9122,"titulo":"Queja por retardo de justicia","cabecilla":"<p style=\"text-indent:2em\">La actora -que promovió una acción de expropiación inversa- se presentó directamente ante la Corte con motivo de la demora que atribuye a la Suprema Corte de Justicia de la Provincia de Buenos Aires en resolver su recurso y solicitó que se ordene la resolución del asunto. </p><p style=\"text-indent:2em\">El Tribunal hizo lugar a la queja por retardo de justicia y dispuso que el tribunal mencionado se pronuncie sin dilación alguna sobre los recursos interpuestos ante sus estrados.</p><p style=\"text-indent:2em\">Tuvo en cuenta para ello que del informe recibido resulta que asiste razón a la presentante ya que desde hace casi diez (10) años el proceso se encuentra tramitando ante los estrados del tribunal superior provincial sin que aún haya recaído resolución alguna.</p><p style=\"text-indent:2em\">Señaló que la dilación injustificada de un tribunal no puede redundar en un perjuicio irreparable para los recurrentes que, como consecuencia de una conducta ajena y que no pueden modificar, se ven impedidos de obtener una sentencia definitiva en tiempo útil.</p><p style=\"text-indent:2em\">Recordó que en supuestos de manifiesta excepcionalidad la Corte admite quejas por retardo de justicia con referencia a asuntos en trámite ante jurisdicciones provinciales, cuando las circunstancias del caso exigen su intervención,  medida extrema que se utiliza como último recurso para evitar una efectiva privación de justicia.</p>","esNovedad":true,"fecha":1752116400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1752242380077,"usuarioCreacion":11,"fechaCreacion":1752177281841,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":140278,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33197277,"numeroExpediente":90257,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 2 - FLOR PEREIRA, FELIX c/ EN-M INTERIOR-DNM s/RECURSO DIRECTO DNM","verificacionMesa":"N","etiqueta":null,"hij