[{"codigo":7718433,"analisisDocumental":{"id":771843,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":80009,"valor":"ADMITE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231243,"fechaModLong":201008231243,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"SANTA FE, PROVINCIA DE c/ ESTADO NACIONAL s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","alias":null,"caratula":"SANTA FE, PROVINCIA DE c/ ESTADO NACIONAL s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":3282,"titulo":"Tasa de interés aplicable a la deuda por reintegros de coparticipación de impuestos","cabecilla":"<p>En un pronunciamiento anterior en la misma causa la Corte declar&oacute; la inconstitucionalidad del art. 76 de la ley 26.078, en lo atinente a la detracci&oacute;n del 15% de la masa de impuestos coparticipables pactada en el &ldquo;Acuerdo entre el Gobierno Nacional y los Gobiernos Provinciales&rdquo; y conden&oacute; al Estado Nacional a pagar a la Provincia de Santa Fe la suma resultante, con m&aacute;s los intereses seg&uacute;n la legislaci&oacute;n aplicable. Dicha sentencia tuvo -seg&uacute;n la Corte- el firme prop&oacute;sito de que las partes convinieran y determinaran tanto la cuant&iacute;a de la condena como la forma y plazos de su cumplimiento pero dicho prop&oacute;sito no se alcanz&oacute; a 6 a&ntilde;os de aquella, lo cual coloc&oacute; nuevamente al Tribunal en la situaci&oacute;n de tener que decidir acerca de la cuant&iacute;a de la condena. La provincia actora practic&oacute; la liquidaci&oacute;n y, para el c&aacute;lculo de los intereses, aplic&oacute; la tasa activa del Banco de la Naci&oacute;n Argentina. El Estado Nacional impugn&oacute; dicha liquidaci&oacute;n y present&oacute; una nueva, considerando que los distintos pasivos de las provincias con el Estado Nacional han tenido usualmente una tasa del 6% anual. <strong>La Corte decidi&oacute;</strong> que, conforme a lo ya resuelto en la causa &quot;San Luis&quot; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7504731&amp;cache=1638904583149\">(Fallos: 342:85)</a> correspond&iacute;a disponer que los intereses se computen a la tasa pasiva promedio que publica el Banco Central de la Rep&uacute;blica Argentina. Agreg&oacute; que la pretensi&oacute;n del demandado no resultaba admisible, porque dicho porcentaje no fue previsto por las partes en el Consenso Fiscal para la situaci&oacute;n de los juicios con sentencia firme del Tribunal y, por otro lado, que las defensas atinentes a los alcances de la obligaci&oacute;n del Estado Nacional de restituir los recursos coparticipables detra&iacute;dos ileg&iacute;timamente ya hab&iacute;a sido objeto de discusi&oacute;n amplia a lo largo del proceso de conocimiento ya sustanciado lo que importaba considerar la existencia de cosa juzgada sobre el punto.</p>","esNovedad":true,"fecha":1638846000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1639159674069,"usuarioCreacion":11,"fechaCreacion":1638904612619,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":32869,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","