[{"codigo":8161296,"analisisDocumental":{"id":816129,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - YPF SA c/ GASNEA SA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","inconstitucional":false,"falloDestacado":{"id":9801,"titulo":"Contrato de comercialización de hidrocarburos: laudo arbitral y conflicto de competencia","cabecilla":"<p style=\"text-indent:2em\">La empresa YPF S.A. promovió demanda ante el Tribunal de Arbitraje General de la Bolsa de Comercio de Buenos Aires, a efectos de que se condene a GASNEA S.A. a abonarle una suma de dinero por la diferencia de cambio generada entre la fecha de vencimiento hasta el día hábil anterior al efectivo pago de las facturas emitidas por la actora en concepto de provisión de gas natural. El tribunal de arbitraje mencionado, mediante un laudo, desestimó el reclamo y contra el mismo la actora interpuso un recurso de apelación que fue rechazado y originó las quejas que suscitaron un conflicto negativo de competencia entre la Cámara Nacional de Apelaciones en lo Comercial y la Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal. </p><p style=\"text-indent:2em\">La Corte recordó que el art. 763 del Código Procesal Civil y Comercial de la Nación prevé que en los procesos arbitrales “conocerá de los recursos el tribunal jerárquicamente superior al juez a quien habría correspondido conocer si la cuestión no se hubiera sometido árbitros, salvo que el compromiso estableciera la competencia de otros árbitros para entender en dichos recursos”.</p><p style=\"text-indent:2em\">Entendió que la cuestión conducía a la preponderante interpretación y aplicación de normas que integran el marco regulatorio del gas —<a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-24076-475/actualizacion\">ley 24.076</a>, sus disposiciones reglamentarias, <a href=\"https://www.argentina.gob.ar/normativa/nacional/decreto-1053-2018-316448/texto\">DNU 1053/2018</a> y las resoluciones ENARGAS 466/2019; 624/2019 y 735/2019, entre otras— para cuyo juzgamiento resulta competente el fuero contencioso administrativo federal. Agregó que la cuestión no está ceñida exclusivamente a una relación contractual entablada entre particulares, ni se trata de una desavenencia simplemente comercial, sino que resulta clara la prioritaria relevancia que los aspectos propios del derecho administrativo asumen para la solución del caso, sin perjuicio de que también puedan llegar a aplicarse normas de derecho común.</p><p style=\"text-indent:2em\">Concluyó así que la Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal debe resolver la queja articulada por YPF S.A., toda vez que ese tribunal sería el órgano judicial competente para entender en el recurso de apelación interpuesto contra el laudo dictado por el Tribunal de Arbitraje, en el caso de resultar favorablemente resuelta la queja deducida por aquélla.</p>","esNovedad":true,"fecha":1762830000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1763035878303,"usuarioCreacion":11,"fechaCreacion":1762884115381,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":144681,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35871133,"numeroExpediente":16209,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2,"tema":null},"caratula":"YPF SA c/ DISTRIBUIDORA DE GAS DEL CENTRO SA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"16209. "},"recurso":{"id":6861566,"expediente":{"id":35871133,"numeroExpediente":16209,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2,"tema":null},"caratula":"YPF SA c/ DISTRIBUIDORA DE GAS DEL CENTRO SA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"16209. "},"tipoRecurso":{"id":1103,"codigo":"COM","descripcion":"COMPETENCIA"},"claveRecurso":"CAF 016209/2021/CS002","identifica