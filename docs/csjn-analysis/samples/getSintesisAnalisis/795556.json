[{"codigo":7955563,"analisisDocumental":{"id":795556,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ZAMORA, RAUL ESTEBAN c/ LOPEZ, CRISTOBAL NAZARENO Y OTRO s/INCIDENTE DE COMPETENCIA","inconstitucional":false,"falloDestacado":{"id":6744,"titulo":"Contienda no tradicional de competencia: indebida interferencia jurisdiccional","cabecilla":"<p style=\"text-indent:2em\">Un tribunal oral federal hizo lugar al pedido formulado por la demandada y dispuso la suspensión de la subasta que había dispuesto un juez provincial.</p><p style=\"text-indent:2em\">La Corte consideró que se verificaba una <em>contienda no tradicional de competencia</em> y que ella se encontraba habilitada para corregir <em>actuaciones deformadas</em> como la que se había configurado.</p><p style=\"text-indent:2em\">Recordó que las sentencias no pueden ser interferidas o revisadas por una vía inadecuada y que ello incluye otras decisiones que se dictan en causas diferentes, en tanto se afecta el adecuado respeto que merecen las decisiones judiciales.</p><p style=\"text-indent:2em\">Dejó entonces sin efecto la decisión del tribunal oral federal al considerar que su oposición a que su par provincial lleve adelante la ejecución de su propia sentencia de remate no se encontraba debidamente justificada y había implicado una indebida e infundada interferencia jurisdiccional.</p>","esNovedad":true,"fecha":1713841200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1713976269229,"usuarioCreacion":4,"fechaCreacion":1713960675507,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":119305,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35078420,"numeroExpediente":10138,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":9489,"descripcion":"MEDIDA PRECAUTORIA","idMateria":4,"tema":{"id":507,"codigo":"MEDIDAS"}},"caratula":"GRUPO BELLEVILLE HOLDINGS LLC c/ INVERSORA DE MEDIOS Y COMUNICACIONES SA Y OTROS s/MEDIDA PRECAUTORIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10138. "},"recurso":{"id":6413837,"expediente":{"id":35078420,"numeroExpediente":10138,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":9489,"descripc