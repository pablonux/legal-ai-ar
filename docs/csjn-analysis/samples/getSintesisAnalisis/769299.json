[{"codigo":7692998,"analisisDocumental":{"id":769299,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":250005,"valor":"DDHH- Institucional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"AGRUPACION POLITICA: FRENTE CAMBIEMOS LA PAMPA s/ CUESTIONES DE COMPETENCIA","alias":null,"caratula":"Incidente Nº 2 - AGRUPACION POLITICA: FRENTE CAMBIEMOS LA PAMPA  s/CUESTIONES DE COMPETENCIA","inconstitucional":false,"falloDestacado":{"id":2802,"titulo":"Proceso electoral: conflicto entre jueces a los fines de definir el destino de las boletas","cabecilla":"<p>Conflicto suscitado entre la C&aacute;mara Nacional Electoral y un juzgado federal con respecto a la entrega de urnas que contienen votos emitidos para la elecci&oacute;n de diputados nacionales - Causa tramitada ante la justicia nacional electoral donde se pretend&iacute;a la apertura de las urnas&nbsp; a fin de constatar la existencia de votos marcados y declarar la nulidad y actuaciones en un juzgado federal donde se investiga la posible comisi&oacute;n de un delito electoral - Ante la decisi&oacute;n de la Junta Electoral de entregar las urnas a la fiscal&iacute;a penal la C&aacute;mara Nacional Electoral solicit&oacute; la intervenci&oacute;n de la Corte - No se trata de una tradicional contienda de competencia, ya que no se trata de dilucidar cu&aacute;l es el tribunal que debe conocer en el asunto sino de determinar si los jueces involucrados adoptaron decisiones contradictorias y, en tal caso, si alguno de ellos interfiri&oacute; injustificadamente en la jurisdicci&oacute;n del otro - Interpretaci&oacute;n del art. 123 del C&oacute;digo Electoral Nacional - La falta de impugnaci&oacute;n en tiempo sell&oacute; definitivamente la suerte de las boletas, que deben ser destruidas de conformidad con lo ordenado por la C&aacute;mara Electoral - Lo dispuesto por la jueza federal, al requerir la entrega de las urnas a efectos de utilizar su contenido como prueba ha interferido indebidamente con la sentencia de la c&aacute;mara mencionada y debe ser dejado sin efecto - Disidencia de los jueces Rosenkrantz y Highton de Nolasco: para evitar que desaparezca lo que podr&iacute;a constituir prueba fundamental en el marco del proceso penal corresponde mantener la suspensi&oacute;n de la destrucci&oacute;n de las boletas - Las actuaciones cumplidas en la causa penal no contradicen ni interfieren con lo resuelto en el &aacute;mbito electoral.</p>","esNovedad":true,"fecha":1632970800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1633457608161,"usuarioCreacion":11,"fechaCreacion":1633096564926,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":32000,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30944459,"numeroExpediente":10566,"anioExpediente":2017,"tomoExpediente":null,"le