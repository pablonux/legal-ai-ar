[{"codigo":8069654,"analisisDocumental":{"id":806965,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":80008,"valor":"RECHAZA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231243,"fechaModLong":201008231243,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"LORENZETTI, DIEGO HERNAN c/ SAN LUIS, PROVINCIA DE Y OTRO s/ACCION AUTONOMA DE NULIDAD","inconstitucional":false,"falloDestacado":{"id":8381,"titulo":"Nulidad de la cosa juzgada por sentencia írrita","cabecilla":"<p style=\"text-indent:2em\">Entre otros planteos, el actor promovió una “acción autónoma de nulidad de la cosa juzgada por sentencia írrita” a fin de que se declare la nulidad del pronunciamiento dictado por la Corte el 11 de julio de 2023 que rechazó su recurso de queja. A su entender, la referida sentencia de la Corte se encontraría viciada porque no se habrían considerado las presentaciones en las que se invocaron inobservancias judiciales locales previas que, a su juicio, determinarían la procedencia de la queja.</p><p style=\"text-indent:2em\">La Corte, de conformidad con la doctrina de Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=254&amp;pagina=320\">254:320</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=279&amp;pagina=54\">279:54</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=283&amp;pagina=66\">283:66</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=323&amp;pagina=1222\">323:1222</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=328&amp;pagina=2773\">328:2773</a>, entre otros, rechazó el planteo toda vez que no se hallaban reunidos en el caso los requisitos a los que se subordina la procedencia de la acción autónoma de nulidad por cosa juzgada írrita.</p><p style=\"text-indent:2em\">Según el Tribunal, la pretensión intentada importaba un intento tardío por obtener la revocación del fallo mediante argumentos que, valorados a la luz del criterio restrictivo con que debe juzgarse la admisibilidad de la vía intentada no permiten tener por configurada la nulidad pretendida, máxime cuando la parte pudo deducir los remedios que el ordenamiento procesal contempla para la defensa de los derechos que entiende vulnerados.</p>","esNovedad":true,"fecha":1742353200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1742488281155,"usuarioCreacion":4,"fechaCreacion":1742411852829,"privado":false,"posicion":2,"resumen":{"idResumen":121,"resumen":"La Corte rechazó la acción autónoma de nulidad contra su fallo anterior, al no cumplirse los requisitos para cosa juzgada írrita. Consideró que era un intento tardío de revocar el fallo sin configurar nulidad.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":134360,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descrip