[{"codigo":7839615,"analisisDocumental":{"id":783961,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - OVIEDO ADOLFO CATALINO c/ AGUA Y ENERGIA ELECTRICA SOCIEDAD DEL ESTADO Y OTROS s/OTROS PROCESOS LABORALES","inconstitucional":false,"falloDestacado":{"id":5641,"titulo":"Proceso de privatización de empresas y solidaridad en obligaciones laborales","cabecilla":"<p>La cámara reconoció el derecho de los actores, en su calidad de jubilados y/o pensionados de Agua y Energía Eléctrica S.E., a percibir el rubro “rebaja de tarifa” de luz y de gas, que debería ser abonado por la continuadora de dicha empresa estatal. Apelada por la condenada, la Corte resolvió <b>confirmar la sentencia apelada</b>. Para así decidir, recordó lo señalado en el precedente <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=3778721&amp;cache=1688504050605\">“Di Tullio”  (Fallos: 319:3071)</a> en cuanto que correspondía aplicar al caso la tutela que la Ley de Contrato de Trabajo otorga a los créditos laborales en ocasión de la transferencia de establecimientos (arts. 225 y 228), imponiendo respecto de las obligaciones correspondientes a aquéllos, la solidaridad entre el transmitente y el adquirente y que las cláusulas del pliego de bases y condiciones que establecían que las sociedades licenciatarias no sustituían a su predecesora en sus obligaciones y responsabilidades, no podían tener otro alcance que el de otorgar a la sociedad licenciataria el derecho a una acción de regreso contra el Estado Nacional. Consideró así que la empresa continuadora codemandada no podía deslindarse de la regla de solidaridad  prevista para las obligaciones de índole laboral que ampara a los trabajadores afectados por el proceso de privatización de empresas, aun cuando la relación laboral y la causa del crédito que se reclamara fueran anteriores a la privatización y los reclamantes no hubieran sido transferidos. </p>","esNovedad":true,"fecha":1688439600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1688568477757,"usuarioCreacion":4,"fechaCreacion":1688504081186,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":109086,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31927817,"numeroExpediente":12000037,"anioExpediente":2001,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":23,"codigo":"23","abreviatura":"FRE","descripcion":"Justicia Federal de