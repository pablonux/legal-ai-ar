[{"codigo":8120443,"analisisDocumental":{"id":812044,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"NATURGY BAN S.A. (ANTES GAS NATURAL BAN S.A.) c/ BUENOS AIRES, PROVINCIA DE s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":9167,"titulo":"Facultades regulatorias del servicio público de distribución de gas natural: competencia originaria de la Corte","cabecilla":"<p style=\"text-indent:2em\">En su condición de licenciataria del servicio público de distribución de gas natural la actora promovió una acción contra la Provincia de Buenos Aires a fin de que se declare la inconstitucionalidad de la ley local 14.692, en cuanto la obliga a establecer oficinas de atención personalizada en las ciudades cabecera de cada uno de los distritos en los que presta el servicio, con el objeto de que los usuarios o consumidores puedan efectuar reclamos y consultas en forma personal. </p><p style=\"text-indent:2em\">La Corte, por mayoría, declaró que la causa corresponde a su competencia originaria en tanto exige dilucidar si la provincia demandada está ejerciendo facultades regulatorias del servicio público de distribución de gas natural, imponiendo cargas u obligaciones a las empresas prestatarias e interfiriendo en una actividad de carácter federal, reglada por una legislación específica, que incluye lo referente a las obligaciones del prestador con relación a la atención de los usuarios.</p><p style=\"text-indent:2em\">El Tribunal rechazó la medida cautelar de no innovar tendiente a que se ordene a la provincia que se abstenga de aplicar la ley cuestionada, de adoptar actos de aplicación de la misma, y que se disponga la suspensión de las actuaciones que se encuentren en trámite en sede provincial o municipal. Consideró que no resultaba suficientemente acreditada la configuración de los presupuestos establecidos en los incisos 1° y 2° del artículo 230 del código adjetivo para acceder a la medida solicitada, especialmente teniendo en consideración la estrictez con que corresponden ser apreciados tales extremos en virtud de naturaleza de la presente y la amplitud de la tutela cautelar requerida.</p>","esNovedad":true,"fecha":1752721200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1752854107367,"usuarioCreacion":11,"fechaCreacion":1752784088441,"privado":false,"posicion":11,"resumen":null},"reciboEntrada":{"id":140638,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31928301,"numeroExpediente":936,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10564,"descripcion":"ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","idMateria":0,"tema":null},"caratula":"NATURGY BAN S.A. (ANTES GAS NATURAL BAN S.A.) c/ B