[{"codigo":7850265,"analisisDocumental":{"id":785026,"competencia":null,"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"YACYLEC SA TF 24786-I c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","inconstitucional":false,"falloDestacado":{"id":5601,"titulo":"Impuesto a las ganancias: criterio de \"vida útil probable\"","cabecilla":"<p>La empresa actora - adjudicataria de la construcción de un electroducto - celebró con la Unidad Especial Sistema de Transmisión Yacyretá un contrato de construcción, operación y mantenimiento (COM) y el Fisco determinó de oficio su obligación tributaria frente al impuesto a las ganancias. La sociedad amortizó contable e impositivamente las obras construidas en quince años y así lo declaró a los fines del mismo. Dicho criterio fue aceptado por la cámara pero cuestionado por el Fisco, quien consideró que el plazo de amortización de la obra debía estimarse de acuerdo con su vida útil probable. La Corte revocó el pronunciamiento. Consideró que la Ley de Impuesto a las Ganancias estableció como principio general que el plazo de amortización de los bienes debe ser determinado de acuerdo a su vida útil probable y que el informe realizado en sede administrativa que estimó que la vida útil del bien en cincuenta años fue el único instrumento producido que tuvo por objeto acreditar aquel extremo y que si bien la actora ofreció diversos medios probatorios, ninguno se dirigió a demostrar que dicha vida útil fuera de quince años, como lo había exteriorizado en sus declaraciones juradas.</p>","esNovedad":true,"fecha":1687834800000,"relevancia":1,"usuarioModificacion":12,"fechaModificacion":1687963800543,"usuarioCreacion":11,"fechaCreacion":1687892209505,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":110401,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33893848,"numeroExpediente":39800,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2,"tema":null},"caratula":"YACYLEC SA TF 24786-I c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":35123326,"numeroExpediente":39800,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":