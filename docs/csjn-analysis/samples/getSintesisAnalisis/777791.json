[{"codigo":7777913,"analisisDocumental":{"id":777791,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"PFANNSHMIDT MORALES, CLAUDIO GUILLERMO c/ DIRECCION NACIONAL DE MIIGRACIONES s/CONTENCIOSO ADMINISTRATIVO-VARIOS","alias":null,"caratula":"PFANNSHMIDT MORALES, CLUDIO GUILLERMO c/ DIRECCION NACIONAL DE MIIGRACIONES s/CONTENCIOSO ADMINISTRATIVO-VARIOS","inconstitucional":false,"falloDestacado":{"id":4563,"titulo":"Expulsión del territorio nacional: aplicación de la ley vigente","cabecilla":"<p>Un migrante fue expulsado del territorio nacional, con prohibición de reingreso por el término de diez (10) años, con fundamento en sus antecedentes penales y por aplicación del régimen de migraciones que regía al momento del dictado de la condena penal. Con posterioridad, y luego de la interposición del recurso extraordinario, una nueva normativa varió sustancialmente el encuadramiento normativo sobre las características que debía reunir dicha condena penal para habilitar la expulsión. La Corte resolvió que correspondía devolver las actuaciones al juez de la causa para que, adecuando el proceso, examine el asunto a la luz de las nuevas disposiciones y dicte un nuevo pronunciamiento.</p>","esNovedad":true,"fecha":1664247600000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1664892982459,"usuarioCreacion":4,"fechaCreacion":1664308823560,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":34999,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29394863,"numeroExpediente":3061,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1099,"descripcion":"AMPARO LEY 16.986","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"CENTRO DE ESTUDIOS LEGALES Y SOCIALES Y OTROS c/ EN-DNM s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"3061. "},"recurso":{"id":5426963,"expediente":{"id":29394863,"numeroExpediente":3061,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1099,"descripcion":"AMPARO LEY 16.986","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"CENTRO DE ESTUDIOS LEGALES Y SOCIALES Y O