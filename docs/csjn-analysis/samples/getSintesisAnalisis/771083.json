[{"codigo":7710832,"analisisDocumental":{"id":771083,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"C. M. L y B. H. M. EN NOMBRE DE SU HIJA MENOR, V. A. B. c/ OBRA SOCIAL DE CONDUCTORES CAMIONEROS Y PERSONAL DEL TRANSPORTE AUTOMOTOR DE CARGAS s/ AMPARO LEY 16.986 *","alias":null,"caratula":"C. M. L Y B. H.M. EN NOMBRE DE SU HIJA MENOR, V. A. B. c/ OBRA SOCIAL DE CONDUCTORES CAMIONEROS Y PERSONAL DEL TRANSPORTE AUTOMOTOR DE CARGAS s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":3101,"titulo":"Cobertura de tratamientos médicos y modificación del cuadro normativo","cabecilla":"<p>Los padres de una ni&ntilde;a iniciaron acci&oacute;n de amparo contra una obra social para que se le provea la&nbsp;<strong>cobertura total del tratamiento con un medicamento</strong>&nbsp;indicado para la peque&ntilde;a con motivo de la enfermedad que padece. La C&aacute;mara hizo lugar al reclamo y contra esta sentencia la demandada interpuso recurso extraordinario expresando que el medicamento ten&iacute;a&nbsp;<strong>car&aacute;cter experimental</strong>&nbsp;al no estar aprobado por ANMAT y que su elevado costo implicar&iacute;a la quiebra de la entidad, as&iacute; como la desatenci&oacute;n de sus restantes afiliados. La Corte, que confirm&oacute; la sentencia apelada, comenz&oacute; recordando que sus sentencias deben ce&ntilde;irse a las circunstancias existentes al momento de la decisi&oacute;n, aunque ellas sean sobrevinientes a la interposici&oacute;n del remedio federal ya que, hall&aacute;ndose la causa a su estudio se dictaron diversas normas que deb&iacute;an tenerse en cuenta. Hizo referencia a una primera resoluci&oacute;n de la Secretar&iacute;a de Gobierno de Salud del Ministerio de Salud y Desarrollo Social mediante la cual el medicamento hab&iacute;a sido incorporado al Programa M&eacute;dico Obligatorio con cobertura del 100% a cargo del agente del seguro de salud pero tambi&eacute;n a su derogaci&oacute;n por una resoluci&oacute;n posterior. Tuvo en cuenta que, si bien la droga solicitada no integra en la actualidad el conjunto de principios incorporados al PMO, se estableci&oacute; que los agentes del seguro de salud deben garantizar la continuidad de la cobertura de los tratamientos de dichos pacientes que se hubieran iniciado durante la vigencia de aquella primera resoluci&oacute;n y se estableci&oacute; un sistema a trav&eacute;s del que se autoriza al agente que hubiera brindado dicha prestaci&oacute;n a peticionar un reintegro. Concluy&oacute; entonces el Tribunal que, teniendo en cuenta que la manda contenida en el fallo ya hab&iacute;a sido satisfecha por parte de la obra social demandada y que &eacute;sta tiene derecho a obtener determinado reembolso por las erogaciones efectuadas,&nbsp;<strong>correspond&iacute;a confirmar la sentencia apelada</strong>.&nbsp;</p>","esNovedad":true,"fecha":1636599600000,"relevancia":2,"u