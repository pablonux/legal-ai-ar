[{"codigo":8036693,"analisisDocumental":{"id":803669,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ASOCIACION CIVIL UNIVERSIDAD DEL SALVADOR c/ I.G.J. 359207/7902016 s/RECURSO DIRECTO A CAMARA","inconstitucional":false,"falloDestacado":{"id":7921,"titulo":"Sobre el requisito del dictamen del servicio jurídico permanente contemplado en la ley 19.549","cabecilla":"<p style=\"text-indent:2em\">La Sala “I” de la Cámara Nacional de Apelaciones en lo Civil confirmó la resolución de la Inspección General de Justicia por la cual se le impuso a la Asociación Civil Universidad del Salvador un apercibimiento con la obligación de publicar la decisión en un diario de circulación masiva, por diversos incumplimientos y objeciones en torno a los estados contables cerrados el 31 de marzo de 2017 y de 2018, por la falta de explicación adecuada respecto de operaciones registradas con fundaciones y por encontrarse pendiente la inscripción de autoridades desde la vista conferida el 9 de junio de 2016.</p><p style=\"text-indent:2em\">Recurrida la sentencia, la Corte la revocó.</p><p style=\"text-indent:2em\">Para decidir de este modo sostuvo que la resolución cuestionada por la actora no contó con el dictamen del servicio jurídico permanente del organismo  demandado previsto en el artículo 7, inciso d, de la ley 19.549.  Añadió que el requisito del dictamen del servicio jurídico permanente contemplado en el artículo 7°, inciso d, de la<a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-19549-22363/actualizacion\"> ley 19.549</a>, en palabras de la Corte, hace a la juridicidad de la actuación administrativa y debe ser cumplido antes de que la Administración exprese su voluntad (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=301&amp;pagina=953\">301:953</a>,“Duperial”).</p><p style=\"text-indent:2em\">Por consiguiente, concluyó el Tribunal, el gravamen causado por el vicio en el requisito esencial de procedimiento, alegado por la actora al recurrir la resolución administrativa y mantenido en el recurso extraordinario, no perdió virtualidad a los efectos de resolver si la resolución sancionatoria resulta inválida.</p>","esNovedad":true,"fecha":1732158000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1732713636477,"usuarioCreacion":4,"fechaCreacion":1732224151633,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":130279,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33640315,"numeroExpediente":4753,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descr