[{"codigo":7873295,"analisisDocumental":{"id":787329,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"LA SEGUNDA ASEGURADORA DE RIESGOS DE TRABAJO SA c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","inconstitucional":false,"falloDestacado":{"id":5861,"titulo":"Requisitos para la determinación de oficio del impuesto a las ganancias en concepto de salidas no documentadas","cabecilla":"<p>La Administración Federal de Ingresos Públicos (AFIP) determinó de oficio el impuesto a las salidas no documentadas de una empresa y le aplicó la multa establecida en el art. 46 de la ley 11.683. Dicha determinación resultó confirmada por la Cámara de Apelaciones. Recurrida la sentencia, la <b>Corte revocó </b>e hizo lugar a la demanda entablada por la empresa por considerar que los fundamentos brindados por el Fisco para aplicar el art. 37 de la LIG resultaban notoriamente insuficientes. Recordó el Tribunal que, conforme a su doctrina de <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=326&amp;pagina=2987\">Fallos: 326:2987</a>, una salida de dinero carece de documentación tanto cuando no hay documento alguno referente a ella, como en el supuesto en que si bien la hay, el instrumento carece de aptitud para demostrar la causa de la erogación e individualizar -al tratarse de actos carentes de sinceridad- a su verdadero beneficiario. En la especie, concluye la sentencia, se observa la falta de concurrencia de los extremos exigidos por la doctrina mencionada, impidiendo, por ende, la aplicación del referido instituto en esta causa.</p>","esNovedad":true,"fecha":1694487600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1694692863037,"usuarioCreacion":11,"fechaCreacion":1694547816567,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":113440,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32887241,"numeroExpediente":79966,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2,"tema":null},"caratula":"LA SEGUNDA ASEGURADORA DE RIESGOS DE TRABAJO SA c/ DIRECC