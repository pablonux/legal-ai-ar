[{"codigo":7717373,"analisisDocumental":{"id":771737,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"GARAY CORINA ELENA c/ ANSES s/REAJUSTES VARIOS","alias":null,"caratula":"GARAY CORINA ELENA c/ ANSES s/REAJUSTES VARIOS","inconstitucional":false,"falloDestacado":{"id":3284,"titulo":"Vulnerabilidad de personas mayores y cargas procesales desproporcionadas","cabecilla":"<p>En el marco de un reajuste de haberes jubilatorios se&nbsp;declararon&nbsp;exentas del pago del impuesto a las ganancias las retroactividades abonadas por la ANSeS y se estableci&oacute; que no correspond&iacute;a a ese organismo la devoluci&oacute;n de las sumas ya retenidas ya que su funci&oacute;n se limita a ser agente de retenci&oacute;n, por lo cual se estableci&oacute; que la actora deb&iacute;a ocurrir ante la AFIP mediante el tr&aacute;mite administrativo correspondiente.&nbsp;<strong>La Corte, por unanimidad </strong>revoc&oacute; esta decisi&oacute;n y orden&oacute; dictar un nuevo pronunciamiento. Destac&oacute; la condici&oacute;n de vulnerabilidad de ciertos individuos frente a pretensiones judiciales que implican dilatar irrazonablemente el cumplimiento de decisiones firmes de naturaleza patrimonial. Consider&oacute; que se trata de evitar imponer a las personas ancianas cargas procesales desproporcionadas y desajustadas al estado actual del proceso. Sostuvo asimismo que, teniendo en &nbsp;cuenta&nbsp; el tiempo transcurrido desde el inicio de la acci&oacute;n, la avanzada edad que presentaba la actora y la posibilidad expresamente planteada y omitida de satisfacer la condena sin m&aacute;s dilaciones en este expediente trayendo al organismo recaudador al proceso, la decisi&oacute;n de sujetar a la accionante a un nuevo tr&aacute;mite administrativo y/o judicial no especificado, configuraba un exceso ritual manifiesto que pod&iacute;a frustrar la sustancia de su derecho conforme al desenvolvimiento natural de los hechos. Agreg&oacute; que no resultaba razonable exigir a los recurrentes que deduzcan dos planteos ante distintos organismos a fin de lograr id&eacute;ntico reconocimiento, ya que no solo importaba un arbitrario retraso en la declaraci&oacute;n de derechos de naturaleza alimentaria que cuentan con amparo constitucional, sino que trasuntaba un dispendio jurisdiccional que se opone a principios b&aacute;sicos de econom&iacute;a y concentraci&oacute;n procesal.</p>","esNovedad":true,"fecha":1638846000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1639159562907,"usuarioCreacion":11,"fechaCreacion":1638906750467,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":32841,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":25583950,"numeroExpediente"