más acorde a la realidad del caso. La Corte <b>desestimó el planteo y reiteró</b><b> la intimación</b>. Señaló que el art. 6° de la ley de tasas judiciales refiere a otra instancia del proceso y que la exigencia del depósito previo en las quejas por denegación de recursos ante la Corte resulta del art. 286 del Código Procesal Civil y Comercial de la Nación y no de las leyes nacionales en materia de sellado y tasa judicial, a las cuales aquel precepto solo se remite para incorporar la nómina de exenciones que estas contemplan.</p>","esNovedad":true,"fecha":1694487600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1694692764022,"usuarioCreacion":11,"fechaCreacion":1694615453797,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":113903,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35860796,"numeroExpediente":1918,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MACHUCA, ESTER GUADALUPE c/ ALONSO, DIANA JORGELINA s/accion de colacion ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1918. "},"recurso":{"id":6143928,"expediente":{"id":35860796,"numeroExpediente":1918,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":