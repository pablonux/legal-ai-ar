[{"codigo":8233623,"analisisDocumental":{"id":823362,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":80013,"valor":"DECLARA INOFICIOSO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009221235,"fechaModLong":201009221235,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - FERRARI, MARIA ALICIA Y OTRO c/ LEVINAS, GABRIEL ISAIAS s/RENDICION DE CUENTAS","inconstitucional":false,"falloDestacado":{"id":10263,"titulo":"Cuestión que devino abstracta ante la resolución del conflicto de competencia","cabecilla":"<p style=\"text-indent:2em\">Contra la sentencia de cámara que condenó al demandado a abonar una suma de dinero, este interpuso recurso extraordinario federal cuya denegación motivó una queja ante la Corte.</p><p style=\"text-indent:2em\">Simultáneamente y contra la misma resolución, el demandado también planteó un recurso de inconstitucionalidad local, en los términos de los artículos 27 y 28 de la ley local 402 y 113 de la Constitución de la Ciudad Autónoma de Buenos Aires, que derivó en un conflicto jurisdiccional que fue resuelto por la Corte declarando competente al Tribunal Superior de Justicia de la Ciudad Autónoma de Buenos Aires para revisar aquella sentencia (<b>Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=8055351&amp;cache=1772132208810\">347:2286</a></b>).</p><p style=\"text-indent:2em\">A partir de dicha decisión el Tribunal declaró inoficioso pronunciarse respecto de la queja al haber devenido abstracta la cuestión planteada.</p>","esNovedad":true,"fecha":1772074800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1772201516032,"usuarioCreacion":4,"fechaCreacion":1772132235226,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":152518,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33715789,"numeroExpediente":78500,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":648,"descripcion":"RENDICION DE CUENTAS","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 1 - FERRARI, MARIA ALICIA Y OTRO c/ LEVINAS, GABRIEL ISAIAS s/RENDICION DE CUENTAS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"78500. "},"recurso":{"id":5620596,"expediente":{"id":33715789,"numeroExpediente":78500,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":648,"descripc