[{"codigo":8241123,"analisisDocumental":{"id":824112,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 2 - CONS AV ELCANO 3401/13 ESQ GRAL E MARTINEZ c/ DI CARLO, GUSTAVO JORGE s/BENEFICIO DE LITIGAR SIN GASTOS","inconstitucional":false,"falloDestacado":{"id":10361,"titulo":"Beneficio de litigar sin gastos: imposibilidad de demostrar la concurrencia de los requisitos para obtenerlo","cabecilla":"<p style=\"text-indent:2em\">Un abogado en causa propia solicitó el beneficio de litigar sin gastos con el objeto de resultar exento del depósito previo exigido por el artículo 286 del Código Procesal Civil y Comercial de la Nación en virtud del recurso de queja que promovió en el marco de un expediente principal en trámite ante la Corte. La cámara desestimó el pedido alegando que no se encontraba comprometido el derecho al acceso a la jurisdicción sino, únicamente, la posibilidad de acceder al Tribunal y que dicho recurso de queja no revestía suficiente verosimilitud en el derecho dado que los agravios remitían a cuestiones de hecho y derecho común, ajenas a la instancia extraordinaria.</p><p style=\"text-indent:2em\">La Corte descalificó esta sentencia en los términos de la doctrina sobre arbitrariedad de sentencias.</p><p style=\"text-indent:2em\">Señaló que el rechazo in limine del beneficio obligaría al peticionante a hacerse cargo del pago del depósito sin que en las instancias pertinentes se le hubiera permitido demostrar si concurren los requisitos necesarios para obtener el beneficio solicitado a fin de eximirse de esa obligación instando su trámite.</p><p style=\"text-indent:2em\">Tuvo en cuenta que lo decidido desatendió la finalidad de dicho instituto desde que el asunto se dirimió examinando requisitos que son ajenos a la procedencia del beneficio, como lo son los recaudos formales y sustanciales que hacen a la procedencia de los recursos interpuestos ante la Corte.</p>","esNovedad":true,"fecha":1773284400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1773751039995,"usuarioCreacion":4,"fechaCreacion":1773344968829,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":153700,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":39168858,"numeroExpediente":47529,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":573,"descripcion":"EJECUCION DE EXPENSAS","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 1 - Incidente Nº