[{"codigo":7984805,"analisisDocumental":{"id":798480,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"VALLE, OSCAR CELESTINO c/ SUAREZ, PASCUALA Y OTROS s/SUMARISIMO","inconstitucional":false,"falloDestacado":{"id":7101,"titulo":"Omisión de pronunciamiento sobre derechos que se fundaron en normas de carácter federal","cabecilla":"<p style=\"text-indent:2em\">En el marco de un interdicto de recobrar se resolvió suspender el proceso por aplicación de lo dispuesto por la ley 2222 de la Provincia de La Pampa, que disponía la suspensión por un año de los juicios de desalojo de inmuebles rurales siempre que tales terrenos fuesen ocupados por indígenas u originarios o sus descendientes. </p><p style=\"text-indent:2em\">La actora interpuso un recurso donde planteó que la ley mencionada, sus prórrogas y la interpretación que de ella se había realizado eran incompatibles con la ley nacional 26.160 y con los principios y reglas constitucionales que protegen el derecho de propiedad y el debido proceso y cuestionó la procedencia de extender los beneficios de la misma a los denominados “puesteros del Oeste”.</p><p style=\"text-indent:2em\">El superior tribunal local desestimó este recurso, lo que originó la interposición de un recurso ante la Corte, que dejó sin efecto el pronunciamiento apelado. </p><p style=\"text-indent:2em\">Consideró el Tribunal que se había incurrido en un excesivo rigor formal en la valoración de los requisitos de admisibilidad del recurso local, incompatible con el adecuado servicio de justicia y con la exigencia de fundamentación adecuada, lo que se presentaba, en definitiva, como una desestimación arbitraria de los agravios constitucionales invocados.</p><p style=\"text-indent:2em\">Señaló además que la cuestión federal había sido introducida de manera adecuada en el proceso y mantenida en las distintas presentaciones posteriores, oportunidades en que la actora había dado argumentos suficientes para sustentarla en términos que obstaban a su falta de tratamiento.</p>","esNovedad":true,"fecha":1719889200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1720029707931,"usuarioCreacion":11,"fechaCreacion":1719943770018,"privado":false,"posicion":10,"resumen":null},"reciboEntrada":{"id":122599,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34633519,"numeroExpediente":238,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratul