[{"codigo":7941704,"analisisDocumental":{"id":794170,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"COOPERATIVA FARMACEUTICA DE PROVISION Y CONSUMO ALBERDI LTDA c/ PROVINCIA DEL CHACO s/AMPARO","inconstitucional":false,"falloDestacado":{"id":6581,"titulo":"Requisito de propósito de lucro para definir el hecho imponible del impuesto sobre los ingresos brutos","cabecilla":"<p style=\"text-indent:2em\">Una cooperativa promovió amparo a fin de obtener la declaración de inconstitucionalidad del art. 116 del Código Tributario del Chaco y la nulidad de las resoluciones administrativas por las que se había determinado una deuda en concepto de impuesto sobre los ingresos brutos por la actividad sin fines de lucro desarrollada. El planteo fue rechazado en las instancias provinciales. </p><p style=\"text-indent:2em\"><b>La Corte revocó el pronunciamiento</b>.</p><p style=\"text-indent:2em\">Sostuvo en primer lugar que la decisión volvía inoperante la solución normativa prevista en la ley de coparticipación federal de impuestos vigente y que iba en desmedro del propósito de homogeneidad normativa perseguido por la ley mencionada.</p><p style=\"text-indent:2em\">Finalmente, afirmó que interpretación de la sentencia recurrida que permitía gravar con el impuesto sobre los ingresos brutos a toda otra actividad habitual onerosa, aunque sea realizada sin propósito de lucro, tornaba superflua y carente de toda operatividad a la expresión “con fines de lucro” empleada por el artículo 9°, inciso b), punto. I, de la ley 23.548.</p>","esNovedad":true,"fecha":1710817200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1710960184149,"usuarioCreacion":11,"fechaCreacion":1710878686661,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":118002,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33825427,"numeroExpediente":1490,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9482,"descripcion":"AMPARO","idMateria":4,"tema":{"id":502,"codigo":"AMPAROS"}},"caratula":"COOPERATIVA FARMACEUTICA DE PROVISION Y CONSUMO ALBERDI LTDA c/ PROVINCIA DEL CHACO s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1490. "},"recurso":{"id":5641363,"expediente":{"id":33825427,"numeroExpediente":1490,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","