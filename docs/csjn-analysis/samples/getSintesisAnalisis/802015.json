[{"codigo":8020154,"analisisDocumental":{"id":802015,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"EN-CONICET (EXPTE 7334/98) Y OTRO c/ ANDEREGGEN IGNACIO EUGENIO Y OTRO s/PROCESO DE CONOCIMIENTO","inconstitucional":true,"falloDestacado":{"id":7725,"titulo":"Incompatibilidad entre la carrera de investigador y la docencia:  reglamentación irrazonable de la ley 20.464","cabecilla":"<p style=\"text-indent: 2em;\">La cámara rechazó la demanda articulada por un investigador contra el CONICET y el Ministerio de Educación e hizo lugar a la acción que inició dicho ente, condenando al investigador a restituir las remuneraciones que había percibido indebidamente. Se basó para ello en que el sueldo que percibía como docente en la mencionada universidad privada era mayor al que correspondía a un profesor titular con dedicación simple de una universidad nacional (computando la antigüedad), con fundamento en el decreto 1572/76, que entendió que armonizaba con la ley 20.464.</p><p style=\"text-indent: 2em;\">La Corte revocó la sentencia y <b>declaró la inconstitucionalidad del segundo párrafo, del punto 13, anexo I, del decreto 1572/76 (texto según decreto 429/1987)</b>, por afectar el derecho a una retribución justa, reconocido en el art. 18, inciso c, de la ley 20.464 y, principalmente, en el art. 14 bis de la Constitución Nacional.</p><p style=\"text-indent: 2em;\">Señaló que en el diseño de la ley mencionada no existe una tajante y abrupta división e incompatibilidad entre la actividad de investigación y la docencia universitaria; antes bien, la ley las entiende relacionadas.</p><p style=\"text-indent: 2em;\">Afirmó que no se logró establecer de qué modo la mera diferencia salarial entre una universidad nacional y, por caso, una privada puede derivar, <em>per se</em>, en una afectación a la “dedicación exclusiva”.</p><p style=\"text-indent: 2em;\">El Tribunal agregó que la inconstitucionalidad del reglamento impugnado se agudiza si se considera que el investigador, en varios períodos, no percibiría ningún tipo de retribución por su labor en el CONICET, a pesar de que no se le formuló cargo alguno respecto al cumplimiento de sus tareas.</p>","esNovedad":true,"fecha":1728961200000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1729030279220,"usuarioCreacion":11,"fechaCreacion":1729030277010,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":128579,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":10884572,"numeroExpediente":19791,"anioExpediente":2006,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso 