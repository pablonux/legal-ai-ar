[{"codigo":7718992,"analisisDocumental":{"id":771899,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"GCBA c/ DIRECTAMOINT S.A. s/CONCURSO PREVENTIVO","alias":null,"caratula":"Recurso Queja Nº 1 - GCBA c/ DIRECTAMOINT S.A. s/CONCURSO PREVENTIVO","inconstitucional":false,"falloDestacado":{"id":3302,"titulo":"Régimen y procedimiento de la determinación impositiva","cabecilla":"<p>En un concurso preventivo se acogi&oacute; la verificaci&oacute;n de un cr&eacute;dito fiscal del Gobierno de la Ciudad conforme a un monto resultante de la prueba contable producida en el expediente, a pesar de lo decidido en el tr&aacute;mite administrativo previo pues, a criterio de la c&aacute;mara, la circunstancia de haberse decidido en sede administrativa la aplicaci&oacute;n de la al&iacute;cuota no obstaba su revisi&oacute;n. Contra esta decisi&oacute;n recurri&oacute; el acreedor argumentando que la alzada se hab&iacute;a arrogado competencia para revisar lo actuado en sede administrativa.&nbsp;<strong>La Corte acogi&oacute; el reclamo y dej&oacute; sin efecto la sentencia</strong>. En este sentido, afirm&oacute; el Tribunal, de modo concordante con la doctrina de&nbsp;<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoSumario.html?idDocumentoSumario=48\">Fallos: 310:719</a>, atribuir al fuero concursal facultades de revisi&oacute;n de la validez intr&iacute;nseca del t&iacute;tulo invocado en sustento del cr&eacute;dito importa tanto como prescindir inmotivadamente de las disposiciones del C&oacute;digo Fiscal y del C&oacute;digo Contencioso Administrativo y Tributario de la Ciudad de Buenos Aires, que constituyen la regulaci&oacute;n procesal espec&iacute;fica y en los que se prev&eacute;n las v&iacute;as impugnatorias que el contribuyente tiene a su alcance para cuestionar los actos determinativos y plazos para ejercerlas, vencidos los cuales, adquieren firmeza.&nbsp;En otras palabras, seg&uacute;n la Corte, la posici&oacute;n adoptada por la c&aacute;mara constituye el reemplazo del procedimiento de impugnaci&oacute;n previsto legislativamente, sin fundamentaci&oacute;n que lo sustente, supliendo de esa manera la inactividad o falta de diligencia de los interesados.</p>","esNovedad":true,"fecha":1639623600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1640001150738,"usuarioCreacion":11,"fechaCreacion":1639684179366,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":32897,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30054667,"numeroExpediente":1518,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Ape