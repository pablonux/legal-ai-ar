[{"codigo":8044945,"analisisDocumental":{"id":804494,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - PANCHITA G DE NAVEGACION SA c/ SECRETARIA DE TRANSPORTE SUBSECRETARIA DE TRANSPORTE AEROCOMERCIAL FLUVIAL Y MARITIMO Y OTRO s/ACCION MERAMENTE DECLARATIVA","inconstitucional":false,"falloDestacado":{"id":8006,"titulo":"Derecho de la navegación: embarcaciones extranjeras y normas sobre comercio de cabotaje","cabecilla":"<p style=\"text-indent:2em\">Una empresa de nacionalidad paraguaya que efectúa transporte inició una acción a raíz de una decisión de la autoridad marítima que le impidió la maniobra de una barcaza y de su remolcador -también de su propiedad y de origen paraguayo-, por infringir las normas restrictivas sobre comercio de cabotaje.</p><p style=\"text-indent:2em\">La cámara consideró que resultaba comprendido por las limitaciones fijadas para el cabotaje el remolque maniobra y el transporte cuando una o más barcazas son trasladadas desde uno a otro punto cualquiera de nuestras aguas jurisdiccionales para luego o antes ser remolcadas por otro navío hacia o desde un puerto extranjero y que la norma establece que el cabotaje nacional será únicamente practicado por barcos argentinos, con el propósito de fomentar y estimular el armamento nacional.</p><p style=\"text-indent:2em\">La Corte, por mayoría, dejó sin efecto este pronunciamiento.</p><p style=\"text-indent:2em\">Señaló que el traslado que efectuó la empresa actora de una barcaza vacía de su propiedad (a raíz de un desmembramiento provocado por dificultades en la navegación), desde el Puerto de Ramallo al Puerto de San Nicolás -donde iba a ser cargada con rumbo a la República del Paraguay-, no puede ser considerado como comercio de cabotaje reservada a los buques nacionales ya que no medió tráfico de carga o pasajeros, sino que dicha operatoria forma parte del comercio internacional y, consecuentemente, amparado por la libertad constitucional (art. 26 de la Constitución Nacional) y por el Acuerdo de Transporte Fluvial por la Hidrovía Paraguay-Paraná (arts. 6º y 11, primer párrafo).</p><p style=\"text-indent:2em\">Expresó que lo que la ley restringe a los barcos extranjeros es la comunicación y el comercio entre puertos argentinos y no las operaciones propias del remolque necesarias para el transporte internacional, llevadas a cabo por embarcaciones de una misma empresa, supuesto en el que la navegación de los ríos interiores, al no estar alcanzada por el régimen legal vigente de cabotaje nacional, es libre para todas las banderas.</p><p style=\"text-indent:2em\">Afirmó que la cámara hizo eco de las motivaciones que condujeron al legislador en el siglo pasado a fomentar y estimular el armamento nacional pero omitiendo examinar el tipo de transporte utilizado, la mecánica que tal medio emplea y la significación económica de dicho transporte para el comercio e integración regional en el actual contexto, marcada por el Acuerdo de Transporte mencionado.</p>","esNovedad":true,"fecha":1733367600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1733745213687,"usuarioCreacion":4,"fechaCreacion":1733488581166,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":131241,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32734821,"numeroExpediente":8275,"anioExpediente":1999,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":3,"codigo":"3","abreviatura":"CCF","descripcion":"Cámara Nacional de Apelaciones en lo Civil y Comercial Federal","estado":0,"descripcionLarga":"CCF - Cámara Nacional de Apelaciones en lo Civil y Comercial Federal"},"objetoJuicio":{"id":1221,"descripcion":"ACCION MERAMENTE DECLARATIVA","idMateria":3,"tema":{"id":450,"codigo":"OTROS"}},"caratula":"Recurso Queja Nº 1 - PANCHITA G DE NAVEGACION SA c/ SECRETARIA DE TRANSPORTE SUBSECRETARIA DE TRANSPORTE AEROCOMERCIAL FLUVIAL Y MARITIMO Y OTRO s/ACCION MERAMENTE DECLARATIVA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"8275. "},"recurso":{"id":5456555,"expediente":{"id":32734821,"numeroExpediente":8275,"anioExpediente":1999,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":3,"codigo":"3","abreviatura":"CCF","descripcion":"Cámara Nacional de Apelaciones en lo Civil y Comercial Federal","estado":0,"descripcionLarga":"CCF - Cámara Nacional de Apelaciones en lo Civil y Comercial Federal"},"objetoJuicio":{"id":1221,"descripcion":"ACCION MERAMENTE DECLARATIVA","idMateria":3,"tema":{"id":450,"codigo":"OTROS"}},"caratula":"Recurso Queja Nº 1 - PANCHITA G DE NAVEGACION SA c/ SECRETARIA DE TRANSPORTE SUBSECRETARIA DE TRANSPORTE AEROCOMERCIAL FLUVIAL Y MARITIMO 