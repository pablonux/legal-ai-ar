[{"codigo":7744304,"analisisDocumental":{"id":774430,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"CASTELLI, NESTOR RUBEN Y OTROS s/INCIDENTE DE RECURSO EXTRAORDINARIO","alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - IMPUTADO: CASTELLI, NESTOR RUBEN Y OTROS s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":3903,"titulo":"Cómputo de la pena ante la existencia de distintas causas","cabecilla":"<p>La c&aacute;mara no hizo lugar al recurso del fiscal y consider&oacute; correcta la decisi&oacute;n de tener en cuenta, para efectuar el c&oacute;mputo de la pena, el tiempo en que los condenados estuvieron privados cautelarmente de su libertad en otras causas en las que a&uacute;n no se hab&iacute;a dictado sentencia. Ante esto, el fiscal interpuso un recurso extraordinario y la Corte dej&oacute; sin efecto el pronunciamiento apelado por considerar que carec&iacute;a de fundamento v&aacute;lido. Sostuvo que&nbsp;el tiempo de detenci&oacute;n cautelar que los condenados en una causa transcurrieron en otro proceso s&oacute;lo puede ser tenido en cuenta para determinar la pena que les corresponde si est&aacute;n dados los requisitos de la unificaci&oacute;n de condenas pero que si el legislador hubiera querido que al determinarse la pena en concreto tambi&eacute;n se considerase el tiempo que los condenados en una causa estuvieron encarcelados preventivamente en otra as&iacute; lo habr&iacute;a establecido. Record&oacute; el Tribunal que no cabe suponer la inconsecuencia ni la falta de previsi&oacute;n del legislador</p>","esNovedad":true,"fecha":1651546800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1651681011434,"usuarioCreacion":11,"fechaCreacion":1651609049615,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":33748,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34081300,"numeroExpediente":83000804,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":17,"codigo":"17","abreviatura":"FGR","descripcion":"Justicia Federal de General Roca","estado":0,"descripcionLarga":"FGR - Justicia Federal de General Roca"},"objetoJuicio":{"id":2101,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - IMPUTADO: CASTELLI, NESTOR RUBEN Y OTROS s/INCIDENTE DE RECURSO EXTRAORDINARIO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"83000804. "},"recurso":{"id":5686764