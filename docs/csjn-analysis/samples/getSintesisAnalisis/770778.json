[{"codigo":7707784,"analisisDocumental":{"id":770778,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"CAÑUELAS GAS S.A. c/ BUENOS AIRES, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","alias":null,"caratula":"CAÑUELAS GAS S.A. c/ BUENOS AIRES, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","inconstitucional":false,"falloDestacado":{"id":3041,"titulo":"Incompetencia originaria de la Corte ante planteos que exigen interpretar normas locales","cabecilla":"<p>Una empresa promovi&oacute;,&nbsp;ante la Corte, una acci&oacute;n de inconstitucionalidad contra la Provincia de Buenos Aires con el objeto de hacer cesar el estado de incertidumbre en el que se encontrar&iacute;a como consecuencia de la pretensi&oacute;n de la demandada de gravar con el impuesto sobre los ingresos brutos los ingresos obtenidos por reintegros provenientes del &quot;Programa Nacional de Consumo Residencial de Gas Licuado de Petr&oacute;leo (GLP) Envasado&quot;.&nbsp;&nbsp;<strong>El Tribunal&nbsp;consider&oacute; que la causa resultaba ajena a su competencia originaria.</strong> Record&oacute; que la apertura de la jurisdicci&oacute;n originaria en raz&oacute;n de la materia solo procede cuando la acci&oacute;n entablada se funda directa y exclusivamente en prescripciones constitucionales de car&aacute;cter nacional, leyes del Congreso, o tratados, de tal suerte que la cuesti&oacute;n federal sea la predominante en la causa y que por ende quedan excluidos de dicha instancia aquellos procesos en los que se planteen cuestiones de &iacute;ndole local que traigan aparejada la necesidad de hacer m&eacute;rito de estas o que requieran para su soluci&oacute;n la aplicaci&oacute;n de normas de esa naturaleza o el examen o revisi&oacute;n en sentido estricto de actos administrativos de las autoridades provinciales, legislativos o judiciales de car&aacute;cter local. En este sentido, tuvo en cuenta que el planteo efectuado exig&iacute;a, de manera ineludible, interpretar y establecer el alcance del art&iacute;culo 188, inciso d, del C&oacute;digo Fiscal de la Provincia de Buenos Aires (texto ordenado 2018) en tanto la propia actora hab&iacute;a reconocido que la citada disposici&oacute;n excluye de la base imponible para determinar el impuesto cuestionado los ingresos provenientes de subsidios concedidos por el Estado Nacional y que&nbsp; ARBA pretende gravar. Concluy&oacute; el Tribunal que frente a procesos que se pretenden radicar ante su jurisdicci&oacute;n originaria en los cuales se sostiene que la norma es violatoria de las instituciones provinciales y nacionales debe irse primeramente ante los estrados de la justicia provincial y, en su caso, llegar a la Corte por el recurso extraordinario.</p>","esNovedad":true,"fecha":1635994800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1636136105447,"usuarioCreacion":11,"fechaCreacion":1636111375280,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":32525,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaEx