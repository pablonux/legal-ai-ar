entregue copia del contrato de cesi&oacute;n de derechos y los libretos de la serie que se estar&iacute;a filmando. El planteo origin&oacute; un conflicto entre un juzgado nacional en lo civil y un juzgado provincial donde tramita la sucesi&oacute;n de quien motivaba la serie, que fue resuelto por la Corte en favor de este &uacute;ltimo. Tuvo en cuenta que en las medidas preliminares resulta competente el juez que deba conocer en el proceso principal y se&ntilde;al&oacute; que la actora, al iniciar la acci&oacute;n,&nbsp; indic&oacute; los nombres de las futuras partes contrarias en el proceso principal entre los que incluy&oacute; a quien falleciera durante el tr&aacute;mite, por lo que resultaba operativo el fuero de atracci&oacute;n del juicio universal.&nbsp;</p>","esNovedad":true,"fecha":1656990000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1657050920731,"usuarioCreacion":11,"fechaCreacion":1657047907331,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":34361,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34362299,"numeroExpediente":12650,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":23,"codigo":"23","abreviatura":"FRE","descripcion":"Justicia Federal de Resistencia","estado":0,"descripcionLarga":"FRE - Justicia Federal de Resistencia"},"objetoJuicio":{"id":9027,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":112,"tema":{"id":422,"codigo":"DAÑOS"}},"caratula":"WINGEYER, CARLOS ERICO c/ AIME, OSCAR REINALDO Y OTROS s/DAÑOS Y PERJUICIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"12650. "},"recurso":{"id":5946988,"expediente":{"id":34362299,"numeroExpediente":12650,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"c