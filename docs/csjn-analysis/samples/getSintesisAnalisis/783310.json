[{"codigo":7833104,"analisisDocumental":{"id":783310,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"D., H.C. Y OTROS s/GUARDA CON FINES DE ADOPCION-DECLARACION DE ADOPTABILIDAD","inconstitucional":false,"falloDestacado":{"id":5301,"titulo":"Declaración de adoptabilidad","cabecilla":"<p>En el marco de un proceso de declaración de adoptabilidad y guarda con fines de adopción, la cámara confirmó el rechazo in limine de la demanda deducida por la madre biológica y el matrimonio guardador de una niña, con quienes convive desde su nacimiento en el año 2016. Recurrida en queja la cuestión, la Corte declaró admisible el recurso extraordinario y dejó sin efecto la sentencia. Para decidir de esa manera, consideró que los niños tienen derecho a una protección especial cuya tutela debe prevalecer, de modo que, ante un conflicto de intereses de igual rango, el interés moral y material de los infantes debe tener prioridad por sobre cualquier otra circunstancia que pueda presentarse en el proceso. En ese orden, señaló el Tribunal que de las audiencias habidas, surge que la niña considera al matrimonio guardador como sus padres; que la madre biológica se encuentra en la ciudad de San Pablo, Brasil y ratificó su decisión de dar en adopción a su hija y que se quede en Santiago del Estero con el matrimonio guardador, y que la abuela materna no tenía conocimiento de la existencia de su nieta y señaló no estar en condiciones económicas de hacerse cargo de ella. Por lo tanto, consideró que una apreciación conjunta de estas cuestiones, ponderadas a la luz del principio del interés superior, conducía a propiciar la continuación del trámite del proceso a fin de que, oportunamente y adoptando los recaudos que devienen imprescindibles en estos supuestos, se adopte una decisión que permita disipar de manera definitiva la incertidumbre sobre la situación familiar que en la actualidad pesa sobre la infante, de modo de tornar efectivo su derecho a crecer en el seno de una familia.</p>","esNovedad":true,"fecha":1681959600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1682087886826,"usuarioCreacion":4,"fechaCreacion":1682021973428,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":108418,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33953615,"numeroExpediente":1645,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"D., H.C. Y OTROS s/GUARDA CON