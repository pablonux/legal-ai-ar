[{"codigo":7975394,"analisisDocumental":{"id":797539,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GARAY, DIEGO SEBASTIAN c/ PROVINCIA DE MENDOZA s/AMPARO","inconstitucional":false,"falloDestacado":{"id":7104,"titulo":"La obligación del uso del cinturón de seguridad no viola el derecho a la autonomía personal","cabecilla":"<p style=\"text-indent:2em\">A raíz de la infracción que le fue impuesta por no usar el cinturón de seguridad mientras conducía un automóvil el actor planteó la inconstitucionalidad de ciertos artículos de la ley 6082 de tránsito de la Provincia de Mendoza, que establecían su uso obligatorio. Planteó que la infracción vial resulta inconstitucional porque su conducta constituye una acción privada amparada por el artículo 19 de la Constitución Nacional.</p><p style=\"text-indent:2em\">El superior tribunal provincial rechazó el planteo y la Corte confirmó este pronunciamiento.</p><p style=\"text-indent:2em\"><em>Consideró que la obligación del uso del cinturón de seguridad en la vía pública no resulta una interferencia indebida en la autonomía individual, pues lo que procura es la prevención de un riesgo cierto de daño a terceros, que es una de las hipótesis previstas por el mencionado artículo 19 para habilitar la intervención estatal y la jurisdicción de los magistrados</em>.</p><p style=\"text-indent:2em\">Señaló que en el caso de la conducción con -al menos- un pasajero adicional, el recurrente no refuta que la falta de correajes de seguridad por parte de alguno de ellos pone en mayor riesgo a los demás ocupantes del vehículo o, incluso, si fuera un riesgo consentido entre los ocupantes adultos, o si se tratara de un conductor solitario lo cierto es que la falta de correajes de seguridad genera el riesgo de dañar a los terceros fuera del vehículo que forman parte del sistema de circulación vial.</p><p style=\"text-indent:2em\">Agregó que el uso obligatorio del cinturón procura asegurar al conductor al comando de control del automóvil a fin de que ante un accidente se disminuya el riesgo de que el vehículo continúe desplazándose -pero sin control- y produzca mayores daños a los terceros que circulan en la vía pública.</p><p style=\"text-indent:2em\">Además, expresó que no se puede soslayar la relación entre la regulación vial y el rol de garante de la salud pública del Estado argentino. En ese sentido, el riesgo de graves daños que se puedan ocasionar entre sí diferentes personas en el tránsito, por una colisión o impacto a una velocidad superior a la propiamente pedestre, justifica el interés estatal de preservar la salud pública.</p><p style=\"text-indent:2em\">Por último, tuvo en cuenta que desde una perspectiva sistémica de la crítica situación vial, la Organización Mundial de la Salud también resaltó los costos económicos que tales accidentes cargan en el sistema de salud, máxime cuando, como en el nuestro, parte de ese sistema se sostiene por la comunidad de contribuyentes.</p>","esNovedad":true,"fecha":1719889200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1720029614391,"usuarioCreacion":11,"fechaCreacion":1719946417242,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":121679,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30013938,"numeroExpediente":972,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":1226,"descripcion":"AMPARO","idMateria":3,"tema":{"id":460,"codigo":"AMPAROS"}},"caratula":"GARAY, DIEGO SEBASTIAN c/ PROVINCIA DE MENDOZA s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"972. "},"recurso":{"id":5104050,"expediente":{"id":30013938,"numeroExpediente":972,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":1226,"descripcion":"AMPARO","idMateria":3,"tema":{"id":460,"codigo":"AMPAROS"}},"caratula":"GARAY, DIEGO SEBASTIAN c/ PROVINCIA DE MENDOZA s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"972. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CSJ 000972/2017/RH001","identificacionExpediente":"CSJ 000972/2017/RH001"},"piezas":2,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":9,"nombreUsuario":"27203847888","apell