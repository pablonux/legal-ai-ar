[{"codigo":8003212,"analisisDocumental":{"id":800321,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"V, V c/ MUTUAL FEDERADA 25 DE JUNIO -FEDERADA SALUD- s/PRESTACIONES MEDICAS","inconstitucional":false,"falloDestacado":{"id":7541,"titulo":"Afirmaciones dogmáticas al rechazar la cobertura de prestaciones para un niño con discapacidad","cabecilla":"<p style=\"text-indent:2em\">La cámara rechazó la acción de amparo iniciada por la madre de un niño con discapacidad en reclamo de la cobertura de la escuela especial y del acompañamiento terapéutico extraescolar. Argumentó para ello que no se hallaba justificada la inasistencia de la actora a la evaluación del equipo interdisciplinario convocada por la mutual para determinar cuál era la necesidad prestacional del niño.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia por considerarla arbitraria.</p><p style=\"text-indent:2em\">Expresó que se había sustentado en un tramo de la resolución en donde se hallaba prevista dicha evaluación en lugar de efectuar un examen integral del dispositivo normativo, que también determinaba que -dado el aislamiento social dispuesto con motivo de la pandemia por Covid 19- en los casos en los que existiese la necesidad de modificación o inicio de nuevas prestaciones, la documentación necesaria para ello debería ser enviada al agente del seguro de salud por medios digitales.</p><p style=\"text-indent:2em\">Resaltó además que no constituía un dato menor que para la fecha de la entrevista fijada regía aun dicho aislamiento social, preventivo y obligatorio.</p>","esNovedad":true,"fecha":1725937200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1726080230450,"usuarioCreacion":4,"fechaCreacion":1725994342627,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":126183,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35095064,"numeroExpediente":10406,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":13,"codigo":"13","abreviatura":"FBB","descripcion":"Justicia Federal de Bahia Blanca","estado":0,"descripcionLarga":"FBB - Justicia Federal de Bahia Blanca"},"objetoJuicio":{"id":3467,"descripcion":"PRESTACIONES MEDICAS","idMateria":112,"tema":{"id":200,"codigo":"AMPAROS"}},"caratula":"V, V c/ MUTUAL FEDERADA 25 DE JUNIO -FEDERADA SALUD- s/PRESTACIONES MEDICAS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10406. "},"recurso":{"id":6183420,"expediente":{"id":35095064,"numeroExpediente":10406,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":13,"codigo":"13","abreviatura":"FBB","descripcion":"Justicia F