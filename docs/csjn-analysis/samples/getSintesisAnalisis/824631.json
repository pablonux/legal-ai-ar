[{"codigo":8246313,"analisisDocumental":{"id":824631,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":24,"codigoRelacion":80024,"valor":"DECLARA NULIDAD","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201011041306,"fechaModLong":201011041306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - BUTTERA SERGIO HUMBERTO c/ TELECOM ARGENTINA S.A. Y OTROS s/DIFERENCIAS DE SALARIOS","inconstitucional":false,"falloDestacado":{"id":10441,"titulo":"Traslado del recurso extraordinario y debido proceso","cabecilla":"<p style=\"text-indent:2em\">En el marco de una condena por los daños y perjuicios derivados de la falta de emisión de bonos de participación en las ganancias previstos en el artículo 29 de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-23696-98/actualizacion\">ley 23.696</a> la cámara rechazó los agravios del Estado Nacional referidos a los intereses aplicables, lo que motivó la deducción de un recurso extraordinario, cuya denegación originó la correspondiente queja.</p><p style=\"text-indent:2em\">La Corte declaró la nulidad del auto denegatorio.</p><p style=\"text-indent:2em\">Señaló que del cotejo de las actuaciones principales se advertía que dicho remedio había sido denegado sin haberse dado cumplimiento previamente al traslado previsto en el artículo 257 del Código Procesal Civil y Comercial de la Nación respecto de la empresa demandada y que dicho traslado era necesario teniendo en cuenta que las demandadas fueron condenadas solidariamente al pago de las sumas reclamadas. Efectivamente, una eventual decisión favorable a la pretensión del Estado Nacional respecto de la aplicación de las normas sobre consolidación podría tener relevancia en el marco de la ejecución de la sentencia dictada, así como en una eventual ulterior acción de repetición por parte de la codemandada.</p><p style=\"text-indent:2em\">Recordó el Tribunal que el traslado del recurso extraordinario federal tiene por objeto proporcionar a los litigantes la oportunidad de ejercer sus defensas con la amplitud que exige el debido proceso y plantear las cuestiones que sean conducentes para la correcta solución de la causa.</p>","esNovedad":true,"fecha":1774494000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1774555425759,"usuarioCreacion":11,"fechaCreacion":1774550731279,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":154498,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35744770,"numeroExpediente":23071,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9722,"descripcion":"DIFERENCIAS DE SALARIOS","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - BUTTE