[{"codigo":7937543,"analisisDocumental":{"id":793754,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":80005,"valor":"RECHAZA LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008181305,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Caja Complementaria de Previsión para la Actividad Docente c/ Misiones, Provincia de s/acción declarativa de inconstitucionalidad","inconstitucional":false,"falloDestacado":{"id":9322,"titulo":"Acción declarativa de inconstitucionalidad y ausencia de conflicto cierto y actual de intereses","cabecilla":"<p style=\"text-indent:2em\">La Caja Complementaria de Previsión para la Actividad Docente promovió una acción declarativa contra la Provincia de Misiones, a fin de que se declare la inconstitucionalidad de los artículos 1° y 2° de la ley provincial XIX 58, así como de cualquier otra norma, resolución o circular, dictada en su consecuencia.</p><p style=\"text-indent:2em\">La Corte, que en un pronunciamiento anterior había declarado su competencia originaria para entender en la causa, rechazó esta demanda.</p><p style=\"text-indent:2em\">Recordó en primer lugar que la lesión que debe estar presente al promoverse una acción declarativa de inconstitucionalidad es aquella que se ha concretizado en un acto administrativo dirigido contra los intereses legítimos de la parte actora de modo directo e inmediato.</p><p style=\"text-indent:2em\">Tuvo en cuenta que la demandante, si bien había invocado posibles conflictos normativos entre la ley provincial y las normas nacionales, no había probado que al momento de iniciarse la demanda existiera algún acto de autoridad competente que hubiera aplicado la ley con lesión de sus derechos o intereses ni había demostrado que esa lesión sea un efecto directo de la ley impugnada. Señaló que la demanda declarativa fue iniciada el 3 de diciembre de 2013, antes de que la ley XIX 58 entrara en vigencia, lo que recién sucedió con la publicación del decreto 19 del 15 de enero de 2014.</p><p style=\"text-indent:2em\">Concluyó así el Tribunal que la discusión entre las partes no se refería a un conflicto cierto y actual de intereses, sino a un conflicto hipotético que podría tener lugar si autoridades de la provincia demandada adoptasen una interpretación de la norma cuestionada como la temida por la actora, lo cual no fue siquiera alegado, mucho menos probado, por ella.</p>","esNovedad":true,"fecha":1756782000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1756917220661,"usuarioCreacion":11,"fechaCreacion":1756840450861,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":117625,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23315802,"numeroExpediente":1525,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"C","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"Caja Complementa