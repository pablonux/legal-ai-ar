[{"codigo":7964343,"analisisDocumental":{"id":796434,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"G., A.J. c/ J., M.A. s/CUIDADO PERSONAL DE LOS HIJOS","inconstitucional":false,"falloDestacado":{"id":6824,"titulo":"Interés superior del niño: inconveniencia de mantener una medida cautelar que prohibía la alteración de su domicilio","cabecilla":"<p style=\"text-indent:2em\">En el marco de una demanda de cuidado personal el superior tribunal provincial mantuvo la decisión cautelar que había prohibido a ambos progenitores alterar el domicilio del niño sin la conformidad del otro o autorización judicial en su defecto.</p><p style=\"text-indent:2em\">Ante el recurso de la madre la Corte dejó sin efecto esta decisión. </p><p style=\"text-indent:2em\">Consideró que las circunstancias del caso exigían una nueva ponderación de las razones que inicialmente habían sustentado la medida provisional de modo de verificar si dicha medida importa hoy una solución que priorice los intereses del sujeto que cuenta con preferente tutela y sobre quien, en definitiva, recaen principalmente las consecuencias derivadas del ejercicio de la responsabilidad parental. </p><p style=\"text-indent:2em\">Señaló que confirmar la decisión de mantener una orden cautelar de prohibición de cambio de domicilio del niño dictada hace siete años sin que, a estar a las constancias de la causa, se hubiese resuelto de manera definitiva el modo en que los progenitores deberán ejercer la responsabilidad parental, no se presenta como una decisión razonada del derecho vigente ni resulta contemplativa del interés superior del niño que debe primar en el proceso de toma de decisiones que lo afecten.</p><p style=\"text-indent:2em\">Concluyó que una apreciación del asunto, bajo el prisma del interés superior del niño, advierte sobre la inconveniencia de mantener una decisión que no prioriza al infante y, en definitiva, examina dicho interés solo desde la perspectiva del derecho de los progenitores. </p><p style=\"text-indent:2em\">Finalmente, dada la alta conflictividad que se advirtió entre las partes y la importancia que el factor tiempo tiene en estos asuntos, la Corte estimó conveniente encomendar a los progenitores que obren con la premura y mesura que el caso amerita en la resolución definitiva de la controversia, profundizando sus esfuerzos para lograr soluciones respetuosas de los derechos y la condición personal del niño. Por otro lado, exhortó a los magistrados que entienden en el conflicto a aunar sus máximos esfuerzos en vías de lograr una pronta finalización de la controversia de modo de garantizar a todas las partes involucradas una tutela judicial efectiva.</p>","esNovedad":true,"fecha":1715828400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1715968691795,"usuarioCreacion":11,"fechaCreacion":1715891577994,"privado":false,"posicion":8,"r