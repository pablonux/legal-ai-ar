[{"codigo":7967395,"analisisDocumental":{"id":796739,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"B., P. H. E. s/ abuso sexual -art. 119 1° párrafo y amenazas.","alias":null,"caratula":"BAUTISTA , PABLO HECTOR EZEQUIEL s/ABUSO SEXUAL - ART. 119  1° PARRAFO y AMENAZAS","inconstitucional":false,"falloDestacado":{"id":6842,"titulo":"El límite de edad al proceso penal de un menor","cabecilla":"<p style=\"text-indent:2em\">La jueza de menores no hizo lugar al pedido de sobreseimiento respecto de hechos que habrían ocurrido cuando el menor tenía catorce años (14) de edad.</p><p style=\"text-indent:2em\">Luego de sucesivos rechazos de impugnaciones de esta decisión el Ministerio Público dedujo recurso extraordinario federal. La Corte dejó sin efecto el pronunciamiento recurrido.</p><p style=\"text-indent:2em\">Consideró que el a quo omitió considerar los pronunciamientos dictados por la Corte en la materia que explican que, de acuerdo con normas nacionales, constitucionales e internacionales, el límite de edad impide la formación del proceso respecto del niño o la niña, y que constituye un presupuesto irrefutable que los menores comprendidos en esa franja etaria no pueden ser formalmente acusados.</p><p style=\"text-indent:2em\">Sostuvo el Tribunal que se había tomado otro camino, contrario al dispuesto en la Convención sobre los Derechos del Niño y la ley 22.278, al confirmar el impulso de la acción penal contra un menor de catorce años de edad y sostener que en el marco de la investigación para determinar la existencia del delito se imponía “ escuchar al niño”, en lugar de circunscribir la actuación a tomar conocimiento del menor, realizar nuevos informes conducentes al estudio de su personalidad y sus condiciones familiares y ambientales y, en su caso, disponer otras medidas ajenas al procedimiento judicial, en protección de sus derechos.</p>","esNovedad":true,"fecha":1715828400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1715968742321,"usuarioCreacion":11,"fechaCreacion":1715892048382,"privado":false,"posicion":9,"resumen":null},"reciboEntrada":{"id":120698,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34318390,"numeroExpediente":2552,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10579,"descripcion":"EX