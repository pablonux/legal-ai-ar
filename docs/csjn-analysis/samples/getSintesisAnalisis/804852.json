[{"codigo":8048524,"analisisDocumental":{"id":804852,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"TELECOM ARGENTINA SA (TF 70161445-I) c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","inconstitucional":false,"falloDestacado":{"id":8141,"titulo":"Sobre el cobro de dividendos y el impuesto a las ganancias","cabecilla":"<p style=\"text-indent:2em\">La AFIP determinó de oficio el impuesto a las ganancias de Telecom Argentina S.A. correspondiente al período fiscal 2012 y le aplicó una multa en los términos del art. 45 de la<a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-11683-18771/actualizacion\"> ley 11.683</a> (t.o. en 1998 y sus modificaciones).</p><p style=\"text-indent:2em\">El ajuste se basó en la impugnación de la deducción de ciertos gastos vinculados -directa o indirectamente- a la obtención de los dividendos pagados por Telecom Personal S.A en razón de no haber incluido la actora a dichas ganancias “no computables” en el prorrateo de gastos establecido en el artículo 80 de la ley de impuesto a las ganancias (t.o. 1997 y sus modificaciones).</p><p style=\"text-indent:2em\">Llegado el caso a la Corte la discusión giraba en torno a si los gastos asociados al cobro de dividendos resultan deducibles en el impuesto a las ganancias o si corresponde rechazar su deducción con fundamento en que las ganancias en concepto de dividendos generadas por tales acciones no son computables por sus beneficiarios para la determinación de su ganancia neta.</p><p style=\"text-indent:2em\">La Corte confirmó la sentencia apelada que sostuvo que los dividendos derivan de renta alcanzada por el impuesto a las ganancias en cabeza de la sociedad que los distribuye y constituyen ganancia no computable para los accionistas a fin de evitar la doble imposición.</p><p style=\"text-indent:2em\">Destacó la Corte que <b>el silencio o la omisión en una materia que, como la impositiva, requiere ser aplicada restrictivamente, no debe ser suplida por vía de interpretación analógica y, mucho menos aún, por decisión judicial (Fallos: <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=209&amp;pagina=87\">209:87</a>; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=248&amp;pagina=482\">248:482</a>; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=310&amp;pagina=290\">310:290</a>; <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=329&amp;pagina=2511\">329:2511</a>)</b></p>","esNovedad":true,"fecha":1735268400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1735564021739,"usuarioCreacion":4,"fechaCreacion":1735332817150,"privado":false,"posicion":8,"resumen":null},"reciboEntrada":{"id":131521,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30510087,"numeroExpediente":66322,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2,"tema":null},"caratula":"GRUPO FINANCIERO GALICIA SA (TF 37108-I) c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"66322. "},"recurso":{"id":5643403,"expediente":{"id":30510087,"numeroExpediente":66322,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2,"tema":null},"caratula":"GRUPO FINANCIERO GALICIA SA (TF 37108-I) c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"66322. "},"tipoRecurso":{"id":1166,"codigo":"REX","descripcion":"RECURSO EXTRAORDINARIO"},"claveRecurso":"CAF 066322/2017/CS001","identificacionExpediente":"CAF 066322/2017/CS001"},"piezas":2,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":16,"nombreUsuario":"272098804