[{"codigo":7724516,"analisisDocumental":{"id":772451,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"BREARD, JUAN CARLOS c/ PREFECTURA NAVAL ARGENTINA s/ RECLAMOS VARIOS","alias":null,"caratula":"BREARD, JUAN CARLOS c/ PREFECTURA NAVAL ARGENTINA s/RECLAMOS VARIOS","inconstitucional":false,"falloDestacado":{"id":3402,"titulo":"Extensión de los beneficios al personal de la fuerzas de seguridad incapacitado en y por acto de servicio.","cabecilla":"<p>Un miembro de la Prefectura obtuvo sentencia favorable para que se le reconocieran los beneficios establecidos por la ley 26.578, que prev&eacute; la&nbsp; actualizaci&oacute;n de haberes&nbsp;con equipraci&oacute;n&nbsp;a los del grado inmediato superior, en raz&oacute;n de haber sido&nbsp; encuadrado su pase a situaci&oacute;n de retiro obligatorio como ocasionado por enfermedad producida&nbsp;<strong>en actos del servicio</strong>.&nbsp;Contra ese reconocimiento, la Prefectura recurri&oacute; ante la Corte con el argumento&nbsp;de&nbsp;que se hab&iacute;a omitido considerar la distinci&oacute;n reglamentaria entre una enfermedad producida &quot;en actos del servicio&quot; o &quot;por actos del servicio&quot; y la acontecida &quot;en y por actos del servicio en ejercicio de funciones policiales&quot;, y consider&oacute; que este &uacute;ltimo es el supuesto que la ley busc&oacute; amparar. La Corte, con remisi&oacute;n al dictamen de la Procuraci&oacute;n General, confirm&oacute; la sentencia y rechaz&oacute; el recurso de la Prefectura. Consider&oacute; que si el otorgamiento de uno u otro de los beneficios contemplados por las leyes 16.443 y 20.774 se encuentra condicionado a que el hecho que motiv&oacute; el pase a situaci&oacute;n de retiro haya acontecido &ldquo;en acto de servicio&rdquo; (durante el horario de trabajo, aunque no como un riesgo propio y espec&iacute;fico de la profesi&oacute;n) o &ldquo;en y por acto de servicio&rdquo; (en circunstancias que son consecuencia directa e inmediata del ejercicio de las funciones de seguridad), respectivamente, debe concluirse, inevitablemente, en que la extensi&oacute;n del beneficio al personal de la Prefectura Naval Argentina (y a otras fuerzas de seguridad)&nbsp;<strong>le corresponde al personal incapacitado tanto &ldquo;en acto de servicio&rdquo; como &ldquo;en y por acto de servicio&rdquo;.</strong>&nbsp;Agreg&oacute; que si la intenci&oacute;n del legislador, al sancionar esta ley, hubiera sido la de extender &uacute;nicamente el derecho por un hecho ocurrido &ldquo;en y por acto de servicio&rdquo;, habr&iacute;a bastado con que hiciera referencia, en sus disposiciones, solamente a la ley 20.774, sin mencionar tambi&eacute;n &mdash;como, efectivamente, lo hace&mdash; a la ley 16.443. Tuvo en cuenta para ello el Tribunal que la inconsecuencia o la falta de previsi&oacute;n del legislador no se suponen, por lo cual las normas deben interpretarse de conformidad con el sentido propio de las palabras.</p>","esNovedad":true,"fecha":1643857200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1643976522590,"usuarioCreacion":11,"fechaCreacion":1643917847501,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":33086,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":2802782,"numeroExpediente":21011828,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":2014,"descripcion":"RECLAMOS VARIOS","idMateria":112,"tema":{"id":8,"codigo":"LABORAL"}},"caratula":"BREARD, JUAN CARLOS c/ PREFECTURA NAVAL ARGENTINA s/RECLAMOS VARIOS","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"21011828. "},"recurso":{"id":5068418,"expediente":{"id":2802782,"numeroExpediente":21011828,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":2014,"descripcion":"RECLAMOS VARIOS","idMateria":112,"tema":{"id":8,"codigo":"LABORAL"}},"caratula":"BREARD, JUAN CARLOS c/ PREFECTURA NAVAL ARGENTINA s/RECLAMOS VARIOS","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"21011828. "},"tipoRecurso":{"id":1166,"codigo":"REX","descripcion":"RECU