{"id":770610,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"A. G. L. I. c/ R. M. G. H. s/RESTITUCION INTERNACIONAL DE MENORES","alias":null,"caratula":"A. G. L. I. c/ R. M. G. H. s/RESTITUCION INTERNACIONAL DE MENORES","inconstitucional":false,"falloDestacado":{"id":2981,"titulo":"Restitución internacional de niñas y el alcance de sus manifestaciones","cabecilla":"<p>Con sustento en la oposici&oacute;n de las ni&ntilde;as de regresar a su pa&iacute;s de residencia habitual, el superior tribunal provincial rechaz&oacute; el pedido de restituci&oacute;n a Espa&ntilde;a. Contra ese pronunciamiento, su madre interpuso un recurso extraordinario.&nbsp;<strong>La Corte, por unanimidad, revoc&oacute; la sentencia apelada e hizo lugar a la demanda de restituci&oacute;n</strong>. Para tomar dicha decisi&oacute;n consider&oacute; que, con relaci&oacute;n a la oposici&oacute;n de las ni&ntilde;as a regresar a su pa&iacute;s de residencia habitual no cabe adherir a una sumisi&oacute;n irrestricta respecto de la opini&oacute;n que pudiese haber expresado el infante sino que la posibilidad de negar el regreso solo se abre frente a una voluntad cualificada que no ha de consistir en una mera preferencia o negativa, sino en una verdadera oposici&oacute;n, entendida como un repudio genuino e irreductible a regresar. Asimismo, la Corte consider&oacute; que correspond&iacute;a descartar la existencia de una autorizaci&oacute;n para trasladar la residencia de las ni&ntilde;as a la Argentina por lo que hab&iacute;a quedado verificada la ilicitud a la que la Convenci&oacute;n de La Haya supedita la operatividad del dispositivo de restituci&oacute;n. Agreg&oacute; tambi&eacute;n el Tribunal en su sentencia, que las ni&ntilde;as fueron adecuadamente o&iacute;das durante el proceso de manera directa por los magistrados intervinientes en las diferentes instancias y tambi&eacute;n por intermedio de profesionales especializados, sin que de una adecuada ponderaci&oacute;n tanto de sus dichos como de las consideraciones efectuadas en las distintas resoluciones e informes emitidos pueda concluirse la existencia de una oposici&oacute;n a retornar con las caracter&iacute;sticas exigidas para configurar dicha excepci&oacute;n.</p>","esNovedad":true,"fecha":1635390000000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1635507866899,"usuarioCreacion":11,"fechaCreacion":1635507861931,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":32452,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"rec