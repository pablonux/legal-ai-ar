{"id":825606,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":230004,"valor":"RECURSO DE REVOCATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Maldonado, Miguel Angel s/HOMICIDIO CULPOSO CALIFICADO","inconstitucional":false,"falloDestacado":{"id":10563,"titulo":"Plazo para interponer la queja: ampliación en razón de la distancia","cabecilla":"<p style=\"text-indent:2em\">En un <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=8237271&amp;cache=1776372494359\">pronunciamiento anterior</a> la Corte desestimó la queja por resultar extemporánea. Contra esa decisión la recurrente interpuso recurso de revocatoria argumentando que se habría incurrido en un error material al no haberse computado la ampliación de los plazos (art. 158 del Código Procesal Civil y Comercial de la Nación), ya que esa parte había constituido domicilio en la ciudad de Mar del Plata.</p><p style=\"text-indent:2em\">La Corte consideró que tal aseveración resultaba incorrecta y desestimó la presentación.</p><p style=\"text-indent:2em\">Señaló que la ampliación debe determinarse respecto del lugar de asiento del tribunal que desestimó el recurso extraordinario, que en el caso era la Suprema Corte de Justicia de la Provincia de Buenos Aires, con sede en la ciudad de La Plata.</p><p style=\"text-indent:2em\">Así, en consecuencia, el plazo para interponer la queja era de cinco días, sin la ampliación prevista en la norma antes mencionada y el recurso presentado había resultado extemporáneo.</p>","esNovedad":true,"fecha":1776308400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1776372507227,"usuarioCreacion":11,"fechaCreacion":1776372349202,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":155859,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38547588,"numeroExpediente":5401,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":7081,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 1 - Principal en Tribunal Oral Nº 0 - PARRA, DIEGO JAVIER s/INFRACCION LEY 23.737 (ART.5 INC.C) ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"5401. "},"recurso":{"id":6776047,"expediente":{"id":38547588,"numeroExpediente":5401,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":7081,"descripcion":