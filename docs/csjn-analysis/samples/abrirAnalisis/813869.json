{"id":813869,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"BELSITO, NOEMI s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":9402,"titulo":"Acceso ilegítimo a cuentas personales de redes sociales: conflicto de competencia","cabecilla":"<p style=\"text-indent:2em\">A raíz de una denuncia en la que relató que personas desconocidas habrían accedido a una cuenta de “Instagram” y se comunicaron con distintos contactos por esa red social, a quienes engañaron con la falsa promesa de la venta de dólares, se originó un conflicto negativo de competencia entre un magistrado de la justicia en lo penal, contravencional y faltas y un magistrado de la justicia nacional en lo criminal y correccional federal, ambos de la Ciudad de Buenos Aires.</p><p style=\"text-indent:2em\">La Corte expresó que resulta competente la justicia ordinaria para entender en la investigación respecto del acceso ilegítimo a cuentas personales de redes sociales y correos electrónicos, pues no basta para excitar la jurisdicción federal la mera circunstancia de que el delito se cometa en el entorno de las redes de comunicación, sino que debe ocurrir además una real afectación al servicio de interés público tutelado. </p><p style=\"text-indent:2em\">Teniendo en cuenta que dicha situación no se advertía <em>prima facie</em> en el caso y, dado que no se ha transferido a la justicia de la Ciudad Autónoma de Buenos Aires la competencia para entender en el juzgamiento de estos delitos, declaró la competencia de la justicia nacional con competencia ordinaria en esta ciudad, aunque no haya intervenido en la contienda.</p>","esNovedad":true,"fecha":1757991600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1758117233923,"usuarioCreacion":11,"fechaCreacion":1758116316231,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":142409,"secretaria":{"id":209,"tipo":"S","descripcion":"Sec. Penal Especial","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal Especial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35952361,"numeroExpediente":11018,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8761,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Incidente Nº 1 - DENUNCIANTE: CARBONE, MYRIAM BEATRIZ NN: N.N. s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"11018. "},"recurso":{"id":6326850,"expediente":{"id":35952361,"numeroExpediente":11018,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8761,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratu