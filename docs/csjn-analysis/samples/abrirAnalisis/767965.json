{"id":767965,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"GOMEZ ROCCA JAVIER HERNAN c/ CREATORE VICTOR JUAN Y OTROS s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","alias":null,"caratula":"Recurso Queja Nº 1 - GOMEZ ROCCA JAVIER HERNAN c/ CREATORE VICTOR JUAN Y OTROS s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","inconstitucional":false,"falloDestacado":{"id":2505,"titulo":"Oponibilidad a terceros del límite de cobertura del contrato de seguro de un establecimiento educativo","cabecilla":"<p>La obligaci&oacute;n del asegurador de reparar el da&ntilde;o tiene naturaleza meramente &quot;contractual&quot;, y su origen no es el da&ntilde;o sino el contrato de seguro -&nbsp; La pretensi&oacute;n de que la aseguradora se haga cargo del pago de la indemnizaci&oacute;n &quot;m&aacute;s all&aacute; de las limitaciones cuantitativas establecidas en el contrato&quot; carece de fuente jur&iacute;dica que la justifique -&nbsp;Los establecimientos educativos no se encuentran exceptuados ni ajenos a contratar un seguro de responsabilidad civil obligatorio con la determinaci&oacute;n de un l&iacute;mite de cobertura m&iacute;nimo y, a su vez, las aseguradoras a responder en ese marco -&nbsp;No obstante la magnitud del da&ntilde;o ocasionado a los alumnos del establecimiento educativo demandado, no es posible considerar que la condena a la aseguradora m&aacute;s all&aacute; de la p&oacute;liza contratada est&eacute; sustentada en el inter&eacute;s superior del ni&ntilde;o - No cabe considerar al inter&eacute;s superior del ni&ntilde;o como fuente directa de integraci&oacute;n de las prestaciones patrimoniales de un contrato celebrado por terceros - Ello implicar&iacute;a, por un lado, desbordar la finalidad a la que alude el art. 3&deg; de la Convenci&oacute;n sobre los Derechos del Ni&ntilde;o, y por el otro, desnaturalizar la razonable previsibilidad que constituye el eje del funcionamiento del contrato - Se revoca la decisi&oacute;n apelada y se admite que el l&iacute;mite de cobertura previsto en el contrato de seguro es oponible al tercero damnificado y que la sentencia no podr&aacute; ser ejecutada contra la aseguradora sino en los l&iacute;mites de la contrataci&oacute;n - Disidencia de los jueces Maqueda y Rosatti: recursos extraordinarios inadmisibles (art. 280 CPCCN).</p>","esNovedad":true,"fecha":1628737200000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1628880195021,"usuarioCreacion":11,"fechaCreacion":1628858592544,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31568,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24196854,"numeroExpediente":63965,"anioExpediente":2005,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara"