{"id":817839,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - GUARDIA, VICTOR HUGO c/ AFIP s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":9783,"titulo":"Apartamiento de la pauta normativa en la distribución de las costas","cabecilla":"<p style=\"text-indent:2em\">La cámara confirmó la sentencia de primera instancia en cuanto había hecho lugar a la acción de amparo y, en consecuencia, declarado la inconstitucionalidad del artículo 79, inc. c, de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-20628-17699/texto\">ley 20.628</a> (texto según ley 27.346) y ordenado a la demandada que se abstuviera de efectuar descuentos en concepto de impuesto a las ganancias sobre los haberes previsionales que percibe el actor. También confirmó la imposición de las costas y distribuyó las de la alzada por su orden.</p><p style=\"text-indent:2em\">El actor interpuso recurso extraordinario y la Corte <b>dejó sin efecto la sentencia</b> en lo relacionado con este último aspecto.</p><p style=\"text-indent:2em\">Señaló que la cámara impuso las costas por su orden pero sin considerar que el artículo 68 del Código Procesal Civil y Comercial de la Nación que citó resultaba inaplicable a este asunto pues, tratándose de un proceso de amparo, las costas debían ser impuestas según lo normado en el artículo 14 de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-16986-46871/texto\">ley 16.986</a> -precepto vinculado directamente a la concreta situación suscitada en la causa-, que establece la imposición de las costas a la parte vencida con la sola excepción de que, con anterioridad a la contestación del informe previsto en su artículo 8°, se produzca el cese del acto u omisión en que se fundó el amparo, supuesto que no había ocurrido en estas actuaciones.</p><p style=\"text-indent:2em\">Añadió que de las constancias de la causa se advertía que la cámara no había proporcionado una razón válida para justificar su apartamiento de la pauta normativa que, en materia de costas, le imponía atender al resultado del pleito.</p>","esNovedad":true,"fecha":1762830000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1763035898961,"usuarioCreacion":11,"fechaCreacion":1762884939542,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":146381,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35915864,"numeroExpediente":1079,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id