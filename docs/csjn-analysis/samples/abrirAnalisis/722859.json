illa":"<p>Recurso de queja desestimado ante incumplimiento de esta carga - Recurso de reposici&oacute;n - Ley 26.685 autorizando comunicaciones electr&oacute;nicas - Reglamentaci&oacute;n del Sistema de Notificaciones por Medios Electr&oacute;nicos por Acordada 31/2011 - Remisi&oacute;n a prescripciones de art. 41, 1&deg; p&aacute;rrafo del CPCCN ante omisi&oacute;n de inscripci&oacute;n del letrado en el nuevo sistema - Se desestima la petici&oacute;n - Disidencia Juez Maqueda: Supuesto excepcional - Art. 286 CPCCN: intimaci&oacute;n ante omisi&oacute;n o integraci&oacute;n insuficiente del dep&oacute;sito debe realizarse personalmente o por c&eacute;dula - Dep&oacute;sito dirigido de manera incorrecta a la orden de otro tribunal - Art. 41, primer p&aacute;rrafo CPCCN reconoce excepciones en resguardo de defensa en juicio - Aplicaci&oacute;n anal&oacute;gica de dichas salvedades - Interpretaci&oacute;n arm&oacute;nica de las normas procesales - Omisi&oacute;n de constituir domicilio electr&oacute;nico no impide librar c&eacute;dula - Intimaci&oacute;n fehaciente a completar dep&oacute;sito de art. 286 CPCCN no puede practicarse por ministerio de la ley</p>","esNovedad":true,"fecha":1435028400000,"relevancia":2,"usuarioModificacion":13,"fechaModificacion":1599067897725,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":16852,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23485820,"numeroExpediente":255,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"D","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":n