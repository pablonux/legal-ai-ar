a acordada 4/2007.  Asimismo, la intimación fehaciente a completar el depósito al que alude el último párrafo del art. 286 del C.P.C.C.N. que expresamente exige la comunicación personal o por cédula- no puede practicarse por ministerio de ley.\r\n","comentarios":null,"enPreparacion":null,"formulaDesarrollo":null,"audPublica":"N","articulo16Ley48":"N","inicializacion":"N","amicue_curie":"N","conOpinion":null,"chequeoVoto":"S","cambiaJurisp":null,"sentenciaModelo":null,"citaDoctrina":null,"citaExtranjera":null,"votosOpinion":"N","art11Acordada4":null,"resolucionOriginarios":null,"cuestionesFederales":[],"formulas":[],"recusExcus":[],"voces":[{"tipoVoz":{"codigoTabla":null,"codigoValor":4129,"codigoRelacion":104129,"valor":"RECURSO DE REPOSICION O REVOCATORIA","activo":"S","usuarioCreacion":"JUR0V0","usuarioMod":"JUR3WP","fechaCreacionLong":201112061134,"fechaModLong":201211081450,"orden":null,"visible":null},"orden":1,"usuarioCreacion":"JURC5F","usuarioModificacion":"JURC5F","fechaCreacion":201904160930,"fechaModificacion":201904160930},{"tipoVoz":{"codigoTabla":null,"codigoValor":3534,"codigoRelacion":103534,"valor":"SENTENCIA DE LA CORTE SUPREMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":"JURC5F","usuarioModificacion":"JURC5F","fechaCreacion":201904160930,"fechaModificacion":201904160930},{"tipoVoz":{"codigoTabla":null,"codigoValor":4322,"codigoRelacion":104322,"valor":"NOTIFICACION ELECTRONICA","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201303071257,"fechaModLong":201303071257,"orden":null,"visible":null},"orden":3,"usuarioCreacion":"JURC5F","usuarioModificacion":"JURC5F","fechaCreacion":201904160930,"fechaModificacion":201904160930},{"tipoVoz":{"codigoTabla":null,"codigoValor":2784,"codigoRelacion":102784,"valor":"NOTIFICACION POR CEDULA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"A