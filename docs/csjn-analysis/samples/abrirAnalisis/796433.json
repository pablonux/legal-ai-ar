 disp la intervención del defensor gral.\r\nindican costas  en el orden causado. \r\nel Dr Petre indica poner Disidencia Parcial  en el voto del Dr Rtz , asi se hace y se pone a la SEc 1 cartel de Verificar arreglo indicado.\r\n","usuarioCreacion":{"id":10,"nombreUsuario":"27179020438","apellido":"Messuti","nombre":"Mariana","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583843772000,"nombreUsuarioMigrado":null,"codigo":"JURW6J","mail":"mmessuti@csjn.gov.ar","intentos":0,"notificacion":false},"usuarioCreacionOld":"JURW6J","usuarioModificacion":{"id":10,"nombreUsuario":"27179020438","apellido":"Messuti","nombre":"Mariana","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583843772000,"nombreUsuarioMigrado":null,"codigo":"JURW6J","mail":"mmessuti@csjn.gov.ar","intentos":0,"notificacion":false},"usuarioModificacionOld":"JURW6J","fechaCreacion":202405020758,"fechaModificacion":202405031141}],"fecha":1714618800000,"fechaLong":20240502,"observaciones":null,"codigoUsuario":"JURW6J","fechaString":"02/05/2024"},"observaciones":null,"comentarios":null,"enPreparacion":"N","formulaDesarrollo":null,"audPublica":"N","articulo16Ley48":"S","inicializacion":"S","amicue_curie":"N","conOpinion":null,"chequeoVoto":"S","cambiaJurisp":"N","sentenciaModelo":"N","citaDoctrina":"N","citaExtranjera":"N","votosOpinion":"N","art11Acordada4":"N","resolucionOriginarios":null,"cuestionesFederales":[{"tipoCuestionFederal":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":50001,"valor":"ARTÍCULO 14 DE LA LEY 48 ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JURJ3F","fechaCreacionLong":201006041222,"fechaModLong":202203141533,"orden":null,"visible":null},"usuarioCreacion":"JURW6J","usuarioModificacion":"JURW6J","fechaCreacion":202405020814,"fechaModificacion":202405020814},{"tipoCuestionFederal":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":50002,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"A