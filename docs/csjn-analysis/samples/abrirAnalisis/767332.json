{"id":767332,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"DESARROLLOS EDUCATIVOS S.A. c/ ESTADO NACIONAL Y OTRO s/AMPARO LEY 16.986","alias":null,"caratula":"DESARROLLOS EDUCATIVOS S.A. c/ ESTADO NACIONAL Y OTRO s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":2305,"titulo":"Suspensión de presencialidad en establecimientos educativos y conflictos de competencia","cabecilla":"<p>Acci&oacute;n de amparo contra el Estado Nacional y la Provincia de Buenos Aires a fin de que se ordene la cesaci&oacute;n de las medidas dispuestas por el DNU 241/21, solicitando que se declare su inconstitucionalidad y se except&uacute;e al establecimiento educativo de la suspensi&oacute;n de la presencialidad - Invocaci&oacute;n de que la norma impugnada vulnera especialmente los derechos a ense&ntilde;ar y aprender e invade la esfera de competencias propias de la provincia - Conflicto negativo de competencia entre la justicia provincial y la justicia federal - No corresponde a la competencia originaria del Tribunal, en tanto la relaci&oacute;n jur&iacute;dica sustancial que da origen al reclamo es de eminente derecho p&uacute;blico local, puesto que la demanda se dirige a cuestionar prioritariamente conductas y actos emanados de autoridades de la provincia demandada - Tampoco se advierte que el asunto exija dilucidar si la actividad proveniente de la autoridad local invade un &aacute;mbito que podr&iacute;a ser propio de la Naci&oacute;n en materia educativa - El proceso debe tramitar ante la justicia provincial, dado que el respeto del sistema federal y de las autonom&iacute;as provinciales exige que sean dichos magistrados los que intervengan en las causas en que se ventilen cuestiones de ese car&aacute;cter, sin perjuicio de que las de &iacute;ndole federal que tambi&eacute;n puedan comprender esos pleitos sean susceptibles de adecuada tutela por la v&iacute;a del recurso extraordinario regulado por el art. 14 de la ley 48.</p>","esNovedad":true,"fecha":1624503600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1624628265123,"usuarioCreacion":11,"fechaCreacion":1624626351660,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31381,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35119105,"numeroExpediente":37628,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":26,"codigo":"26","abreviatura":"FSM","descripcion":"Justicia Federal de San Martin","estado":0,"descripcionLarga":"FSM - Justicia Federal de San Martin"},"objetoJuicio":{"id":7096,"descripcion":"AMPARO COLECTIVO","idMateria":112,"tema":{"id":320,"codigo":"AMPAROS"}},"caratula":"GUILLOT SEBASTIAN, Y OTROS Y OTROS c/ GOBERNAC