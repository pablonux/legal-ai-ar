{"id":781340,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"DON EMILIO S.A. s/RECURSO DE QUEJA","alias":null,"caratula":"DON EMILIO S.A. s/RECURSO DE QUEJA","inconstitucional":false,"falloDestacado":{"id":4906,"titulo":"Interpretación del contrato, naturaleza de la obligación asumida y cláusula penal","cabecilla":"<p>A) En el marco de una acción de cumplimiento de contrato la cámara hizo lugar al reclamo del saldo de precio y también admitió la <b>cláusula penal equivalente a U$D 2.000 diarios por cada día de demora</b>, con fundamento en el incumplimiento por la vendedora de una de las condiciones establecidas en el contrato: la aprobación del plano de mensura y reparcelamiento del inmueble rural que se había pactado que debía realizarse. B) <b>La Corte dejó sin efecto la sentencia</b>.  C) Señaló que el tribunal omitió, sin justificación alguna, expedirse con respecto a la naturaleza, el contenido y la extensión de la obligación (<em>en particular si ésta era de medios o de resultado</em>), los intercambios epistolares y demás prueba demostrativa de la intención de las partes, los perjuicios padecidos por cada una y las consecuencias del pronunciamiento en relación con la magnitud del negocio jurídico celebrado, teniendo en cuenta que, la procedencia de la multa de U$S 2.000 diarios por el período que va desde que se cumplieron los 90 días pactados hasta que se aprobaron los planos superaría el millón de dólares. D) Consideró el Tribunal que la prescindencia de estas circunstancias relevantes y conducentes para la solución del litigio afectaba en forma directa e inmediata las garantías constitucionales invocadas y convertía en arbitrario el pronunciamiento.</p>","esNovedad":true,"fecha":1671591600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1671730404316,"usuarioCreacion":4,"fechaCreacion":1671651887779,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":105855,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34001122,"numeroExpediente":1745,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"DON EMILIO S.A. s/RECURSO DE QUEJA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1745. "},"recurso":{"id":5668650,"expediente":{"id":34001122,"numeroExpediente":1745,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descr