{"id":806980,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"S. Z., A. D. s/ medida autosatisfactiva.","alias":null,"caratula":"SILVA ZARRANZ, ANA DELFINA s/medida autosatisfactiva","inconstitucional":false,"falloDestacado":{"id":8402,"titulo":"Régimen de contacto y cuidado personal: injustificado rigor formal en el rechazo de un recurso local","cabecilla":"<p style=\"text-indent:2em\">En el marco de una medida autosatisfactiva de suspensión cautelar del régimen de contacto y cuidado personal de una niña el superior tribunal local declaró inadmisible el recurso de casación con fundamento en que la actora no había agotado la vía recursiva ordinaria. Consideró que al no haberse otorgado traslado al padre de la niña se trataba de un auto dictado sin sustanciación contra el cual procedía el recurso de reposición previsto en el código procesal provincial. </p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia por considerarla dogmática.</p><p style=\"text-indent:2em\">Señaló que resultaba evidente que la decisión había importado una clara restricción, sin límite temporal alguno, de los derechos de la recurrente y que, dada la índole de los derechos involucrados, ella era susceptible de causar perjuicios de imposible, muy difícil o insuficiente reparación ulterior.</p><p style=\"text-indent:2em\">Agregó que la desestimación del recurso extraordinario local basada en la supuesta ausencia de una decisión de fondo resultaba de una rigurosidad excesiva e incompatible con el adecuado servicio de justicia que afectaba en forma directa e inmediata el derecho de defensa de la recurrente.</p>","esNovedad":true,"fecha":1742353200000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1742911815394,"usuarioCreacion":4,"fechaCreacion":1742414114339,"privado":false,"posicion":3,"resumen":{"idResumen":122,"resumen":"La CSJN revocó la sentencia que declaró inadmisible el recurso de casación. La restricción de derechos de la recurrente ameritaba revisión judicial urgente, y la exigencia de agotar instancias previas era excesiva, afectando su derecho de defensa.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":134400,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35317651,"numeroExpediente":70866,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":9189,"descripcion":"DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 2 - SCHROH, ANDREA VA