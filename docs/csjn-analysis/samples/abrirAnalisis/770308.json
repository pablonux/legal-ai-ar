{"id":770308,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"ROMERO, JONATHAN IVAN c/ MINISTERIO DE EDUCACION Y DEPORTES DE LA NACION s/ JUICIO SUMARISIMO","alias":null,"caratula":"Recurso Queja Nº 1 - ROMERO, JONATHAN IVAN c/ MINISTERIO DE EDUCACION Y DEPORTES DE LA NACION s/JUICIO SUMARISIMO","inconstitucional":false,"falloDestacado":{"id":2902,"titulo":"Contratación de empleo público por tiempo determinado y tutela sindical","cabecilla":"<p>Acci&oacute;n tendiente a que se declare la nulidad del despido de quien se desempe&ntilde;aba en un Ministerio al considerar que pose&iacute;a tutela sindical y se configuraba una conducta discriminatoria.&nbsp;La c&aacute;mara de apelaciones orden&oacute; la reinstalaci&oacute;n del actor en el puesto y, al mismo tiempo, el pago de salarios ca&iacute;dos y da&ntilde;o moral con fundamento en que su designaci&oacute;n como consejero gremial constitu&iacute;a un cargo que requer&iacute;a representaci&oacute;n gremial por lo que la decisi&oacute;n rescisoria no se hab&iacute;a ajustado al procedimiento establecido en el art&iacute;culo 52 de la ley 23.551.&nbsp; La Corte, por mayor&iacute;a, revoc&oacute; la sentencia apelada. Entre los fundamentos, se consider&oacute; que el pronunciamiento viol&oacute; la exigencia de que los fallos sean fundados sin perjuicio de que omiti&oacute; considerar un planteo oportunamente introducido y conducente para una adecuada soluci&oacute;n del pleito. A criterio del Tribunal, la contrataci&oacute;n era transitoria y por tiempo determinado en cuyo caso, siempre que sea regular, implica que el v&iacute;nculo se extingue autom&aacute;ticamente por el mero vencimiento del t&eacute;rmino convenido, sin necesidad de acto administrativo alguno. Por lo dem&aacute;s, a criterio de la Corte, para arribar a una decisi&oacute;n fundada sobre la legitimidad de la extinci&oacute;n del v&iacute;nculo, la c&aacute;mara debi&oacute; considerar si la circunstancia de adquirir el car&aacute;cter de representante sindical pod&iacute;a, por si sola, modificar la naturaleza jur&iacute;dica de la relaci&oacute;n preexistente entre las partes. No basta que haya existido activismo sindical para tener por acreditado que la extinci&oacute;n de un v&iacute;nculo obedece a motivos discriminatorios sino que es necesario, adem&aacute;s, evaluar si dicha actividad es prima facie la raz&oacute;n por la que se dio por terminado el v&iacute;nculo y, luego, considerar si el empleador logr&oacute; acreditar que la extinci&oacute;n respondi&oacute; a un m&oacute;vil ajeno a toda discriminaci&oacute;n. Sobre dicha base, se revoc&oacute; la sentencia apelada y mand&oacute; dictar un nuevo pronunciamiento. Por su parte, en disidencia los jueces Rosatti y Maqueda sostuvieron que el recurso extraordinario es inadmisible (art&iacute;culo 280 del C&oacute;digo Procesal Civil y Comercial de la Naci&oacute;n).</p>","esNovedad":true,"fecha":1634785200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1634924850312,"usuarioCreacion":11,"fechaCreacion":1634903949283,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":32336,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32683245,"numeroExpediente":40803,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9715,"descripcion":"JUICIO SUMARISIMO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - ROMERO, JONATHAN IVAN c/ MINISTERIO DE EDUCACION Y DEPORTES DE LA NACION s/JUICIO SUMARISIMO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"40803. "},"recurso":{"id":5449058,"expediente":{"id":32683245,"numeroExpediente":40803,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9715,"descripcion":"JUICIO SUMARISIMO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - ROMERO, JONATHAN IVAN c/ MINISTERIO DE EDUCACION Y DEPORTES DE LA NACION s/JUICIO SUMARISIMO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"40803. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CNT 040803/2017/1/RH001","identificacionExpediente":"CNT 040803/2017/1/RH001"},"piezas":3,"urgente":"N","observaciones":null,"usuarioCreacion":null,"usuarioCreacionOld":"JURJ3F","us