{"id":790426,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"CURTUME CBR S.A. s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":6104,"titulo":"Competencia de la justicia provincial ante una presunta infracción a la ley de residuos peligrosos","cabecilla":"<p>Al resolver una contienda negativa de competencia en una causa en que se investiga la presunta infracción a la ley de residuos peligrosos por parte de una curtiembre la Corte decidió que sea la justicia provincial quien siga entendiendo en su estudio. Recordó que la ley 24.051 delimita su aplicación, y por ende la competencia federal, a aquellos sucesos que puedan afectar a las personas o el ambiente más allá de la frontera de la provincia en que se hubiesen generado y que de la lectura de la ley 25.675 se concluye que la regla es la competencia ordinaria y la excepción, la competencia federal para aquellos casos en que, efectivamente, se verifique una afectación interjurisdiccional. Tuvo en cuenta que de los relevamientos e informes técnicos se desprendía que la presunta afectación ambiental estaría circunscripta a la provincia de La Rioja y, por ello, entendió que corresponde a las autoridades locales valorar y juzgar si ello afecta aspectos propios del derecho provincial, en uso de la facultad que les corresponde de aplicar los criterios de protección ambiental que consideren conducentes para el bienestar de la comunidad para la que gobiernan.</p>","esNovedad":true,"fecha":1699326000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1699445879270,"usuarioCreacion":11,"fechaCreacion":1699445876474,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":115343,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":11174049,"numeroExpediente":10008,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"NEXTEL COMMUNICATIONS ARGENTINA SA c/ EN-SC Y OTRO s/PROCESO DE CONOCIMIENTO","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10008. "},"recurso":{"id":5983213,"expediente":{"id":11174049,"numeroExpediente":10008,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Ad