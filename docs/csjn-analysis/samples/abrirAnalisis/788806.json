{"id":788806,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":80006,"valor":"HACE LUGAR A  LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008251405,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ADMINISTRACION DE PARQUES NACIONALES c/ SAN LUIS, PROVINCIA DE s/acción declarativa de inconstitucionalidad y escrituración","inconstitucional":true,"falloDestacado":{"id":5941,"titulo":"Inmuebles afectados al régimen régimen legal de parques nacionales","cabecilla":"<p>La Administración de Parques Nacionales promovió demanda contra la Provincia de San Luis, a fin de que se declare la inconstitucionalidad de la ley local que había declarado de utilidad pública y sujetos a expropiación los derechos previamente cedidos por la demandada al Estado Nacional sobre los inmuebles afectados al funcionamiento del Parque Nacional Sierra de las Quijadas. La Corte hizo lugar a la demanda y declaró la inconstitucionalidad de la ley V-0721- 2010 de la provincia. Consideró que ésta no puede arrogarse sin más la propiedad de un establecimiento de utilidad nacional que no ha sido desafectado de su destino al uso público por una ley del Congreso Nacional y, por lo tanto, desconocer el régimen legal del referido parque nacional. Agregó que la vía elegida por el legislador provincial implicaba una alteración del reparto de competencias que establece la Constitución en el artículo 75, inciso 30, puesto que desconocía el interés público que había determinado la creación del establecimiento.</p>","esNovedad":true,"fecha":1696302000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1696506674711,"usuarioCreacion":11,"fechaCreacion":1696361421507,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":114226,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23382913,"numeroExpediente":642,"anioExpediente":2010,"tomoExpediente":46,"letraExpediente":"A","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ADMINISTRACION DE PARQUES NACIONALES c/ SAN LUIS, PROVINCIA DE s/acción declarativa de inconstitucionalidad y escrituración","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"A. 642. XLVI. "},"recurso":{"id":3131373,"expediente":{"id":23382913,"numeroExpediente":642,"anioExpediente":2010,"tomoExpediente":46,"letraExpediente":"A","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ADMINISTRACION DE PARQUES NACIONALES c/ SAN LUIS, PROVINCIA DE s/acción declarativa de inconstitucionalidad y escrituración","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"A. 642. XLVI. "},"t