{"id":804480,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"CARSA SA-TF 34186-I c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","inconstitucional":false,"falloDestacado":{"id":8085,"titulo":"Impuesto a las ganancias: quebranto impositivo y confiscatoriedad","cabecilla":"<p style=\"text-indent: 2em;\">El Tribunal Fiscal hizo lugar a la acción de repetición del impuesto a las ganancias por un período fiscal y la cámara revocó esta decisión. Se basó en que de las constancias de la causa no surgía de forma precisa y unívoca información que permitiese saber si el impuesto efectivamente ingresado había absorbido una parte sustancial de la renta obtenida por el contribuyente como consecuencia de no haber aplicado el mecanismo de ajuste por inflación.</p><p style=\"text-indent: 2em;\">La Corte dejó sin efecto esta sentencia. </p><p style=\"text-indent: 2em;\">Señaló que la conclusión a la que arribó la sentencia luego de analizar el material probatorio de la causa resultaba descalificable bajo la doctrina de la arbitrariedad de sentencias pues la comprobación de los peritos de ambas partes de que la aplicación del mecanismo de ajuste por inflación arrojaba un quebranto impositivo demostraba la existencia de un supuesto de confiscatoriedad, al no existir ganancia que pudiera dar lugar al pago del impuesto.</p><p style=\"text-indent: 2em;\">Por otra parte, lo sostenido en el sentido de que “los expertos manifestaron que no era posible calcular los porcentuales requeridos, dado que los resultados impositivos arrojaban quebranto, o determinaron que el porcentaje era cero” no contradice, sino que reafirma la conclusión de que de las constancias de autos surgía de forma precisa y unívoca la prueba de un supuesto de confiscatoriedad en el pago del impuesto.</p>","esNovedad":true,"fecha":1734577200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1734642100358,"usuarioCreacion":4,"fechaCreacion":1734642079947,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":131220,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37093018,"numeroExpediente":2132,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MUNICIPALIDAD DE PARANA c/ TELEFONICA MOVILES ARGENTINA S.A. s/MONITORIO APREMIO ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2132. "},"recurso":{"i