{"id":764324,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":80005,"valor":"RECHAZA LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008181305,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Recurso Queja Nº 1 - COMPANIA ARGENTINA DE GRANOS S.A c/ AFIP (D.G.I.) s/CONTENCIOSO ADMINISTRATIVO-VARIOS","alias":null,"caratula":"Recurso Queja Nº 1 - COMPANIA ARGENTINA DE GRANOS S.A c/  AFIP (D.G.I.) s/CONTENCIOSO ADMINISTRATIVO-VARIOS","inconstitucional":false,"falloDestacado":{"id":1683,"titulo":"Repetición de montos ingresados al Fisco como agente de retención del impuesto al valor agregado","cabecilla":"<p>Sentencia de c&aacute;mara que hizo lugar a la demanda de repetici&oacute;n de los importes ingresados en concepto de retenciones del IVA por las compras de cereal realizadas a ciertos proveedores - Ausencia de un adecuado y preciso examen de los hechos configurativos de la causa - La actora no solicit&oacute; la repetici&oacute;n de las sumas ingresadas en su condici&oacute;n de contribuyente del impuesto sino que persigui&oacute; la repetici&oacute;n de los montos ingresados al Fisco en su car&aacute;cter de agente de retenci&oacute;n- Interpretaci&oacute;n que aparece como la aplicaci&oacute;n mec&aacute;nica de un principio procesal fuera del &aacute;mbito que le es propio - La actora fund&oacute; su reclamo en la alegaci&oacute;n de un perjuicio patrimonial derivado del ingreso de retenciones practicadas sobre operaciones declaradas inexistentes por la AFIP, en tanto que el Fisco solicit&oacute; el rechazo de la demanda aseverando que el perjuicio no se encontraba configurado, por cuanto nunca hab&iacute;a considerado que las operaciones no existieran, sino tan solo que no exist&iacute;an los proveedores consignados en ellas - Error que condujo a que la demandada se viera privada injustificadamente de la consideraci&oacute;n de la defensa aludida, lo cual vulnera la garant&iacute;a de defensa en juicio - Corresponde dejar sin efecto la sentencia - Dado el tiempo transcurrido desde que se iniciaron los autos y la trascendencia institucional de las cuestiones planteadas corresponde hacer uso de la facultad del art. 16, segunda parte, de la ley 48 y decidir sobre el fondo de la causa - Sentencia que incurri&oacute; en un error al sostener que el ente recaudador hab&iacute;a declarado la inexistencia de las operaciones de compraventa pues tal afirmaci&oacute;n se fund&oacute; en las conclusiones de un peritaje contable desarrolladas sobre la base del mismo error lo que impide reconocerle error probatorio - Es requisito de validez de las sentencias que ellas se encuentren fundadas y constituyan una derivaci&oacute;n razonada del derecho vigente aplicable a las circunstancias de la causa - Los agentes de retenci&oacute;n solo se encuentran autorizados a demandar la repetici&oacute;n de los impuestos en los supuestos en los que el cumplimiento del deber que la legislaci&oacute;n les impone ha derivado en un perjuicio personal - Actora que no ha demostrado como correspond&iacute;a la existencia y acreditaci&oacute;n de perjuicio alguno - Se declara procedente el recurso y se rechaza la demanda.</p>","esNovedad":true,"fecha":1615431600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1615810857391,"usuarioCreacion":11,"fechaCreacion":1615556204460,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30369,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":27544971,"numeroExpediente":52030001,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":15,"codigo":"15","abreviatura":"FCB","descripcion":"Justicia Federal de Córdoba","estado":0,"descripcionLarga":"FCB - Justicia Federal de Córdoba"},"objetoJuicio":{"id":2662,"descripcion":"CONTENCIOSO ADMINISTRATIVO-VARIOS","idMateria":112,"tema":{"id":86,"codigo":"CONTADM"}},"caratula":"Recurso Queja Nº 1 - COMPANIA ARGENTINA DE GRANOS S.A c/  AFIP (D.G.I.) s/CONTENCIOSO ADMINISTRATIVO-VARIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"52030001. "},"recurso":{"id":4709162,"expediente":{"id":27544971,"numeroExpediente":52030001,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":15,"codigo":"15","abreviatura":"FCB","descripcion":"Justicia Federal de Córdoba","estado":0,"descripcionLarga":"FCB - Justicia Federal de Córdoba"},"objetoJuicio":{"id":2662,"descripcion":"CONTENCIOSO ADMINISTRATIVO-VARIOS","idMateria":112,"tema":{"id":86,"codigo":"CONTADM"}},"caratula":"Recurso Queja Nº 1 - COMPANIA ARGENTINA DE GRANOS S.A c/  AFIP (D.G.I.) s/CONTENCIOSO ADMINISTRATIVO-VARIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"52030001. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"