{"id":805821,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ALBARRACIN CARLOS CIRO c/ ESTADO NACIONAL-MINISTERIO DE DEFENSA s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","inconstitucional":false,"falloDestacado":{"id":8182,"titulo":"Suplementos remunerativos: interpretación de la ley","cabecilla":"<p style=\"text-indent: 2em;\">La cámara hizo lugar a la inclusión, como parte integrante del haber de retiro del actor, el suplemento por vuelo y/o actividad riesgosa.</p><p style=\"text-indent: 2em;\">La Corte revocó este pronunciamiento y rechazó la demanda.</p><p style=\"text-indent: 2em;\">Sostuvo que la sentencia se había apartado de lo dispuesto en la ley 19.101 y había realizado una exégesis teleológica que prescindía directamente de su texto.</p><p style=\"text-indent: 2em;\">Expresó que el demandante era beneficiario de un haber de retiro a partir del 31 de diciembre de 1972 y que el art. 74 de la ley mencionada establece que el haber de retiro se calculará sobre el cien por ciento de la suma del haber mensual y suplementos generales a que tuviera derecho a la fecha de su pase a situación de retiro, en los porcentajes que fija la escala del art. 79 y dispone asimismo, que los suplementos particulares del art. 57 quedan excluidos a los efectos de ese cálculo.</p>","esNovedad":true,"fecha":1738810800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1738872455470,"usuarioCreacion":11,"fechaCreacion":1738872453218,"privado":false,"posicion":3,"resumen":{"idResumen":117,"resumen":"La Corte revocó el fallo de la cámara y rechazó la demanda. Argumentó que la sentencia se apartó de la ley 19.101 al incluir un suplemento en el haber de retiro, realizando una interpretación que ignoraba el texto legal que excluye suplementos particulares del cálculo.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":132483,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29108430,"numeroExpediente":2923,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":5,"codigo":"5","abreviatura":"CSS","descripcion":"Camara Federal de la Seguridad Social","estado":0,"descripcionLarga":"CSS - Camara Federal de la Seguridad Social"},"objetoJuicio":{"id":10618,"descripcion":"PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","idMateria":6,"tema":{"id":540,"codigo":"PREV"}},"caratula":"Recurso Queja Nº 1 - ALBARRACIN CARLOS CIRO c/ ESTADO NACIONAL-MINISTERIO DE DEFENSA s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2923. "},"recurso":{"id":4980066,"expediente":{"id":29108430,"numeroExpediente":2923,"anioExpediente":2007,"tomoE