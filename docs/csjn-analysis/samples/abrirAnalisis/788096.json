{"id":788096,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - TREBINO, EDUARDO ABEL c/ EN - M SEGURIDAD - PFA s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","inconstitucional":false,"falloDestacado":{"id":5862,"titulo":"Monto mínimo de apelabilidad y violación a la garantía del debido proceso adjetivo","cabecilla":"<p>El actor promovió una demanda para obtener la declaración de nulidad de las resoluciones mediante las cuales se había dispuesto su cesantía como docente de una escuela federal de suboficiales. El juzgado hizo lugar a la demanda y declaró la nulidad de las normas cuestionadas por considerar que habían existido irregularidades en el procedimiento administrativo. El Estado Nacional dedujo recurso de apelación y la cámara lo declaró mal concedido al considerar que el valor económico reconocido en la sentencia no alcanzaba el monto establecido en el art. 242 del Código Procesal Civil y Comercial de la Nación. El demandado planteó un recurso extraordinario con fundamento en que la cámara entendió que la apelación sólo se relacionaba con el pago de una suma de dinero cuando el mayor agravio que su parte sufrió fue la declaración de nulidad de las aludidas resoluciones. La Corte dejó sin efecto la sentencia apelada. Consideró que aun si se adoptara la postura más desfavorable para el recurrente, o sea considerar que debían aplicarse las previsiones de la norma citada, el valor económico involucrado en el proceso superaba el mínimo dispuesto por ella, por lo que la decisión impugnada se apartaba  palmariamente de lo estatuido por las normas aplicables al caso.</p>","esNovedad":true,"fecha":1694487600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1694692889761,"usuarioCreacion":11,"fechaCreacion":1694547961601,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":113899,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35022975,"numeroExpediente":44999,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1116,"descripcion":"PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 1 - TREBINO, EDUARDO ABEL c/ EN - M SEGURIDAD - PFA s/PERSONAL MILITAR Y CIVIL DE LAS FFAA Y DE SEG","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"44999. "},"recurso":{"id":5882860,"expediente":{"id":35022975,"numeroExpedie