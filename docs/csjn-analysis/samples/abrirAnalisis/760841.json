{"id":760841,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":80009,"valor":"ADMITE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231243,"fechaModLong":201008231243,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":230008,"valor":"RECURSO EXTRAORDINARIO POR SALTO DE INSTANCIA","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201311070841,"fechaModLong":201311071335,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":250005,"valor":"DDHH- Institucional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Bertuzzi, Pablo Daniel y otro c/ EN - PJN y otro s/ amparo ley 16.986 ","alias":null,"caratula":"Recurso Salto Instancia Nº 1 - BERTUZZI, PABLO DANIEL Y OTRO c/ EN-PJN Y OTRO s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":1485,"titulo":"Traslado de jueces federales y admisibilidad del recurso extraordinario por salto de instancia","cabecilla":"Decisión de primera instancia que rechazó el amparo interpuesto por magistrados integrantes de la Cámara Nacional de Apelaciones en lo Criminal y Correccional Federal de la Capital Federal contra el Estado Nacional - Planteo que persigue la inconstitucionalidad y nulidad de la resolución del Plenario del Consejo de la Magistratura que declaró que sus traslados desde tribunales orales federales al mencionado tribunal federal de alzada no habían completado el procedimiento constitucional - Interposición de recurso extraordinario por salto de instancia ante la Corte ante este rechazo - Derechos de acceso a justicia y de tutela efectiva resguardados en los artículos 18 y 43 de la Constitución Nacional y los instrumentos internacionales con jerarquía constitucional - Necesidad de que la tutela jurisdiccional de los derechos posea la virtualidad de resolver la cuestión sometida a su conocimiento mediante una respuesta judicial idónea, oportuna, efectiva y eficaz - El recurso extraordinario por salto de instancia constituye una vía procesal excepcionalísima, lo que exige que deba ser interpretada y aplicada de modo restringido - Exigencia del cumplimiento de diversos requisitos formales y sustanciales cuya verificación deba ser realizada con particular estrictez - Necesidad de que sea el único remedio eficaz para la protección del derecho federal comprometido - Al momento de interposición del recurso correspondía que la Corte se abstuviera de adoptar una decisión a fin de respetar el margen temporal prudencial de acción del tribunal de alzada - Las circunstancias originarias se han modificado por acontecimientos sobrevinientes que implican pasos concretos destinados a obtener la inmediata ejecución de las medidas impugnadas, con el riesgo cierto de tornar ilusorio el derecho cuya tutela procuran los actores - El planteo constitucional ventilado excede el mero interés de las partes en el proceso y atañe al de la comunidad- Garantía del juez natural - Se declara admisible el recurso extraordinario por salto de instancia sin que implique pronunciarse sobre el fondo de la cuestión- Se comunica al Consejo de la Magistratura que debe abstenerse de llevar adelante actos de ejecución de la resolución cuestionada hasta que se pronuncie la Corte - Voto del juez Rosenkrantz: causa en la que podría estar en juego la inamovilidad de los jueces nacionales - Impacto sistémico de la decisión a la que en definitiva se arribe - Caso que reviste una gravedad institucional inusitada - Intervención inmediata de la Corte como el único remedio eficaz para evitar tanto el daño individual sobre los derechos de los actores como, principalmente, el daño a las instituciones de la República","esNovedad":true,"fecha":1601348400000,"relevancia":3,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29599,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34970332,"numeroExpediente":11174,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1099,"descripcion":"AMPARO LEY 16.986","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Salto Instancia Nº 1 - BERTUZZI, PABLO DANIEL Y OTRO c/ EN-PJN Y OTRO s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"11174. "},"recurso":{"id":5866361,"expediente":{"id":34970332,"numeroExpediente":11174,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1099,"descripcion":"AMPARO LEY 16.986","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Salto Instancia Nº 1 - BERTUZZI, PABLO DANIEL Y OTRO c/ EN-PJN Y OTRO