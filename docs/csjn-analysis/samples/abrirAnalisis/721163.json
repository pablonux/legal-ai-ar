mutuo con promesa de constitución de hipoteca sobre la vivienda familiar de la deudora, era aplicables los precedentes \"Longobardi\" ( Fallos:330:5345, votos concurrentes) y \"Grillo\" ( FAllos:330:2902), que la ley 26.167 no resultaba aplicable y que la deuda debía liquidarse en la forma establecida por la alzada-consentida por el acreedor- y que según los términos de la ley 26.497 los montos del fideicomiso de refinanciación hipotecaria podían extenderse, a solicitud del deudor, hasta cubrir la deuda. \r\n-El Tribunal sostiene que la Cámara, en su nuevo fallo, ha utilizado argumentos que eluden la aplicación de la ley 26.497 apartándose de las pautas por él indicadas en su pronunciamiento anterior. ","comentarios":null,"enPreparacion":null,"formulaDesarrollo":null,"audPublica":"N","articulo16Ley48":"S","inicializacion":"N","amicue_curie":"N","conOpinion":null,"chequeoVoto":"S","cambiaJurisp":null,"sentenciaModelo":null,"citaDoctrina":null,"citaExtranjera":null,"votosOpinion":"N","art11Acordada4":null,"resolucionOriginarios":null,"cuestionesFederales":[{"tipoCuestionFederal":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":50001,"valor":"ARTÍCULO 14 DE LA LEY 48 ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JURJ3F","fechaCreacionLong":201006041222,"fechaModLong":202203141533,"orden":null,"visible":null},"usuarioCreacion":"JURC5F","usuarioModificacion":"JURC5F","fechaCreacion":201904161527,"fechaModificacion":201904161527}],"formulas":[],"recusExcus":[],"voces":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3890,"codigoRelacion":103890,"valor":"REFINANCIACION HIPOTECARIA","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009171335,"fechaModLong":201009171335,"orden":null,"visible":null},"orden":1,"usuarioCreacion":"JURC5F","usuarioModificacion":"JURC5F","fechaCreacion":201904161527,"fechaModificacion":201904161527},{"tipoVoz":{"codigoTabla":null,"codigoValor":3848,"codigoRelacion":103848,"valor":"VIVIENDA UNICA","activ