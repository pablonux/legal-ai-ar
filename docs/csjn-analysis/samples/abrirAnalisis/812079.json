{"id":812079,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 4 - PUGIBET FEVRIER JACQUELINE Y OTRO s/INCIDENTE CIVIL","inconstitucional":false,"falloDestacado":{"id":9165,"titulo":"Remoción de albacea: falta de tratamiento adecuado a la controversia","cabecilla":"<p style=\"text-indent:2em\">En el marco de un proceso sucesorio testamentario la cámara removió de su cargo al albacea ante lo solicitado por uno de los herederos forzosos.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia.</p><p style=\"text-indent:2em\">Consideró que en la ponderación de la intervención del albacea en la confección del inventario y el avalúo de los bienes que integran el acervo hereditario la cámara omitió analizar la conducta de los herederos como así también la inexistencia de un perjuicio concreto a los bienes inventariados que tuviera su causa en la actuación que el tribunal a quo reprochó al albacea.</p><p style=\"text-indent:2em\">Expresó también que la cámara tampoco había precisado cuál hubiera sido el temperamento correcto que debería haber adoptado el albacea ante el conflicto entre los herederos y los legatarios de cuota respecto de la composición y valuación del acervo.</p><p style=\"text-indent:2em\">Finalmente, con respecto al cuestionamiento de la cámara con relación a las actividades del albacea ajenas a su función que, a su entender, habían provocado demoras en el trámite del sucesorio, el Tribunal señaló que no se sustentaba en norma alguna que prohíba dicha actuación ni en argumentos que demuestren que esta hubiera sido la causa del referido retardo.</p>","esNovedad":true,"fecha":1752721200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1752854050467,"usuarioCreacion":11,"fechaCreacion":1752779467476,"privado":false,"posicion":8,"resumen":null},"reciboEntrada":{"id":140663,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35105747,"numeroExpediente":17936,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":8493,"descripcion":"SUCESION TESTAMENTARIA","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 1 - Incidente Nº 4 - PUGIBET FEVRIER JACQUELINE Y OTRO s/INCIDENTE CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"17936. "},"recurso":{"id":5911541,"expediente":{"id":35105747,"numeroExpediente":17936,"anioExpediente":2007,"tomoExpediente":null,"letraExpediente":null,"tipoExped