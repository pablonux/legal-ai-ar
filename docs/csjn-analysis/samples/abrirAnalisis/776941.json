l precedente “Graffigna Latino” (<a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=308&amp;pagina=961\">Fallos: 308:961</a>), rechazó el planteo por la falta de demostración de una grave transgresión a las reglas estructurales del debido proceso sin perjuicio de considerar que, además, mediaban en el recurso serios defectos de fundamentación que resultan especialmente graves cuando se presentan en una causa de revisión de un juicio político.</p>","esNovedad":true,"fecha":1660273200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1660330983802,"usuarioCreacion":4,"fechaCreacion":1660330796707,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":34705,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30059658,"numeroExpediente":48031,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descripcionLarga":"FLP - Justicia Federal de La Plata"},"objetoJuicio":{"id":11241,"descripcion":"RECURSO DIRECTO","idMateria":112,"tema":null},"caratula":"CABRERA LOPEZ, MARCO ANTONIO c/ DIRECCION NACIONAL DE MIGRACIONES s/RECURSO DIRECTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"48031. "},"recurso":{"id":5479619,"expediente":{"id":30059658,"numeroExpediente":48031,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descripcionLarga":"FLP - Justicia Federal de La Plata"},"objetoJuicio":{"id":11241,"descripcion":"RECURSO DIRECTO","idMateria":112,"tema":null},"caratula":"CABRERA LOPEZ, MARCO ANTONIO c/ DIRE