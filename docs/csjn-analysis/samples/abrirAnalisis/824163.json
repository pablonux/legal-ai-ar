{"id":824163,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"NOE, NESTOR c/ ANSES Y OTRO s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":10404,"titulo":"Arbitraria denegatoria de un beneficio jubilatorio","cabecilla":"<p style=\"text-indent: 2em;\">La cámara hizo lugar al recurso deducido por la Administración Nacional de la Seguridad Social y rechazó la acción de amparo tendiente a que se revoque la denegatoria del beneficio jubilatorio que había solicitado el actor - juez de faltas- en los términos de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/ley-24018-417/actualizacion\">ley 24.018</a> de Jubilaciones y Pensiones del Poder Ejecutivo, Poder Judicial y Legisladores.</p><p style=\"text-indent: 2em;\">La Corte dejó sin efecto este pronunciamiento por considerarlo arbitrario.</p><p style=\"text-indent: 2em;\">Señaló que el tribunal omitió considerar prueba conducente para la resolución del pleito en tanto no realizó una valoración de los actos previos de la administración que, en la práctica, equipararon la situación del actor con la de los jueces expresamente incluidos en el Anexo “A” del Acta Complementaria y, en consecuencia, en el sistema de la ley 24.018.</p><p style=\"text-indent: 2em;\">Tuvo en cuenta también que tanto la administración local como la federal, sin efectuar reclamo u objeción alguna, equipararon al actor a las personas comprendidas en el régimen de la ley mencionada y percibieron por un prolongado período de tiempo sus aportes a ese régimen, denegándole con posterioridad el acceso a la jubilación especial.</p>","esNovedad":true,"fecha":1773716400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1773778822331,"usuarioCreacion":11,"fechaCreacion":1773778819681,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":153799,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24937640,"numeroExpediente":95192,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":5,"codigo":"5","abreviatura":"CSS","descripcion":"Camara Federal de la Seguridad Social","estado":0,"descripcionLarga":"CSS - Camara Federal de la Seguridad Social"},"objetoJuicio":{"id":10604,"descripcion":"PENSIONES","idMateria":6,"tema":{"id":540,"codigo":"PREV"}},"caratula":"VILTE BENITA c/ ANSES s/PENSIONES","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"95192. "},"recurso":{"id":4899063,"