{"id":773607,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"INDAR TAX SA c/ G.C.B.A. Y OTROS s/IMPUGNACION ACTOS ADMINISTRATIVOS S/ RECURSO DE INCONSTITUCIONALIDAD CONCEDIDO","alias":null,"caratula":"INDAR TAX SA c/ G.C.B.A. Y OTROS s/IMPUGNACION ACTOS ADMINISTRATIVOS S/ RECURSO DE INCONSTITUCIONALIDAD CONCEDIDO","inconstitucional":false,"falloDestacado":{"id":3642,"titulo":"Atribuciones propias de las legislaturas locales para legislar sobre la caducidad de las licencias de taxi","cabecilla":"<p>Ante la sanci&oacute;n de caducidad de una licencia de taxi por haber sido conducido el veh&iacute;culo por un chofer que no estaba habilitado,&nbsp;la empresa accionante&nbsp;impugn&oacute; la resoluci&oacute;n y adujo que&nbsp;por error hab&iacute;a dado de baja dicho registro. Cuestion&oacute; tambi&eacute;n la&nbsp;constitucionalidad de la ordenanza de la Ciudad de Buenos Aires&nbsp;en que se fundaba&nbsp;por no contemplar atenuantes ni supuestos de excepci&oacute;n y, ante la desestimaci&oacute;n del planteo, interpuso un recurso extraordinario ante la Corte. El Tribunal, al desestimar el recurso, comenz&oacute; por recordar que&nbsp;la sola alegaci&oacute;n de que una norma vulnera la Constituci&oacute;n Nacional no satisface la exigencia de debida fundamentaci&oacute;n si no se expresan razones justificantes de tal aserto y que tampoco resulta suficiente la reiteraci&oacute;n dogm&aacute;tica de meras manifestaciones, opuestas con anterioridad y atendidas, a su turno, por los jueces de la causa. Se&ntilde;al&oacute; que la tacha de inconstitucionalidad de las normas se hallaba efectuada sobre la base de la aplicaci&oacute;n de la norma y no sobre su cotejo con los derechos y garant&iacute;as previstos en la Constituci&oacute;n Nacional y que&nbsp;parec&iacute;a que lo pretendido, m&aacute;s que el control de constitucionalidad de la norma, era obtener una norma confeccionada y sancionada a la medida de la actora. Destac&oacute; que la misi&oacute;n m&aacute;s delicada que compete al Poder Judicial es la de saber mantenerse dentro de la &oacute;rbita de su jurisdicci&oacute;n, sin menoscabar las funciones que incumben a otros poderes o jurisdicciones y que&nbsp;una decisi&oacute;n en el sentido propuesto por la apelante importar&iacute;a una intromisi&oacute;n en las atribuciones propias de la Legislatura del Gobierno de la Ciudad de Buenos Aires sobre el modo de legislar en una materia, como es el ejercicio del poder de polic&iacute;a local, que le resulta exclusiva y excluyente. Por otra parte, agreg&oacute; que&nbsp;no resultaba irrazonable ni desproporcionado establecer una sanci&oacute;n rigurosa frente a una falta de similar gravedad como es la conducci&oacute;n de tax&iacute;metro por un sujeto no habilitado, pues el sistema sancionatorio apunta a reducir la inseguridad vial al evitar que el transporte p&uacute;blico de pasajeros quede en manos de choferes inhabilitados, de los que no se sabe si re&uacute;nen o no los requisitos para desempe&ntilde;arse en dicha tarea.</p>","esNovedad":true,"fecha":1647918000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1648037622009,"usuarioCreacion":11,"fechaCreacion":1647977438553,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":33481,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32447146,"numeroExpediente":1638,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"INDAR TAX SA c/ G.C.B.A. Y OTROS s/IMPUGNACION ACTOS ADMINISTRATIVOS S/ RECURSO DE INCONSTITUCIONALIDAD CONCEDIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1638. "},"recurso":{"id":5408984,"expediente":{"id":32447146,"numeroExpediente":1638,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"INDAR TAX SA c/ G.C.B.A. Y OTROS s/IMPUGNACION ACTOS ADMINISTRATIVOS S/ RECURSO DE INCONSTITUCIONALIDAD CONCEDIDO"