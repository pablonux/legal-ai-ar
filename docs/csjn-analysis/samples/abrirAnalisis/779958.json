{"id":779958,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"MINISTERIO PUBLICO FISCAL s/INCIDENTE DE INCOMPETENCIA","alias":null,"caratula":"MINISTERIO PUBLICO FISCAL s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":4821,"titulo":"Competencia de la justicia federal para investigar un accidente aeronáutico","cabecilla":"<p>Con motivo del incendio en vuelo de una avioneta del que resultó su destrucción en tierra y el fallecimiento de los tres pasajeros y lesiones graves en el piloto se originó una contienda negativa de competencia entre la justicia provincial y la justicia federal. La Corte entendió que correspondía a esta última proseguir con el trámite de la causa ya que no podía descartarse que el hecho objeto de contienda hubiese afectado la seguridad de la navegación aérea. Tuvo en cuenta para ello que la Junta de Investigación concluyó que la aeronave siniestrada no estaba equipada de acuerdo con la normativa vigente, que la batería no era de uso aeronáutico y el tapizado no era ignífugo. Estas observaciones técnico operativas permitían entonces sostener que las condiciones riesgosas de vuelo en las que se originó el incendio de la avioneta determinaron que se frustrara la travesía de navegación programada y que su posterior destrucción en tierra no pudiera ser evitada con el aterrizaje forzoso realizado por el piloto.</p>","esNovedad":true,"fecha":1668481200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1668706905656,"usuarioCreacion":4,"fechaCreacion":1668534927055,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":105051,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34677475,"numeroExpediente":79637,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXPEDIENTES PENALES","idMateria":9,"tema":null},"caratula":"Incidente Nº 2 -  IMPUTADO: CRUZ, EMANUEL  s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"79637. "},"recurso":{"id":5852258,"expediente":{"id":34677475,"numeroExpediente":79637,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXPE