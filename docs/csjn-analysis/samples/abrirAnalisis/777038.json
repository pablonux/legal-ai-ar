{"id":777038,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"GIACOSA, LUIS RODOLFO Y BALDI, PEDRO RICARDO c/ SALTA, PROVINCIA DE s/ REGULACIÓN DE HONORARIOS","alias":null,"caratula":"GIACOSA, LUIS RODOLFO Y BALDI, PEDRO RICARDO c/ SALTA, PROVINCIA DE s/REGULACION DE HONORARIOS","inconstitucional":false,"falloDestacado":{"id":4281,"titulo":"Alcance de la prórroga de la competencia pactada en un convenio de servicios profesionales","cabecilla":"<p>Dos letrados, que intervinieron en una causa con competencia originaria ante la Corte, habían suscripto un convenio de actuación profesional según el cual cualquier divergencia que se suscitara con respecto a su interpretación o ejecución, las partes se sometían a la jurisdicción de los tribunales provinciales. En razón de ello, llegado el momento de la regulación de los emolumentos, la Corte remitió la causa a la justicia provincial. Ésta consideró que lo atinente a la determinación de la base y posterior regulación eran de competencia del Tribunal ante el cual tramitó de manera originaria la causa en la que los profesionales desplegaron su labor. La Corte, rechazó la radicación en su jurisdicción originaria por entender que la declaración de incompetencia que había realizado con motivo del pedido de regulación de los honorarios, importó desprenderse del conocimiento de la totalidad de las vicisitudes que podían presentarse en relación al contrato de locación de servicios celebrado entre las partes, en función de haberse prorrogado expresamente la competencia originaria del Tribunal ante cualquier divergencia vinculada a la ejecución del contrato, en favor de la jurisdicción provincial, a la que, por lo tanto, se habilitó para conocer en la cuestión sin límite alguno.</p>","esNovedad":true,"fecha":1659409200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1659546479072,"usuarioCreacion":11,"fechaCreacion":1659533655565,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":34729,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23443179,"numeroExpediente":425,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"G","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"GRANJA TRES ARROYOS S.A. Y OTRO c/ MENDOZA, PROVINCIA DE s/acción declarativa de inconstitucionalidad","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"G. 425. XLIX. "},"recurso":{"id":3107002,"expediente":{"id":23443179,"numeroExpediente":425,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"G","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de 