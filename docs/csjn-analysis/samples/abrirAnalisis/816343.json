{"id":816343,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - CASCANTE, ALEJANDRO EDUARDO c/ EN-ANAC s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":9503,"titulo":"Recurso extraordinario y recurso de queja invocando la calidad de gestor ","cabecilla":"<p style=\"text-indent: 2em;\">Un abogado interpuso un recurso de queja invocando la calidad de gestor del actor, de conformidad con la facultad prevista en el artículo 48 del Código Procesal Civil y Comercial de la Nación.</p><p style=\"text-indent: 2em;\">La Corte expresó que la norma mencionada admite la comparecencia en juicio de quien no tuviere representación conferida cuando deban realizarse actos procesales urgentes y existan hechos o circunstancias que impidan la actuación de la parte que ha de cumplirlos pero establece que dicha facultad sólo podrá ejercerse una vez en el curso del proceso.</p><p style=\"text-indent: 2em;\">Señaló que de las constancias de la causa resultaba que el letrado patrocinante del actor, en oportunidad de interponer el recurso extraordinario federal, había hecho uso de la facultad acordada en el mencionado artículo 48 por lo que, en atención a sus claros términos, el profesional no podía recurrir nuevamente a esa facultad al deducir la presentación directa ante la Corte.</p><p style=\"text-indent: 2em;\">En consecuencia, y toda vez que el escrito de interposición del recurso de queja solo contaba con la firma del letrado patrocinante, el Tribunal consideró que constituía un acto jurídico inexistente y no susceptible de convalidación posterior y desestimó la queja.</p>","esNovedad":true,"fecha":1759806000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1759865191167,"usuarioCreacion":11,"fechaCreacion":1759865183921,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":144861,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32150079,"numeroExpediente":66736,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 2 - CHAVEZ FREFERIC, AGUSTIN ANTONIO c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"66736. "},"recurso":{"id":5373164,"expediente":{"id":32150079,"numeroExpediente":66736,"anioExpediente":2017,"