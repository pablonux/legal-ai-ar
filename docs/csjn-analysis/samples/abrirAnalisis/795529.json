{"id":795529,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"A., L. G. c/ R.G.F., F. s/ALIMENTOS","inconstitucional":false,"falloDestacado":{"id":6682,"titulo":"Incompetencia de la jurisdicción originaria en un reclamo de cuota alimentaria contra un cónsul extranjero","cabecilla":"<p style=\"text-indent:2em\">La justicia local se declaró incompetente para entender en una demanda de pago de cuota alimentaria por considerar que al ser el demandado -padre de los niños- cónsul de la República Federativa del Brasil de la República Federativa del Brasil, ella correspondía a la instancia originaria de la Corte Suprema. </p><p style=\"text-indent:2em\">El Tribunal declaró su incompetencia para entender en la causa.</p><p style=\"text-indent:2em\">Consideró que la pretensión, en tanto no se encuentra vinculada con el ejercicio de las funciones propias del carácter de cónsul del demandado, es ajena a los privilegios y exenciones que corresponden a los funcionarios consulares en su carácter público. Señaló que la competencia originaria de la Corte respecto de los cónsules extranjeros está reservada a las causas que versan sobre privilegios y exenciones de aquellos en su carácter público, debiendo entenderse por tales las seguidas por hechos o actos cumplidos en ejercicio de sus funciones propias, siempre que en ellas se cuestione su responsabilidad civil o criminal.</p>","esNovedad":true,"fecha":1713236400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1713362370882,"usuarioCreacion":4,"fechaCreacion":1713297041480,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":119240,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23429743,"numeroExpediente":51,"anioExpediente":1988,"tomoExpediente":22,"letraExpediente":"O","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":614,"descripcion":"ESCRITURACION","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"OGANDO ROBERTO AGUSTIN c/ PROVINCIA DE BUENOS AIRES Y BCO.AGRARIO COMER CIAL E INDUSTRIAL S.A. s/ESCRITURACION - ESCRITURACION","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"O. 51. XXII. "},"recurso":{"id":3064208,"expediente":{"id":23429743,"numeroExpediente":51,"anioExpediente":1988,"tomoExpediente":22,"letraExpediente":"O","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":614,"descripcion":"ESCRITURACION","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"OGANDO ROBERTO AGUSTIN c/ PROVINCIA DE BUENOS AIRES Y BCO.AGRARIO COMER CIAL E INDUSTRIAL S.A. s/ESCRITURACION - ESCRITURACION","verificacionMesa":"M","etiqueta":"