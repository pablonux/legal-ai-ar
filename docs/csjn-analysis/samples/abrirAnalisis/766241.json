{"id":766241,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"COCA COLA FEMSA DE BUENOS AIRES S.A. c/ BUENOS AIRES, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","alias":null,"caratula":"COCA COLA FEMSA DE BUENOS AIRES S.A. c/ BUENOS AIRES, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","inconstitucional":false,"falloDestacado":{"id":1925,"titulo":"Impuesto sobre los ingresos brutos y requisito de peligro irreparable en la demora para una tutela anticipada","cabecilla":"<p>&nbsp;Acci&oacute;n declarativa de certeza a fin de hacer cesar el estado de incertidumbre que conlleva la aplicaci&oacute;n de una diferencia de al&iacute;cuota m&aacute;s gravosa en la determinaci&oacute;n del impuesto sobre los ingresos brutos por aquellos ingresos provenientes de la jurisdicci&oacute;n demandada, cuando parte de la actividad es desarrollada en un establecimiento industrial fuera de esa jurisdicci&oacute;n - Solicitud del dictado de una medida cautelar de no innovar - Realizaci&oacute;n de audiencias - Manifestaci&oacute;n de las partes referida a la imposibilidad de arribar a un acuerdo - Todo sujeto que pretenda la tutela anticipada proveniente de una medida precautoria debe acreditar prima facie la existencia de verosimilitud en el derecho invocado y el peligro irreparable en la demora - El examen de la concurrencia del segundo requisito mencionado exige una apreciaci&oacute;n atenta de la realidad comprometida - Extremo que debe resultar en forma objetiva del examen sobre los distintos efectos que podr&iacute;a provocar la aplicaci&oacute;n de las diversas disposiciones impugnadas - Elementos y antecedentes considerados hasta el momento que no permiten tener por configurados dichos presupuestos de admisibilidad de la cautela requerida - La accionada no ha iniciado, por el momento, procedimiento de verificaci&oacute;n alguno tendiente a determinar la existencia de una deuda - Se declara que la causa corresponde a la competencia originaria de la Corte y se rechaza la medida cautelar requerida.</p>","esNovedad":true,"fecha":1620874800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1621018363982,"usuarioCreacion":11,"fechaCreacion":1621017652594,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31028,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29115642,"numeroExpediente":1925,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"GOBIERNO DE LA CIUDAD DE BUENOS AIRES c/ BUENOS AIRES, PROVINCIA DE s/EJECUCIÓN FISCAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1925. "},"recurso":{"id":4981247,"expediente":{"id":29115642,"numeroExpediente":192