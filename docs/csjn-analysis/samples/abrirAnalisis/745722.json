{"id":745722,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":{"codigoTabla":null,"codigoValor":380,"codigoRelacion":90380,"valor":"COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201903220947,"fechaModLong":201903220947,"orden":null,"visible":null},"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"José Mármol 824 (ocupantes de la finca) s/ incidente de incompetencia","alias":null,"caratula":"Incidente Nº 1 -  IMPUTADO: JOSE MARMOL 824 (OCUPANTES DE LA FINCA), . s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":1156,"titulo":" La Corte Suprema debe resolver los conflictos de competencia entre magistrados nacionales y federales con asiento en la Ciudad Autónoma de Buenos Aires .","cabecilla":"<p>Causa instruida a ra&iacute;z de un procedimiento policial por emanaci&oacute;n de olores t&oacute;xicos procedentes de un dep&oacute;sito situado en la Ciudad de Buenos Aires - El juez federal declin&oacute; la competencia por no haber afectaci&oacute;n interjurisdiccional alguna - El juez nacional de instrucci&oacute;n rechaz&oacute; la competencia por tratarse de materia federal (art. 58 ley 24.051) - La Corte entiende que dicha contienda debe ser resuelta a la luz de la doctrina de los precedentes Nisman&nbsp;(Fallos: 339:1342), consid. 5&deg;) y Corrales&nbsp;(Fallos: 338:1517, voto de Lorenzetti y Maqueda) - Se abandona el criterio que situaba a estos supuestos en la excepci&oacute;n prevista en el art. 24, inc. 7&deg; del decreto-ley 1285/58, seg&uacute;n el cual los conflictos de competencia entre magistrados nacionales y federales con asiento en la Ciudad Aut&oacute;noma de Buenos Aires deb&iacute;an ser resueltos por la c&aacute;mara de la que depend&iacute;a el juez que primero hubiera conocido y se establece que corresponde a la Corte resolverlos en virtud de lo dispuesto en el primer supuesto contemplado en dicha norma - Se declara la competencia de la justicia nacional de instrucci&oacute;n - Disidencia de la jueza Highton de Nolasco: contienda entre dos jueces nacionales - Debe ser dirimida por el tribunal de alzada correspondiente a aquel que haya prevenido - Disidencia del juez Rosenkrantz: Los fallos &quot;Corrales&quot; y &quot;Nisman&quot; no modificaron la interpretaci&oacute;n de la regla de competencia prevista en la norma indicada, por ello estos conflictos de competencia entre jueces nacionales de primera instancia deben ser resueltos por la alzada del juez preventor</p>","esNovedad":true,"fecha":1528772400000,"relevancia":3,"usuarioModificacion":13,"fechaModificacion":1598985544768,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":23871,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":27663060,"numeroExpediente":9688,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcio