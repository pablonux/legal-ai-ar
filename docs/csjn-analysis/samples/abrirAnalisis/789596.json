{"id":789596,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":40,"codigoRelacion":80040,"valor":"PROCEDIMIENTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201512101503,"fechaModLong":201512101503,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"FRIGORIFICO PALADINI S.A. c/ ENTRE RIOS, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","inconstitucional":false,"falloDestacado":{"id":6024,"titulo":"Tasa de justicia en un juicio no susceptible de apreciación pecuniaria","cabecilla":"<p>En el marco de la jurisdicción originaria la actora perseguía una declaración que hiciera cesar el estado de incertidumbre en torno a la constitucionalidad de las normas tributarias provinciales que le impusieron la aplicación de una alícuota diferencial al impuesto sobre los ingresos brutos que debía tributar. La Corte entendió que de la demanda no se podían extraer elementos que permitieran afirmar que se pretendía un resarcimiento económico o neutralizar el actuar de la administración del que surgiera un explícito propósito de percibir una suma de dinero y que solo se perseguía un pronunciamiento declarativo con efectos hacia el futuro, sin retroactividad alguna. Concluyó así que ello impedía afirmar que el litigio tuviera un valor económico determinado por lo que el pago efectuado resultaba suficiente y cancelatorio de la tasa de justicia correspondiente a las actuaciones en los términos del art. 6° de la ley 23.898.</p>","esNovedad":true,"fecha":1697684400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1697747266052,"usuarioCreacion":11,"fechaCreacion":1697747010958,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":114783,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30590809,"numeroExpediente":1997,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION DECLARATIVA DE CERTEZA","idMateria":0,"tema":null},"caratula":"FRIGORIFICO PALADINI S.A. c/ ENTRE RIOS, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1997. "},"recurso":{"id":5193942,"expediente":{"id":30590809,"numeroExpediente":1997,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION DECLARATIVA DE CERTEZA","idMateria":0,"tema":null},"caratula":"FRIGORIFICO PALADINI S.A. c/ ENTRE RIOS, PROVINCIA DE s/ACCION DECLARATIVA DE CERTEZA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1997. "},"tipoRecurso":{"id":1243,"codigo":"CIR","descripcion":"CIRCULACION DEL EXPEDIENTE"},"claveRecurso":null,"identificacionExpediente":"CSJ 1997/2017"},"piezas":1,"urgente":null,"observ