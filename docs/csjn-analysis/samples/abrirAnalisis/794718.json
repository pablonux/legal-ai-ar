{"id":794718,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"REQUERIDO: QUIÑONES DE LA CRUZ, NESTOR PEDRO s/EXTRADICION","inconstitucional":false,"falloDestacado":{"id":6602,"titulo":"Extradición: duración razonable del procedimiento extranjero","cabecilla":"<p style=\"text-indent: 2em;\">El juez de primera instancia denegó la extradición del requerido a la República del Perú para ser sometido a enjuiciamiento por el delito de robo agravado y ello originó el recurso de los representantes del Ministerio Público Fiscal.</p><p style=\"text-indent: 2em;\">La Corte revocó la sentencia apelada y declaró procedente la extradición.</p><p style=\"text-indent: 2em;\">Tuvo en cuenta que juez había considerado que se había violado el plazo razonable de duración del proceso en el extranjero, para lo cual acudió a estándares de la jurisprudencia interamericana y citó precedentes de la Corte aplicables a procedimientos judiciales internos cuando en realidad sólo podía ingresar al análisis de ese aspecto por el estrecho marco de las normas del código penal del país requirente en razón de la limitación cognoscitiva que establece el tratado aplicable. Concluyó en este punto que mantenía subsistencia temporal la persecución penal en el país extranjero, con arreglo a las disposiciones expresas de su legislación.</p><p style=\"text-indent: 2em;\">Con respecto al segundo argumento señaló que ni el tratado internacional ni la ley nacional prevén como impedimento para conceder la extradición que el requerido tenga una familia con hijos menores de edad, máxime si se tiene en consideración que en el caso quedarían al cuidado de su pareja.</p>","esNovedad":true,"fecha":1710817200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1710939319539,"usuarioCreacion":4,"fechaCreacion":1710939316915,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":118556,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35305688,"numeroExpediente":921,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":15,"codigo":"15","abreviatura":"FCB","descripcion":"Justicia Federal de Córdoba","estado":0,"descripcionLarga":"FCB - Justicia Federal de Córdoba"},"objetoJuicio":{"id":2581,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"REQUERIDO: QUIÑONES DE LA CRUZ, NESTOR PEDRO s/EXTRADICION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"921. "},"recurso":{"id":6440788,"expediente":{"id":35305688,"numeroExpediente":921,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":15,"codigo":"15","abreviatura":"FCB","descripcion":"Justicia Federal de Cór