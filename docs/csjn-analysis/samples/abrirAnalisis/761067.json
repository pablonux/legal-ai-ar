{"id":761067,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"Padilla, Laura Rosario c/ Hospital de General Roca y otros s/ amparo  apelación ","alias":null,"caratula":"PADILLA, LAURA ROSARIO c/ HOSPITAL DE GENERAL ROCA Y OTROS s/amparo - apelacion","inconstitucional":false,"falloDestacado":{"id":1571,"titulo":"El deber de fundar las sentencias cuando se trata de  reclamaciones basadas en la tutela del derecho a la salud","cabecilla":"Pronunciamiento que condenó a un hospital, al ministerio de salud pública provincial y a la provincia a brindar a la peticionaria la cobertura al 100% de las prestaciones médicas sobre la base de que  los magros ingresos de la actora le impedían afrontar el costo de los coseguros exigidos por la obra social a la que se hallaba afiliada - Procedencia del recurso extraordinario interpuesto por la demandada pues el fallo dictado por el superior tribunal de la causa, afecta la garantía de defensa en juicio en tanto se apartó de las circunstancias del caso y de las normas aplicables a este - Planteos que exigían al tribunal a quo una especial consideración - Agravios relativos a que el convenio en el que la actora fundó su pretensión no incluyó disposición alguna sobre la atención de su salud y a que el Estado se halla obligado a brindar las prestaciones enunciadas en la ley de Discapacidad solo de manera subsidiaria, pues dicha cobertura corresponde a las obras sociales - Fallo que luce dogmático - No hay razones que justifiquen eximir ni mitigar el deber de fundar las sentencias cuando se trata de  reclamaciones basadas en la tutela del derecho a la salud - Exigencia arraigada en la Constitución Nacional y en la Convención Americana sobre Derechos Humanos de que los fallos cuenten con argumentos consistentes y racionalmente sostenibles, al encontrarse comprometidas las garantías de defensa en juicio y de tutela judicial efectiva de las partes - Se deja sin efecto la sentencia apelada - Disidencia del juez Rosatti: recurso extraordinario inadmisible (art. 280 CPCCN)","esNovedad":true,"fecha":1605150000000,"relevancia":2,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29676,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32062247,"numeroExpediente":1090,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"PADILLA, LAURA ROSARIO c/ HOSPITAL DE GENE