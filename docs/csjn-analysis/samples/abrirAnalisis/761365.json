o implica la afectación del principio de congruencia y de las garantías de defensa y debido proceso - La oportunidad de los tribunales de origen para desprenderse de las actuaciones sólo puede verificarse al inicio de la acción o al resolver una excepción de competencia - El juez de primera instancia había aceptado la competencia para entender en el caso, sustanciado la apelación y dictado la sentencia interlocutoria que concluyó el proceso - Causa que lleva más de 8 años en trámite ante el fuero federal - Incompetencia que no fue declarada por el juez de grado, sino por la cámara, en forma extra petita, ante la apelación que cuestionaba la declaración de caducidad de instancia - Vulneración del principio de congruencia al pronunciarse sobre una cuestión que no fue objeto de análisis en la sentencia de primera instancia y no se encontraba controvertida por las partes - Se deja sin efecto la sentencia apelada","esNovedad":true,"fecha":1605150000000,"relevancia":1,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29771,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":15534806,"numeroExpediente":22093981,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":9162,"descripcion":"RECURSO DE APELACION LEY 24557","idMateria":112,"tema":null},"caratula":"LIMA ARNALDO RUBEN c/ PROVINCIA ART SA s/RECURSO DE APELACION LEY 24557","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"22093981. "},"recurso":{"id":5559149,"expediente":{"id":15534806,"numer