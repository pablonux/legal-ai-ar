unal referente a que el examen de normas de derecho común, de derecho público local y la apreciación de la prueba constituyen, por vía de principio, facultad de los jueces de la causa y no son susceptibles de revisión en la instancia extraordinaria, ello no es óbice para que la Corte pueda conocer en los casos cuyas particularidades hacen excepción a ese principio, como aconteció en el caso toda vez que la decisión recurrida no constituye una derivación razonada del derecho vigente con arreglo a las circunstancias comprobadas del caso y afecta en forma directa e inmediata garantías constitucionales - Exigencia de que las sentencias sean fundadas y constituyan una derivación razonada del derecho vigente con aplicación a las circunstancias comprobadas de la causa - En uso de las atribuciones conferidas por el art. 16, segundo párrafo, de la ley 48, se deja sin efecto la sentencia apelada","esNovedad":true,"fecha":1600311600000,"relevancia":2,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29232,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30135211,"numeroExpediente":1205,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"BARRACO, VICTOR DOMINGO c/ BODEGAS Y VIÑEDOS GIOL (EN LIQUIDACION) s/COBRO DE PESOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1205. "},"recurso":{"id":5125275,"expediente":{"id":30135211,"numeroExpediente":1205,"ani