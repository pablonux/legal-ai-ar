{"id":768549,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":80008,"valor":"RECHAZA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231243,"fechaModLong":201008231243,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"COMUNIDAD INDIGENA TOBA LA PRIMAVERA - NAVOGOH c/ FORMOSA, PROVINCIA DE Y OTROS s/ORDINARIO","alias":null,"caratula":"COMUNIDAD INDIGENA TOBA LA PRIMAVERA - NAVOGOH c/ FORMOSA, PROVINCIA DE  Y OTROS s/ORDINARIO","inconstitucional":false,"falloDestacado":{"id":2501,"titulo":"Pretensión de reconocimiento de propiedad comunitaria indígena","cabecilla":"<p>Impugnaci&oacute;n del relevamiento t&eacute;cnico-jur&iacute;dico-catastral de la situaci&oacute;n dominial de las tierras ocupadas por la comunidad actora -&nbsp;Cuestionamiento referido a que no se habr&iacute;a respetado el croquis elaborado por los miembros de la comunidad en el que se ubicaron una serie de top&oacute;nimos (puntos de posesi&oacute;n y uso comunitario) que se encuentran &iacute;ntimamente relacionados con su cultura y que forman parte del territorio ancestral reclamado -&nbsp;Planteo referido a que&nbsp;la conclusi&oacute;n del relevamiento no puede hacer caducar su leg&iacute;timo derecho a las tierras ancestrales, ya que de ese modo se estar&iacute;a desconociendo la vigencia de la Convenci&oacute;n Americana de Derechos Humanos en punto al reconocimiento del derecho de los pueblos originarios al goce de dichas tierras - Solicitud de que&nbsp;se disponga la ampliaci&oacute;n de la medida cautelar oportunamente decretada, a fin de ordenarle a la Administraci&oacute;n de Parques Nacionales que garantice el uso tradicional ind&iacute;gena y el acceso al sector reclamado - Las impugnaciones formuladas se encuentran directamente vinculadas a la cuesti&oacute;n de fondo planteada en el proceso principal - Ninguna decisi&oacute;n corresponde adelantar en el estado procesal en el que se encuentran las actuaciones - La admisi&oacute;n de la pretensi&oacute;n cautelar afectar&iacute;a el ejercicio de las atribuciones y funciones de manejo, control y vigilancia del &aacute;rea asignada al Parque Nacional R&iacute;o Pilcomayo en cabeza del organismo de aplicaci&oacute;n nacional -&nbsp;Se resuelve diferir la decisi&oacute;n para luego del dictado de la sentencia definitiva.</p>","esNovedad":true,"fecha":1628737200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1628880303131,"usuarioCreacion":11,"fechaCreacion":1628857088099,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31705,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23344661,"numeroExpediente":528,"anioExpediente":2011,"tomoExpediente":47,"letraExpediente":"C","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"COMUNIDAD INDIGENA TOBA LA PRIMAVERA - NAVOGOH c/ FORMOSA, PROVINCIA DE  Y OTROS s/ORDINARIO","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldId