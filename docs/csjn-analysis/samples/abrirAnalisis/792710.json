{"id":792710,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - GORRITI ECHEGARAY, DARIO PEDRO c/ SWISS MEDICAL ART S.A. Y OTROS s/OTROS RECLAMOS","inconstitucional":false,"falloDestacado":{"id":6381,"titulo":"Competencia en la revisión judicial de las decisiones de las comisiones médicas","cabecilla":"<p> </p><p style=\"text-indent:2em\">La Cámara Nacional de Apelaciones del Trabajo señaló que la revisión judicial de las decisiones de las comisiones médicas corresponde a la justicia ordinaria del fuero laboral de la jurisdicción provincial o de la Ciudad Autónoma de Buenos Aires, según corresponda al domicilio de la comisión médica que intervino.</p><p style=\"text-indent:2em\">Apelada la cuestión, la Corte desestimó el recurso por considerar que <b>las decisiones en materia de competencia no constituyen fallos definitivos </b>a los fines del recurso extraordinario excepto que concurra la denegatoria del fuero federal o una efectiva privación de justicia. No consideró presente el primer supuesto ya que la sentencia no denegaba el fuero federal ya que solo atribuía competencia a la justicia laboral local y el actor pretendía la nacional del trabajo. Tampoco se colocaba al impugnante en una situación de privación de justicia que afectara en forma directa e inmediata la defensa en juicio, pues no se había clausurado la vía procesal promovida.</p>","esNovedad":true,"fecha":1707188400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1707402948973,"usuarioCreacion":4,"fechaCreacion":1707242827198,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":116781,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35284914,"numeroExpediente":47587,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9736,"descripcion":"OTROS RECLAMOS","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - GORRITI ECHEGARAY, DARIO PEDRO c/ SWISS MEDICAL ART S.A. Y OTROS s/OTROS RECLAMOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"47587. "},"recurso":{"id":5967338,"expediente":{"id":35284914,"numeroExpediente":47587,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abrevia