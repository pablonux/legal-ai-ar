{"id":793195,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"IRIGOYTIA, CARLOS FRANCISCO Y OTROS c/ SUPERIOR GOBIERNO DE LA PROVINCIA DE ENTRE RIOS s/ordinario - daños y perjuicios ","inconstitucional":false,"falloDestacado":{"id":6402,"titulo":"Responsabilidad del Estado por error judicial. Exigencias para su procedencia","cabecilla":"<p style=\"text-indent:2em\">Los actores promovieron demanda de daños y perjuicios contra la Provincia de Entre Ríos por el accionar ilegítimo del poder judicial local, derivado de la prisión preventiva y procesamiento.</p><p style=\"text-indent:2em\">La Corte provincial desestimó el reclamo por considerar que no se encontraban reunidos los recaudos para la procedencia de la responsabilidad del Estado pues los daños que los actores manifestaban haber sufrido comportaban consecuencias normales y procesales del ejercicio regular del servicio de justicia.</p><p style=\"text-indent:2em\">Recurrida la decisión, <b>la Corte confirmó la sentencia apelada</b>. Según el Tribunal (que remitió al dictamen del Procurador) es preciso tener en cuenta que la sola circunstancia de haber sido absuelto el imputado en la causa penal no basta para responsabilizar al Estado de los daños sufridos por el procesado durante el término de su detención.</p><p style=\"text-indent:2em\">Conforme a ello, recordó la Corte, como principio, sólo puede responsabilizarse al Estado por error judicial en la medida en que el acto jurisdiccional que origina el daño haya sido declarado ilegítimo y dejado sin efecto, pues antes de ese momento el carácter de verdad legal que ostenta la sentencia pasada en autoridad de cosa juzgada impide, en tanto se mantenga, juzgar que hay error. Lo contrario importaría un atentado contra el orden social y la seguridad jurídica, pues la acción de daños y perjuicios constituiría un recurso contra el pronunciamiento firme, no previsto ni admitido por ley (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=311&amp;pagina=1007\">311:1007</a> y <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=318&amp;pagina=1990\">318:1990</a>).</p>","esNovedad":true,"fecha":1708398000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1708610480101,"usuarioCreacion":4,"fechaCreacion":1708520798801,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":117260,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expedie