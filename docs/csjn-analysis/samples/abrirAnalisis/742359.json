{"id":742359,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":80003,"valor":"REVOCA PARCIALMENTE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051034,"fechaModLong":201008181300,"orden":null,"visible":null},"materia":{"codigoTabla":null,"codigoValor":381,"codigoRelacion":90381,"valor":"CONSTITUCIONAL","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"SJC287","fechaCreacionLong":201903220948,"fechaModLong":201909170908,"orden":null,"visible":null},"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"Castillo, Carina Viviana y otros c/ Provincia de Salta - Ministerio de Educación de la Prov. de Salta s/ amparo ","alias":null,"caratula":"CASTILLO, CARINA VIVIANA Y OTROS Y OTRO c/ PROVINCIA DE SALTA MINISTERIO DE EDUCACION DE LA PROV. DE SALTA s/AMPARO","inconstitucional":true,"falloDestacado":{"id":321,"titulo":"Educación religiosa en escuelas públicas en la Provincia de Salta","cabecilla":"<p>Acci&oacute;n de amparo colectiva - Sostenimiento de la religi&oacute;n cat&oacute;lica como limitado al &quot;sostenimiento econ&oacute;mico&quot; - Principio de neutralidad - Criterios de control de constitucionalidad m&aacute;s estrictos que los tradicionales - Examen m&aacute;s riguroso que la sola razonabilidad - Categor&iacute;as sospechosas e inversi&oacute;n de la carga de la prueba - Norma que incluye la educaci&oacute;n religiosa en horario escolar, dentro del plan de estudios y con el aval de la autoridad religiosa - Norma de apariencia neutral pero con efectos discriminatorios - Pr&aacute;cticas y usos propios del catolicismo efectuados fuera del espacio curricular destinado a la educaci&oacute;n religiosa - Patrones sistem&aacute;ticos de trato desigualitario hacia grupos religiosos minoritarios y hacia los no creyentes - Formularios para manifestar voluntad de que los hijos reciban educaci&oacute;n religiosa como violaci&oacute;n al derecho de no revelar aspectos de la esfera personal - Derecho a recibir contenidos de historia y filosof&iacute;a de las religiones expuestos de manera objetiva y neutral - Se revoca parcialmente la sentencia apelada declarando la inconstitucionalidad del inc. &quot;&ntilde;&quot; del art. 27 de la ley 7546 y de la disposici&oacute;n 45/09 de la Direcci&oacute;n General de Educaci&oacute;n Primaria y Educaci&oacute;n Inicial de la Provincia de Salta - Disidencia parcial del Juez Rosatti: Libertad religiosa en su dimensi&oacute;n negativa como reconocimiento de la existencia de una esfera de inmunidad de coacci&oacute;n y en su dimensi&oacute;n positiva como &aacute;mbito de autonom&iacute;a personal que permite a los hombres actuar libremente - Conocimientos sobre el n&uacute;cleo de las creencias y valores que respondan a las convicciones de los padres con una pedagog&iacute;a neutral y objetiva que valide la pluralidad - Contenido curricular que respete ense&ntilde;anza de otros cultos, ate&iacute;smo y agnosticismo - Deber para el estado provincial de realizar una oferta educativa pluralista y objetiva - Constitucionalidad de la normativa cuestionada - Antijuridicidad de las pr&aacute;cticas que desvirt&uacute;an las normas - Se declara la inconstitucionalidad de toda pr&aacute;ctica que, en la implementaci&oacute;n de la ense&ntilde;anza de religi&oacute;n implique la prevalencia conceptual de un culto por sobre los dem&aacute;s y de la obligaci&oacute;n para los alumnos de tener que permanecer en el aula cuando se desarrollan las clases de religi&oacute;n que no respeten las convicciones de sus padres</p>","esNovedad":true,"fecha":1513047600000,"relevancia":3,"usuarioModificacion":5,"fechaModificacion":1598988449991,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":22844,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24119409,"numeroExpediente":1870,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":1226,"descripcion":"AMPARO","idMateria":3,"tema":{"id":460,"codigo":"AMPAROS"}},"caratula":"CASTILLO, CARINA VIVIANA Y OTROS Y OTRO c/ PROVINCIA DE SALTA MINISTERIO DE EDUCACION DE LA PROV. DE SALTA s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1870. "},"recurso":{"id":3566417,"expediente":{"id":24119409,"numeroExpediente":1870,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":1226,"descripcion":"AMPARO","idMateria":3,"tema":{"id":460,"codigo":"AMPAROS"}},"caratula":"CASTILLO, CARINA VIVIANA Y OTROS Y OTRO c/ PRO