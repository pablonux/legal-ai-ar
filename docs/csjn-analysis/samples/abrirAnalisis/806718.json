{"id":806718,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"RODRIGUEZ, DANIEL PASCUAL Y OTROS c/ TELEFONICA MOVILES DE ARGENINA S.A. s/AMPARO AMBIENTAL","inconstitucional":false,"falloDestacado":{"id":8541,"titulo":"Amparo ambiental por funcionamiento de una antena de telefonía celular: competencia federal","cabecilla":"<p style=\"text-indent:2em\">Los vecinos promovieron un amparo ambiental a fin de obtener de manera urgente e inmediata el cese del funcionamiento y el desmantelamiento de una antena portante de telefonía celular y ello originó un conflicto negativo de competencia entre la justicia local y la justicia federal.</p><p style=\"text-indent:2em\">La Corte decidió que esta última debía entender en la causa.</p><p style=\"text-indent:2em\">Señaló que para resolver el pleito hay que interpretar el sentido y alcance de normas de carácter federal, como lo es la ley de comunicaciones 19.798 y que, además, podría verse comprometido el servicio telefónico celular empleado a nivel interprovincial o internacional y ello afectaría intereses que exceden los encomendados a los tribunales provinciales y se encuentran reservados a la jurisdicción federal.</p>","esNovedad":true,"fecha":1744254000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1744386439031,"usuarioCreacion":4,"fechaCreacion":1744372718121,"privado":false,"posicion":5,"resumen":{"idResumen":148,"resumen":"La Corte resolvió que la justicia federal debe entender en el amparo ambiental por la antena de telefonía celular, ya que implica interpretar normas federales y podría afectar el servicio telefónico interprovincial/internacional.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":134018,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37072047,"numeroExpediente":2080,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"N. N. s/INCIDENTE DE INCOMPETENCIA - DENUNCIANTE: GIGLIO, MIRIAM FABIANA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2080. "},"recurso":{"id":6417129,"expediente":{"id":37072047,"numeroExpediente":2080,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,