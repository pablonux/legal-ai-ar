{"id":796417,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - R., P. c/ OSDE s/SUMARISIMO DE SALUD","inconstitucional":false,"falloDestacado":{"id":6881,"titulo":"Argumentos dogmáticos y contradictorios para denegar una prestación a una persona con discapacidad","cabecilla":"<p style=\"text-indent:2em\">La cámara rechazó la acción de amparo para que se le brindara al actor la cobertura de las prestaciones educativas previstas en la ley 24.901 sobre prestaciones básicas en habilitación y rehabilitación integral a favor de las personas con discapacidad.</p><p style=\"text-indent:2em\"><b>La Corte dejó sin efecto esta decisión</b>.</p><p style=\"text-indent:2em\">Señaló que los argumentos para mostrar que la demanda no debía cubrir la prestación solicitada constituían observaciones dogmáticas y notoriamente contradictorias. Según la Corte, la cámara comenzó su razonamiento procurando evidenciar la carga probatoria pero seguidamente descartó la procedencia de la reclamación, sin ponderar que la <em>actora había demostrado las circunstancias exigidas a la parte peticionaria en dicho fallo, relativas tanto a la condición de su hijo y a su carácter de afiliado, como a la prescripción profesional sobre la necesidad de la prestación educativa que reclamaba. </em></p><p style=\"text-indent:2em\">Agregó que la sentencia soslayó además que era la demandada la que debía ocuparse concretamente de probar y poner a disposición de la peticionaria una institución adecuada para satisfacer la prestación, así como de demostrar que la modificación de la institución educativa de que se trate no resultaría nociva para la evolución del niño.</p>","esNovedad":true,"fecha":1716260400000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1716396810749,"usuarioCreacion":4,"fechaCreacion":1716317255349,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":120281,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35506666,"numeroExpediente":29055,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - GONZALEZ, RAMON ANTONIO c/ ABRIL S.A. Y OTRO s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"29055. "},"recurso":{"id":6036539,"expediente":{"id":35506666,"numeroExpediente":29055,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codig