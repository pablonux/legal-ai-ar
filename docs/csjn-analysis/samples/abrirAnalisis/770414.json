{"id":770414,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"CAILLAVA, ADRIANA LAURA Y OTROS c/ VESS LOGISTICA SRL (SINDICO DELAVAULT FERNANDO AGUSTIN) Y OTROS s/ACCIDENTE - ACCION CIVIL","alias":null,"caratula":"Recurso Queja Nº 2 - CAILLAVA, ADRIANA LAURA Y OTROS c/ VESS LOGISTICA SRL (SINDICO DELAVAULT FERNANDO AGUSTIN) Y OTROS s/ACCIDENTE - ACCION CIVIL","inconstitucional":false,"falloDestacado":{"id":2962,"titulo":"Exclusión de la responsabilidad civil de la aseguradora de riesgos del trabajo","cabecilla":"<p>La viuda de trabajador fallecido mientras conduc&iacute;a en Brasil un cami&oacute;n de una de las empresas demandadas, promovi&oacute; la acci&oacute;n por los da&ntilde;os y perjuicios. La c&aacute;mara de apelaciones conden&oacute; a las empresas demandadas y a la aseguradora en forma solidaria al pago de la indemnizaci&oacute;n reclamada con fundamento en el derecho civil. Contra dicha decisi&oacute;n la aseguradora interpuso el recurso extraordinario fund&aacute;ndose en que no pod&iacute;a haber efectuado ning&uacute;n control eficaz porque la empleadora no hab&iacute;a registrado el contrato con el causante ni lo hab&iacute;a declarado. La Corte, por mayor&iacute;a, hizo lugar al recurso y dej&oacute; sin efecto la sentencia apelada. Para decidir de tal modo, entre otros fundamentos consider&oacute; que, si bien el art&iacute;culo 4&deg; de la ley 24.557 exige a las aseguradoras adoptar las medidas legalmente previstas para prevenir eficazmente los riesgos del trabajo, es claro que la c&aacute;mara jam&aacute;s pudo &mdash;como lo hizo&mdash; atribuir responsabilidad a la aseguradora por no verificar si el actor sab&iacute;a manejar el cami&oacute;n, o por no haber controlado si el trabajador ten&iacute;a conocimiento de las rutas internacionales o sobre c&oacute;mo conducir un veh&iacute;culo de gran porte dado que el trabajo era clandestino y no hab&iacute;a sido informado a la aseguradora. En disidencia, los jueces Rosatti y Maqueda desestimaron la presentaci&oacute;n directa (art&iacute;culo 280 del C&oacute;digo Procesal Civil y Comercial de la Naci&oacute;n).</p>","esNovedad":true,"fecha":1635390000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1635531505925,"usuarioCreacion":4,"fechaCreacion":1635453414741,"privado":false,"posicion":10,"resumen":null},"reciboEntrada":{"id":32374,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30231731,"numeroExpediente":37957,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id"