{"id":757563,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Miranda, Guillermo s/ recurso extraordinario de inaplicabilidad de ley ","alias":null,"caratula":"MIRANDA, GUILLERMO s/recurso extraordinario de inaplicabilidad de ley","inconstitucional":false,"falloDestacado":{"id":1288,"titulo":"Cómputo de la pena del \"dos por uno\" y reclusión perpetua","cabecilla":"<p>Pena de reclusi&oacute;n perpetua - Est&aacute;ndares constitucionales y de derechos humanos - La reclusi&oacute;n, entendida como encerramiento sine die en total aislamiento, resulta incompatible con el ordenamiento jur&iacute;dico argentino - Doctrina del precedente &quot;M&eacute;ndez&quot; (Fallos: 328:137) Rese&ntilde;a de los antecedentes del C&oacute;digo Penal - En la actualidad la pena de reclusi&oacute;n se ejecuta de igual manera que la pena de prisi&oacute;n - La reclusi&oacute;n como encierro con aislamiento (perspectiva etimol&oacute;gica) o como encierro con trabajos obligatorios dentro o fuera del establecimiento carcelario (perspectiva jur&iacute;dico evolutiva) no se encuentra vigente en la Argentina - Actualmente no hay distinci&oacute;n legal en el encierro del recluso y el del preso - Pierde toda raz&oacute;n la diferencia prevista para computar el tiempo cumplido en prisi&oacute;n preventiva por penados a reclusi&oacute;n, y ello incluye las diferencias pautadas en el computo privilegiado del art 7&deg; ley 24.390 - Dos por uno - Corresponde hacer lugar al recurso de la defensa y dejar sin efecto el pronunciamiento apelado &ndash; Voto concurrente del juez Rosenkrantz: La privaci&oacute;n a determinada categor&iacute;a de personas (como son los penados &#39;con reclusi&oacute;n) del mecanismo de compensaci&oacute;n por la demora judicial en la tramitaci&oacute;n del proceso y la consecuente excesiva privaci&oacute;n preventiva de la libertad, implica la afectaci&oacute;n del derecho que ellas tienen a que se presuma su inocencia, e importa la afectaci&oacute;n de la garant&iacute;a que la Convenci&oacute;n Americana sobre Derechos Humanos &ndash; Violaci&oacute;n del derecho a la igualdad (art&iacute;culo 16de la Constituci&oacute;n Nacional) - Corresponde declarar, la inconstitucionalidad del art&iacute;culo 7&deg; de la ley 24.390 - Disidencia del juez Maqueda: recurso extraordinario inadmisible (art. 280 CPCCN)</p>","esNovedad":true,"fecha":1577329200000,"relevancia":3,"usuarioModificacion":5,"fechaModificacion":1599074448739,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":28393,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23397615,"numeroExpediente":611,"anioExpediente":2014,"tomoExpediente":50,"letraExpediente":"P","tipoExpediente":null,"cam