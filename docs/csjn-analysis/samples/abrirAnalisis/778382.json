{"id":778382,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"SANCHEZ, CRISTIAN GABRIEL Y OTRO s/ INCIDENTE DE RECURSO EXTRAORDINARIO","alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - IMPUTADO: SANCHEZ, CRISTIAN GABRIEL Y OTRO s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":4522,"titulo":"Interpretación del articulo 50 del Código Penal","cabecilla":"<p>Un tribunal oral denegó la petición de declaración de reincidencia con apoyo en la interpretación del artículo 50 del Código Penal según la cual sólo el cumplimiento efectivo de encierro carcelario por un lapso equivalente, al menos, a las dos terceras partes del total de la pena impuesta podría justificar la agravación por reincidencia de la condena por un delito posterior. Ante el recurso del Ministerio Público la cámara de casación rechazó la impugnación con fundamento en que no había demostrado la existencia de una cuestión federal. <b>La Corte, por mayoría, dejó sin efecto dicho pronunciamiento</b>. Señaló que la doctrina invocada fue reiteradamente considerada como motivo de arbitrariedad porque conduciría prácticamente a eliminar la reincidencia de nuestro derecho positivo y que cuando está en juego el examen de un agravio de carácter federal, no es posible soslayar la intervención de las cámaras que cumplen la función procesal de tribunal intermedio.</p>","esNovedad":true,"fecha":1663642800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1663787962038,"usuarioCreacion":11,"fechaCreacion":1663703533811,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":35200,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34119564,"numeroExpediente":2086,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MAZZARA NAVARRO, EMMANUEL MATIAS s/RECURSO EXTRAORDINARIO DE INAPLICABILIDAD DE LEY","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2086. "},"recurso":{"id":5696221,"expediente":{"id":34119564,"numeroExpediente":2086,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nació