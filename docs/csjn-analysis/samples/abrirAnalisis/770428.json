{"id":770428,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"FUNDACIÓN CIUDADANOS INDEPENDIENTES c/ SAN JUAN, PROVINCIA DE, ESTADO NACIONAL Y OTROS s/ ACCIÓN AMBIENTAL MERAMENTE DECLARATIVA","alias":null,"caratula":"FUNDACION CIUDADANOS INDEPENDIENTES c/ SAN JUAN, PROVINCIA DE, ESTADO NACIONAL Y OTR OS s/ACCION AMBIENTAL MERAMENTE DECLARATIVA","inconstitucional":false,"falloDestacado":{"id":2921,"titulo":"La recomposición del daño ambiental colectivo corresponde a la competencia de los tribunales de justicia ordinarios","cabecilla":"<p>Se promovi&oacute; una demanda ante la Corte Suprema con el objeto obtener certeza acerca de la legalidad de las autorizaciones para explotar proyectos mineros ubicados en la zona cordillerana donde existen glaciares que requieren protecci&oacute;n. La Corte, por unanimidad, declar&oacute; su incompetencia para conocer por v&iacute;a de su competencia originaria. En ese sentido, sostuvo que el hecho de que la demandante invoque la responsabilidad del Estado Nacional por ser el emprendimiento Pascua-Lama de car&aacute;cter binacional no funda&nbsp;<em>per se</em>&nbsp;la competencia originaria en raz&oacute;n de la materia, pues esa jurisdicci&oacute;n procede tan solo cuando la acci&oacute;n entablada se basa &ldquo;directa y exclusivamente&rdquo; en prescripciones constitucionales de car&aacute;cter nacional, ley del Congreso o tratados, de tal suerte que la cuesti&oacute;n federal sea predominante en la causa, pero no cuando se incluyen tambi&eacute;n temas de &iacute;ndole local y de competencia de los poderes locales como son los atinentes a la protecci&oacute;n ambiental de la provincia afectada. En hip&oacute;tesis que tienen por fin la recomposici&oacute;n del da&ntilde;o ambiental colectivo la competencia corresponde a los tribunales de justicia ordinarios, y solo excepcionalmente a los del fuero federal, en aquellos casos en los que se encuentran afectados recursos naturales de distintas jurisdicciones y en el caso, sostuvo finalmente el Tribunal, no se encuentra acreditada la afectaci&oacute;n de recursos ambientales interjurisdiccionales.</p>","esNovedad":true,"fecha":1634785200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1634924734114,"usuarioCreacion":11,"fechaCreacion":1634906150346,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":32379,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23522036,"numeroExpediente":121,"anioExpediente":2009,"tomoExpediente":45,"letraExpediente":"F","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"FUNDACION CIUDADANOS INDEPENDIENTES c/ SAN JUAN, PROVINCIA DE, ESTADO NACIONAL Y OTR OS s/ACCION AMBIENTAL MERAMENTE DECLARATIVA","verificacionMesa":"M","eti