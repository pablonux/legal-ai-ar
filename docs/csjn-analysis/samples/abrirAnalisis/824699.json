{"id":824699,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"KIM, TEAYUN c/ EN - DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":10447,"titulo":"Planteo introducido recién en el escrito de interposición del recurso extraordinario","cabecilla":"<p style=\"text-indent:2em\">Luego de que la Dirección Nacional de Migraciones declarara irregular la permanencia en el país de una migrante de nacionalidad surcoreana y ordenara su expulsión del territorio nacional, la cámara confirmó el rechazo del recurso judicial directo deducido por ella.</p><p style=\"text-indent:2em\">La Corte desestimó el recurso intentado contra esta decisión.</p><p style=\"text-indent:2em\">Sostuvo para ello que el planteo referente al alcance que corresponde asignar al artículo 29, inciso c, de la <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-25871-92016/actualizacion\">ley 25.871</a>, texto original, en el supuesto de condenas provenientes de tribunales extranjeros, no fue oportunamente introducido por el recurrente. En efecto, configuró una alegación extemporánea, formulada recién en el escrito de interposición del recurso extraordinario, como fruto de una reflexión tardía, que se reveló insuficiente para habilitar la vía del artículo 14 de la ley 48.</p><p style=\"text-indent:2em\">Recordó el Tribunal que no resulta procedente someter a su conocimiento cuestiones que no fueron propuestas oportunamente ante el tribunal de alzada.</p>","esNovedad":true,"fecha":1774494000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1774556925245,"usuarioCreacion":11,"fechaCreacion":1774556714431,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":154620,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31263840,"numeroExpediente":1366,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":2916,"descripcion":"DIFERENCIAS SALARIALES","idMateria":112,"tema":{"id":168,"codigo":"LABORAL"}},"caratula":"LEGUIZAMON, LUIS Y OTROS c/ EST. NAC. ARGENTINO- PEN- MINISTERIO DE SEGURIDAD- DNG s/DIFERENCIAS SALARIALES","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1366. "},"recurso":{"id":7523024,"expediente":{"id":31263840,"numeroExpediente":1366,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Jus