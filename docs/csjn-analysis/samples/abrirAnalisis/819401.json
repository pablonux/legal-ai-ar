{"id":819401,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - CHAVEZ, EDGARDO MIGUEL Y OTROS Y OTROS c/ ESTADO NACIONAL - Y OTRO s/SUPLEMENTOS FUERZAS ARMADAS Y DE SEGURIDAD","inconstitucional":false,"falloDestacado":{"id":9883,"titulo":"Cobro de diferencias salariales: plazo de prescripción y afectación del principio de congruencia","cabecilla":"<p style=\"text-indent: 2em;\">La cámara revocó la sentencia que había reconocido el derecho de los actores a percibir los suplementos creados por el decreto 1305/12 —y sus modificatorios— con carácter remunerativo y bonificable y que le había ordenado al Estado Nacional liquidar retroactivamente las diferencias devengadas, a partir de la entrada en vigencia de cada decreto y hasta el límite temporal de la normativa vigente a partir del año 2017. Consideró para ello que la acción se encontraba prescripta debido a los cambios producidos por la entrada en vigencia del Código Civil y Comercial el 1/8/2015.</p><p style=\"text-indent: 2em;\">La Corte dejó sin efecto esta sentencia.</p><p style=\"text-indent: 2em;\">Señaló que en el recurso de apelación deducido ante la cámara la demandada no cuestionó el derecho de los actores a requerir el pago de las diferencias salariales correspondientes al período transcurrido desde el inicio de la demanda hasta la derogación de los decretos impugnados y tampoco puso en tela de juicio el derecho de los demandantes a reclamar las diferencias devengadas en los dos años anteriores a la iniciación del pleito. A lo que el Estado Nacional únicamente se opuso en esa presentación fue a la aplicación del plazo quinquenal de prescripción establecido en el inciso 3° del artículo 4027 del Código Civil.</p><p style=\"text-indent: 2em;\">Por ello, la decisión de declarar prescripta la acción no solo incurrió en una errónea interpretación de los hechos y de la normativa aplicable al caso sino que también se apartó de los límites de competencia que solo atribuyen al tribunal de segunda instancia la jurisdicción que resulta de los recursos deducidos ante ella, límite que tiene jerarquía constitucional. </p>","esNovedad":true,"fecha":1763434800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1763562445880,"usuarioCreacion":4,"fechaCreacion":1763562440562,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":147840,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37188861,"numeroExpediente":7212,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":16,"codigo":"16","abreviatura":"FCT","descripcion":"Justicia Federal de Corrientes","estado":0,"descripcionLarga":"FCT - Justicia Federal de Corrientes"},