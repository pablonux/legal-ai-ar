{"id":772661,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"MUNICIPALIDAD DE LA CIUDAD CAPITAL s/ CASACIÓN","alias":null,"caratula":"MUNICIPALIDAD DE LA CIUDAD CAPITAL s/CASACION","inconstitucional":false,"falloDestacado":{"id":3462,"titulo":"Tutela jurisdiccional y ritualismo procesal","cabecilla":"<p>El Intendente de la Ciudad de La Rioja interpuso dos recursos de casaci&oacute;n contra las decisiones del Tribunal de Cuentas provincial que implementaron la ley que dispuso el sometimiento de todos los municipios provinciales al control de dicho Tribunal. El superior tribunal provincial los declar&oacute; inadmisibles porque, a su entender, correspond&iacute;a el tr&aacute;mite por la v&iacute;a de la competencia originaria y no por recurso.&nbsp;La Corte revoc&oacute; las sentencias apeladas. Consider&oacute; que el tribunal de justicia provincial hab&iacute;a reconocido que los reclamos deb&iacute;an tramitar ante &eacute;l mismo no obstante lo cual los desestim&oacute; por considerar que correspond&iacute;a la competencia originaria. En su fallo, la Corte consider&oacute; que medi&oacute; un ritualismo y tuvo en cuenta que el tribunal local ten&iacute;a facultades suficientes para dar curso a la pretensi&oacute;n impugnatoria por la v&iacute;a procesal que considerara pertinente. Agreg&oacute; el Tribunal que los m&aacute;ximos organismos judiciales de cada provincia no pueden negar la tutela jurisdiccional por medio de las v&iacute;as que autoricen la Constituci&oacute;n y leyes provinciales locales en funci&oacute;n de la &iacute;ndole constitucional federal de la materia examinada.</p>","esNovedad":true,"fecha":1645066800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1645202243652,"usuarioCreacion":11,"fechaCreacion":1645128831420,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":33135,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32329738,"numeroExpediente":1490,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MUNICIPALIDAD DE LA CIUDAD CAPITAL s/CASACION","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":32329746,"numeroExpediente":1491,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"