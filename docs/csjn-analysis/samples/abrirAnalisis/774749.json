{"id":774749,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":24,"codigoRelacion":80024,"valor":"DECLARA NULIDAD","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201011041306,"fechaModLong":201011041306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"SUPERINTENDENCIA DE RIESGOS DEL TRABAJO c/ EXPERTA ASEGURADORA DE RIESGOS DEL TRABAJO S.A. s/ EJECUTIVO","alias":null,"caratula":"SUPERINTENDENCIA DE RIESGOS DEL TRABAJO c/ EXPERTA ASEGURADORA DE RIESGOS DEL TRABAJO S.A. s/EJECUTIVO","inconstitucional":false,"falloDestacado":{"id":3983,"titulo":"Falta de debida fundamentación en la concesión de un recurso extraordinario","cabecilla":"<p>La c&aacute;mara deneg&oacute; una apelaci&oacute;n por considerar que el monto no superaba el m&iacute;nimo de apelabilidad. Contra dicha decisi&oacute;n la ejecutada interpuso recurso extraordinario federal fundado tanto en la existencia de arbitrariedad como de una cuesti&oacute;n federal. La c&aacute;mara rechaz&oacute; el recurso por arbitrariedad, pero lo concedi&oacute; por la cuesti&oacute;n federal bajo el fundamento de que el asunto&nbsp;involucraba aspectos de la ley 24.557. La Corte, por unanimidad, anul&oacute; la concesi&oacute;n del recurso pues, era evidente que en su resoluci&oacute;n la c&aacute;mara no hab&iacute;a formulado ninguna inteligencia sobre el alcance y aplicaci&oacute;n al caso de una norma federal sino que se hab&iacute;a limitado a examinar lo atinente a la procedencia del recurso de apelaci&oacute;n interpuesto en cuanto al monto debatido. En tales condiciones, estim&oacute; la Corte, el auto de concesi&oacute;n carece ostensiblemente de una debida fundamentaci&oacute;n.</p>","esNovedad":true,"fecha":1652756400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1652975415785,"usuarioCreacion":11,"fechaCreacion":1652813865346,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":33872,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34542052,"numeroExpediente":305,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":9492,"descripcion":"EJECUTIVO","idMateria":4,"tema":{"id":510,"codigo":"EJECUTIVOS"}},"caratula":"SUPERINTENDENCIA DE RIESGOS DEL TRABAJO c/ EXPERTA ASEGURADORA DE RIESGOS DEL TRABAJO S.A. s/EJECUTIVO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"305. "},"recurso":{"id":5961372,"expediente":{"id":34542052,"numeroExpediente":305,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional