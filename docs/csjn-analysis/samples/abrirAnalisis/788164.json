{"id":788164,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":230004,"valor":"RECURSO DE REVOCATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"HYGL CONSTRUCCIONES S.A. Y OTROS c/ MUNICIPALIDAD DE TRES DE FEBRERO s/QUEJA POR DENEGATORIA DE RECURSOS EXTRAORDINARIOS DE NULIDAD E INAPLICABILIDAD DE LEY","inconstitucional":false,"falloDestacado":{"id":5881,"titulo":"Litisconsorcio facultativo: deber de cada uno de los recurrentes de integrar el depósito previo","cabecilla":"<p>En el marco de un recurso de queja deducido por dieciocho recurrentes se acompañó una boleta correspondiente al pago de un solo depósito. La Secretaría intimó a que se efectuaran los depósitos restantes o, en su caso, se indicara a quién correspondía el único depósito acreditado. En respuesta a ello el letrado apoderado del litisconsorcio facultativo planteó un recurso de reposición argumentando que las actuaciones versaban sobre una única pretensión común y que la única demanda iniciada tenía como objeto disipar la incertidumbre sobre la constitucionalidad de una tasa municipal. La Corte <b>desestimó el recurso e intimó a que se efectúen los depósitos restantes</b>. Expresó que no se advertía la existencia de un litisconsorcio necesario ya que los actores optaron por unificar su personería, pero sus intereses permanecían propios y autónomos. Agregó que tampoco se había acreditado un imperativo legal que les impidiese actuar en forma separada ni se apreciaba que resultara imposible dictar una sentencia útil sin la representación conjunta de los demandantes.</p>","esNovedad":true,"fecha":1695092400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1695233651351,"usuarioCreacion":11,"fechaCreacion":1695149687244,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":113915,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32711232,"numeroExpediente":71973,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1117,"descripcion":"DIRECCION GENERAL IMPOSITIVA","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"STRAZZOLINI, RONALDO EMILIO c/ EN-AFIP-DGI s/DIRECCION GENERAL IMPOSITIVA","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":35838808,"numeroExpediente":71973,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":