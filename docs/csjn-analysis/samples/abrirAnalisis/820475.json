{"id":820475,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 3 - Incidente Nº 117 - IMPUTADO: TOGNOLI, HUGO DAMIAN Y OTROS s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":9921,"titulo":"Suspensión del juicio a prueba: afirmaciones dogmáticas y ausencia de debida fundamentación","cabecilla":"<p style=\"text-indent:2em\">La cámara de casación revocó la sentencia de condena del tribunal oral e hizo lugar a la suspensión del juicio a prueba solicitada por la defensa oficial.</p><p style=\"text-indent:2em\">El fiscal general dedujo recurso extraordinario y la Corte <b>dejó sin efecto la sentencia</b> al advertir vicios de fundamentación.</p><p style=\"text-indent:2em\">Tuvo en cuenta que para conceder la suspensión del juicio a prueba, el tribunal aseveró que las situaciones procesales de las imputadas se encontraban comprendidas en los supuestos previstos en el artículo 76 bis del Código Penal, soslayando -cuanto menos- sopesar la gravitación que pudiera tener la prohibición prevista en el párrafo 7° de la norma citada a los fines de la concesión del beneficio o, si correspondiera, los motivos para fundar un apartamiento de la misma en el caso concreto. Ello cobraba particular relevancia ya que el tribunal oral juzgó probada la participación de funcionarios públicos en el comercio de estupefacientes investigado en el caso y condenó a miembros de la fuerza policial provincial a quienes consideró involucrados.</p><p style=\"text-indent:2em\">El Tribunal consideró que se había prescindido así, sin brindar razones, de normativa vigente y aplicable a la materia a decidir, lo que tiñó de dogmatismo una apreciación que terminaba emanando exclusivamente de la voluntad del juzgador.</p>","esNovedad":true,"fecha":1764212400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1764592066589,"usuarioCreacion":11,"fechaCreacion":1764280787120,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":149059,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35899230,"numeroExpediente":8308,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":1921,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Recurso Queja Nº 3 - Incidente Nº 117 - IMPUTA