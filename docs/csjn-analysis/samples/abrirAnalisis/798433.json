{"id":798433,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ARMANI, RAFAEL ARIEL c/ FISCO DE LA PROVINCIA DE BUENOS AIRES s/ACCIDENTE DE TRABAJO - ACCION ESPECIAL","inconstitucional":false,"falloDestacado":{"id":7181,"titulo":"Riesgos del trabajo: comisiones médicas y aptitud jurisdiccional de la justicia provincial","cabecilla":"<p style=\"text-indent: 2em;\">El superior tribunal provincial revocó la sentencia del tribunal del trabajo que había declarado la inconstitucionalidad de la ley provincial 14.997 y del artículo 46 de la ley 24.557 y declaró la incompetencia de dicho tribunal para entender en la causa. </p><p style=\"text-indent: 2em;\">La Corte dejó sin efecto esta sentencia y habilitó la instancia ante la justicia local. </p><p style=\"text-indent: 2em;\">Señaló que el actor inició las actuaciones administrativas y agotó ese procedimiento durante la vigencia de la ley 15.057 y que presentó demanda dentro del plazo previsto por el artículo 2, inciso j, de esa norma. Afirmó que estos extremos fácticos y jurídicos eran relevantes y conducentes para resolver la cuestión en debate pero no fueron ponderados por la sentencia apelada que, con remisión a precedentes que no resultaban análogos al caso, se había limitado a declarar la validez constitucional de las leyes 27.348 y 14.997, y declarado inhabilitada la vía procesal ante la justicia laboral local sin brindar fundamentos adicionales que justificaran su postura.</p>","esNovedad":true,"fecha":1720666800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1720720218855,"usuarioCreacion":4,"fechaCreacion":1720720216964,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":122499,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35613274,"numeroExpediente":1184,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ARMANI, RAFAEL ARIEL c/ FISCO DE LA PROVINCIA DE BUENOS AIRES s/ACCIDENTE DE TRABAJO - ACCION ESPECIAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1184. "},"recurso":{"id":6069222,"expediente":{"id":35613274,"numeroExpediente":1184,"anioExpediente":2021,"tomoExpediente":null,"letraExpedien