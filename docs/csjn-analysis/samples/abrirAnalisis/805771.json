{"id":805771,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ROSSINI, MARCELO EDUARDO c/ AFIP-DGI s/CONTENCIOSO ADMINISTRATIVO-VARIOS","inconstitucional":false,"falloDestacado":{"id":8181,"titulo":"Reconocimiento de crédito fiscal originado en ventas de gasoil - Ante quien debe solicitarse","cabecilla":"<p style=\"text-indent:2em\">La cámara sostuvo que el régimen establecido en la resolución general de la DGI 2477/84 resultaba aplicable para tramitar las solicitudes tendientes a que se reconozca un crédito fiscal -originado en ventas de gasoil a subcontratistas de la Entidad Binacional Yacyretá- y su compensación con respecto a otros impuestos y que habían sido rechazadas por la AFIP. </p><p style=\"text-indent:2em\">La Corte revocó este pronunciamiento.</p><p style=\"text-indent:2em\">Señaló que una correcta interpretación de la normativa en juego permitía concluir que el régimen establecido por la resolución general de la AFIP 3044/11 -que establece la solicitud del reintegro de los impuestos que le fueron oportunamente liquidados directamente a su proveedora- era el que resultaba de aplicación en el caso, por lo que se había prescindido de la solución normativa prevista.</p><p style=\"text-indent:2em\">Agregó que no obstaba a tal conclusión el hecho de que la demandada hubiera encauzado y resuelto con anterioridad, en el marco del procedimiento establecido por la RG 2477/84, solicitudes análogas a las que fueran objeto de tratamiento por los actos administrativos examinados en el caso debido a que las presentaciones fueron deducidas por la accionante durante la vigencia de la RG 3044/11.</p>","esNovedad":true,"fecha":1738810800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1739196705098,"usuarioCreacion":4,"fechaCreacion":1738868494584,"privado":false,"posicion":1,"resumen":{"idResumen":115,"resumen":"La Corte revocó el fallo de la cámara y determinó que la resolución general de la AFIP 3044/11 era aplicable al caso, no la resolución general de la DGI 2477/84.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":132338,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31864833,"numeroExpediente":7181,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":23,"codigo":"23","abreviatura":"FRE","descripcion":"Justicia Federal de Resistencia","estado":0,"descripcionLarga":"FRE - Justicia Federal de Resistencia"},"objetoJuicio"