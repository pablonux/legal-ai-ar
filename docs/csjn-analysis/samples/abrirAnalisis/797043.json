{"id":797043,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - ALOY, ELEONORA CLAUDIA Y OTRO c/ NOTO CORDERO, MARIA FLORENCIA s/EJECUCION DE ACUERDO","inconstitucional":false,"falloDestacado":{"id":6883,"titulo":"Recurso de queja sin previa denegatoria del recurso extraordinario","cabecilla":"<p style=\"text-indent:2em\">La cámara declaró desierto el recurso de apelación y dejó firme la sentencia de la instancia anterior que había mandado llevar adelante la ejecución promovida. Contra dicho pronunciamiento la ejecutada interpuso recurso extraordinario y el tribunal resolvió tenerlo por no presentado. </p><p style=\"text-indent:2em\">La ejecutada interpuso un recurso de queja ante la Corte, que desestimó esta presentación.</p><p style=\"text-indent:2em\">Reiteró que la queja prevista en el art. 285 del Código Procesal Civil y Comercial de la Nación constituye un <em>medio de impugnación solo de decisiones que deniegan recursos deducidos por ante ella misma</em> y no es idónea, en cambio, para cuestionar otras decisiones, aun cuando ellas se relacionen con el trámite de aquellos recursos.</p><p style=\"text-indent:2em\">Concluyó entonces que frente a la ausencia de toda decisión denegatoria -expresa o implícita- del recurso extraordinario, la queja era inadmisible por no configurar la vía procesalmente apta para obtener la revisión del pronunciamiento impugnado.</p>","esNovedad":true,"fecha":1716260400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1716319710036,"usuarioCreacion":4,"fechaCreacion":1716319628486,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":121041,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37745191,"numeroExpediente":642,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"CARNIEL, LEANDRO ATILIO s/sucesion ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"642. "},"recurso":{"id":6559640,"expediente":{"id":37745191,"numeroExpediente":642,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"CARNIEL, LEANDRO ATILIO s/sucesion ","ver