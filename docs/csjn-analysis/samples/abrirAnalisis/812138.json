{"id":812138,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 1 - ACTOR: DIEGO DEPORTES S.A. Y OTROS CONCURSADO: DIEGO DEPORTES S.A. s/INCIDENTE DE REVISION DE CREDITO","inconstitucional":false,"falloDestacado":{"id":9302,"titulo":"Verificación tardía de créditos en el concurso preventivo","cabecilla":"<p style=\"text-indent:2em\">La cámara admitió el recurso presentado por la concursada y rechazó las deudas reclamadas por el Fisco (AFIP-DGI) mediante el incidente de verificación tardía de créditos en el concurso preventivo.</p><p style=\"text-indent:2em\">La Corte revocó esta sentencia.</p><p style=\"text-indent:2em\">Expresó que si bien la cámara valoró que las declaraciones juradas presentadas por la empresa fueron la base sobre la que el organismo recaudador se sustentó para efectuar los cálculos de los créditos pretendidos, al mismo tiempo, prescindió de considerar dos cuestiones que eran fundamentales para la correcta solución de la controversia.</p><p style=\"text-indent:2em\">En primer lugar omitió valorar que, con base en las declaraciones juradas presentadas, el Fisco había liquidado las acreencias cuya verificación pretendía, lo cual plasmó en los certificados de deuda y las liquidaciones administrativas acompañadas. De tal manera, no consideró, sin brindar razones plausibles para ello, la presunción de legitimidad de tales actos administrativos.</p><p style=\"text-indent:2em\">En segundo lugar, la cámara ignoró el carácter de declaración jurada: i) que poseían los documentos en los que la contribuyente había plasmado la posición por ella asumida frente a los tributos y los aportes y contribuciones con destino al régimen nacional de la seguridad social en discusión; como así también, ii) de los formularios mediante los cuales la concursada adhirió al plan de facilidades de pago.</p>","esNovedad":true,"fecha":1756177200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1767031148074,"usuarioCreacion":11,"fechaCreacion":1756239184676,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":140672,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34110803,"numeroExpediente":4387,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial