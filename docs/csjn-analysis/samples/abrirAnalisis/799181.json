{"id":799181,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - MOREYRA ANDRES GUSTAVO c/ SMG ART S.A. s/ACCIDENTE - ACCION CIVIL","inconstitucional":false,"falloDestacado":{"id":7241,"titulo":"Improcedencia de la responsabilidad civil de la ART si no está debidamente fundada","cabecilla":"<p style=\"text-indent:2em\">La cámara hizo lugar a la demanda que entabló el actor a fin de obtener la reparación integral del daño auditivo que dijo padecer a raíz de las tareas que desplegaba para su empleadora. Estimó que la ART había omitido acatar sus obligaciones y que ello guardaba un nexo de causalidad adecuado con la hipoacusia que aquel presentaba y le significaba una incapacidad del 8% de la T.O.</p><p style=\"text-indent:2em\"><b>La Corte dejó sin efecto esta sentencia. </b></p><p style=\"text-indent:2em\">Expresó que omitió ponderar que el peritaje técnico había dado cuenta de que, al poco tiempo de su ingreso al establecimiento empleador, al trabajador se le habían suministrado elementos de protección auditiva, cuya constancia fue acompañada por el perito. Agregó que tampoco evaluó que el dictamen pericial había concluido que la demandada efectuó mediciones e inspecciones en el lugar de trabajo y que el nivel sonoro del establecimiento, si bien era cercano al límite permitido, se encontraba dentro de los valores admisibles.</p><p style=\"text-indent:2em\">Concluyó el Tribunal que si a dichas constancias probatorias se añadía el escaso tiempo que trabajó el actor en las condiciones indicadas (menos de un año y medio), la atribución de responsabilidad civil a la ART no resultaba razonable ni adecuadamente fundada.</p>","esNovedad":true,"fecha":1722481200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1722611714721,"usuarioCreacion":4,"fechaCreacion":1722538802370,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":123219,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34018979,"numeroExpediente":6185,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9702,"descripcion":"ACCIDENTE - ACCION CIVIL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - MOREYRA ANDRES GUSTAVO c/ SMG ART S.A. s/ACCIDENTE - ACCION CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"6185. "},"recurso":{"id":5672746,"expediente":{"id":34018979,"numeroExpediente":6185,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"cama