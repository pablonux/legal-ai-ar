{"id":805354,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"LAGO, ADRIANA MARCELA Y OTRO c/ AEROLINEAS ARGENTINAS S.A. s/ORDINARIO","inconstitucional":false,"falloDestacado":{"id":8342,"titulo":"Cancelación de pasajes y servicios turísticos: competencia federal","cabecilla":"<p style=\"text-indent:2em\">La Cámara Nacional de Apelaciones en lo Comercial declaró la competencia del fuero para conocer en la acción contra una empresa aérea con el objeto de que se disponga la reparación de los daños y perjuicios que fueron irrogados por la cancelación de los pasajes y los servicios turísticos contratados en razón de las restricciones impuestas por la pandemia causada por el virus “covid-19”.</p><p style=\"text-indent:2em\">La Corte revocó esta sentencia y declaró que resultaba competente para conocer en las actuaciones la justicia nacional en lo civil y comercial federal.</p><p style=\"text-indent:2em\">Fundó la procedencia del fuero federal en el hecho de que se controvertía la regularidad del proceder de la línea aérea en relación con los boletos adquiridos y su devolución, con lo cual la cuestión central debatida se vinculaba principalmente con el servicio de transporte aéreo.</p>","esNovedad":true,"fecha":1741748400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1741890709298,"usuarioCreacion":4,"fechaCreacion":1741808780275,"privado":false,"posicion":3,"resumen":{"idResumen":126,"resumen":"La Corte revocó la sentencia de la Cámara y declaró la competencia de la justicia nacional en lo civil y comercial federal. Se funda en que se controvierte la regularidad del proceder de la línea aérea en relación con los boletos adquiridos y su devolución.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":131901,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36316096,"numeroExpediente":3504,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":1267,"descripcion":"DEVOLUCION DE PASAJES","idMateria":3,"tema":{"id":457,"codigo":"TRANSPORTE"}},"caratula":"LAGO, ADRIANA MARCELA Y OTRO c/ AEROLINEAS ARGENTINAS SA s/DEVOLUCION DE PASAJES","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"3504. "},"recurso":{"id":6596346,"expediente":{"id":36316096,"numeroExpediente":3504,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Naci