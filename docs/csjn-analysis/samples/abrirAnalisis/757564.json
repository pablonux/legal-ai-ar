cesarias para operativizar mandatos concretos de jerarqu&iacute;a constitucional no puede conllevar la frustraci&oacute;n de los derechos o prerrogativas consagrados por la Constituci&oacute;n Nacional - Jurisprudencia de la Corte Interamericana de Derechos Humanos - Ante el dictado de una sentencia condenatoria en sede casatoria la garant&iacute;a de la doble instancia debe ser salvaguardada directamente mediante la interposici&oacute;n de un recurso de casaci&oacute;n que deber&aacute;n resolver otros magistrados que integren ese tribunal, sin necesidad de previamente recurrir a la Corte Suprema - Se deja sin efecto el pronunciamiento apelado</p>","esNovedad":true,"fecha":1577329200000,"relevancia":3,"usuarioModificacion":5,"fechaModificacion":1599073830131,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":28393,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23397615,"numeroExpediente":611,"anioExpediente":2014,"tomoExpediente":50,"letraExpediente":"P","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"P., S. M. c/   Y OTRO s/recurso extraordinario","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"P. 611. L. "},"recurso":{"id":3118910,"expediente":{"id":23397615,"numeroExpediente":611,"anioExpediente":2014,"tomoExpediente":50,"letraExpediente":"P","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{