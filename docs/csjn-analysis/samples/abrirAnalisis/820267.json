{"id":820267,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":230004,"valor":"RECURSO DE REVOCATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - BERNASCONI, MARTA ELISA c/ INDUSTRIAL AND COMMERCIAL BANK OF CHINA ARGENTINA SAU s/AMPARO","inconstitucional":false,"falloDestacado":{"id":9924,"titulo":"Pago del depósito previo y perentoriedad de los plazos procesales","cabecilla":"<p style=\"text-indent: 2em;\">Tras reiteradas intimaciones el recurrente realizó el pago del depósito previsto en el artículo 286 del Código Procesal Civil y Comercial de la Nación una vez vencido el plazo para ello.</p><p style=\"text-indent: 2em;\">La Corte hizo efectivo el apercibimiento y desestimó la queja, ordenando el reintegro de lo pagado tardíamente.</p><p style=\"text-indent: 2em;\">El quejoso pretendió la revocatoria de lo decidido pero el Tribunal rechazó el planteo por considerar que los motivos alegados carecían de todo sustento normativo.</p><p style=\"text-indent: 2em;\">Destacó que lo relevante es la fecha de la presentación de la constancia prevista en el artículo 2° de la <a href=\"https://www.csjn.gov.ar/achist/verResolucionPDF/25388e17b1238d774a6b4f52476610dbcdc3c96f0ad422e28e50ebbee1fe367ea78be33eaa07af0bc353c54eb2c445da58308c1a62ea95cb33d188ba8940af1d\">acordada 47/91</a> y no el día en que fue solicitada o emitida por el órgano administrativo correspondiente y que la falta de presentación en término de la constancia documental allí prevista comporta la caducidad del beneficio del diferimiento del pago del depósito y la consiguiente intimación para que este se hiciera efectivo dentro del plazo de cinco días, recaudo que, al no cumplirse oportunamente, hace aplicable el apercibimiento indicado y determina la desestimación de la queja. Agregó que corresponde adoptar igual criterio si no se ha efectuado oportunamente el depósito previo y la presentación de la constancia de requerimiento de la previsión presupuestaria fue realizada cuando ya se encontraba vencido el plazo previsto en el art. 2° mencionado.</p><p style=\"text-indent: 2em;\">Recordó la Corte que las sentencias definitivas e interlocutorias por ella dictadas no son susceptibles de ser modificadas por la vía de la reposición (artículos 238 y 160 del Código Procesal Civil y Comercial de la Nación) y que las razones invocadas no demostraban la existencia de un supuesto de fuerza mayor o causa grave que justificara el incumplimiento de una exigencia enteramente previsible, ni autorizaban a prescindir del carácter perentorio de los plazos procesales.</p>","esNovedad":true,"fecha":1764212400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1764331445151,"usuarioCreacion":11,"fechaCreacion":1764331439682,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":148699,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35120736,"numeroExpediente":10589,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8784,"descripcion":"ACCION MERE DECLARATIVA DE DERECHO","idMateria":112,"tema":{"id":381,"codigo":"CYCF"}},"caratula":"SOLUCIONES NAVALES SRL c/ AFIP - DGI s/ACCION MERE DECLARATIVA DE DERECHO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10589. "},"recurso":{"id":7082728,"expediente":{"id":35120736,"numeroExpediente":10589,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8784,"descripcion":"ACCION MERE DECLARATIVA DE DERECHO","idMateria":112,"tema":{"id":381,"codigo":"CYCF"}},"caratula":"SOLUCIONES NAVALES SRL c/ AFIP - DGI s/ACCION MERE DECLARATIVA DE DERECHO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10589. "},"tipoRecurso":{"id":1166,"codigo":"REX","descripcion":"RECURSO EXTRAORDINARIO"},"claveRecurso":"FMP 010589/2020/CS001","identificacionExpediente":"FMP 010589/2020/CS001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":7,"nombreUsuario":"27293873432","apellido":"Delaloye","nombre":"Maria Laura","estado":"A","tieneToken":"N","cargo":"JEFE DE DESPACHO","fechaModificacion":null,"fechaCreacion":1533610800000,"nombreUsuarioMigrado":null,"codigo":"SJC287","mail":"ldelaloye@csjn.gov.ar","intentos":0,"notificacion":false},"usuarioCreacionOld":"SJC287","usuarioModificacion":{"id":7,"nombreUsuario":"27293873432","apellido":"Delaloye","