{"id":769963,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":19,"codigoRelacion":80019,"valor":"CONFIRMA PARCIALMENTE","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009281029,"fechaModLong":201009281029,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"CASCO HECTOR ADOLFO s/EXTRADICION - ART. 52","alias":null,"caratula":"CASCO HECTOR ADOLFO s/EXTRADICION - ART. 52","inconstitucional":false,"falloDestacado":{"id":2846,"titulo":"Extradición a la República italiana","cabecilla":"<p>Pronunciamiento que declar&oacute; procedente la extradici&oacute;n a la Rep&uacute;blica italiana - Si los antecedentes agregados permiten inferir que el requerido desde un inicio manejaba el idioma italiano la mera invocaci&oacute;n sobre la existencia de una &quot;barrera idiom&aacute;tica&quot; con base en la nacionalidad el requerido no basta para desvirtuar el contenido de las probanzas - Si su ausencia del pa&iacute;s requirente solo alude a la situaci&oacute;n de hecho en que se coloc&oacute; al trasladarse fuera de su jurisdicci&oacute;n pese a que conoc&iacute;a que su puesta en libertad en sede extranjera no ten&iacute;a ni el contenido ni los alcances que pretendi&oacute; luego esgrimir, corresponde desestimar la pretensi&oacute;n de que se aplique la jurisprudencia del Tribunal en materia de condenados&nbsp;<em>in absentia</em>&nbsp;- Delitos que, como el tr&aacute;fico il&iacute;cito de estupefacientes, afectan a la comunidad de las naciones, requieren razonablemente de un proceso multijurisdiccional basado en la cooperaci&oacute;n judicial - Dada la modalidad en que se llevan a cabo, es com&uacute;n la presencia de jurisdicciones concurrentes&nbsp; para juzgar un mismo hecho o tramos t&iacute;picos de un mismo hecho - Se confirma la resoluci&oacute;n apelada en cuanto declar&oacute; procedente la extradici&oacute;n y se revoca el auto y declara improcedente el pedido para ser sometido a proceso por otros hechos identificados.</p>","esNovedad":true,"fecha":1634180400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1634315482970,"usuarioCreacion":11,"fechaCreacion":1634303217540,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":32209,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":431558,"numeroExpediente":3303,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"CASCO HECTOR ADOLFO s/EXTRADICION - ART. 52 ","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"3303. "},"recurso":{"id":5078309,"expediente":{"id":431558,"numeroExpediente":3303,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"t