{"id":794324,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"C., G. A. y otro c/ Swiss Medical SA s/ amparo de salud.\r\n","alias":null,"caratula":"CABRERA, GUSTAVO ADOLFO Y OTRO c/ SWISS MEDICAL SA s/AMPARO  DE SALUD","inconstitucional":false,"falloDestacado":{"id":6562,"titulo":"Competencia federal en reclamo de cobertura a empresa de medicina prepaga","cabecilla":"<p style=\"text-indent: 2em;\">En el marco de un amparo contra una empresa de medicina de prepaga con el fin de que se brinde diversas prestaciones médicas a una paciente que cuenta con certificado de discapacidad se originó un conflicto negativo de competencia.</p><p style=\"text-indent: 2em;\">El juez federal declinó intervenir fundado en que la demanda conllevaba una determinación sobre los tratamientos y, al no encontrarse la afectada en condiciones de tomar decisiones sobre su estado de salud, procedía la actuación del fuero nacional en lo civil donde tramitaba un proceso dirigido a establecer su capacidad jurídica. Por otro lado, la magistrada nacional rechazó la radicación basada en que el reclamo compromete la aplicación de normas y principios de trascendencia para la estructura del sistema de salud implementado por el Estado Nacional.</p><p style=\"text-indent: 2em;\">La Corte decidió que corresponde a la justicia en lo civil y comercial federal entender en la causa.</p><p style=\"text-indent: 2em;\">Tuvo en cuenta para ello que el objeto del litigio conduce, en principio, al estudio de las obligaciones asignadas a las empresas de la medicina prepaga y que los procesos que versan, en último término, sobre situaciones alcanzadas por normas federales, deben tramitar ante ese fuero por razón de la materia.</p><p style=\"text-indent: 2em;\">Recordó el Tribunal que el planteo autónomo de la cobertura prestacional excede la competencia exclusiva y excluyente que concierne a los juzgados nacionales en lo civil –dedicados a los asuntos de familia y capacidad de las personas–, máxime cuando el trámite de determinación de la capacidad no ejerce fuero de atracción.</p>","esNovedad":true,"fecha":1710212400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1710273870278,"usuarioCreacion":4,"fechaCreacion":1710273867087,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":118155,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":27783748,"numeroExpediente":63110101,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descripcionLarga":"FLP - Justicia Federal de La Plata"},"objetoJuicio":{"id":8066,"descripcion":"REAJUSTE DE HABERES","idMateria":