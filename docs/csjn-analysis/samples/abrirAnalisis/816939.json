{"id":816939,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - REALES, MARTIN c/ Y.P.F. YACIMIENTOS PETROLIFEROS FISCALES S.A. Y OTRO s/PART. ACCION OBRERO","inconstitucional":false,"falloDestacado":{"id":9545,"titulo":"Arbitrariedad de sentencias: falta de  sustento en las constancias de la causa","cabecilla":"<p style=\"text-indent: 2em;\">La cámara revocó la sentencia de primera instancia y condenó al Estado Nacional a compensar a la actora la diferencia entre la cotización de los bonos octava serie que recibió y los bonos cuarta serie 2% y atribuyó al Estado haber incumplido con el pago a causa del “largo proceso de apelaciones” al que sometió a aquella.</p><p style=\"text-indent: 2em;\">La Corte, por mayoría, entendió que la sentencia impugnada tenía una <b>fundamentación aparente</b> y la <b>dejó sin efecto</b>.</p><p style=\"text-indent: 2em;\">Consideró que de las constancias de la causa y del propio relato efectuado por el tribunal anterior en grado, surgía que fue la actuación de ambas partes la que motivó la prolongación del juicio, mediante el ejercicio regular del derecho de defensa.</p><p style=\"text-indent: 2em;\">Concluyó así que carecía de asidero entonces atribuir al Estado haber incumplido con su obligación de pago y sometido a una espera indebida al acreedor mediante un largo proceso de apelaciones y justificar sobre la base de esta errónea premisa la compensación otorgada.</p>","esNovedad":true,"fecha":1760583600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1760651861193,"usuarioCreacion":4,"fechaCreacion":1760650540533,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":145331,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24290334,"numeroExpediente":4235,"anioExpediente":1998,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":10825,"descripcion":"PART. ACCION OBRERO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 1 - REALES, MARTIN c/ Y.P.F. YACIMIENTOS PETROLIFEROS FISCALES S.A. Y OTRO s/PART. ACCION OBRERO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"4235. "},"recurso":{"id":3598078,"expediente":{"id":24290334,"numeroExpediente":4235,"anioExpediente":1998,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de A