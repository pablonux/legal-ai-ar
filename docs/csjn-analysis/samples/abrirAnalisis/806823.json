{"id":806823,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"B., S. S. c/ C., R. R. s/HOMOLOGACION DE CONVENIO (CIVIL)","inconstitucional":false,"falloDestacado":{"id":8602,"titulo":"Régimen comunicacional: centro de vida del niño para determinar la competencia","cabecilla":"<p style=\"text-indent:2em\">En el marco de una causa vinculada al régimen comunicacional de una niña se originó un conflicto positivo de competencia entre un juez de la Provincia de Entre Ríos y una jueza de la Provincia de Santa Fe.</p><p style=\"text-indent:2em\">La Corte resolvió que sea la justicia de esta última provincia la que intervenga en los autos y que los magistrados competentes deberán resolver sobre el régimen de comunicación y cuidado personal de la niña a la mayor brevedad posible.</p><p style=\"text-indent:2em\">Tuvo en cuenta que del acta de audiencia de vista de cau