{"id":806164,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - Incidente Nº 1 - AUTOSERVICIO MAYORISTA DIARCO SA c/ MUNICIPALIDAD DE LA MATANZA s/INC APELACION","inconstitucional":false,"falloDestacado":{"id":8361,"titulo":"Improcedencia de una cautelar genérica que impide la actuación de la jurisdicción provincial","cabecilla":"<p style=\"text-indent:2em\">Una cámara federal dispuso como medida cautelar que la municipalidad se abstenga de ejecutar la sentencia dictada en un juicio de apremio tramitado ante la justicia provincial.</p><p style=\"text-indent:2em\">La Corte consideró que esta medida interfería con la decisión adoptada por la justicia provincial.</p><p style=\"text-indent:2em\">Sostuvo que esa superposición jurisdiccional provocaba como resultado que la sentencia dictada por el tribunal provincial quede desvirtuada, a tal extremo que la privaba de efecto. Señaló que admitir dicha situación implicaría consentir un menoscabo de las atribuciones de los jueces para cumplir su función jurisdiccional, además de violentar derechos individuales constitucionalmente reconocidos.</p><p style=\"text-indent:2em\">Según el Tribunal,  <em>la conducta desplegada por la actora resultaba objetable y que la protección cautelar conformaba una suerte de inmunidad jurisdiccional de carácter genérico</em> de ella frente al municipio, que se traducía en la afectación de la institución municipal, que enerva el sistema federal en cuanto impide u obstruye la actuación de la jurisdicción provincial en su propio ámbito material y geográfico.</p><p style=\"text-indent:2em\">Finalmente, y habida cuenta la existencia de una contienda positiva de competencia suscitada con posterioridad a la interposición de la queja, el Tribunal hizo uso de la facultad que le confiere el artículo 16, segunda parte, de la ley 48 y declaró la competencia de la justicia provincial para conocer en la causa.</p>","esNovedad":true,"fecha":1741748400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1741890639998,"usuarioCreacion":4,"fechaCreacion":1741807661903,"privado":false,"posicion":1,"resumen":{"idResumen":124,"resumen":"La Corte resolvió que la medida cautelar dictada por la cámara federal interfería con la decisión de la justicia provincial, afectando la institución municipal y el sistema federal. Declaró la competencia de la justicia provincial en la causa.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":132983,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36424051,"numeroExpediente":1724,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":26,"codigo":"26","abreviatura":"FSM","d