{"id":766757,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"Recurso Queja Nº 1 - TORRES NOEMI MARTA c/ VILLAMIL ALTUBE VIAJES SRL Y OTRO s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE) *","alias":null,"caratula":"Recurso Queja Nº 1 - TORRES NOEMI MARTA c/ VILLAMIL ALTUBE VIAJES SRL Y OTRO s/DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","inconstitucional":false,"falloDestacado":{"id":2162,"titulo":"Carga de la prueba del contrato","cabecilla":"<p>Cobertura por accidentes personales en un viaje de turismo: valoraci&oacute;n parcial de la prueba - Demanda de indemnizaci&oacute;n de los da&ntilde;os y perjuicios contra una empresa de turismo derivados de un accidente de tr&aacute;nsito ocurrido en el exterior - Condena que se hace extensiva a la citada en garant&iacute;a en los t&eacute;rminos del art. 118 de la ley 17.418 - Recurso interpuesto por la aseguradora - Conclusiones que se basan, en lo sustancial, en documentaci&oacute;n aportada por la actora de la que solo surgen las condiciones generales del servicio de asistencia en viaje - Valoraci&oacute;n parcial del documento en tanto tiene por acreditada la cobertura por accidentes personales, cuando de su lectura surge que dicho beneficio es un servicio adicional al de asistencia m&eacute;dica cuya inclusi&oacute;n debe estar prevista y verificada en las condiciones particulares del producto comprado - No resulta razonable que una de las partes deba cargar con las consecuencias de la falta de producci&oacute;n de la prueba del contrato que deb&iacute;a encontrarse en poder de cualquiera de ellas, sobre todo cuando no resulta indubitable su existencia antes de la fecha del accidente ni su contenido, requisito esencial para la acreditaci&oacute;n de responsabilidad de la recurrente- Se afectar&iacute;a el derecho de defensa al tener por existente un documento que, al no haber sido aportado a la causa, solo tiene virtualidad en el relato de la contraria, ajustado con precisi&oacute;n a sus intereses - Se deja sin efecto la sentencia - Disidencia del juez Maqueda: recurso extraordinario inadmisible (art. 280 CPCCN)</p>","esNovedad":true,"fecha":1622689200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1623090498512,"usuarioCreacion":11,"fechaCreacion":1622812105181,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31215,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32531266,"numeroExpediente":22041,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{