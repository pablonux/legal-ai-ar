{"id":783816,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"MUNICIPALIDAD DE GENERAL ROCA s/ACCIÓN DE INCONSTITUCIONALIDAD (Leyes Provinciales N° 4317 y 4318)","inconstitucional":false,"falloDestacado":{"id":5501,"titulo":"Determinación de los límites territoriales de los municipios y proceso de formación de leyes","cabecilla":"<p>La Municipalidad de General Roca inició una acción tendiente a que se declare la inconstitucionalidad de las leyes provinciales que determinaron los límites territoriales de dos municipios y los ejidos colindantes por afectar la Constitución, una ley y varias ordenanzas, todas ellas provinciales. El superior tribunal local la desestimó y ello originó un recurso extraordinario. La Corte desestimó el agravio referido a que la legislatura local habría violado el reglamento de ese cuerpo durante el trámite de formación de las leyes cuestionadas al omitir requerir los dictámenes de las comisiones legislativas pertinentes. Consideró que en la decisión apelada se había considerado que las leyes habían sido aprobadas por la decisión unánime del cuerpo, de acuerdo a una práctica parlamentaria arraigada, actuando la Legislatura como intérprete final de su reglamento y que ello resultaba una interpretación posible  del ordenamiento jurídico que, al margen de ser debatible y/u opinable, acordaba sustento bastante al fallo recurrido. </p>","esNovedad":true,"fecha":1685588400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1685717904644,"usuarioCreacion":11,"fechaCreacion":1685714370695,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":108936,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28955072,"numeroExpediente":1641,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MUNICIPALIDAD DE GENERAL ROCA s/ACCIÓN DE INCONSTITUCIONALIDAD (Leyes Provinciales N° 4317 y 4318)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1641. "},"recurso":{"id":4953420,"expediente":{"id":28955072,"numeroExpediente":1641,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CS