{"id":764248,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"REQUERIDO: GARIN, MAURICIO JOSE s/EXTRADICION - ART. 52","alias":null,"caratula":"REQUERIDO: GARIN, MAURICIO JOSE s/EXTRADICION - ART. 52","inconstitucional":false,"falloDestacado":{"id":1588,"titulo":"Extradición: Introducción de exigencias formales ajenas al tratado aplicable","cabecilla":"<p>Rechazo por parte del juzgado de primera instancia de la extradici&oacute;n a la Rep&uacute;blica de Guatemala para someter al requerido a proceso por su posible participaci&oacute;n en la comisi&oacute;n de los delitos de asociaci&oacute;n il&iacute;cita y lavado de dinero u otros activos- Recurso de apelaci&oacute;n interpuesto por la representante del Ministerio P&uacute;blico - Pedido de extradici&oacute;n suficientemente claro al referir que la imputaci&oacute;n es por la administraci&oacute;n, inversi&oacute;n y ocultamiento de fondos captados a resultas del delito de cohecho activo con el fin de obtener la adjudicaci&oacute;n de la obra p&uacute;blica en cuesti&oacute;n - Resulta ajeno a este tr&aacute;mite incorporar mayores exigencias sobre la prueba obrante en el proceso extranjero que da sustento a la imputaci&oacute;n y/o a la materialidad de los hechos en que se apoya - Cuestiones que conciernen al debate sobre el fondo teniendo en cuenta que en el juicio de extradici&oacute;n no se puede discutir acerca de la existencia del hecho imputado o la culpabilidad del requerido - El hecho de que la asociaci&oacute;n il&iacute;cita extranjera estuviera conformada por el requerido junto a varias otras personas permite tener por cumplido el m&iacute;nimo de tres personas que exige el derecho argentino - Nada impide que los Estados intervinientes eval&uacute;en la viabilidad del traslado del requerido al extranjero y, en su caso, arbitren las medidas necesarias para que se efect&uacute;e resguardando su integridad con especial consideraci&oacute;n a la patolog&iacute;a que detenta y seg&uacute;n el estad&iacute;o por el que atraviese en ese momento - Adopci&oacute;n por parte del pa&iacute;s requirente de las medidas necesarias para que su permanencia en esa jurisdicci&oacute;n tenga lugar en condiciones que salvaguarden sus condiciones de salud - Se revoca la resoluci&oacute;n apelada y se declara procedente la extradici&oacute;n del requerido.</p>","esNovedad":true,"fecha":1612407600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1612793185750,"usuarioCreacion":6,"fechaCreacion":1612534258055,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30346,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28674312,"numeroExpediente":9961,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":