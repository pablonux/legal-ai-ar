{"id":794554,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"L., C. C. c/ OAM (Obra Asistencial Mutual Mar del Plata) y otro s/ incidente. ","alias":null,"caratula":"Incidente Nº 1 - ACTOR: LEIVA, CECILIA CAROLINA DEMANDADO: OAM (OBRA ASISTENCIAL MUTUAL MAR DEL PLATA) Y OTRO s/INCIDENTE","inconstitucional":false,"falloDestacado":{"id":6601,"titulo":"Derecho a la salud: competencia federal para entender en un reclamo de afiliación","cabecilla":"<p style=\"text-indent:2em\">La actora -que posee certificado de discapacidad- inicia un amparo que persigue su afiliación a una obra asistencial mutual para agentes municipales a raíz de haber sido designada como personal del municipio. Relata que, pese a sus reclamos, la demandada dilata injustificadamente su incorporación mediante evasivas y actos obstructivos y que, con esa conducta, no solo le imposibilita acceder a la cobertura de salud sino, también, el cobro de sus haberes.</p><p style=\"text-indent:2em\">El magistrado federal declinó conocer con fundamento en que la accionada es una entidad mutual con personería jurídica provincial que no estaría comprendida en el Sistema Nacional de Seguro de Salud y la jueza local rechazó la atribución argumentando que sí se trataría de un agente natural de dicho Sistema.</p><p style=\"text-indent:2em\">La Corte resolvió que la justicia federal es quien debe entender en la causa. Afirmó que el tema objeto de litigio conduce, en principio, al examen del alcance de las obligaciones impuestas a las mutuales y a las empresas de medicina prepaga por la ley 26.682 y que, más allá de la relevancia de aspectos contractuales eventualmente involucrados, procede estar a la doctrina según la cual los procesos que versan, en último término, sobre situaciones alcanzadas por normas federales deben tramitar ante ese fuero en razón de la materia. </p>","esNovedad":true,"fecha":1710817200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1710956921255,"usuarioCreacion":11,"fechaCreacion":1710881702419,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":118341,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38281806,"numeroExpediente":19083,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8765,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":380,"codigo":"AMPAROS"}},"caratula":"Incidente Nº 1 - ACTOR: L., C. C. DEMANDADO: OAM (OBRA ASISTENCIAL MUTUAL MAR DEL PLATA) Y OTRO s/INCIDENTE","verificacionMesa":"N","etiqueta":null,"hijos"