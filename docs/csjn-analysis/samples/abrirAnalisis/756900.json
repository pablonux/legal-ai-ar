{"id":756900,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":80005,"valor":"RECHAZA LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008181305,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Estado Nacional (Estado Mayor General del Ejército) c/ Mendoza, Provincia de s/ acción declarativa de inconstitucionalidad ","alias":null,"caratula":"ESTADO NACIONAL (ESTADO MAYOR GENERAL DEL EJERCITO) c/ MENDOZA, PROVINCIA DE s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":1292,"titulo":"Demanda del Estado Nacional contra la Provincia de Mendoza a fin de que se declare la inconstitucionalidad de las leyes locales por medio de las cuales se estableció el carácter de \"área natural protegida\" y sujeta a expropiación","cabecilla":"<p>&Aacute;reas especialmente protegidas que constituyen ecosistemas, que se deben conservar o preservar en estado inalterable a largo plazo, para beneficio y goce de las presentes y futuras generaciones - Predio utilizado por el Ej&eacute;rcito Argentino - Art. 41 de la Constituci&oacute;n Nacional - Protecci&oacute;n del ambiente - Ley 25.675 de presupuestos m&iacute;nimos para el logro de una gesti&oacute;n sustentable y adecuada del ambiente - Ley local que regula el sistema provincial de &aacute;reas naturales protegidas - Interacci&oacute;n de las potestades federales y las competencias locales en la protecci&oacute;n del ambiente - Ejercicio de las competencias concurrentes - Delegaci&oacute;n de las Provincias a la Naci&oacute;n de la competencia para dictar las normas que contengan los presupuestos m&iacute;nimos de protecci&oacute;n ambiental (arts. 41 y 121 de la Constituci&oacute;n Nacional) - Leyes ambientales provinciales que complementan a la ley nacional de presupuestos m&iacute;nimos en el sentido de agregar alguna exigencia o requisito no contenido en la legislaci&oacute;n complementada - Bienes del patrimonio natural y cultural, de enorme riqueza por la gran variedad de destacados paisajes, de excepcional belleza, y biodiversidad existentes, que los califican en especial en materia de educaci&oacute;n ambiental y su difusi&oacute;n, para promover, facilitar y realizar investigaciones cient&iacute;ficas, y por el inter&eacute;s tur&iacute;stico que despiertan, como bienes panor&aacute;micos o esc&eacute;nicos, de valor recreativo - Se rechaza la demanda - Disidencia del juez Rosenkrantz: En el esquema previsto en el art. 75, inc. 30 de la Constituci&oacute;n son inv&aacute;lidas no solamente las interferencias en el cumplimiento de los fines nacionales que puedan llevar a cabo las autoridades locales, sino tambi&eacute;n todo intento del gobierno provincial dirigido a sustituir al Congreso en la designaci&oacute;n de los fines a cuya realizaci&oacute;n se encuentra afectado el establecimiento - Disidencia de la jueza Highton de Nolasco: Las facultades provinciales, por importantes y respetables que sean, no justifican la prescindencia de la solidaridad requerida por el destino com&uacute;n de los dem&aacute;s estados aut&oacute;nomos y de la Naci&oacute;n toda - Las disposiciones dictadas en virtud del poder de polic&iacute;a que se pretende atribuir a la Provincia de Mendoza, interfieren en el ejercicio de las funciones que ejecuta el Estado Nacional a trav&eacute;s del establecimiento militar regido por normas federales</p>","esNovedad":true,"fecha":1576551600000,"relevancia":3,"usuarioModificacion":5,"fechaModificacion":1599073706632,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":28022,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23751080,"numeroExpediente":85,"anioExpediente":2006,"tomoExpediente":42,"letraExpediente":"E","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ESTADO NACIONAL (ESTADO MAYOR GENERAL DEL EJERCITO) c/ MENDOZA, PROVINCIA DE s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"E. 85. XLII. "},"recurso":{"id":3335302,"expediente":{"id":23751080,"numeroExpediente":85,"anioExpediente":2006,"tomoExpediente":42,"letraExpediente":"E","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ESTADO NACIONAL (ESTADO MAYOR GENERAL DEL EJERCITO) c/ MENDOZA, PROVINCIA DE s/ACCION DECLARATIVA DE INCONSTITUCIONALIDAD","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"E. 85. XLII. "},"tipoRecurso":{"id":1154,"codigo":"ORI","descripcion":"ORIGINARIO                   "},"claveRecurso":"CSJ 000085/2006(42-E)/CS001","identificacionExpediente":"E. 85. XLII.