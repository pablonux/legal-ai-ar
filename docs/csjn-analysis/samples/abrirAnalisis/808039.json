{"id":808039,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - CAMARA DE PRODUCTORES Y COMERCIALIZADORES DE INFUSIONES DEL NORTE (CAPROCOINO) c/ INSTITUTO NACIONAL DE LA YERBA MATE s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":8643,"titulo":"Tribunal superior de la causa: denegación en forma errónea","cabecilla":"<p style=\"text-indent: 2em;\">La Cámara Federal de Apelaciones de Mendoza declaró competente al Juzgado Federal de Posadas para entender en la causa y le remitió los autos.</p><p style=\"text-indent: 2em;\">La actora interpuso un recurso extraordinario contra este pronunciamiento, que fue agregado por el juez mencionado para luego remitir las actuaciones a la Cámara Federal de Apelaciones de Posadas.</p><p style=\"text-indent: 2em;\">Esta última corrió el traslado previsto en el artículo 257 del Código Procesal Civil y Comercial de la Nación y no hizo lugar al recurso extraordinario, lo que originó la presentación de la correspondiente queja. </p><p style=\"text-indent: 2em;\">La Corte dejó sin efecto este pronunciamiento. </p><p style=\"text-indent: 2em;\">Señaló que la sentencia impugnada era la emanada de la Cámara Federal de Apelaciones de Mendoza que, de tal forma, era el superior tribunal de la causa cuando, no obstante ello y en forma errónea, la Cámara Federal de Apelaciones de Posadas, había asumido dicho carácter resolviendo sobre la procedencia del remedio federal.</p>","esNovedad":true,"fecha":1746673200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1746732212335,"usuarioCreacion":4,"fechaCreacion":1746732209350,"privado":false,"posicion":1,"resumen":{"idResumen":134,"resumen":"La Corte dejó sin efecto la resolución de la Cámara Federal de Apelaciones de Posadas, al considerar que no era el superior tribunal competente para resolver sobre el recurso federal.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":135959,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36160630,"numeroExpediente":194,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1105,"descripcion":"INHIBITORIA","idMateria":2,"tema":{"id":340,"codigo":"CO