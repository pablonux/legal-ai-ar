{"id":762055,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Ministerio de Trabajo, Empleo y Seguridad Social c/ Asociación Profesional Policial y Penitenciaria de Entre Ríos s/ ley de asoc. sindicales ","alias":null,"caratula":"MINISTERIO DE TRABAJO EMPLEO Y SEGURIDAD SOCIAL c/ ASOCIACION PROFESIONAL POLICIAL Y PENITENCIARIA DE ENTRE RIOS s/LEY DE ASOC.SINDICALES","inconstitucional":false,"falloDestacado":{"id":1555,"titulo":"La prohibición de asociarse con fines gremiales alcanza al personal penitenciario","cabecilla":"Pronunciamiento que hizo lugar al pedido de la  Asociación Profesional Policial y Penitenciaria de Entre Ríos a inscribirse como organización sindical - Cuestión análoga a la resuelta en Fallos: 340:437 Sindicato Policial Buenos Aires - Aún después de adoptados los tratados internacionales con jerarquía constitucional, el derecho a sindicalizarse de los miembros de la policía está sujeto a las restricciones o a la prohibición que surjan de la normativa interna - La normativa local ha proscripto al personal policial asociarse con fines gremiales - A la misma conclusión debe llegarse respecto del personal penitenciario - La normativa que regula al personal penitenciario en la provincia contiene una disposición casi idéntica a la del personal policial - Si bien la doctrina del precedente mencionado fue elaborada teniendo en miras al personal policial y no al personal penitenciario, en ambos supuestos se trata de miembros de fuerzas de seguridad estatales cuya organización, actividades y estatutos legales exhiben una clara similitud - Tanto el personal penitenciario como el policial tienen deberes y prohibiciones estrictamente análogos entre sí y las funciones asignadas a ambos son también similares - Sin perjuicio de que dicha normativa pueda modificarse o derogarse en el futuro, la peticionante no puede constituirse hoy como una entidad sindical - Se revoca la sentencia apelada y se confirma la resolución del Ministerio de Trabajo, Empleo y Seguridad Social de la Nación que había denegado la inscripción gremial - Disidencia del juez Maqueda: remisión a su voto en Fallos: 340:437 - Disidencia del juez Rosatti: remisión a sus votos en Fallos: 340:437 y 343:767","esNovedad":true,"fecha":1606964400000,"relevancia":2,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29937,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":27205856,"numeroExpediente":44551,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"desc