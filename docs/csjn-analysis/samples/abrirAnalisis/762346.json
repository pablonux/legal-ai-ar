{"id":762346,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":23,"codigoRelacion":80023,"valor":"DECLARA MAL CONCEDIDO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201010151430,"fechaModLong":201010151430,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"B., V. S. y otro c/ Omint s/ amparo contra actos de particulares ","alias":null,"caratula":"B.,V.S Y OTRO c/ OMINT s/AMPARO CONTRA ACTOS DE PARTICULARES","inconstitucional":false,"falloDestacado":{"id":1548,"titulo":"Concesión del recurso extraordinario","cabecilla":"Pronunciamiento de cámara que, tras meritar que lo debatido era la interpretación de una norma de carácter federal, concedió el recurso extraordinario interpuesto por el beneficiario de la regulación de honorarios y descartó la arbitrariedad denunciada - Los órganos judiciales llamados a expedirse sobre la concesión del recurso extraordinario federal, deben resolver categórica y circunstanciadamente si tal apelación, prima facie valorada, satisface todos los recaudos formales y sustanciales que condicionan su admisibilidad y, entre ellos, la presencia de una cuestión federal - El a quo desechó estar frente un supuesto de arbitrariedad pero consideró que la apelación extraordinaria era procedente asignando carácter federal a la ley 27.423 - Conclusión objetable ya que, no mediando circunstancias excepcionales, son ajenas a la jurisdicción extraordinaria las cuestiones concernientes a la interpretación de las disposiciones arancelarias y, en general, todo lo atinente a los honorarios regulados en las instancias ordinarias, aun cuando se invoque su carácter nacional - Conflictos de naturaleza esencialmente procesal, incluso cuando el trámite se haya consumado ante tribunales federales - Se declara mal concedido el recurso extraordinario","esNovedad":true,"fecha":1607569200000,"relevancia":1,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29987,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31527833,"numeroExpediente":19977,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":1922,"descripcion":"AMPARO CONTRA ACTOS DE PARTICULARES","idMateria":112,"tema":{"id":0,"codigo":"AMPAROS"}},"caratula":"B.,V.S Y OTRO c/ OMINT s/AMPARO CONTRA ACTOS DE PARTICULARES","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"19977. "},"recurso":{"id":5659786,"expediente":{"id":31527833,"numeroExpediente":19977,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario"