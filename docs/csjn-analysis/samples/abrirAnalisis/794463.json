{"id":794463,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"OLEAGINOSA OESTE S.A. c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","inconstitucional":false,"falloDestacado":{"id":6621,"titulo":"Determinación de oficio del impuesto a las ganancias sobre exportaciones","cabecilla":"<p style=\"text-indent:2em\">La Administración Federal de Ingresos Públicos (AFIP) determinó de oficio el impuesto a las ganancias de la actora  y sostuvo que los precios de transferencia de las exportaciones de <em>commodities</em> agropecuarios realizadas a la empresa vinculada radicada en Suiza no respondían a las prácticas normales de mercado entre partes independientes. </p><p style=\"text-indent:2em\">El Tribunal Fiscal de la Nación revocó parcialmente esta resolución y la cámara confirmó la decisión. </p><p style=\"text-indent:2em\">La AFIP interpuso un recurso extraordinario y la Corte revocó parcialmente la sentencia apelada. </p><p style=\"text-indent:2em\">En cuanto a la determinación de si las operaciones eran comparables o no a los fines de la aplicación del método del precio comparable no controlado consideró que se trataba una cuestión típica de hecho y prueba que corresponde a los jueces de la causa, salvo los supuestos de desaciertos y omisiones de gravedad extrema, a causa de los cuales los pronunciamientos no pueden adquirir validez jurisdiccional.</p><p style=\"text-indent:2em\">Por otro lado, el Tribunal consideró que las instancias anteriores omitieron pronunciarse sobre una cuestión debidamente introducida por la demandada y reconocida por la actora, conducente para la correcta solución del caso, referida a que la empresa actora no había logrado demostrar fehacientemente la fecha de concertación de las ventas efectuadas a la empresa vinculada por carecer de registros, lo que la obligó a determinarla mediante un cálculo aproximado en función de la fecha de facturación. Recordó que si el juzgador ha prescindido de efectuar un tratamiento adecuado del asunto conforme a las pruebas producidas, y si los argumentos expuestos por la cámara han franqueado el límite de razonabilidad al que está subordinada la valoración de la prueba, el pronunciamiento no constituye un acto judicial válido.</p>","esNovedad":true,"fecha":1712199600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1712273976748,"usuarioCreacion":11,"fechaCreacion":1712270428438,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":118275,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"