{"id":766958,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"REQUERIDO: RAMIREZ, HORACIO ALBERTO s/EXTRADICION","alias":null,"caratula":"REQUERIDO: RAMIREZ, HORACIO ALBERTO s/EXTRADICION","inconstitucional":false,"falloDestacado":{"id":2201,"titulo":"Extradición y prescripción de la pena de acuerdo al tratado bilateral aplicable ","cabecilla":"<p>Resoluci&oacute;n que declar&oacute; procedente la extradici&oacute;n del requerido al Reino de Espa&ntilde;a -&nbsp;Solicitud del Procurador General de la Naci&oacute;n interino para que se revoque el auto apelado y se declare improcedente el pedido de extradici&oacute;n -&nbsp;Cuesti&oacute;n previa relativa a si desde el momento en que qued&oacute; firme el auto de condena extranjero en que se sustenta el pedido ha transcurrido el plazo de prescripci&oacute;n de la pena seg&uacute;n el derecho argentino - Exigencias del Tratado bilateral seg&uacute;n el cual no se conceder&aacute; la extradici&oacute;n cuando de acuerdo a la ley de alguna de las Partes se hubiera extinguido la pena o la acci&oacute;n penal correspondiente al delito por el cual se la solicita -&nbsp;Decisi&oacute;n del&nbsp;juez que resolvi&oacute; rechazar la excepci&oacute;n de prescripci&oacute;n de la pena&nbsp; por considerar que deb&iacute;a tenerse el t&eacute;rmino como renacido al momento en que fue detenido en nuestro pa&iacute;s, es decir, con anterioridad a que se agotara el plazo - Falta de&nbsp;cr&iacute;tica alguna a ese fundamento en el memorial - Se confirma la sentencia apelada que declar&oacute; procedente la extradici&oacute;n - Disidencia del juez Rosenkrantz:&nbsp;sea que el plazo se compute desde la fecha de firmeza informada por la autoridad judicial espa&ntilde;ola o desde el registro en Interpol de la orden de captura, la conclusi&oacute;n es que la sanci&oacute;n aplicada se extingui&oacute; para la ley argentina.</p>","esNovedad":true,"fecha":1623294000000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1623414412993,"usuarioCreacion":11,"fechaCreacion":1623412744515,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31267,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":15802277,"numeroExpediente":60002406,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descripcionLarga":"FLP - Justicia Federal de La Plata"},"objetoJuicio":{"id":7921,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"REQUERIDO: RAMIREZ, HORACIO ALBERTO s/EXTRADICION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"60002406. "},"recurso":{"id":5392192,"expedi