{"id":779774,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"COSCIA, ORLANDO ARCANGEL c/ ESTADO NACIONAL (PODER EJECUTIVO NACIONAL) Y OTRO s/ AMPARO LEY 16.986","alias":null,"caratula":"COSCIA, ORLANDO ARCANGEL c/ ESTADO NACIONAL (PODER EJECUTIVO NACIONAL) Y OTRO s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":4844,"titulo":"Rechazo de la recusación de los miembros de la Corte en una causa sobre el régimen jubilatorio de magistrados y funcionarios judiciales","cabecilla":"<p>Una cámara federal declaró la inconstitucionalidad del art. 9°, inc. b, de la ley 24.018 modificada por la ley 27.546 en cuanto dispone como requisito para acceder al trámite de la jubilación “cesar definitivamente en el ejercicio del cargo”. La demandada interpuso recurso extraordinario y recusó a todos los miembros de la Corte, solicitando la designación de conjueces ajenos al Poder Judicial de la Nación, ya que sus integrantes se encuentran incluidos en el régimen jubilatorio cuestionado. <b>La Corte desestimó las recusaciones planteadas.</b> Señaló que la recurrente omitió señalar cuál es el interés personal en el pleito de los miembros del Tribunal, máxime cuando la causal de recusación invocada se refiere a intereses económicos o pecuniarios y no se invoca esa circunstancia. Agregó que la normativa cuestionada forma parte del capítulo II de la ley 24.018, cuyo ámbito de aplicación en principio no alcanza a los jueces de la Corte Suprema de Justicia de la Nación, cuyos derechos están incluidos en el capítulo I de dicha ley.</p>","esNovedad":true,"fecha":1669258800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1669389936837,"usuarioCreacion":4,"fechaCreacion":1669315947207,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":104997,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35262241,"numeroExpediente":358,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":17,"codigo":"17","abreviatura":"FGR","descripcion":"Justicia Federal de General Roca","estado":0,"descripcionLarga":"FGR - Justicia Federal de General Roca"},"objetoJuicio":{"id":2103,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":20,"codigo":"AMPAROS"}},"caratula":"COSCIA, ORLANDO ARCANGEL c/ ESTADO NACIONAL (PODER EJECUTIVO NACIONAL) Y OTRO s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"358. "},"recurso":{"id":6380430,"expediente":{"id":35262241,"numeroExpediente":358,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":17,"codigo":"17","abreviatura":"FGR","descripcion":"Justicia Federal de General Roca","estado":0,"des