{"id":784302,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - KOLB KOSLOSKY , MARIA  c/ ANSES s/REAJUSTES VARIOS","inconstitucional":false,"falloDestacado":{"id":5464,"titulo":"Pensión por fallecimiento y actualización de las remuneraciones","cabecilla":"<p>La actora obtuvo beneficio de pensión directa por el fallecimiento de su esposo -el 7 de febrero de 2009-  y la cámara dispuso que por aplicación de la ley 26.417 no correspondía revisión alguna del haber inicial de la misma. Contra esa decisión la accionante dedujo recurso extraordinario que fue denegado y dio lugar a la correspondiente queja. La Corte revocó el pronunciamiento apelado. Para decidir de ese modo, señaló que no eran  aplicables las prescripciones de la ley citada, dado que la resolución SSS 6/2009 establece en su art. 4° que aquellas solo resultan de aplicación para las prestaciones cuyos titulares hubieran cesado a partir del 28 de febrero de 2009 inclusive. Consecuentemente, indicó que la actualización de las remuneraciones debería realizarse mediante el uso del índice de salarios básicos de convenio de la industria y la construcción, conforme la doctrina que de los precedentes “Elliff” (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=332&amp;pagina=1914\">Fallos: 332:1914</a>) y del voto de la mayoría en la causa “Blanco” (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=341&amp;pagina=1924\">Fallos: 341:1924</a>),  hasta la fecha de adquisición del derecho. Ello toda vez que, de otro modo, los salarios computables no reflejarían las importantes variaciones habidas desde el cese, particularmente, las acontecidas a partir del año 2002.</p>","esNovedad":true,"fecha":1684810800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1684874636215,"usuarioCreacion":11,"fechaCreacion":1684874600802,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":109541,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30029023,"numeroExpediente":67316,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":5,"codigo":"5","abreviatura":"CSS","descripcion":"Camara Federal de la Seguridad Social","estado":0,"descripcionLarga":"CSS - Camara Federal de la Seguridad Social"},"objetoJuicio":{"id":10645,"descripcion":"ACCION MERAMENTE DECLARATIVA","idMateria":6,"tema":{"id":540,"codigo":"PREV"}},"caratula":"Recurso Queja Nº 1 - DEL BUSTO LAURA ELENA c/ ANSES s/ACCION MERAMENTE DECLARATIVA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"67316. "},"recurso":{"id":5106902,"expediente":{"id":30029023,"numeroExpe