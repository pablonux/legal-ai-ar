{"id":775704,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"SANCHEZ, OSCAR VICENTE c/ MUNICIPALIDAD DE ESQUINA (CORRIENTES) Y OTRO Y/O QUIEN RESULTE RESPONSABLE s/ ACCIÓN CONTENCIOSA ADMINISTRATIVA","alias":null,"caratula":"SANCHEZ, OSCAR VICENTE c/ MUNICIPALIDAD DE ESQUINA (CORRIENTES) Y OTRO Y/O QUIEN RESULTE RESPONSABLE s/accion contenciosa administrativa","inconstitucional":false,"falloDestacado":{"id":4124,"titulo":"Despido arbitrario, legítima expectativa del trabajador y protección constitucional","cabecilla":"<p>El superior tribunal provincial rechaz&oacute; la demanda del actor que solicitaba a un municipio el pago de diferencias salariales e indemnizaciones por la ruptura del v&iacute;nculo de empleo, argumentando que solo se hab&iacute;a probado una relaci&oacute;n laboral de naturaleza precaria y eventual. La Corte, por mayor&iacute;a, revoc&oacute; ese pronunciamiento ordenando el dictado de un nuevo fallo. Para decidir de este modo, consider&oacute; que medi&oacute; una evidente desviaci&oacute;n de poder, al encubrir una designaci&oacute;n que debi&oacute; haber revestido car&aacute;cter permanente bajo el ropaje de una supuesta actividad precaria y eventual. Esa actuaci&oacute;n irregular, se&ntilde;al&oacute; el Tribunal, &nbsp;no pudo derivar en un beneficio para la administraci&oacute;n al momento de disponer la desvinculaci&oacute;n, pues hab&iacute;a generado en el agente una leg&iacute;tima expectativa de permanencia laboral que merec&iacute;a la protecci&oacute;n que el art&iacute;culo 14 bis de la Constituci&oacute;n Nacional otorga al trabajador contra el &ldquo;despido arbitrario&rdquo;.</p>","esNovedad":true,"fecha":1655780400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1655906712688,"usuarioCreacion":4,"fechaCreacion":1655841863941,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":34231,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32509420,"numeroExpediente":1748,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"SANCHEZ, OSCAR VICENTE c/ MUNICIPALIDAD DE ESQUINA (CORRIENTES) Y OTRO Y/O QUIEN RESULTE RESPONSABLE s/accion contenciosa administrativa ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1748. "},"recurso":{"id":5418286,"expediente":{"id":32509420,"numeroExpediente":1748,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"co