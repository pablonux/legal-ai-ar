{"id":801161,"competencia":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":190013,"valor":"QUEJA POR RETARDO DE JUSTICIA","activo":"S","usuarioCreacion":"CYCJ3F","usuarioMod":"CYCJ3F","fechaCreacionLong":202603171152,"fechaModLong":202603171152,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"M. S., M. G. c/ F., M. V. s/RESTITUCIÓN INTERNACIONAL DE MENORES ","inconstitucional":false,"falloDestacado":{"id":7584,"titulo":"Restitución internacional: oposición del niño a su devolución como excepción que debe ser interpretada de manera restrictiva","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal provincial rechazó el pedido de restitución internacional de un niño al Reino de España en los términos del Convenio sobre los Aspectos Civiles de la Sustracción Internacional de Menores.</p><p style=\"text-indent:2em\">Ante el recurso del padre <b>la Corte revocó esta sentencia e hizo lugar a la demanda de restitución internacional</b>.</p><p style=\"text-indent:2em\">Consideró que la retención se había tornado ilícita y que no se encontraba configurada la excepción convencional, invocada por el tribunal apelado, relativa a la existencia de oposición del niño a su reintegro.</p><p style=\"text-indent:2em\">Expresó que la existencia de una simple oposición o preferencia del niño no resulta una circunstancia que, por sí sola, resulte suficiente para rechazar la restitución internacional y que la excepción prevista en el artículo 13, segundo párrafo, de la Convención de La Haya en cuanto se refiere a la opinión de los niños, sólo procede frente a una verdadera oposición, entendida como un repudio genuino, coherente e irreductible a regresar, y no como una mera preferencia o negativa.</p><p style=\"text-indent:2em\">Agregó que reforzaba la solución el peritaje elaborado en respuesta a la medida para mejor proveer ordenada por la suprema corte local, según el cual el niño cuenta con los recursos y mecanismos psicológicos necesarios para afrontar una situación de traslado y que probablemente la restitución sea propiciatoria para el devenir subjetivo del niño, en tanto le permitirá leer, resignificar y trazar un fragmento de su historia singular que se delinea anulado y obstruido, con el acompañamiento y la asistencia profesional adecuada.</p><p style=\"text-indent:2em\">Por lo demás, agregó el Tribunal, de las constancias se desprende que el menor fue oído durante el proceso de manera directa, tanto por la jueza de grado, así como también por profesionales especializados, en múltiples oportunidades, sin que las expresiones de este, ponderadas a la luz de las conclusiones alcanzadas por los peritos actuantes, puedan configurar una verdadera oposición, entendida como un repudio genuino e irreductible de regresar a España</p>","esNovedad":true,"fecha":1726542000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1726831841787,"usuarioCreacion":11,"fechaCreacion":1726602935583,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":127738,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36350909,"numeroExpediente":450,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"SCHMIDT, CARLOS EDUARDO c/ PEREZ, DANTE EDMUNDO BALTASAR Y OTRA s/ordinario ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"450. "},"recurso":{"id":6264941,"expediente":{"id":36350909,"numeroExpediente":450,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"SCHMIDT, CARLOS EDUARDO c/ PEREZ, DANTE EDMUNDO BALTASAR Y OTRA s/ordinario ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"450. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CSJ 000450/2022/RH001","identificacionExpediente":"CSJ 000450/2022/RH001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":9,"nombreUsuario":"27203847888","apellido":"Sicardi","nombre":"Alexia","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583843697000,"nombreUsuarioMigrado":null,"codig