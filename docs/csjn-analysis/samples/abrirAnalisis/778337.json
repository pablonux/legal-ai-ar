{"id":778337,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"CEBALLOS, ESTEFANÍA ITATÍ Y OTRO c/ DIRECCIÓN NACIONAL DE VIALIDAD Y OTROS s/ DAÑOS Y PERJUICIOS","alias":null,"caratula":"Recurso Queja Nº 3 - CEBALLOS , ESTEFANÍA ITATÍ Y OTRO c/ DIRECCIÓN NACIONAL DE VIALIDAD Y OTROS s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":4541,"titulo":"Responsabilidad del Estado Nacional por un incendio: exigencia de demostrar la prestación irregular","cabecilla":"<p>La actora demandó a la Dirección Nacional de Vialidad y al Estado Nacional a fin de obtener el cobro de una indemnización por los daños y perjuicios ocasionados en un campo  por un incendio que se habría iniciado en la banquina de una ruta nacional. La cámara hizo lugar a la demanda y esta decisión, apelada por el Estado, <b>fue revocada por la Corte</b>. Recordó el Tribunal que la falta de servicio no es suficiente por sí misma para dar nacimiento a la obligación estatal de resarcir, pues debe atenderse a la relación de causalidad entre ella y el daño ocasionado. Agregó que el Estado solo responde si incumplió con un deber legal que le impone obstar el evento lesivo, puesto que una conclusión contraria llevaría al irrazonable extremo de convertirlo en un ente asegurador de todo hecho dañoso que se cometiera. Y que, al considerar que la banquina era una cosa riesgosa cuya custodia se encontraba a cargo del Estado Nacional como dueño o guardián, prescindió del factor de atribución previsto en el art. 1112 del código civil vigente en ese momento, que exigía indagar en las normas que regulan y estructuran los servicios brindados por las autoridades para demostrar concretamente su prestación irregular o defectuosa. Agregó además que la Dirección demandada fue constituida como una entidad autárquica de derecho público que tiene a cargo la conservación de rutas nacionales por lo que se había considerado al Estado como titular de bienes que posiblemente no le pertenezcan.</p>","esNovedad":true,"fecha":1663642800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1663787763374,"usuarioCreacion":11,"fechaCreacion":1663762098943,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":35185,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33367970,"numeroExpediente":31010333,"anioExpediente":2006,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":16,"codigo":"16","abreviatura":"FCT","descripcion":"Justicia Federal de Corrientes","estado":0,"descripcionLarga":"FCT - Justicia Federal de Corrientes"},"objetoJuicio":{"id":3667,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":112,"tema":{"id":222,"codigo":"DAÑOS"}},"caratula":"Recurso Queja Nº 3 - CEBALLOS , ESTEFANÍA ITATÍ Y OTRO 