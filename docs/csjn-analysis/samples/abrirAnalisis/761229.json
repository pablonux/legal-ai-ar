specto una obligación de resultado - Caída sufrida por la actora en la calle cuando iba caminando hacia su trabajo en un día lluvioso - Sentencia que  hizo lugar a la pretensión deducida en concepto de reparación integral, con apoyo en el derecho civil, sin justificar de qué manera la mencionada figura tenía cabida - Sentencia que se limitó a mencionar el citado deber de seguridad sin efectuar examen pormenorizado alguno respecto de la previsibilidad del  acontecimiento y la posibilidad del empleador de adoptar las medidas pertinentes a su respecto - Ausencia de prueba de la relación de causalidad adecuada entre el daño alegado y la conducta de la demandada, presupuesto indispensable para la atribución de responsabilidad civil , requisito no se verifica con la sola circunstancia de que la víctima posea un vínculo laboral con el demandado - Se deja sin efecto la sentencia","esNovedad":true,"fecha":1606359600000,"relevancia":2,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":29729,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31495641,"numeroExpediente":432,"anioExpediente":2011,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":3,"codigo":"3","abreviatura":"CCF","descripcion":"Cámara Nacional de Apelaciones en lo Civil y Comercial Federal","estado":0,"descripcionLarga":"CCF - Cámara Nacional de Apelaciones en lo Civil y Comercial Federal"},"objetoJuicio":{"id":1283,"descripcion":"ACCIDENTE DE TRABAJO/ENFERM. PROF. ACCION CIVIL","idMateria":3,"tema":{"id":444,"codigo":"DAÑOSYPER"}},"caratula":"Recurso Queja Nº 1 - MARTINEZ ROSA ARGENTINA c/ LA SEGUNDA ASEGURADORA DE RIESGOS DE TRABAJO SA Y OTRO s/ACCIDENTE DE TRABAJO/ENFERM. PROF. ACCION CIVIL","verificacionMe