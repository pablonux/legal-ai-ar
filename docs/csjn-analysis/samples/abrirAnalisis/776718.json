umplido en tiempo con la obligación de presentar el informe según lo previsto por una resolución dictada por la Secretaría de Industria. <b>La Corte revocó esta sentencia</b> por considerar que había eludido el tratamiento de planteos conducentes articulados claramente por la apelante en su memorial de agravios. Expresó que el tribunal había omitido lo expuesto por la recurrente en cuanto a que la caducidad de los beneficios debía disponerse mediante el dictado de un acto administrativo que cumpliera los requisitos previstos por la ley 19.549 y que tampoco se había expedido acerca de la alegada inconstitucionalidad de la resolución invocada como fundamento de la decisión.</p>","esNovedad":true,"fecha":1660273200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1660671140636,"usuarioCreacion":11,"fechaCreacion":1660654536968,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":34617,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":15632310,"numeroExpediente":21030369,"anioExpediente":1987,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8807,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":112,"tema":{"id":382,"codigo":"DAÑOS"}},"caratula":"DUART VICTOR HUGO (H) Y OTROS C/ BCRA S/  DA�OS Y PERJUICIOS ","verificacionMesa":"M","etiqueta":null,"hijos":[{"id":29964018,"numeroExpediente":21030369,"anioExpediente":1987,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio"