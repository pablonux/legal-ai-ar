{"id":800050,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - LACUADRA JONATAN DANIEL c/ DIRECTV ARGENTINA S.A. Y OTROS s/DESPIDO","inconstitucional":false,"falloDestacado":{"id":7301,"titulo":"Reajuste de créditos laborales que conduce a un resultado manifiestamente desproporcionado","cabecilla":"<p style=\"text-indent:2em\">La cámara del trabajo confirmó la condena en concepto de créditos salariales e indemnizaciones laborales y ordenó, con pretendido arreglo a las disposiciones del Código Civil y Comercial de la Nación que al capital se le adicionaran los accesorios previstos en el acta 2783/2024 de la citada cámara. Esto último implicó imponer, desde la fecha de exigibilidad de los créditos laborales, la aplicación del CER (Coeficiente de Estabilización de Referencia) sobre el capital de condena, más una tasa de interés pura del 6% anual, con una única capitalización -exclusivamente sobre esa tasa pura- a la fecha de notificación de la demanda.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia.</p><p style=\"text-indent:2em\">Comenzó recordando que recientemente en la causa “Oliva” (<a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=347&amp;pagina=100\">Fallos: 347:100</a>) había descalificado por arbitrario el criterio asentado por la cámara en su anterior acta 2764/2022 (utilización de tasas de interés activas con capitalización anual desde la fecha de notificación del traslado de la demanda) porque carecía de respaldo en las disposiciones del código antes mencionado y, además, arrojaba un resultado económico desproporcionado. Sostuvo que este nuevo criterio de reajuste tampoco encuentra fundamento en las disposiciones del código y arroja resultados igualmente irrazonables.</p><p style=\"text-indent:2em\">Expresó que, en virtud de la génesis, finalidad y forma de cálculo establecidas en las normas que lo implementaron, resulta evidente que el CER en modo alguno es una tasa de interés “reglamentada por el BCRA” como lo afirma la nueva acta de la cámara y que ello se evidencia con mayor claridad aún ante la directiva de que al capital obtenido por aplicación del mencionado coeficiente debe adicionarse, a su vez, un interés “puro” del 6% anual.</p><p style=\"text-indent:2em\">Señaló el Tribunal que el método de reajuste instituido por la cámara en el acta 2783/2024 implica apartarse sin fundamento de las facultades acordadas a los jueces por el inciso c del artículo 768 del Código Civil y Comercial de la Nación ya que comporta la aplicación de un coeficiente para la actualización del capital y no de una tasa de interés fijada según las reglamentaciones del Banco Central.</p>","esNovedad":true,"fecha":1723518000000,"relevancia":3,"usuarioModificacion":4,"fechaModificacion":1723652137134,"usuarioCreacion":11,"fechaCreacion":1723574418535,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":125218,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38944457,"numeroExpediente":49054,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - LACUADRA JONATAN DANIEL c/ DIRECTV ARGENTINA S.A. Y OTROS s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"49054. "},"recurso":{"id":6896000,"expediente":{"id":38944457,"numeroExpediente":49054,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - LACUADRA JONATAN DANIEL c/ DIRECTV ARGENTINA S.A. Y OTROS s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"49054. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CNT 049054/2015/1/RH001","identificacionExpediente":"CNT 049054/2015/1/RH001"},"piezas":null,"urgente":null,"observaciones":"8-8-24  urg - s/carpeta- entregado 15.44","usuarioCreacion":{"id":10,"nombreUsuario":"27179020438","apellido":"Messuti","nombre":"Mariana","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583843772000,"nombreUsuarioM