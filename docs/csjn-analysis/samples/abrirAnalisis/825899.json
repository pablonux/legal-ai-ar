{"id":825899,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ALLEMAN, ELVIO RAMON c/ EMMI SRL Y OTROS s/ORDINARIO - ACCIDENTE CON FUNDAMENTO EN EL DERECHO COMUN ","inconstitucional":false,"falloDestacado":{"id":10623,"titulo":"Reparación integral por fallecimiento de hijo: omisión de consideración de cuestiones relevantes","cabecilla":"<p style=\"text-indent: 2em;\">El superior tribunal provincial modificó la sentencia de cámara que había admitido la demanda por accidente de trabajo y condenado a los codemandados al pago de una reparación integral por la muerte del hijo de los actores.</p><p style=\"text-indent: 2em;\">La Corte declaró parcialmente procedente el recurso extraordinario interpuesto por los demandantes y dispuso que vuelvan los autos al tribunal de origen para que se dicte un nuevo pronunciamiento.</p><p style=\"text-indent: 2em;\">Con respecto al daño moral señaló que el tribunal no había explicado por qué las particulares circunstancias que mencionó y consideró relevantes justificaban fijar el daño moral como un porcentaje del daño material, y en esa cuantía, limitándose a establecerlo de modo puramente dogmático. Recordó en este sentido que en los casos donde se reclama la indemnización del daño por la muerte de un familiar cercano, la reparación por daño moral no tiene necesariamente que guardar relación con el daño material pues no se trata de un daño accesorio a este.</p><p style=\"text-indent: 2em;\">En relación al rechazo de la pérdida de chance expresó que la víctima tenía un trabajo registrado y estable, realizaba tareas superiores a su categoría de registro y tenía muchos años de desarrollo profesional por delante, lo que tornaba infundada la conclusión del tribunal apelado según la cual no había razones para creer que la muerte hubiera frustrado un hipotético progreso económico.</p><p style=\"text-indent: 2em;\">Por último, en cuanto a la decisión de la sentencia apelada de rebajar los montos por los gastos de traslado, el Tribunal consideró que omitió ponderar las particulares circunstancias del caso y las constancias que acreditaban que el padre presentaba un conjunto de enfermedades graves que demandaban apoyo para su movilidad, lo que evidenciaba la necesidad de que contara con apoyos para el traslado durante la internación de su hijo, y la imposibilidad e inconveniencia de hacerlo, por los riesgos que implicaba para su salud, mediante el transporte de colectivos.</p>","esNovedad":true,"fecha":1776913200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1776979216675,"usuarioCreacion":11,"fechaCreacion":1776979211778,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":156281,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34875269,"numeroExpediente":608,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ALLEMAN, ELVIO RAMON c/ EMMI SRL Y OTROS s/ORDINARIO - ACCIDENTE CON FUNDAMENTO EN EL DERECHO COMUN ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"608. "},"recurso":{"id":5841748,"expediente":{"id":34875269,"numeroExpediente":608,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ALLEMAN, ELVIO RAMON c/ EMMI SRL Y OTROS s/ORDINARIO - ACCIDENTE CON FUNDAMENTO EN EL DERECHO COMUN ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"608. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CSJ 000608/2020/RH001","identificacionExpediente":"CSJ 000608/2020/RH001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":7,"nombreUsuario":"27293873432","apellido":"Delaloye","nombre":"Maria Laura","estado":"A","tieneToken":"N","cargo":"JEFE DE DESPACHO","fechaModificacion":null,"fechaCreacion":1533610800000,"nombreUsuarioMigrado":null,"codigo":"SJC287","mail":"ldelaloye@csjn.gov.ar","