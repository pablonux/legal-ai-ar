{"id":802524,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":250002,"valor":"Previsional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Moliné O Connor Eduardo José A c/ EN - Mº Desarollo Social - resol 3085/04 219/05 dto 1319/05 s/proceso de conocimiento","inconstitucional":false,"falloDestacado":{"id":7821,"titulo":"Exclusión del beneficio jubilatorio a un juez que fue removido","cabecilla":"<p style=\"text-indent:2em\">La cámara declaró la inconstitucionalidad del artículo 29 de la ley 24.018 e hizo lugar a la demanda promovida por un ex juez de la Corte Suprema dirigida a obtener la anulación de las normas que, con fundamento en su destitución por juicio político, dejaron sin efecto la asignación mensual vitalicia que le había sido concedida por haberse desempeñado como Ministro de la Corte Suprema de Justicia de la Nación. Consideró para ello que el artículo 60 de la Constitución Nacional, al atribuir al Senado de la Nación la facultad de juzgar la acusación de la Cámara de Diputados, había establecido que su fallo “no tendrá más efecto que destituir al acusado”, por lo que la norma mencionada, al instaurar una consecuencia adicional y distinta a la única prevista para el veredicto del Senado, resultaba contraria a la citada cláusula constitucional.</p><p style=\"text-indent:2em\">La Corte, por mayoría e integrada por conjueces, revocó esta sentencia y, en uso de las facultades del artículo 16, segunda parte, de la ley 48, rechazó la demanda.</p><p style=\"text-indent:2em\">Expresó que la validez de la norma cuestionada ya había sido examinada en los precedentes \"<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7049401\">Marquevich</a>\", del 11 de diciembre de 2014 y “Boggiano” (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=339&amp;pagina=323\">339:323</a>) donde se concluyó que el art. 29 de la ley 24.018, en tanto establece un requisito para la procedencia de los beneficios previsionales regulados por dicha ley, no se opone a las prescripciones del artículo 60 de la Constitución Nacional ni afecta derechos adquiridos.</p>","esNovedad":true,"fecha":1730257200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1730308324286,"usuarioCreacion":11,"fechaCreacion":1730304784780,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":129138,"secretaria":{"id":19,"tipo":"S","descripcion":"Sec. Judicial Nº 2","orden":2,"activo":"S","codigoRelacion":250002,"descripcionWeb":"Previsional","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23365812,"numeroExpediente":768,"anioExpediente":2014,"tomoExpediente":50,"letraExpediente":"M","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuic