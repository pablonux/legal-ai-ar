{"id":761174,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"CONSUMIDORES FINANCIEROS ASOC. CIVIL PARA SU DEFENSA c/ BANCO DE SAN JUAN S.A. Y OTRO s/ORDINARIO","alias":null,"caratula":"Recurso Queja Nº 1 - CONSUMIDORES FINANCIEROS ASOC. CIVIL PARA SU DEFENSA c/ BANCO DE SAN JUAN S.A. Y OTRO s/ORDINARIO","inconstitucional":false,"falloDestacado":{"id":2601,"titulo":"Tope a la tasa de interés que percibe el banco por descubierto y principio de congruencia","cabecilla":"<p>Pronunciamiento que conden&oacute; al banco demandado a cesar para el futuro en el cobro de sumas en concepto de &ldquo;comisi&oacute;n por sobregiro&rdquo;, tanto para clientes que tengan autorizaci&oacute;n para el descubierto como para los que no cuenten con &eacute;l, en la medida en que esa comisi&oacute;n se superponga con el cobro de un inter&eacute;s por ese descubierto - Estableci&oacute; tambi&eacute;n que los intereses no deben exceder -como tope- la tasa cobrada por el Banco de la Naci&oacute;n Argentina por descubiertos bancarios generados por adelantos transitorios de fondos - El tribunal excedi&oacute; los l&iacute;mites de su jurisdicci&oacute;n - La jurisdicci&oacute;n de las c&aacute;maras est&aacute; limitada por los t&eacute;rminos en que qued&oacute; trabada la relaci&oacute;n procesal y el alcance de los recursos concedidos y la prescindencia de tal limitaci&oacute;n infringe el principio de congruencia que se sustenta en los art&iacute;culos 17 y 18 de la Constituci&oacute;n Nacional - La actora no reclam&oacute; en su escrito inaugural la fijaci&oacute;n de un l&iacute;mite m&aacute;ximo para la tasa de inter&eacute;s en las operaciones cuestionadas -&nbsp; El tope establecido por la c&aacute;mara implic&oacute; resolver extra petita, pues concedi&oacute; algo distinto a lo peticionado, que no fue objeto de la demanda y que, en consecuencia, resulta ajena a la relaci&oacute;n jur&iacute;dico-procesal de la causa - La sentencia recurrida no hace m&eacute;rito sobre la aplicaci&oacute;n de tasas desproporcionadamente elevadas - Doctrina de la arbitrariedad - Se deja sin efecto la sentencia apelada.</p>","esNovedad":true,"fecha":1630551600000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1632240998055,"usuarioCreacion":11,"fechaCreacion":1630674288027,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":29712,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24724744,"numeroExpediente":56570,"anioExpediente":2008,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones e