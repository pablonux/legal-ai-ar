{"id":779122,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"BERGONCI ILDA LEONOR c/ YPF S.A. Y OTROS s/ DESPIDO","alias":null,"caratula":"Recurso Queja Nº 1 - BERGONCI ILDA LEONOR c/ YPF S.A. Y OTROS s/DESPIDO","inconstitucional":false,"falloDestacado":{"id":4661,"titulo":"Solidaridad laboral (artículo 30 LCT): defectos en la fundamentación y arbitrariedad","cabecilla":"<p>La cámara hizo extensiva por aplicación de las disposiciones del art. 30 de la Ley de Contrato de Trabajo a YPF S.A. y a YPF Gas S.A. la condena al pago de créditos laborales impuesta a la propietaria de la estación de servicio en la que la demandante había trabajado al considerar que las empresas que proveían de combustibles eran solidariamente responsables por el cumplimiento de las obligaciones derivadas de la relación de trabajo. La Corte, por mayoría, revocó la sentencia apelada afirmando que carecía de rigor lógico y que no brindaba fundamento válido a la condena solidaria impuesta. Consideró que al limitarse a señalar que la dueña de la estación de servicio había celebrado con las codemandadas un contrato de suministro no explicaba cómo dicho contrato pudo implicar una cesión parcial de la actividad “normal y habitual” de las recurrentes, que se ceñía a la venta al por mayor, a la empresa que explotaba una estación de servicio, obviamente dedicada a la venta minorista de dichos combustibles.</p>","esNovedad":true,"fecha":1666062000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1666191086452,"usuarioCreacion":11,"fechaCreacion":1666114901652,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":104539,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31536410,"numeroExpediente":52304,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - BERGONCI ILDA LEONOR c/ YPF S.A. Y OTROS s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"52304. "},"recurso":{"id":5300523,"expediente":{"id":31536410,"numeroExpediente":52304,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - BERGONCI ILDA LEONOR c/ YPF S.A. Y OT