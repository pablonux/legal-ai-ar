{"id":765706,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"ROA RESTREPO, HENRY c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","alias":null,"caratula":"ROA RESTREPO, HENRY c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":1902,"titulo":"Permanencia de extranjeros en territorio nacional y control de legalidad y razonabilidad","cabecilla":"<p>Disposici&oacute;n de la Direcci&oacute;n Nacional de Migraciones por la que declar&oacute; irregular la permanencia en el pa&iacute;s de un ciudadano de nacionalidad colombiana y orden&oacute; su expulsi&oacute;n- Fundamento en lo establecido en el art&iacute;culo 29, inciso c, de la ley 25.871 y en la condena penal que pesaba sobre el migrante - Sentencia de c&aacute;mara que interpret&oacute; que si bien la conducta no pod&iacute;a encuadrarse dentro del citado precepto, resultaba aplicable el supuesto contemplado en el art&iacute;culo 29, inciso j, de la ley mencionada dado que la reiteraci&oacute;n en la comisi&oacute;n de delitos se encontraba prevista en el art&iacute;culo 62, inciso b, de la misma norma como impedimento para la radicaci&oacute;n permanente de extranjeros - Por razones diferentes a las consideradas en sede administrativa concluy&oacute; en que el acto impugnado resultaba leg&iacute;timo - El control judicial de los actos denominados tradicionalmente discrecionales o de pura administraci&oacute;n no implica que el juez reemplace a la Administraci&oacute;n, ya que dicha competencia jurisdiccional es revisora, mas no sustitutiva - La causal impediente para la permanencia en el pa&iacute;s no pudo ser reemplazada en sede judicial por una distinta, que ni siquiera fue considerada por la autoridad administrativa - La determinaci&oacute;n de las razones que obstan a la permanencia de un migrante en el pa&iacute;s corresponde, seg&uacute;n la ley 25.871, a la autoridad migratoria - La concurrencia de la causal impediente hace a la motivaci&oacute;n del acto y debe estar expuesta en &eacute;l y no puede ser modificada posteriormente por los jueces cuando su validez es cuestionada - Decisi&oacute;n que excedi&oacute; el control de legalidad y razonabilidad y que implic&oacute; sustituir los motivos del acto administrativo sin la debida oportunidad de debate en sede administrativa y judicial por parte del migrante - Se revoca la sentencia recurrida.</p>","esNovedad":true,"fecha":1620270000000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1620409129765,"usuarioCreacion":11,"fechaCreacion":1620409127219,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30853,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30299241,"numeroExpediente":53869,"