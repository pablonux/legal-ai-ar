{"id":801423,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Favero, Juan Manuel y otro s/ incidente de recurso extraordinario","alias":null,"caratula":"Incidente Nº 4 - QUERELLANTE: GALEANO , ALEJANDRO ADOLFO  Y OTRO IMPUTADO: FAVERO, JUAN MANUEL Y OTRO s/INCIDENTE DE RECURSO EXTRAORDINARIO","inconstitucional":false,"falloDestacado":{"id":8481,"titulo":"Personería del letrado como apoderado de los querellantes: insuficiencia de las constancias","cabecilla":"<p style=\"text-indent:2em\">Una letrada interpuso un recurso extraordinario invocando el poder otorgado por los damnificados, constituidos en querellantes, durante el transcurso de la audiencia de debate y, de manera subsidiaria, se amparó en la figura del gestor procesal prevista por el artículo 48 del Código Procesal Civil y Comercial de la Nación, alegando la situación de pandemia y el distanciamiento social. </p><p style=\"text-indent:2em\">Luego de ser intimada a acompañar los documentos que acreditasen su personería se presentó uno de los dos sujetos que actuaron como querellantes en el proceso principal, quien expresó su conformidad con todos los actos realizados por su mandataria.</p><p style=\"text-indent:2em\">La Corte desestimó el recurso y declaró la nulidad de lo actuado.</p><p style=\"text-indent:2em\">Consideró que las constancias elevadas y los argumentos brindados para justificar la actuación de la abogada recurrente no resultaban suficientes para legitimar su personería como apoderada de los querellantes, más allá de su participación en ese rol durante el juicio oral, ni resultaba tampoco oportuna, en los términos de la norma mencionada, la ratificación recién ante la sede del Tribunal de la actividad cumplida como gestora procesal al deducir la apelación federal.</p>","esNovedad":true,"fecha":1743649200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1743783078495,"usuarioCreacion":11,"fechaCreacion":1743708059401,"privado":false,"posicion":2,"resumen":{"idResumen":150,"resumen":"La Corte desestimó el recurso por falta de acreditación de personería de la letrada como apoderada de los querellantes, y declaró la nulidad de lo actuado. La ratificación tardía no subsana la falta de legitimación.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":128119,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35197973,"numeroExpediente":33900,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXP