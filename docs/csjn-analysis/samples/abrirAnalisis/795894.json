{"id":795894,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":24,"codigoRelacion":80024,"valor":"DECLARA NULIDAD","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201011041306,"fechaModLong":201011041306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"FERNANDEZ, CRISTINA ELISABET c/ FEINMANN, EDUARDO GUILLERMO s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":6743,"titulo":"Nulidad de la resolución que concede el recurso extraordinario si no se halla fundada","cabecilla":"<p style=\"text-indent: 2em;\">La Cámara confirmó el rechazo de la demanda por daños y perjuicios contra un periodista. Contra esa decisión la actora interpuso el recurso extraordinario que fue concedido toda vez que -según entendió la cámara-  el artículo 14 de la ley 48 dispone que podrán apelarse ante la Corte Suprema las sentencias definitivas pronunciadas por los tribunales superiores cuando la validez de una ley, decreto o autoridad de Provincia se haya puesto en cuestión bajo la pretensión de ser repugnante a la Constitución Nacional, a los Tratados o leyes del Congreso, y la decisión haya sido en favor de la validez de la ley o autoridad de provincia (inc. 2°), extremo que supuestamente se daban en la causa.</p><p style=\"text-indent: 2em;\"><b>La Corte declaró la nulidad de la resolución por la que se concedió el recurso extraordinario</b>. Para decidir de ese modo señaló que los órganos judiciales llamados a expedirse sobre la concesión del recurso extraordinario federal deben resolver categórica y circunstanciadamente si tal apelación satisface todos los recaudos formales y sustanciales que condicionan su admisibilidad (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=310&amp;pagina=1014\">310:1014</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=313&amp;pagina=934\">313:934</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=323&amp;pagina=1247\">323:1247</a>).</p><p style=\"text-indent: 2em;\">En la especie, señaló el Tribunal, los términos del auto de concesión  ponen en evidencia que la cámara solo había sustentado la viabilidad de la apelación federal en una motivación inexistente pues no formuló ninguna inteligencia sobre el alcance y aplicación al caso de una norma federal.</p>","esNovedad":true,"fecha":1713841200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1713900793065,"usuarioCreacion":11,"fechaCreacion":1713900790173,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":119718,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29209694,"numeroExpediente":88115,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Naciona