ial, en cuyo &aacute;mbito habr&iacute;an ocurrido los hechos m&aacute;s graves - El tribunal declarado competente deber&aacute; adoptar las medidas que resulten adecuadas para moderar los efectos negativos del delito, como as&iacute; tambi&eacute;n procurar que el da&ntilde;o sufrido por la v&iacute;ctima hoy adolescente no se vea incrementado como consecuencia del contacto con el sistema de justicia, asegurando que en todas las fases del procedimiento penal se proteja su integridad f&iacute;sica y psicol&oacute;gica.</p>","esNovedad":true,"fecha":1626318000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1626442142173,"usuarioCreacion":11,"fechaCreacion":1626441037714,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31566,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33493285,"numeroExpediente":1523,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"Incidente Nº 1 -  NN: N.N. s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1523. "},"recurso":{"id":5581834,"expediente":{"id":33493285,"numeroExpediente":1523,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula