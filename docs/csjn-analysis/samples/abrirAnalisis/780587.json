{"id":780587,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"BANCO CENTRAL DE LA REPUBLICA ARGENTINA c/ GOBIERNO DE LA CIUDAD DE BUENOS AIRES s/ACCION DECLARATIVA DE CERTEZA","alias":null,"caratula":"BANCO CENTRAL DE LA REPUBLICA ARGENTINA c/ GOBIERNO DE LA CIUDAD DE BUENOS AIRES s/ACCION DECLARATIVA DE CERTEZA - (EXPEDIENTE DIGITAL)","inconstitucional":false,"falloDestacado":{"id":4846,"titulo":"Jurisdicción originaria de la Corte para un reclamo del Banco Central al Gobierno de la Ciudad Autónoma de Buenos Aires","cabecilla":"<p>El Banco Central de la República Argentina (BCRA) promovió acción declarativa de certeza e inconstitucionalidad contra el Gobierno de la Ciudad Autónoma de Buenos Aires a fin de que se decrete la inconstitucionalidad de diversas normas locales que eliminan la exención del impuesto sobre los ingresos brutos o gravan con ese impuesto determinadas actividades. La Corte declaró que la causa <em>corresponde a su competencia originaria en razón de la persona</em>. Entendió que el Banco Central es una entidad autárquica nacional, que según lo dispuesto en los arts. 116 de la Constitución Nacional y 55 de su Carta Orgánica, está sometido al fuero federal y el Gobierno de CABA demandado tiene el mismo puesto que las provincias en el sistema normativo que rige la jurisdicción de los tribunales federales y, por lo tanto, el mismo derecho a dicha competencia originaria, por lo que la única forma de conciliar ambas prerrogativas jurisdiccionales es sustanciando la acción en esa instancia.</p>","esNovedad":true,"fecha":1669258800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1669389841601,"usuarioCreacion":4,"fechaCreacion":1669377841681,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":105506,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35197381,"numeroExpediente":1753,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION DECLARATIVA DE CERTEZA","idMateria":0,"tema":null},"caratula":"BANCO CENTRAL DE LA REPUBLICA ARGENTINA c/ GOBIERNO DE LA CIUDAD DE BUENOS AIRES s/ACCION DECLARATIVA DE CERTEZA - (EXPEDIENTE DIGITAL)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1753. "},"recurso":{"id":5945049,"expediente":{"id":35197381,"numeroExpediente":1753,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION DECLARATIVA DE CERTEZA","idMateria":0,"tema":null},"caratula":"BANCO CENTRAL DE LA REPUBLICA ARGE