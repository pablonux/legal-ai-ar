{"id":800314,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"LA NUEVA FOURNIER S.R.L. s/CONCURSO PREVENTIVO. INCIDENTE DE VERIFICACIÓN TARDÍA PROMOVIDO POR LA AFIP ","inconstitucional":false,"falloDestacado":{"id":7522,"titulo":"Verificación de créditos tributarios: imposibilidad de revisar los actos no cuestionados judicialmente","cabecilla":"<p style=\"text-indent:2em\">El Fisco Nacional intentó verificar en un concurso preventivo diversos créditos tributarios originados en multas fijadas mediante actos administrativos que se encontraban firmes y saldos impagos en el impuesto a las ganancias y en el impuesto al valor agregado. El juez del concurso consideró que tenía la posibilidad de revisar las resoluciones administrativas a fin de analizar la admisibilidad de cada uno de los créditos insinuados, admitió parcialmente las acreencias insinuadas y rechazó varios créditos. </p><p style=\"text-indent:2em\">Ante el rechazo de sus planteos en las instancias anteriores la AFIP interpuso un recurso ante la Corte, que dejó sin efecto esta decisión.</p><p style=\"text-indent:2em\">Consideró que la posición adoptada por las anteriores instancias implicaba el reemplazo del procedimiento de impugnación previsto legislativamente, supliendo así la inactividad o falta de diligencia de los interesados.</p><p style=\"text-indent:2em\">Recordó la doctrina sentada en los precedentes “GCBA c/ Directamoint S.A.” (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=344&amp;pagina=3695\">Fallos: 344:3695</a>) y “Casa Marroquín” (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=310&amp;pagina=719\">Fallos: 310:719</a>) donde se señaló que atribuir al fuero concursal facultades de revisión de la validez intrínseca del título invocado en sustento del crédito importa tanto como prescindir inmotivadamente de las disposiciones que constituyen la regulación procesal específica y en las que se prevén las vías impugnatorias que el contribuyente tiene a su alcance para cuestionar los actos determinativos y plazos para ejercerlas, vencidos los cuales, adquieren firmeza.</p>","esNovedad":true,"fecha":1725937200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1726080182277,"usuarioCreacion":11,"fechaCreacion":1726001837017,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":126180,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32545814,"numeroExpediente":28041,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":24,"codigo":"24","abreviatura":"FSA","descripcion":"Justicia Federal de Salta","estado":0,"d