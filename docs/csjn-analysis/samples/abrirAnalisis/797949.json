{"id":797949,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"D.G.I. C/ IBERA S.A. INVERSIONES Y MANDATOS S/  COBRO DE PESOS ","inconstitucional":false,"falloDestacado":{"id":7124,"titulo":"Demanda por cobro de pesos: carga procesal de demostrar la cuantía de la deuda","cabecilla":"<p style=\"text-indent:2em\">El Fisco Nacional demandó por cobro de pesos contra una sociedad anónima, continuadora de un banco, por las sumas provenientes de retenciones indebidas de tributos recaudados por éste último en el marco del convenio de recaudación suscripto entre el organismo fiscal y dicha entidad bancaria.</p><p style=\"text-indent:2em\">Luego de dos pronunciamientos anteriores de la Corte, la cámara condenó a la sociedad anónima al pago de una suma de dinero.</p><p style=\"text-indent:2em\">La Corte revocó la sentencia apelada. Advirtió que la decisión recurrida se apartaba claramente de los antecedentes de la causa y de lo decidido por el Tribunal en sus pronunciamientos previos.</p><p style=\"text-indent:2em\">Señaló que ambos recurrentes coincidían en reconocer que de los antecedentes de la causa surgía que el monto de capital por el que reclamaba el fisco no era el indicado por la cámara. Por ello, aun cuando se admitiera el razonamiento propuesto por la alzada, la circunstancia de tomar como punto de partida para el cálculo un monto que no correspondía, conducía a partir de una premisa errónea que alteraba per se su resultado.</p><p style=\"text-indent:2em\">Agregó que, tratándose de un juicio de conocimiento, el modo en que había quedado trabada la litis, exigía del fisco tener que demostrar acabadamente el quantum inicialmente reclamado y, en su caso, la medida en que esa deuda debía ser asumida por la demandada, sin que la prueba producida en el proceso hubiera alcanzado tal propósito.</p>","esNovedad":true,"fecha":1719889200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1720029893095,"usuarioCreacion":11,"fechaCreacion":1719951036570,"privado":false,"posicion":14,"resumen":null},"reciboEntrada":{"id":122119,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":15721741,"numeroExpediente":12000610,"anioExpediente":1996,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":23,"codigo":"23","abreviatura":"FRE","descripcion":"Justicia Federal de Resistencia","estado":0,"descripcionLarga":"FRE - Justicia Federal de Resistencia"},"objetoJuicio":{"id":9001,"descripcion":"COBRO DE PESOS/SUMAS DE DINERO","idMateria":112,"tema":{"id":421,"codigo":"CYCF"}},"caratula":"D.G.I. C/ IBERA S.A. INVERSIONES Y MANDATOS S/  COBRO DE PESOS ","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpedien