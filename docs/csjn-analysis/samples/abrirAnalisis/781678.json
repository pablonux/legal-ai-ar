{"id":781678,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"M., G. A. c/ OBRA SOCIAL DEL PODER JUDICIAL DE LA NACION s/LEYES ESPECIALES","alias":null,"caratula":"Recurso Queja Nº 2 - MILLAN, GUSTAVO ALFREDO c/ OBRA SOCIAL DEL PODER JUDICIAL DE LA NACION s/LEYES ESPECIALES (diabetes, cáncer,fertilidad","inconstitucional":false,"falloDestacado":{"id":4981,"titulo":"Recurso de apelación declarado desierto y arbitrariedad de la sentencia","cabecilla":"<p>La sentencia de primera instancia hizo lugar al amparo para que se le brindara al actor la cobertura total de la cirugía que requería en una clínica y con un médico determinado. La obra social apeló este pronunciamiento y la cámara declaró desierto el recurso señalando que no había efectuado una crítica concreta y razonada de los fundamentos. La Corte consideró que este rechazo de la apelación fue dogmático, sobre todo ante el agravio de la apelante referido a que el fallo de origen se había apartado de las disposiciones que determinan que la obra social se halla legalmente obligada a brindar las prestaciones requeridas solo en el marco de un plan cerrado con sus prestadores y hasta el valor previsto en aquellas. Recordó el Tribunal que no hay razones que justifiquen eximir ni mitigar el deber de fundar las sentencias cuando se trata de reclamaciones fundadas en la tutela del derecho a la salud.</p>","esNovedad":true,"fecha":1675911600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1676036056982,"usuarioCreacion":11,"fechaCreacion":1676036035836,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":106217,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35973182,"numeroExpediente":24060,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8775,"descripcion":"LEYES ESPECIALES (diabetes, cáncer,fertilidad","idMateria":112,"tema":{"id":380,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 2 - M., G. A. c/ OBRA SOCIAL DEL PODER JUDICIAL DE LA NACION s/LEYES ESPECIALES (diabetes, cáncer,fertilidad","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"24060. "},"recurso":{"id":6177825,"expediente":{"id":35973182,"numeroExpediente":24060,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8775,"descripcion":"LEYES ESPECIALES (diabetes, cáncer,f