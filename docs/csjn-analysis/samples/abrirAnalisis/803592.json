{"id":803592,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Cruz Chávez, Jaime Leoncio s/ abuso sexual - art. 119 1° párrafo.","alias":null,"caratula":"CISTERNA, IVANA s/ABUSO SEXUAL - ART. 119  1° PARRAFO","inconstitucional":false,"falloDestacado":{"id":7925,"titulo":"Violencia de género y absolución arbitraria","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal provincial declaró inadmisible la impugnación de la absolución del imputado por el delito de abuso sexual.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia al considerar que conducía, sin fundamentos adecuados, a una restricción sustancial de la vía utilizada por la acusación pública.</p><p style=\"text-indent:2em\">Expresó que la fiscalía había fundamentado de manera suficiente por qué la absolución dictada era arbitraria y que los fundamentos del tribunal frente a la reseña de los agravios que el procurador general local había efectuado obturaron una adecuada respuesta jurisdiccional, cuya consecuencia directa es la afectación de la garantía del debido proceso, la cual también ampara al Ministerio Público Fiscal.</p><p style=\"text-indent:2em\">Agregó que la cuestión adquiere mayor entidad si se tiene en cuenta que el accionar del acusado tuvo lugar en un claro contexto de violencia de género contra su ex pareja, conforme los artículos 1º de la Convención de Belém do Pará y 4° de su ley reglamentaria n° 26.485 de Protección Integral de las Mujeres. Recordó que la citada convención obliga a los Estados Partes a actuar con la debida diligencia para prevenir, investigar y sancionar la violencia de género a la vez que establece que la mujer tiene derecho a obtener una respuesta oportuna y efectiva, y a la amplitud probatoria teniendo en cuenta las circunstancias especiales en las que se desarrollan los actos de violencia y quiénes son sus naturales testigos.</p>","esNovedad":true,"fecha":1732158000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1732287918004,"usuarioCreacion":4,"fechaCreacion":1732278131513,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":130172,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32798658,"numeroExpediente":2215,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10579,"desc