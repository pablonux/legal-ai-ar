{"id":796530,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ANGIO SALUD SA c/ GOBIERNO DE LA PCIA DE SANTA CRUZ MINISTERIO DE ASUNTOS SOCIALES s/COBRO DE SUMAS DE DINERO","inconstitucional":false,"falloDestacado":{"id":6803,"titulo":"Improcedencia de la competencia originaria cuando se trata de una pretensión regida por el derecho público local","cabecilla":"<p style=\"text-indent:2em\">Una firma con domicilio en la Ciudad Autónoma de Buenos Aires promovió demanda, ante un juzgado civil y comercial federal contra la Provincia de Santa Cruz, a fin de obtener el pago de una suma de dinero por el cobro de diversas facturas por servicios médicos.</p><p style=\"text-indent:2em\">Ante la excepción de incompetencia planteada por la demandada la Corte declaró que la causa es ajena a su competencia originaria.</p><p style=\"text-indent:2em\">Recordó que para que dicha competencia proceda resulta necesario, además, que se trate de una causa de manifiesto contenido federal o de naturaleza civil en cuyo caso resulta esencial la distinta vecindad o nacionalidad de la contraria, quedando excluidos de dicha instancia aquellos procesos que se rigen por el derecho público local. Consideró que éste último supuesto era el que se presentaba en el caso, en tanto la pretensión se rige por el derecho público local.</p><p style=\"text-indent:2em\">Por eso, toda vez que para resolver el pleito se debería examinar, sustancialmente, normas y actos locales, interpretándolos en su espíritu y en los efectos que la soberanía local ha querido darles, deben ser los jueces provinciales los que tengan a su cargo el conocimiento y la decisión de tales cuestiones.</p>","esNovedad":true,"fecha":1715050800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1715173704948,"usuarioCreacion":4,"fechaCreacion":1715101256638,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":120401,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24498107,"numeroExpediente":7058,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":3,"codigo":"3","abreviatura":"CCF","descripcion":"Cámara Nacional de Apelaciones en lo Civil y Comercial Federal","estado":0,"descripcionLarga":"CCF - Cámara Nacional de Apelaciones en lo Civil y Comercial Federal"},"objetoJuicio":{"id":1219,"descripcion":"COBRO DE SUMAS DE DINERO","idMateria":3,"tema":{"id":441,"codigo":"COBROPESOS"}},"caratula":"ANGIO SALUD SA c/ GOBIERNO DE LA PCIA DE SANTA CRUZ MINISTERIO DE ASUNTOS SOCIALES s/COBRO DE SUMAS DE DINERO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"7058. "},"recurso":{"id":6400942,"expediente":{"id":24498107,"numeroE