{"id":764766,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"Recurso Queja Nº 1 - JUAREZ, SERGIO DANIEL c/ FEDERACION PATRONAL SEGUROS S.A. Y OTRO s/ACCIDENTE - LEY ESPECIAL","alias":null,"caratula":"Recurso Queja Nº 1 - JUAREZ,  SERGIO DANIEL c/ FEDERACION PATRONAL SEGUROS S.A. Y OTRO s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":1747,"titulo":"Responsabilidad civil de la ART por accidentes de trabajo","cabecilla":"<p>Demanda promovida a fin de obtener la reparaci&oacute;n por la incapacidad del 6% derivada de una patolog&iacute;a lumbar - Arbitrariedad en la atribuci&oacute;n de responsabilidad civil - Exigencia de que las sentencias sean fundadas y constituyan una derivaci&oacute;n razonada del derecho vigente con aplicaci&oacute;n a las circunstancias comprobadas de la causa - La sola circunstancia de que el trabajador haya sufrido da&ntilde;os como consecuencia de su labor no autoriza a concluir que la aseguradora de riesgos del trabajo ha incumplido con sus deberes de prevenci&oacute;n y vigilancia a su cargo a los efectos de la eventual imputaci&oacute;n de responsabilidad civil - Omisi&oacute;n de ponderar adecuadamente las conclusiones del informe efectuado por el perito ingeniero laboral que dio cuenta de la profusa actividad desplegada por la compa&ntilde;&iacute;a demandada a fin de prevenir riegos - El esfuerzo f&iacute;sico que requer&iacute;a el trabajo desarrollado por el actor se encontraba dentro de lo permitido por la reglamentaci&oacute;n pertinente y dentro de la denominada &ldquo;zona de seguridad&rdquo; - Se deja sin efecto la sentencia apelada - Disidencia del juez Rosatti: planteos que omiten precisar, en t&eacute;rminos expresos y concretos, la magnitud del perjuicio que la sentencia le ocasiona - Presentaci&oacute;n recursiva que no guarda relaci&oacute;n con lo actuado en el pleito.</p>","esNovedad":true,"fecha":1617850800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1618230542770,"usuarioCreacion":11,"fechaCreacion":1618230534886,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30516,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":27812453,"numeroExpediente":4848,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"APARICIO, JUAN CARLOS c/ ASOCIART ART S.A. s/enfermedad accidente ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"4848. "},"recurso":{"id":47541