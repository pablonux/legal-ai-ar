{"id":813413,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - AFIP c/ ORGANIZACION COORDINADORA ARGENTINA S R L s/EJECUCION FISCAL - AFIP","inconstitucional":false,"falloDestacado":{"id":9303,"titulo":"Arbitrariedad en la regulación de honorarios: base regulatoria","cabecilla":"<p style=\"text-indent: 2em;\">El Fisco Nacional dedujo recurso extraordinario contra el pronunciamiento que reguló los honorarios del letrado de la parte ejecutada. Fundó su agravio en que para determinar los honorarios la cámara tomó como base el monto por el que se mandó a llevar adelante la ejecución y no la suma correspondiente a los intereses punitorios, controversia que motivó la regulación.</p><p style=\"text-indent: 2em;\">La Corte dejó sin efecto este pronunciamiento.</p><p style=\"text-indent: 2em;\">Recordó que si bien lo atinente a las regulaciones de honorarios en las instancias ordinarias es materia ajena a la instancia del artículo 14 de la ley 48, ello no es óbice para conocer del asunto cuando la decisión no es derivación razonada del derecho vigente con aplicación a las circunstancias comprobadas de la causa.</p><p style=\"text-indent: 2em;\">Señaló que en la regulación de los honorarios del letrado de la demandada por la contestación del traslado del recurso extraordinario se prescindió del artículo 16, inc. a, de la ley 27.423, pues al decidir la cámara que la base regulatoria estaba conformada por la suma que surge de la boleta de deuda que motivó la ejecución y no por el monto de los intereses liquidados por la AFIP -con fundamento en que por haber sido rechazado “no forma parte del capital de los autos en cuestión\"-, no tuvo en cuenta el monto del único “asunto” controvertido en el recurso extraordinario que respondió la ejecutada.</p>","esNovedad":true,"fecha":1756177200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1756241487968,"usuarioCreacion":11,"fechaCreacion":1756241486048,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":142058,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34647256,"numeroExpediente":24276,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1113,"descripcion":"EJECUCION FISCAL - ARCA (Ex A.F.I.P.)","idMateria":2,"tema":{"id":341,"codigo":"TRIB"}},"caratula":"Recurso Queja Nº 2 - AFIP c/ ORGANIZACION COORDINADORA ARGENTINA S R L s/EJECUCION FISCAL - AFIP","verificacio