{"id":798845,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - B., R. A. c/ INSTITUTO NACIONAL DE SERVICIOS SOCIALES PARA JUBILADOS Y PENSIONADOS s/AMPARO LEY 16.986","inconstitucional":true,"falloDestacado":{"id":7342,"titulo":"Acceso a la cobertura de salud de una persona con discapacidad","cabecilla":"<p style=\"text-indent:2em\">La cámara revocó la sentencia de primera instancia que había hecho lugar a la acción de amparo y ordenado al Instituto Nacional de Servicios Sociales para Jubilados y Pensionados la inmediata afiliación de la recurrente, quien padece retraso mental grave y hemiplejía con certificado de discapacidad y goza de una pensión no contributiva otorgada por el Ministerio de Desarrollo Social como adherente de su padre. Invocó para ello el artículo 10 de la resolución 1100/2006 del Instituto Nacional de Servicios Sociales para Jubilados y Pensionados.  </p><p style=\"text-indent:2em\">La Corte dejó sin efecto este pronunciamiento. </p><p style=\"text-indent:2em\">Afirmó que la restricción consagrada en la norma mencionada, que impide a una persona con discapacidad acceder a la cobertura de salud que acuerda la ley 19.032 -en el caso, como integrante del grupo familiar del afiliado titular-, si no renuncia a la pensión social que le corresponde en derecho, <em>resulta irrazonable y desproporcionada, y por ende inconstitucional</em>.</p><p style=\"text-indent:2em\">Señaló que el propósito de alcanzar sistemas sociales sustentables y coherentes no puede justificar reglas de incompatibilidad entre prestaciones que tienden a cubrir riesgos sociales diferentes y complementarios.</p><p style=\"text-indent:2em\">Agregó el Tribunal que la asistencia no contributiva que recibe la amparista está destinada a personas de alta vulnerabilidad social con una discapacidad mínima del 76% (física o mental) no amparadas por otro régimen de previsión y la cobertura de salud, por el contrario, se relaciona con el derecho de toda persona al disfrute del más alto nivel posible de salud física y mental. </p>","esNovedad":true,"fecha":1724122800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1724335596573,"usuarioCreacion":11,"fechaCreacion":1724187325630,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":122958,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31846024,"numeroExpediente":18197,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":