ional del Tribunal por la v&iacute;a del art. 14 de la ley 48 -&nbsp;Nada releva a los &oacute;rganos judiciales de resolver circunstanciadamente si la apelaci&oacute;n federal, prima facie valorada, cuenta con fundamentos suficientes para dar sustento a la invocaci&oacute;n de un caso excepcional, como lo es el de la arbitrariedad - El a quo no analiz&oacute; circunstanciadamente la apelaci&oacute;n federal para poder efectuar la valoraci&oacute;n a que obliga la doctrina citada -&nbsp;Se declara la nulidad de la resoluci&oacute;n por la que se concedi&oacute; el recurso.</p>","esNovedad":true,"fecha":1623898800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1624627633423,"usuarioCreacion":11,"fechaCreacion":1624016113802,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31133,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31192398,"numeroExpediente":2621,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descripcionLarga":"FLP - Justicia Federal de La Plata"},"objetoJuicio":{"id":8068,"descripcion":"RECURSO DIRECTO A JUZGADO","idMateria":112,"tema":{"id":373,"codigo":"RDJ"}},"caratula":"GOROSITO (PDTE.BARRIO PVDO.COSTA VERDE), PAULO c/ MTRIO.DE TRABAJO DE LA NACION s/RECURSO DIRECTO A JUZGADO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2621. "},"recurso":{"id":5380239,"expediente":{"id":31192398,"numeroExpediente":2621,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descripcionLarga":"FLP - Justicia Federal de La Plata"},"objetoJuicio":{"i