{"id":795103,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":24,"codigoRelacion":80024,"valor":"DECLARA NULIDAD","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201011041306,"fechaModLong":201011041306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ASOCIACION CIVIL POR LA IGUALDAD Y LA JUSTICIA c/ EN-M HACIENDA Y OTROS s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":6722,"titulo":"Nulidad de lo actuado ante la omisión de intervención del ministerio pupilar","cabecilla":"<p style=\"text-indent:2em\">La cámara rechazó la acción colectiva de amparo interpuesta por una asociación civil con el objeto de que se declare la inconstitucionalidad de diversas normas que habían dispuesto la reasignación presupuestaria de recursos destinados a garantizar derechos humanos básicos de niños y niñas. Contra dicho pronunciamiento, la actora dedujo recurso extraordinario federal.</p><p style=\"text-indent:2em\">La Corte dispuso dar intervención al Defensor General Adjunto de la Nación, que asumió la representación complementaria de los menores y quien, al contestar la vista conferida, observó que no se había dado intervención al ministerio pupilar en ninguna de las instancias del proceso y por ello se había privado a los menores de gozar de su asistencia y representación, restringiendo indebida y gravemente su derecho de defensa en juicio.</p><p style=\"text-indent:2em\">Resolvió entonces el Tribunal que, ante la omisión de intervención del defensor en las decisiones dictadas antes del recurso planteado ante su instancia, se declare la nulidad de todo lo actuado a partir de la contestación de la demanda.</p>","esNovedad":true,"fecha":1713236400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1713379360398,"usuarioCreacion":4,"fechaCreacion":1713361807530,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":118819,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31528878,"numeroExpediente":20352,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"EN-M HACIENDA c/ TIG INSURANCE COMPANY s/PROCESO DE CONOCIMIENTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"20352. "},"recurso":{"id":6173555,"expediente":{"id":31528878,"numeroExpediente":20352,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Admin