{"id":793238,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"FIDEICOMISO EDIFICIO LA FAVORITA DE ROSARIO c/ DIRECCION GENERAL IMPOSITIVA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","inconstitucional":false,"falloDestacado":{"id":6521,"titulo":"Impuesto a las ganancias y fideicomisos con fiduciantes-beneficiarios residentes en el país y en el exterior","cabecilla":"<p style=\"text-indent:2em\">La cámara revocó la resolución de la Dirección General Impositiva que había determinado de oficio el impuesto a las ganancias de un fideicomiso no financiero con  fiduciantes-beneficiarios residentes en el país y en el exterior.</p><p style=\"text-indent:2em\">Ante ello el Fisco interpuso un recurso extraordinario.</p><p style=\"text-indent:2em\">La Corte consideró que la cuestión a decidir era si resultaba ajustado a derecho que la actora haya liquidado e ingresado el impuesto a las ganancias únicamente por las utilidades correspondientes a los beneficiarios residentes en el exterior o si, tal como sostenía Fisco en el acto impugnado, debió abonar la gabela por la totalidad de las rentas obtenidas, es decir, incluyendo en la base imponible del impuesto, las ganancias atribuidas a los residentes en el país, ante la falta de previsión de la normativa sobre la posibilidad de que se realicen liquidaciones proporcionales.</p><p style=\"text-indent:2em\">El Tribunal confirmó el pronunciamiento apelado al señalar que no se desprende de las normas que la mecánica del impuesto establecida en relación con los fiduciantes-beneficiarios que residan en el país y que ha sido prevista fundamentalmente en el artículo 49 de la ley 20.628, se encuentre condicionada a que todos los integrantes del fideicomiso tengan residencia dentro del territorio nacional.</p>","esNovedad":true,"fecha":1709607600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1709738320362,"usuarioCreacion":4,"fechaCreacion":1709666435578,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":117250,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34282561,"numeroExpediente":58752,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381