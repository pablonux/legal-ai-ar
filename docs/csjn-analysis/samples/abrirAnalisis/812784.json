{"id":812784,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - CARRIZO, ROBERTO ANTONIO c/ GALENO ART S.A. s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":9261,"titulo":"Accidente de trabajo: exigencia de que las sentencias sean fundadas","cabecilla":"<p style=\"text-indent:2em\">La cámara hizo lugar a la acción entablada por el actor tendiente a obtener las prestaciones dinerarias de la <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/27971/actualizacion\">ley 24.557</a> de Riesgos del Trabajo a raíz de la incapacidad que dijo padecer producto de un accidente laboral. Señaló que si bien las dolencias físicas no se vinculaban con el siniestro, sí debía indemnizarse la incapacidad psicológica en tanto no se habían acompañado a la causa el examen preocupacional y los controles periódicos de salud, lo cual no podía constituir un eximente de responsabilidad frente a la comprobación posterior de un daño.</p><p style=\"text-indent:2em\">Ante el recurso interpuesto por la aseguradora demandada la Corte dejó sin efecto este pronunciamiento.</p><p style=\"text-indent:2em\">Afirmó que de acuerdo a las pericias médicas la secuela psicológica aducida en la demanda carecía de nexo causal con el accidente denunciado y que, en el marco de la prueba producida, se advertía que la sola circunstancia de no haberse acompañado constancias del examen preocupacional o de los eventuales controles periódicos respecto de la salud, reprochada por la cámara como punto de apoyo de la responsabilidad que endilgó a la demandada, sin otros elementos de convicción, no resultaba suficiente para desvirtuar las conclusiones de los peritajes producidos.</p>","esNovedad":true,"fecha":1755745200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1755868170428,"usuarioCreacion":4,"fechaCreacion":1755803782935,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":141138,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29601281,"numeroExpediente":20335,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9702,"descripcion":"ACCIDENTE - ACCION CIVIL","idMateria":5,"tema":null},"caratula":"FIGUEREDO , NESTOR OBDULIO c/ ASOCIART ART S.A. s/ACCIDENTE - ACCION CIVIL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"20335. "},"recurso":{"id":7025799,"expediente":{"id":29601281,"numeroExpediente":20335,"anioExpediente":2017,"tomoExpediente":nu