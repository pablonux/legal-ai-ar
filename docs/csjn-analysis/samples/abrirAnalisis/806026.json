{"id":806026,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":230004,"valor":"RECURSO DE REVOCATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 1 - ACTOR: FERRARI, MARIA ALICIA DEMANDADO: LEVINAS, GABRIEL ISAIAS s/INCIDENTE","inconstitucional":false,"falloDestacado":{"id":8262,"titulo":"Revocatorias contra el precedente \"Ferrari\": Falta de legitimación","cabecilla":"<p style=\"text-indent: 2em;\">La Asociación de Magistrados y Funcionarios de la Justicia Nacional planteó un recurso de “revocatoria y suspensión de efectos” contra la sentencia de la Corte de fecha 27 de diciembre de 2024 (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=347&amp;pagina=2286\">347:2286</a>).</p><p style=\"text-indent: 2em;\">El Tribunal consideró que la petición resultaba inadmisible. Expresó que debía aplicarse el mismo criterio que en el supuesto del recurso extraordinario y que no están habilitados para recurrir la decisión quienes no revistan la calidad de parte con participación legitimada en el proceso, aun cuando aleguen tener un gravamen configurado por la decisión atacada.</p><p style=\"text-indent: 2em;\">Agregó que no se configuraban especiales circunstancias que justificaran hacer excepción a tal principio y que, de todos modos, el planteo resultaba improcedente pues las sentencias definitivas e interlocutorias de la Corte no son susceptibles de ser modificadas por el recurso de revocatoria, ni por el de nulidad, salvo situaciones excepcionales que no concurrían en la causa.</p><p style=\"text-indent: 2em;\">En similar sentido se pronunció ante el recurso intentado por la Defensora General de la Nación (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=8060251\">Ver fallo</a>)</p>","esNovedad":true,"fecha":1739847600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1739899465123,"usuarioCreacion":11,"fechaCreacion":1739899462620,"privado":false,"posicion":2,"resumen":{"idResumen":111,"resumen":"La Corte Suprema rechaza el recurso de revocatoria de la Asociación de Magistrados contra la sentencia del 27/12/24, al no ser parte legitimada en el proceso. Tampoco admite el recurso de la Defensora General de la Nación.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":132798,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":39694163,"numeroExpediente":325,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0