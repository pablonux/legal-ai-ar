{"id":768939,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":29,"codigoRelacion":80029,"valor":"DECLARA MAL DENEGADO","activo":"S","usuarioCreacion":"JUR202","usuarioMod":"JUR202","fechaCreacionLong":201111081514,"fechaModLong":201111081514,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":250005,"valor":"DDHH- Institucional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"QUIROGA, RAUL FERNANDO c/ M JUSTICIA Y DDHH s/INDEMNIZACIONES - LEY 24043 - ART 3","alias":null,"caratula":"Recurso Queja Nº 1 - QUIROGA, RAUL FERNANDO c/ M JUSTICIA Y DDHH s/INDEMNIZACIONES - LEY 24043 - ART 3","inconstitucional":false,"falloDestacado":{"id":2682,"titulo":"Denegatoria del recurso extraordinario como requisito para la procedencia de la queja","cabecilla":"<p>Resoluci&oacute;n de c&aacute;mara que tuvo por no presentado el remedio federal con fundamento en que&nbsp;incumpl&iacute;a con algunos de los requisitos establecidos en el reglamento aprobado por la acordada 4/2007&nbsp;y orden&oacute; su desglose - Interposici&oacute;n de un&nbsp;nuevo recurso extraordinario que tambi&eacute;n fue rechazado, sin sustanciaci&oacute;n, por considerar que era improcedente - La recurrente interpone una queja y postula que su recurso extraordinario ha sido mal denegado -&nbsp;La queja contemplada en el art. 285 CPCCN constituye un medio de impugnaci&oacute;n solo de decisiones que deniegan recursos deducidos para ante la Corte y no es id&oacute;nea para cuestionar otras decisiones, aun cuando ellas se relacionen con el tr&aacute;mite de aquellos recursos - Dado que&nbsp;la c&aacute;mara no emiti&oacute; una resoluci&oacute;n denegatoria, expresa o impl&iacute;cita, del remedio federal interpuesto en primer t&eacute;rmino, sino que &uacute;nicamente lo tuvo por no presentado y orden&oacute; su desglose, el segundo recurso extraordinario de la enjuiciada contra esa decisi&oacute;n fue debidamente interpuesto -&nbsp;&nbsp;Se declara mal denegado el recurso.</p>","esNovedad":true,"fecha":1631156400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1632240964198,"usuarioCreacion":11,"fechaCreacion":1631284396470,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31870,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31701021,"numeroExpediente":47384,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7346,"descripcion":"INDEMNIZACIONES - LEY 24043 - ART 3","idMateria":2,"tema":null},"caratula":"Recurso Queja Nº 1 - QUIROGA, RAUL FERNANDO c/ M JUSTICIA Y DDHH s/INDEMNIZACIONES - LEY 24043 - ART 3","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"47384. "},"recurso":{"id":5310665,"expediente":{"id":31701021,"numeroExpediente":47384,"anioExpediente":2016,"to