{"id":780694,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"C. A., A. N. c/ EN-M SALUD-INCUCAI s/ AMPARO LEY 16.986","alias":null,"caratula":"Recurso Queja Nº 1 - C. A., A. N. c/ EN-M SALUD-INCUCAI s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":4864,"titulo":"Cambio de circunstancias que tornan inoficioso un pronunciamiento de la Corte","cabecilla":"<p>La madre de una niña solicitó que esta fuera inscripta en la lista de espera para trasplantes hepáticos y planteó la inconstitucionalidad de la normativa que le veda esa posibilidad por su condición de extranjera, no residente permanente. Ante el rechazo de la pretensión el defensor público interpuso un recurso ante la Corte. La Defensora General de la Nación expresó en su dictamen que, tras el dictado del fallo impugnado, el estado de salud de la niña se había agravado -al haber rechazado un transplante hepático de donante vivo- por lo que ahora sí se configuraría un cuadro de excepción que, de conformidad con la reglamentación, posibilitaría la inscripción en la lista de espera del INCUCAI. La Corte señaló entonces que dicha situación importaba el cumplimiento del objeto que perseguía la acción de amparo por lo cual resultaba de aplicación su jurisprudencia según la cual sus sentencias deben ceñirse a las circunstancias existentes al momento de la decisión, aunque ellas sean sobrevinientes a la interposición del recurso extraordinario. Desestimó así la presentación directa por considerar que no correspondía emitir pronunciamiento cuando a la luz de las circunstancias se había tornado inoficioso decidir la cuestión materia de agravios.</p>","esNovedad":true,"fecha":1670295600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1670428757678,"usuarioCreacion":11,"fechaCreacion":1670418889984,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":105607,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34403109,"numeroExpediente":27226,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9736,"descripcion":"OTROS RECLAMOS","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - ASOCIACION TRABAJADORES DEL ESTADO c/ ESTADO NACIONAL - MINISTERIO DE TRABAJO EMPLEO Y SEGURIDAD SOCIAL DE LA NACION s/OTROS RECLAMOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"27226. "},"recurso":{"id":5755478,"expediente":{"id":34403109,"numeroExpediente":27226,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":nul