{"id":802736,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"CHAPARRO, MIGUEL ANGEL c/ UBA-FACULTAD DE DERECHO s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":7881,"titulo":"Requisitos para el reconocimiento del diploma de honor a estudiantes universitarios","cabecilla":"<p style=\"text-indent:2em\">La Facultad de Derecho de la Universidad de Buenos Aires denegó el diploma de honor solicitado por el actor, quien finalizó la carrera de abogacía en dicha institución. El fundamento de esta decisión fue que no cumplía con la totalidad de las materias aprobadas, pues había solicitado el reconocimiento de dos materias del Ciclo Básico Común (CBC) en atención a que poseía un título de grado obtenido en otra institución universitaria distinta de la UBA.</p><p style=\"text-indent:2em\">La cámara dejó sin efecto esta decisión, lo que originó un recurso ante la Corte que, por mayoría, revocó esta sentencia. </p><p style=\"text-indent:2em\">Señaló que si bien el actor quedaba comprendido en la categoría de ex alumno -pues ingresó desde el primer año y completó sus estudios en la Facultad de Derecho- lo cierto es que no había cursado ni aprobado la totalidad de la carrera, sino que se le dieron por aprobadas dos materias obligatorias del CBC careciendo, por lo tanto, de una calificación numérica que pueda sumarse para obtener el promedio.</p><p style=\"text-indent:2em\">Agregó que su situación presenta una diferencia sustancial con el supuesto de aquellos estudiantes que, tras realizar un estricto proceso de selección, cursan materias en instituciones universitarias extranjeras con las cuales se han suscripto los respectivos convenios y con quienes cambian de carrera o cursan una segunda carrera en la UBA y se les reconocen equivalencias por asignaturas aprobadas.</p><p style=\"text-indent:2em\">Expresó que ello obsta a la procedencia de los argumentos basados en un supuesto trato desigual o discriminatorio, sin que importe una confirmación del criterio adoptado por la universidad en los casos de otorgamiento, pues se trata de cuestiones que resultan ajenas al proceso.</p>","esNovedad":true,"fecha":1730775600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1730904590573,"usuarioCreacion":4,"fechaCreacion":1730901848757,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":129260,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":11574970,"numeroExpediente":37601,"anioExpedien