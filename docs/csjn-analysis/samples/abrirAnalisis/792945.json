{"id":792945,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - O., N.C. c/ OSDE s/CIVIL y COMERCIAL-VARIOS","inconstitucional":false,"falloDestacado":{"id":7723,"titulo":"Cobertura de prestaciones de salud: violación del principio de cosa juzgada","cabecilla":"<p style=\"text-indent: 2em;\">En la etapa de ejecución en un reclamo de cobertura integral de las prestaciones que requiere un niño con discapacidad la obra social interpuso un recurso ante la Corte. </p><p style=\"text-indent: 2em;\">El Tribunal, por mayoría, dejó sin efecto la sentencia.</p><p style=\"text-indent: 2em;\">Expresó que la decisión de primera instancia había quedado firme en cuanto había condenado a la demandada a la cobertura de las prestaciones requeridas según los valores establecidos por el Ministerio de Salud en el nomenclador aplicable. En consecuencia, si la demandada apeló el fallo para discutir la cuantía del adicional por zona desfavorable y la actora solo lo cuestionó respecto a la imposición de las costas, los jueces de la causa no podían, <b>sin violar el alcance de la cosa juzgada</b>, ordenar llevar adelante la ejecución por el reintegro total de los gastos efectuados que no se hallaban contemplados en la condena la que, en rigor, se había limitado a la devolución de los importes abonados por las prestaciones practicadas según los valores establecidos en el referido nomenclador.</p><p style=\"text-indent: 2em;\">Recordó la Corte que a menos que se verifiquen circunstancias excepcionales es la parte dispositiva del fallo, y no los considerandos, la que reviste el carácter de cosa juzgada.</p><p style=\"text-indent: 2em;\">Finalmente destacó la relevancia constitucional del principio de cosa juzgada y recordó que los alcances de la cobertura integral en favor de una persona con discapacidad no pueden ampliarse más allá de lo que fue objeto de condena ya que lo contrario implicaría un injustificado exceso de los alcances tanto de la <em>litis contestatio</em> cuanto de la cosa juzgada.</p>","esNovedad":true,"fecha":1728961200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1729021001487,"usuarioCreacion":11,"fechaCreacion":1729020999585,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":117017,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30926117,"numeroExpediente":78105,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7346,"d