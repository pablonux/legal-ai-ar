{"id":770148,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"L. M. s/ABRIGO","alias":null,"caratula":"L. M. s/ABRIGO","inconstitucional":false,"falloDestacado":{"id":2822,"titulo":"Interés superior del niño y alternativa de vinculación en el marco de un \"triángulo adoptivo afectivo\"","cabecilla":"<p>Pronunciamiento que revoc&oacute; la decisi&oacute;n que hab&iacute;a confirmado la declaraci&oacute;n del estado de adoptabilidad de la infante y orden&oacute; que en la instancia de origen se llevara a cabo el proceso de revinculaci&oacute;n con su progenitora -&nbsp;Recurso extraordinario interpuesto por los guardadores de la ni&ntilde;a -&nbsp;Examen parcial del asunto, realizado solo desde la perspectiva de uno de los sujetos involucrados, sin ponderar la situaci&oacute;n real de la ni&ntilde;a ni las consecuencias que podr&iacute;an derivarse para esta &uacute;ltima - Omisi&oacute;n de&nbsp;toda valoraci&oacute;n de las circunstancias que unieron a la ni&ntilde;a con sus guardadores preadoptivos, como de la incidencia que podr&iacute;a tener en su vida una vinculaci&oacute;n con su progenitora y la ulterior modificaci&oacute;n del entorno sociofamiliar en el que se encontraba inserta desde temprana edad - Inter&eacute;s superior del ni&ntilde;o, en tanto sujetos de tutela preferente - Necesidad de privilegiar la situaci&oacute;n real del sujeto m&aacute;s vulnerable, no debiendo ello ser desplazado por los intereses de los progenitores y/o de aquellos que ejercen la guarda preadoptiva por m&aacute;s leg&iacute;timos que resulten - La declaraci&oacute;n de adoptabilidad decretada luce como la soluci&oacute;n m&aacute;s respetuosa del inter&eacute;s superior de la ni&ntilde;a - Se encomienda al juez de grado que, al momento de definir la situaci&oacute;n familiar de la ni&ntilde;a, eval&uacute;e si establecer una vinculaci&oacute;n en el marco de un &ldquo;tri&aacute;ngulo adoptivo afectivo&rdquo; constituye una alternativa posible para una mejor protecci&oacute;n de los derechos de las personas involucradas en el conflicto, en especial los del sujeto m&aacute;s vulnerable - Se deja sin efecto la sentencia apelada y se mantiene la declaraci&oacute;n de adoptabilidad de la ni&ntilde;a.</p>","esNovedad":true,"fecha":1633575600000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1633634013748,"usuarioCreacion":11,"fechaCreacion":1633634010548,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":32276,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34176356,"numeroExpediente":2209,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte 