orte hizo lugar al recurso y revocó la sentencia apelada. Entendió que, al no figurar informe alguno de la Comisión de Seguimiento del acuerdo de estabilidad de precios al que voluntariamente se había suscripto la actora y el Ministerio de Energía y Minería, no había una motivación válida del acto administrativo que había denegado la pretensión, constituyendo así una causa de nulidad del acto emitido en base a los arts. 7° y 14 de la ley 19.549. </p>","esNovedad":true,"fecha":1671591600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1671709188876,"usuarioCreacion":4,"fechaCreacion":1671651115548,"privado":false,"posicion":8,"resumen":null},"reciboEntrada":{"id":105674,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31057974,"numeroExpediente":88240,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria":2,"tema":null},"caratula":"AMARILLA GAS SA c/ M DE ENERGIA Y MINERIA s/RECURSO DIRECTO DE ORGANISMO EXTERNO","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":34390151,"numeroExpediente":88240,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":7381,"descripcion":"RECURSO DIRECTO DE ORGANISMO EXTERNO","idMateria"