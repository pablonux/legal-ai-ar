{"id":765717,"competencia":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":190007,"valor":"APELACION ORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":19,"codigoRelacion":80019,"valor":"CONFIRMA PARCIALMENTE","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009281029,"fechaModLong":201009281029,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"REQUERIDO: LAZZARI, DERVAL s/EXTRADICION","inconstitucional":false,"falloDestacado":{"id":1928,"titulo":"Extradición y principio de doble incriminación","cabecilla":"<p>Resoluci&oacute;n del juez de primera instancia que declar&oacute; procedente la extradici&oacute;n del requerido a los Estados Unidos de Norteam&eacute;rica por los tres cargos en que se sustent&oacute; el pedido - Conspiraci&oacute;n para cometer fraude electr&oacute;nico (Cargo I), fraude electr&oacute;nico (Cargo II) y conspiraci&oacute;n para obstruir la justicia a) obstaculizando la investigaci&oacute;n de un delito federal y b) con la destrucci&oacute;n de registros (Cargo III) - Los antecedentes acompa&ntilde;ados por el pa&iacute;s requirente incluyen una relaci&oacute;n sumaria de los hechos del delito de acuerdo a las exigencias del tratado bilateral que rige el tr&aacute;mite, sin que se advierta la falta de precisi&oacute;n sobre lo que la parte denomina &quot;l&iacute;mite de la acusaci&oacute;n&quot; y/o &quot;hechos concretos&quot; de la imputaci&oacute;n extranjera - La referencia que el tratado efect&uacute;a a la &quot;conspiracy&quot; y a la &quot;asociaci&oacute;n il&iacute;cita&quot; lejos est&aacute; de suponer una &quot;homologaci&oacute;n&quot; de ambos tipos penales, sino que tiene por objeto erigir ambas conductas t&iacute;picas como figuras aut&oacute;nomas que cada una de las legislaciones contempla de manera expresa en su derecho interno y que consagraron como delito extraditable - Caracter&iacute;sticas peculiares que presenta la tarea de la subsunci&oacute;n en la legislaci&oacute;n nacional a los fines del principio de doble incriminaci&oacute;n - Cargo III: La descripci&oacute;n de que da cuenta la Acusaci&oacute;n Formal s&oacute;lo incluye como integrante de esa conspiraci&oacute;n al requerido junto con un co-imputado - No se configura respecto de ese cargo la exigencia referida al n&uacute;mero de intervinientes que contempla el art&iacute;culo 210 del C&oacute;digo Penal argentino - Se declara procedente la extradici&oacute;n &uacute;nicamente por los cargos I y II en que se sustent&oacute; el pedido.</p>","esNovedad":true,"fecha":1620874800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1621018405602,"usuarioCreacion":11,"fechaCreacion":1621017837847,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30829,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28934875,"numeroExpediente":40200,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Feder