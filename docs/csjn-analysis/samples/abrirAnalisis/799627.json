{"id":799627,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 1 - DENUNCIANTE: LOPEZ BARRIOS, LUCAS DAMIAN IMPUTADO: DE ANGELIS, MAURO DARIO Y OTROS s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":7502,"titulo":"Boleto de compraventa y desbaratamiento de derechos acordados (competencia)","cabecilla":"<p style=\"text-indent:2em\">Ante el incumplimiento del vendedor luego de la firma de un boleto de compraventa y la posterior la existencia de otra escritura de venta se originó una contienda negativa de competencia que la Corte debió resolver.</p><p style=\"text-indent:2em\">El Tribunal señaló que el delito de desbaratamiento de los derechos acordados se consuma cuando, ya realizada la disposición patrimonial, se torna incierto o litigioso el derecho adquirido.</p><p style=\"text-indent:2em\">Teniendo en cuenta que el magistrado bonaerense no desconocía que el delito se habría consumado al momento de la venta del inmueble en una escribanía de un partido bonaerense se dispuso que a él le correspondía asumir la investigación, sin perjuicio de las cuestiones que posteriormente pudiera plantear con otro juez de su misma provincia de conformidad con las reglas del procedimiento local, cuya interpretación y aplicación resulta ajena a la jurisdicción nacional.</p>","esNovedad":true,"fecha":1725332400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1725463325936,"usuarioCreacion":11,"fechaCreacion":1725391244608,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":123818,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32898129,"numeroExpediente":43777,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXPEDIENTES PENALES","idMateria":9,"tema":null},"caratula":"Recurso Queja Nº 4 - Principal en Tribunal Oral 0 - IMPUTADO: RAPAGNANI , NICOLÁS Y OTRO s/ABUSO SEXUAL - ART. 119  1° PARRAFO QUERELLANTE: ROITMAN , NANCY MARIANA (Y PONCE, JORGE DANIEL) Y OTROS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"43777. "},"recurso":{"id":5514062,"expediente":{"id":32898129,"numeroExpediente":43777,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional 