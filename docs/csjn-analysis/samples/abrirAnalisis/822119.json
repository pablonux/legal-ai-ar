{"id":822119,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"COLEGIO DE MARTILLEROS Y CORREDORES DE COMERCIO DE LA PROVINCIA DE LA PAMPA Y OTRO c/ ESTADO PROVINCIAL DE LA PAMPA s/amparo ","inconstitucional":false,"falloDestacado":{"id":10165,"titulo":"Excesivo rigor formal al examinar los requisitos que debe reunir un recurso","cabecilla":"<p style=\"text-indent:2em\">Los actores interpusieron una acción de amparo con el objeto de que se declare la inconstitucionalidad de normas provinciales según las cuales las locaciones de viviendas prohíben a los corredores inmobiliarios percibir honorarios del locatario cuando este es persona física, y al mismo tiempo establecen un tope para el arancel a cobrar al locador. Luego del rechazo del planteo en primera y segunda instancia el superior tribunal provincial declaró inadmisible el recurso extraordinario local por estimar que incumplió el requisito de “fundamentación diferenciada” exigido en su legislación procesal local y que, además, no refutó todos y cada uno de los argumentos en que se había sustentado la sentencia de la cámara de apelaciones.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto el pronunciamiento apelado.</p><p style=\"text-indent:2em\">Consideró que, sobre la base de genéricas consideraciones formales, desvinculadas de la causa, prescindió de examinar las cuestiones de índole constitucional claramente planteadas. </p><p style=\"text-indent:2em\">Señaló que de la compulsa de las actuaciones resultaba que en el recurso extraordinario local la demandante había efectuado una crítica precisa de los argumentos que sustentaron la sentencia de segunda instancia y, además, sostuvo el planteo de inconstitucionalidad de las normas cuestionadas expresando suficientes argumentos al respecto.</p>","esNovedad":true,"fecha":1770692400000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1770836635329,"usuarioCreacion":11,"fechaCreacion":1770759554249,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":150859,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36913423,"numeroExpediente":1678,"anioExpediente":2022,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"COLEGIO DE MARTILLEROS Y CORREDORES DE COMERCIO DE LA PROVINCIA DE LA PAMPA Y OTRO c/ ESTADO PROVINCIAL DE LA PAMPA s/amparo ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1678. "},"recurso":{"id"