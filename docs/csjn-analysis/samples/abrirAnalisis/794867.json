{"id":794867,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - ASCUA MARCELO RAFAEL ERNESTO c/ ASOCIART A.R.T. S.A. Y OTROS s/ACCIDENTE - ACCION CIVIL","inconstitucional":false,"falloDestacado":{"id":6742,"titulo":"Exigencia de un nexo de causalidad para atribuir responsabilidad civil a la ART","cabecilla":"<p style=\"text-indent:2em\">Un trabajador  promovió una acción con fundamento en el derecho civil contra su empleadora a fin de obtener la reparación integral de los daños que padece con motivo de un accidente laboral.</p><p style=\"text-indent:2em\">La cámara confirmó la condena a la empresa y la hizo extensiva, en forma solidaria, a la Aseguradora de Riesgos del Trabajo.</p><p style=\"text-indent:2em\">La Corte revocó la sentencia.</p><p style=\"text-indent:2em\">Consideró que mediante la formulación de elucubraciones genéricas acerca de las obligaciones de las ART y <em>sin precisar cómo se habría configurado el nexo de causalidad adecuada</em> entre el siniestro y la conducta de la apelante, la sentencia había soslayado la valoración de la prueba producida en el expediente respecto de la actividad desplegada por aquella y las condiciones en que el actor laboraba.</p><p style=\"text-indent:2em\">Recordó que la sola circunstancia de que el trabajador hubiera sufrido daños como consecuencia de su labor no autoriza a concluir sin más que la aseguradora de riesgos del trabajo incumplió con sus deberes de prevención y vigilancia a los efectos de la eventual imputación de responsabilidad. Además, tuvo en cuenta que el demandante había participado de un curso de capacitación sobre normas de higiene y seguridad y se le habían suministrado elementos de protección personal y que la ART realizó por lo menos 29 inspecciones en el lugar donde laboraba el demandante.</p>","esNovedad":true,"fecha":1713841200000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1713899763712,"usuarioCreacion":11,"fechaCreacion":1713899739675,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":118659,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31947324,"numeroExpediente":24094,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - FRANCO, ANA DEL VALLE c/ RENAULT S.A.S. Y OTROS s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"24094. "},"recurso":{"id":5344290,"expediente":{"id":31947