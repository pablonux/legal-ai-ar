{"id":798463,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - STEIN, RAMON CRISTIAN c/ SWISS MEDICAL ART S.A. s/ACCIDENTE - LEY ESPECIAL","inconstitucional":false,"falloDestacado":{"id":9123,"titulo":"Falta de fundamentación del recurso: omisión de rebatir el argumento en que se basó la decisión apelada","cabecilla":"<p style=\"text-indent:2em\">La cámara revocó la sentencia de primera instancia que había declarado la falta de aptitud de la justicia nacional del trabajo para intervenir en la causa y declaró habilitada la instancia judicial.</p><p style=\"text-indent:2em\">La demandada interpuso recurso extraordinario y argumentó que la cámara se apartó de lo dispuesto por la ley <a target=\"_blank\" href=\"https://www.argentina.gob.ar/normativa/nacional/ley-27348-272119/texto\">27.348</a> ya que habilitó la instancia judicial a pesar de que el actor no agotó la instancia administrativa previa ante las Comisiones Médicas Jurisdiccionales que la norma prevé como obligatoria.</p><p style=\"text-indent:2em\">La Corte desestimó el recurso por considerar que carecía de la debida fundamentación.</p><p style=\"text-indent:2em\">Señaló que la cámara entendió que debía habilitarse la instancia judicial con base en que, de no hacerlo, se vulneraría la garantía de plazo razonable consagrada en el artículo 8.1 de la Convención Americana sobre Derechos Humanos y que ello podría generar responsabilidad internacional del Estado Argentino pero la recurrente, no obstante, se limitó a cuestionar la competencia territorial y, de modo genérico, el apartamiento del tribunal del procedimiento de la de ley 27.348. Es decir, omitió rebatir el único argumento en que se basó la sentencia para habilitar la instancia judicial, esto es, la afectación de la garantía del plazo razonable.</p><p style=\"text-indent:2em\">Recordó que para la procedencia del recurso extraordinario no basta la aserción de una determinada solución jurídica si ella no está razonada y constituye un agravio concretamente referido a las circunstancias del caso, mediante una prolija crítica, de todos y cada uno de los argumentos en que se apoya.</p>","esNovedad":true,"fecha":1752116400000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1752234773786,"usuarioCreacion":4,"fechaCreacion":1752179330210,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":122521,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36233042,"numeroExpediente":19744,"anioExped