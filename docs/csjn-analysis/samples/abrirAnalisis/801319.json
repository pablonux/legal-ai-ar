{"id":801319,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - CARBALLUDE GISELLE MELINA c/ OSDE Y OTRO s/DAÑOS Y PERJUICIOS - RESP.PROF.MEDICOS Y AUX.","inconstitucional":false,"falloDestacado":{"id":7621,"titulo":"Arbitrariedad de la sentencia que atribuyó responsabilidad a una clínica que solo se comprometió a prestar sus instalaciones","cabecilla":"<p style=\"text-indent:2em\">La cámara hizo lugar al reclamo de indemnización de los daños y perjuicios derivados de la atención médica recibida por la actora durante una cesárea. Consideró que, ante la culpa del médico, la responsabilidad de la clínica se tornaba inexcusable por quedar de manifiesto la violación del crédito a la seguridad. </p><p style=\"text-indent:2em\"><b>La Corte, por unanimidad, dejó sin efecto esta sentencia</b>.</p><p style=\"text-indent:2em\">Al respecto, manifestó la Corte, al no haberse comprobado fehacientemente la existencia de una falta concreta cometida por los profesionales o auxiliares de Swiss Medical S.A., carece de fundamento la decisión de la alzada de imponerle un deber de garantía derivado de la deficiente atención prestada por el médico de la empresa de medicina prepaga a la que pertenecía la paciente cuando el sanatorio solo se había comprometido a prestar sus instalaciones.</p><p style=\"text-indent:2em\">De tal modo, señaló el Tribunal, se ha asignado a las estipulaciones del contrato celebrado entre el centro asistencial y la empresa de medicina prepaga codemandada un alcance inadecuado que extiende injustificadamente la responsabilidad del sanatorio respecto de los terceros beneficiarios (<a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=321&amp;pagina=3194\">Fallos: 321:3194</a>).</p>","esNovedad":true,"fecha":1727146800000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1727273791590,"usuarioCreacion":11,"fechaCreacion":1727203240224,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":128061,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34991128,"numeroExpediente":110600,"anioExpediente":2012,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":8540,"descripcion":"DAÑOS Y PERJUICIOS - RESP.PROF.MEDICOS Y AUX.","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 1 - CARBALLUDE GISELLE MELINA c/ OSDE Y OTRO s/DAÑOS Y PERJUICIOS - RESP.PROF.MEDICOS Y AUX.","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentif