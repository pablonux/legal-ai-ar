{"id":796759,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - KARLEN, ALEJANDRO HERNAN c/ ESTADO NACIONAL, PODER EJECUTIVO DE LA NACION s/AMPARO","inconstitucional":false,"falloDestacado":{"id":7142,"titulo":"Pago de las dietas a los parlamentarios del Mercosur","cabecilla":"<p style=\"text-indent:2em\">La Cámara Nacional Electoral ordenó al Estado Nacional que proceda a contemplar, dentro de las partidas presupuestarias pertinentes, no solo los montos correspondientes para hacer frente a los gastos normales del Parlamento del Mercado Común del Sur (Mercosur), sino también aquellos necesarios para que dicho organismo realice el pago de las dietas a los parlamentarios.</p><p style=\"text-indent:2em\">El Estado Nacional interpuso un recurso extraordinario argumentando que la sentencia era de imposible cumplimiento ya que violaba el principio de división de poderes y transgredía normas de un tratado internacional. </p><p style=\"text-indent:2em\">La Corte dejó sin efecto la sentencia apelada. </p><p style=\"text-indent:2em\">Consideró que la cámara debió limitarse a determinar si le correspondía pagar o no las remuneraciones a los parlamentarios, mas no se encontraba habilitada para disponer una medida que resultaba ajena al modo en que quedó trabada la relación procesal, pues ello traducía una vulneración del principio de congruencia que se sustenta en los arts. 17 y 18 de la Constitución Nacional. Expresó que el tribunal había incurrido así en un exceso en el límite de su potestad jurisdiccional.</p>","esNovedad":true,"fecha":1719889200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1720029454007,"usuarioCreacion":11,"fechaCreacion":1720011924254,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":120779,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":29201535,"numeroExpediente":1566,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":4,"codigo":"4","abreviatura":"CNE","descripcion":"Cámara Nacional Electoral","estado":0,"descripcionLarga":"CNE - Cámara Nacional Electoral"},"objetoJuicio":{"id":10667,"descripcion":"AMPARO","idMateria":92,"tema":null},"caratula":"Recurso Queja Nº 1 - KARLEN, ALEJANDRO HERNAN c/ ESTADO NACIONAL, PODER EJECUTIVO DE LA NACION s/AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1566. "},"recurso":{"id":4994985,"expediente":{"id":29201535,"numeroExpedie