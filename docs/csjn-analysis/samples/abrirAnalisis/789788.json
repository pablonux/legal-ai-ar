{"id":789788,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":80006,"valor":"HACE LUGAR A  LA DEMANDA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181305,"fechaModLong":201008251405,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"So Energy Argentina S.A. c/ Salta, provincia de s/accion declarativa de certeza.","inconstitucional":true,"falloDestacado":{"id":6023,"titulo":"Exigencias para que el instrumento único resulte gravable por el impuesto de sellos","cabecilla":"<p>Una empresa promovió acción declarativa de certeza en los términos del artículo 322 del Código Procesal Civil y Comercial de la Nación contra la Provincia de Salta, a fin de que se declare la invalidez e inconstitucionalidad de la pretensión del Estado local de gravar con el impuesto de sellos la carta oferta irrevocable emitida por SEA a Energía Argentina S.A. (ENARSA). La Corte hizo lugar a la demanda. Para ello, entre otras cuestiones, consideró que la nota, por medio de la cual ENARSA aceptó una oferta que únicamente identifica con su fecha de emisión, el número de licitación y la obra a la cual se refiere no cumple con los requisitos y caracteres exigidos por las normas tributarias para configurar un “instrumento” sujeto al impuesto de sellos, razón por la cual la pretensión fiscal de la provincia contraviene, en el orden federal, lo dispuesto en el artículo 9°, acápite 2 de su inciso b, de la ley 23.548, además de no encontrar justificación en su propio texto legal impositivo.</p>","esNovedad":true,"fecha":1697684400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1698063923544,"usuarioCreacion":4,"fechaCreacion":1697746959795,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":114889,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23496785,"numeroExpediente":216,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"S","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"So Energy Argentina S.A. c/ Salta, provincia de s/accion declarativa de certeza.","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"S. 216. XLIX. "},"recurso":{"id":3092625,"expediente":{"id":23496785,"numeroExpediente":216,"anioExpediente":2013,"tomoExpediente":49,"letraExpediente":"S","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"So Energy Argentina S.A. c/ Salta, provincia de s/accion declarativa de certeza.","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"S. 216. XLIX. "},"tipoRecurso":{"id":1154,"codigo":"ORI","descripcion":"ORIGINARIO                   "},"claveRecurso":"CSJ 000216/2013(49-S)/CS001","id