raba inscripción vigente en el Registro Nacional de Prestadores - Sentencia que prescindió de lo informado sin brindar fundamentos consistentes y, en su lugar, se limitó a señalar que la falta de inscripción en el mencionado registro no impedía determinar que le correspondía a la enjuiciada otorgar la cobertura de la prestación - Obra social social demandada que ajustó su conducta a lo normado en las disposiciones vigentes por lo que no es posible endilgarle un incumplimiento de sus obligaciones - Argumentos que resultan ostensiblemente insuficientes para justificar el apartamiento del régimen jurídico aplicable al caso, máxime cuando este no ha sido tachado de ilegítimo - Se deja sin efecto la sentencia apelada - Disidencia del juez Rosatti: recurso extraordinario inadmisible (art. 280 CPCCN)","esNovedad":true,"fecha":1608174000000,"relevancia":2,"usuarioModificacion":null,"fechaModificacion":null,"usuarioCreacion":null,"fechaCreacion":null,"privado":null,"posicion":null,"resumen":null},"reciboEntrada":{"id":30075,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31591220,"numeroExpediente":24350,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":1923,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":0,"codigo":"AMPAROS"}},"caratula":"ROMERO, SILVANA ANDREA c/ OBRA SOCIAL DE CONDUCTORES CAMIONEROS Y PERSONAL DEL TRANSPORTE AUTOMOTOR DE CARGAS s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"24350. "},"recurso":{"id":5713907,"expediente":{"id":31591220,"numeroExpediente":24350,"anioExpediente":2018,"tomoExpediente":null,"let