{"id":765108,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"Recurso Queja Nº 2 - B., M. A. Y OTROS c/ (OSDE) ORGANIZACION DE SERVICIOS DIRECTOS EMPRESARIOS s/AMPARO LEY 16.986","alias":null,"caratula":"Recurso Queja Nº 2 - B., M. A. Y OTROS c/ (OSDE) ORGANIZACION DE SERVICIOS DIRECTOS EMPRESARIOS s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":1746,"titulo":"Cobertura de tratamientos médicos en etapa experimental","cabecilla":"<p>Sentencia de c&aacute;mara que hizo lugar a la acci&oacute;n de amparo y dispuso que se otorgara cobertura completa e integral sin limitaciones a un menor que padece discapacidad - Tratamientos dietarios y biom&eacute;dicos para personas con autismo que no se encuentran previsto en la Ley de Discapacidad ni est&aacute;n incorporados al P.M.O. - Procedimientos diagn&oacute;sticos o terap&eacute;uticos que se encuentran en etapa experimental y no est&aacute;n contemplados en la normativa que rige para los agentes del seguro de salud y las entidades de medicina prepaga - Tratamiento con resultados controversiales y que no son recomendados por centros internacionales dedicados al autismo - Dictamen del Cuerpo M&eacute;dico Forense que fue elocuente con relaci&oacute;n a la ausencia de demostraci&oacute;n cient&iacute;fica respecto de sus supuestos beneficios - El a quo ha soslayado que la autoridad sanitaria no ha otorgado suficiente autorizaci&oacute;n para que los agentes de salud prescriban y apliquen las nuevas pr&aacute;cticas y tratamientos - Se deja sin efecto la sentencia recurrida - Disidencia del juez Rosatti: examen de cuestiones de hecho, prueba y derecho procesal ajenas al recurso extraordinario - Falta de demostraci&oacute;n del perjuicio concreto que la decisi&oacute;n le caus&oacute; - Los agravios relacionados con el reconocimiento de las prestaciones biom&eacute;dicas constituyen una mera discrepancia con el criterio del juzgador.</p>","esNovedad":true,"fecha":1617850800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1618230463232,"usuarioCreacion":11,"fechaCreacion":1618230458232,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":30661,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32904714,"numeroExpediente":51530,"anioExpediente":2014,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":18,"codigo":"18","abreviatura":"FLP","descripcion":"Justicia Federal de La Plata","estado":0,"descripcionLarga":"FLP - Justicia Federal de La Plata"},"objetoJuicio":{"id":7925,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":360,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 2 - B., M. A. Y OTROS c/ (OSDE) ORGANIZACION DE SERVICIOS DIRECTOS EMPRESARIOS s/AMPARO LEY 16