{"id":805619,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"S., A. c/ Estado Nacional - Ministerio del Interior s/ impugnación de acto administrativo.","alias":null,"caratula":"Recurso Queja Nº 2 - SENE, ADAMA c/ ESTADO NACIONAL MINISTERIO DEL INTERIOR s/IMPUGNACION de ACTO ADMINISTRATIVO","inconstitucional":false,"falloDestacado":{"id":8281,"titulo":"Beneficio de litigar sin gastos y depósito previo: oportunidad para su pedido","cabecilla":"<p style=\"text-indent:2em\">La cámara rechazó el beneficio de litigar sin gastos solicitado fundándose en que el actor lo había articulado una vez superada la etapa procesal a la que alude el art. 84, párrafo tercero, del Código Procesal Civil y Comercial de la Nación, sin haber invocado hechos sobrevinientes modificatorios de su situación económica.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia al considerar que desatendía las circunstancias del caso al resolver el incidente sobre la base de un principio procesal dogmáticamente enunciado.</p><p style=\"text-indent:2em\">Expresó que el pronunciamiento omitía ponderar los gastos que podría cubrir el beneficio, como las costas procesales de la alzada y la suma correspondiente al depósito de una eventual queja ante el Tribunal frente a la perspectiva de una decisión adversa en la cámara.</p><p style=\"text-indent:2em\">Recordó que para exceptuarse del depósito previsto por el art. 286 del Código Procesal Civil y Comercial de la Nación, los recurrentes que invoquen incapacidad económica deben solicitar el respectivo beneficio ante el juez del proceso principal con lo cual el rechazo de la petición ocasionaba un dispendio de jurisdicción que no condice con el principio de economía procesal y se desentiende de la finalidad del instituto.</p>","esNovedad":true,"fecha":1740020400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1740145888947,"usuarioCreacion":11,"fechaCreacion":1740075287141,"privado":false,"posicion":2,"resumen":{"idResumen":108,"resumen":"La Corte revocó el rechazo del beneficio de litigar sin gastos. La Cámara no consideró gastos procesales de alzada ni el depósito por queja, afectando el principio de economía procesal.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":132223,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35309223,"numeroExpediente":25351,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8844,"descripcion":"IMPUGNACION de ACTO ADMINISTRATIVO","idMateria":112,"tema":{"id":386,"