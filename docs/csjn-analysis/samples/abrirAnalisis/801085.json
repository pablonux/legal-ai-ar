{"id":801085,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 3 - AMBROSIO NORBERTO NILO c/ HIPODROMO ARGENTINO DE PALERMO SA Y OTROS s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":7603,"titulo":"Atribución de responsabilidad al Estado Nacional  sin demostrar de una prestación irregular o defectuosa","cabecilla":"<p style=\"text-indent:2em\">El actor disputó la séptima carrera programada por el Hipódromo Argentino de Palermo conduciendo un caballo sangre pura de carrera y faltando setecientos metros para llegar al disco, el caballo rodó y lo despidió de su montura, cayendo pesadamente contra el suelo. Como consecuencia de ello, sufrió diversas lesiones, por las cuales responsabilizó al hipódromo Argentino de Palermo S.A. (HAPSA) y al Estado Nacional.</p><p style=\"text-indent:2em\">La cámara condenó al Hipódromo Argentino de Palermo S.A. (HAPSA), al dueño del caballo y al Estado Nacional a pagar una indemnización a raíz de los daños padecidos por el actor durante la carrera.</p><p style=\"text-indent:2em\">Ante el recurso de este último la Corte dejó sin efecto la sentencia.</p><p style=\"text-indent:2em\">Consideró que el tribunal no ofreció una respuesta integral a la cuestión de la responsabilidad, pues no tuvo en cuenta la normativa que rige la concesión que se adjudicó a la sociedad codemandada, ni precisó en forma concreta cuál era el deber incumplido, sin que resultare suficiente una imputación meramente genérica.</p><p style=\"text-indent:2em\">Agregó que se había endilgado responsabilidad al Estado Nacional por ser el “dueño o guardián” del predio en el que se realiza una actividad riesgosa, es decir que se empleó un factor de atribución ajeno a la falta de servicio y pasando por alto que las competencias atribuidas al Hipódromo no le resultan imputables en forma directa.</p><p style=\"text-indent:2em\">Afirmó además el Tribunal que, al resolver de ese modo, la sentencia había omitido ponderar y examinar el contrato mediante el cual se había otorgado la concesión del predio a la firma también demandada, a fin de determinar si el Estado resultaba imputable y, en consecuencia, si había incumplido algún deber legal que le fuera exigible.</p><p style=\"text-indent:2em\">Agregó que el Estado solo responde si incumplió con un deber legal que le impone obstar el evento lesivo, puesto que una conclusión contraria llevaría al irrazonable extremo de convertirlo en un ente asegurador de todo hecho dañoso que se cometiera.</p>","esNovedad":true,"fecha":1727146800000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1729266915957,"usuarioCreacion":11,"fechaCreacion":1727205720802,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":127665,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35185657,"numeroExpediente":224,"anioExpediente":2001,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":3,"codigo":"3","abreviatura":"CCF","descripcion":"Cámara Nacional de Apelaciones en lo Civil y Comercial Federal","estado":0,"descripcionLarga":"CCF - Cámara Nacional de Apelaciones en lo Civil y Comercial Federal"},"objetoJuicio":{"id":1341,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":3,"tema":{"id":444,"codigo":"DAÑOSYPER"}},"caratula":"Recurso Queja Nº 3 - AMBROSIO NORBERTO NILO c/ HIPODROMO ARGENTINO DE PALERMO SA Y OTROS s/DAÑOS Y PERJUICIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"224. "},"recurso":{"id":5940930,"expediente":{"id":35185657,"numeroExpediente":224,"anioExpediente":2001,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":3,"codigo":"3","abreviatura":"CCF","descripcion":"Cámara Nacional de Apelaciones en lo Civil y Comercial Federal","estado":0,"descripcionLarga":"CCF - Cámara Nacional de Apelaciones en lo Civil y Comercial Federal"},"objetoJuicio":{"id":1341,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":3,"tema":{"id":444,"codigo":"DAÑOSYPER"}},"caratula":"Recurso Queja Nº 3 - AMBROSIO NORBERTO NILO c/ HIPODROMO ARGENTINO DE PALERMO SA Y OTROS s/DAÑOS Y PERJUICIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"224. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"CCF 000224/2001/3/RH001","identificacionExpediente":"CCF 000224/2001/3/RH001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":7,"no