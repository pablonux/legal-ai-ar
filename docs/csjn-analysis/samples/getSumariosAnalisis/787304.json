":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 1 - DAMNIFICADO: ALVAREZ, ROBERTO WALTER NN: N.N. s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":5902,"titulo":"Conflicto negativo de competencia a raíz de una privación ilegal de la libertad que se produce en más de una jurisdicción ","cabecilla":"<p>El denunciante fue abordado y amenazado cuando salía de su domicilio en la Ciudad de Buenos Aires para subirse al camión con el que desempeñaba sus tareas laborales, fue obligado a subirse al rodado y lo hicieron circular por una localidad bonaerense donde finalmente lo liberaron. El magistrado nacional declinó su competencia al considerar que tanto el cese de la privación ilegal de la libertad como la consumación del desapoderamiento tuvieron lugar en el ámbito provincial y el provincial rechazó la atribución al entender que los delitos de robo agravado por el uso de armas y privación ilegal se llevaron a cabo en la Ciudad mencionada. La Corte dispuso que sea la justicia provincial la que continúe con el trámite de las actuaciones. Basó su decisión en que cuando pudo haber existido privación ilegítima de la libertad en más de una jurisdicción y en alguna de ellas se cometió otro delito, es a los tribunales de esta última a los que corresponde entender en la causa y la privación ilegal de la libertad y el desapoderamiento del rodado se habían producido en territorio provincial. </p>","esNovedad":true,"fecha":1695697200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1695904061611,"usuarioCreacion":11,"fechaCreacion":1695759214972,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":113417,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35858999,"numeroExpediente":96093,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apelaciones en lo Criminal y Correccional"},"objetoJuicio":{"id":1861,"descripcion":"EXPEDIENTES PENALES","idMateria":9,"tema":null},"caratula":"Incidente Nº 1 - DAMNIFICADO: HEREDIA SANTANA, ROBIN JOSUE IMPUTADO: IAMETTI, ANIBAL RUBEN Y OTRO s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"96093. "},"recurso":{"id":6143366,"expediente":{"id":35858999,"numeroExpediente":96093,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":9,"codigo":"9","abreviatura":"CCC","descripcion":"Camara Nacional de Apelaciones en lo Criminal y Correccional","estado":0,"descripcionLarga":"CCC - Camara Nacional de Apel