[{"id":167561,"orden":1,"ordenRecurso":null,"voces":"PUEBLOS INDIGENAS - PERSONERIA - REPRESENTACION","texto":"<p>Corresponde fijar un plazo de 60 días para que se acredite en la causa la representación de la comunidad Qom Potae Napocna Navogoh, pues la designación de quien se presenta como Qarashe se encuentra vencida y la renovación de las autoridades comunitarias no se llevó a cabo de acuerdo a las pautas que la comunidad se ha dado a sí misma a esos efectos en el título VI de su estatuto.</p>","fullText":"<XML><VOCES>PUEBLOS INDIGENAS - PERSONERIA - REPRESENTACION</VOCES><TEXTO>Corresponde fijar un plazo de 60 días para que se acredite en la causa la representación de la comunidad Qom Potae Napocna Navogoh, pues la designación de quien se presenta como Qarashe se encuentra vencida y la renovación de las autoridades comunitarias no se llevó a cabo de acuerdo a las pautas que la comunidad se ha dado a sí misma a esos efectos en el título VI de su estatuto.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1727146800000,"tomo":347,"pagina":1282,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":7,"holding":0,"linksCitantes":null,"numeroID":8410,"anioFallo":2024,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3146,"codigoRelacion":103146,"valor":"PUEBLOS INDIGENAS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202409241733,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":2944,"codigoRelacion":102944,"valor":"PERSONERIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202409241733,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":3414,"codigoRelacion":103414,"valor":"REPRESENTACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":3,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202409241733,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":8014821,"analisisDocumental":{"id":801482,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":40,"codigoRelacion":80040,"valor":"PROCEDIMIENTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201512101503,"fechaModLong":201512101503,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"COMUNIDAD INDIGENA TOBA LA PRIMAVERA - NAVOGOH c/ FORMOSA, PROVINCIA DE  Y OTROS s/ORDINARIO","inconstitucional":false,"falloDestacado":{"id":7624,"titulo":"Representación de la comunidad indígena. Vigencia","cabecilla":"<p style=\"text-indent: 2em;\">La Corte le requirió al señor Félix Díaz que acredite la vigencia de la representación invocada para actuar en el juicio, en virtud de que su designación como Qarashe – autoridad tradicional - de la comunidad indígena Qom Potae Napocna Navogoh por el plazo de diez años se encontraba vencida.</p><p style=\"text-indent: 2em;\">A su turno, la Provincia de Formosa impugnó la documentación acompañada, ya que -a su juicio- no reúne los requisitos contemplados en el “Estatuto Ley Qom” a los fines de otorgar la representación que dice ostentar.</p><p style=\"text-indent: 2em;\">Según la Corte, tal como sostuvo el INAI en su nota el procedimiento seguido para la renovación de las autoridades comunitarias del que da cuenta la documentación acompañada por el señor Félix Díaz, no se ajusta a las pautas que la comunidad se ha dado a sí misma a esos efectos en el título VI del estatuto presentado ante el organismo de aplicación.</p><p style=\"text-indent: 2em;\">Atento a ello, corresponde concluir que los instrumentos acompañados no acreditan la vigencia de la representación de la comunidad Qom invocada por el señor Potae Napocna Navogoh Félix Díaz, ya que su designación como Qarashe por el plazo de diez años decidida en la asamblea celebrada el 25 de julio de 2011 se encuentra vencida y la renovación de las autoridades comunitarias no se llevó a cabo de acuerdo a las pautas que la comunidad se ha dado a sí misma a esos efectos en el título VI de su estatuto.</p><p style=\"text-indent: 2em;\">Por lo expuesto, se decidió fijar el plazo de sesenta (60) días para la acreditación de la vigencia de la representación de la comunidad Qom Potae Napocna Navogoh invocada en autos por el señor Félix Díaz, de acuerdo al procedimiento previsto en el título IV del estatuto comunitario, bajo apercibimiento de tenerlo por desistido del proceso.</p>","esNovedad":true,"fecha":1727146800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1727209905691,"usuarioCreacion":11,"fechaCreacion":1727209903752,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":128139,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":23344661,"numeroExpediente":528,"anioExpediente":2011,"tomoExpediente":47,"letraExpediente":"C","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"COMUNIDAD INDIGENA TOBA LA PRIMAVERA - NAVOGOH c/ FORMOSA, PROVINCIA DE  Y OTROS s/ORDINARIO","verificacionMesa":"M","etiqueta":"99001","hijos":[],"oldIdentificadorExpediente":"C. 528. XLVII. "},"recurso":{"id":3148572,"expediente":{"id":23344661,"numeroExpediente":528,"anioExpediente":2011,"tomoExpediente":47,"letraExpediente":"C","tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"COMUNIDAD INDIGENA TOBA LA PRIMAVERA - NAVOGOH c/ FORMOSA, PROVINCIA DE  Y OTROS s/ORDINARIO","verificacionMesa":"M","etiqu