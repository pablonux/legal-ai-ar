isible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/ DAÑOS Y PERJUICIOS","alias":null,"caratula":"Recurso Queja Nº 1 - ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":4743,"titulo":"Argumentos insuficientes para habilitar la instancia extraordinaria en un reclamo de daños por indebida dilación del proceso","cabecilla":"<p>La cámara rechazó la demanda interpuesta contra el Estado Nacional y el Poder Judicial de la Nación a fin de obtener una indemnización por los daños y perjuicios derivados de la indebida dilación de la justicia federal de la provincia en ordenar un embargo preventivo, lo que habría posibilitado la insolvencia del deudor mediante la transferencia de todos los inmuebles de su propiedad. La Corte desestimó el recurso al considerar que el agravio relativo a la demora en resolver la causa no resultaba apto para habilitar la instancia extraordinaria. Afirmó que, aun cuando eventualmente resultara injustificado el tiempo que insumió al magistrado ordenar que se agregara un expediente, permanecía incólume el segundo argumento de la cámara para rechazar el planteo, vinculado con <em>la falta de acreditación de la imposibilidad de percibir el monto de sus honorarios como consecuencia de la enajenación de los bienes sobre los cuales se había pedido el embargo</em>. Agregó que este fundamento resultaba independiente del anterior y no había sido rebatido adecuadamente por la recurrente.</p>","esNovedad":true,"fecha":1667271600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1667407280169,"usuarioCreacion":11,"fechaCreacion":1667330605066,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":104999,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28854178,"numeroExpediente":713067,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":27,"codigo":"27","abreviatura":"FTU","descripcion":"Justicia Federal de Tucuman","estado":0,"descripcionLarga":"FTU - Justicia Federal de Tucuman"},"objetoJuicio":{"id":1519,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":12,"tema":null},"caratula":"Recurso Queja Nº 1 - ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/DAÑOS Y PERJUICIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"713067. "},"recurso":{"id":4932323,"expediente":{"id":28854178,"numeroExpediente":713067,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":27,"codigo":"27","abreviatura":"FTU","descripcion":"Justicia Federal de Tucuman","estado":0,"descripcionLarga":"FTU - Justicia Federal de Tucuman"},"objetoJuicio":{"id":1519,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":12,"tema":null},"caratula":"Recurso Queja Nº 1 - ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/DAÑOS Y PERJUICIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"713067. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"FTU 713067/2010/1/RH001","identificacion