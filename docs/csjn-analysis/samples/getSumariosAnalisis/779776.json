n":false},"usuarioModificacionOld":null,"fechaModificacion":202211011554,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"usuarioCreacionOld":null,"fechaCreacion":202211011552,"caratulaLex":"Recurso Queja Nº 1 - ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/DAÑOS Y PERJUICIOS","autos":"ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/ DAÑOS Y PERJUICIOS","tieneDocumento":true,"linkDocumento":"/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7797761&cache=1777030197056","tieneDictamenes":false,"conAnalisis":true,"conAnalisisPrivado":false,"conVotos":true,"caratulaWeb":"ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/ DAÑOS Y PERJUICIOS","numeroExpediente":"FTU 713067/2010/1/RH001","sentenciaArbitraria":false,"inconstitucional":false,"alias":null,"stringVotosMayoria":"","stringVotosVoto":"","stringVotosDisidencia":"","stringVotosDisidenciaParcial":"","stringVotosAbstencion":"","textoResaltado":"<p>Es improcedente el recurso interpuesto contra la sentencia que rechazó el reclamo de daños y perjuicios ocasionados por la indebida dilación de la justicia en ordenar un embargo preventivo, lo que habría posibilitado la insolvencia del deudor, pues aun cuando eventualmente resultara injustificado el tiempo que insumió al magistrado ordenar que se agregara un expediente, permanece incólume el segundo argumento de la cámara para rechazar el planteo, vinculado con la falta de acreditación de la imposibilidad de percibir el monto de sus honorarios como consecuencia de la enajenación de los bienes sobre los cuales se había pedido el embargo; argumento que no fue rebatido adecuadamente por la parte recurrente. </p>","vocesResaltadas":"RECURSO EXTRAORDINARIO - DILACION DEL PROCESO - DAÑOS Y PERJUICIOS - EMBARGO PREVENTIVO - FUNDAMENTOS DEL RECURSO","desvinculado":false,"fechaString":"01/11/2022","stringVotosAnalisis":""},{"id":159685,"orden":2,"ordenRecurso":null,"voces":"SENTENCIA ARBITRARIA - FUNDAMENTOS DE LA SENTENCIA","texto":"<p>La doctrina de la arbitrariedad no tiene por objeto corregir sentencias equivocadas o que el recurrente considere tales, con sustento en su mera discrepancia con la valoración de cuestiones de hecho y prueba realizada por el a quo, sino que reviste un carácter estrictamente excepcional y en virtud de ello, su procedencia requiere un apartamiento inequívoco de la solución normativa o una absoluta carencia de fundamentación, pues de lo contrario se extendería la jurisdicción de la Corte habilitándola para revisar todas las decisiones judiciales que se dicten, con menoscabo de los límites establecidos por la Constitución y las leyes. </p>","fullText":"<XML><VOCES>SENTENCIA ARBITRARIA - FUNDAMENTOS DE LA SENTENCIA</VOCES><TEXTO>La doctrina de la arbitrariedad no tiene por objeto corregir sentencias equivocadas o que el recurrente considere tales, con sustento en su mera discrepancia con la valoración de cuestiones de hecho y prueba realizada por el a quo, sino que reviste un carácter estrictamente excepcional y en virtud de ello, su procedencia requiere un apartamiento inequívoco de la solución normativa o una absoluta carencia de fundamentación, pues de lo contrario se extendería la jurisdicción de la Corte habilitándola para revisar todas las decisiones judiciales que se dicten, con menoscabo de los límites establecidos por la Constitución y las leyes. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1667271600000,"tomo":345,"pagina":1233,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":5,"holding":0,"linksCitantes":null,"numeroID":6605,"anioFallo":2022,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3532,"codigoRelacion":103532,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202211011553,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":4287,"codigoRelacion":104287,"valor":"FUNDAMENTOS DE LA SENTENCIA","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201209281048,"fechaModLong":201209281048,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202211011553,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7797761,"analisisDocumental":{"id":779776,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/ DAÑOS Y PERJUICIOS","alias":null,"caratula":"Recurso Queja Nº 1 - ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":4743,"titulo":"Argumentos insuficientes para habilitar la instancia extraordinaria en un reclamo de daños por indebida dilación del proceso","cabecilla":"<p>La cámara rechazó la demanda interpuesta contra el Estado Nacional y el Poder Judicial de la Nación a fin de obtener una indemnización por los daños y perjuicios derivados de la indebida dilación de la justicia federal de la provincia en ordenar un embargo preventivo, lo que habría posibilitado la insolvencia del deudor mediante la transferencia de todos los inmuebles de su propiedad. La Corte desestimó el recurso al considerar que el agravio relativo a la demora en resolver la causa no resultaba apto para habilitar la instancia extraordinaria. Afirmó que, aun cuando eventualmente resultara injustificado el tiempo que insumió al magistrado ordenar que se agregara un expediente, permanecía incólume el segundo argumento de la cámara para rechazar el planteo, vinculado con <em>la falta de acreditación de la imposibilidad de percibir el monto de sus honorarios como consecuencia de la enajenación de los bienes sobre los cuales se había pedido el embargo</em>. Agregó que este fundamento resultaba independiente del anterior y no había sido rebatido adecuadamente por la recurrente.</p>","esNovedad":true,"fecha":1667271600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1667407280169,"usuarioCreacion":11,"fechaCreacion":1667330605066,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":104999,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28854178,"numeroExpediente":713067,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":27,"codigo":"27","abreviatura":"FTU","descripcion":"Justicia Federal de Tucuman","estado":0,"descripcionLarga":"FTU - Justicia Federal de Tucuman"},"objetoJuicio":{"id":1519,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":12,"tema":null},"caratula":"Recurso Queja Nº 1 - ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/DAÑOS Y PERJUICIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"713067. "},"recurso":{"id":4932323,"expediente":{"id":28854178,"numeroExpediente":713067,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":27,"codigo":"27","abreviatura":"FTU","descripcion":"Justicia Federal de Tucuman","estado":0,"descripcionLarga":"FTU - Justicia Federal de Tucuman"},"objetoJuicio":{"id":1519,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":12,"tema":null},"caratula":"Recurso Queja Nº 1 - ALLUZ RENE GUILLERMO c/ PODER JUDICIAL DE LA NACION Y/O ESTADO NACIONAL s/DAÑOS Y PERJUICIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"713067. "},"tipoRecurso":{"id":1182,"codigo":"RHX","descripcion":"QUEJA RECURSO EXTRAORDINARIO DENEGADO"},"claveRecurso":"FTU 713067/2010/1/RH001","identificacionExpediente":"FTU 713067/2010/1/RH001"},"piezas":9,"urgente":nu