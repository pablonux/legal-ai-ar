LACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"BENITEZ, ANDRES c/ ERIDAY - UTE s/ACCIDENTE DE TRABAJO","alias":null,"caratula":"BENITEZ, ANDRES \"HOY SMIT MARIA BLANCA\" c/ ERIDAY - UTE s/ACCIDENTE DE TRABAJO","inconstitucional":false,"falloDestacado":{"id":7601,"titulo":"Falta de la fecha de estimación de los daños y arbitrariedad de la sentencia","cabecilla":"<p style=\"text-indent:2em\">En un juicio por accidente de trabajo, el tribunal interviniente,  tras valorar prudencialmente las circunstancias personales del trabajador (46 años de edad al momento del accidente -29 de agosto de 1991- del que derivó una incapacidad permanente total y con tres hijos menores de edad a su cargo), lo estableció en $ 13.000.000 (sumatoria del daño moral y material). La cámara consideró consolidada dicha indemnización pero omitió aclarar a valores de qué fecha la había estimado, si incluía o no intereses y, eventualmente, desde cuándo y cómo estos accesorios deberían computarse.</p><p style=\"text-indent:2em\">La Corte descalificó el fallo con base en la doctrina de la arbitrariedad. En efecto, tales deficiencias, expresó la Corte, impiden conocer el verdadero alcance de la condena impuesta y, en definitiva, obstan a un examen serio sobre su razonabilidad y su adecuación a los factores que habrían gravitado para su fijación.</p>","esNovedad":true,"fecha":1727146800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1727270857072,"usuarioCreacion":11,"fechaCreacion":1727202012193,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":127404,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":8312061,"numeroExpediente":81007789,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":16,"codigo":"16","abreviatura":"FCT","descripcion":"Justicia Federal de Corrientes","estado":0,"descripcionLarga":"FCT - Justicia Federal de Corrientes"},"objetoJuicio":{"id":3713,"descripcion":"ACCIDENTE DE TRABAJO","idMateria":112,"tema":{"id":228,"codigo":"LABORAL"}},"caratula":"BENITEZ, ANDRES \"HOY SMIT MARIA BLANCA\" c/ ERIDAY - UTE Y OTRO s/ACCIDENTE DE TRABAJO","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"81007789. "},"recurso":{"id":5533518,"expediente":{"id":8312061,"numeroExpediente":81007789,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":16,"codigo":"16","abreviatura":"FCT","descripcion":"Justicia Federal de Corrientes","estado":0,"descripcionLarga":"FCT - Justicia Federal de Corrientes"},"objetoJuicio":{"id":3713,"descripcion":"ACCIDENTE DE TRABAJO","idMateria":112,"tema":{"id":228,"codigo":"LABORAL"}},"caratula":"BENITEZ, ANDRES \"HOY SMIT MARIA BLANCA\" c/ ERIDAY - UTE Y OTRO s/ACCIDENTE DE TRABAJO","verificacionMesa":"M","etique