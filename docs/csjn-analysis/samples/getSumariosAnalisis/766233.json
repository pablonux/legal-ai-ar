[{"id":154754,"orden":1,"ordenRecurso":null,"voces":"DEPOSITO PREVIO - RECURSO DE QUEJA - FUERZA MAYOR","texto":"Resulta inatendible el pedido efectuado por las empresas recurrente en orden a que se las exima del pago del depósito previo (art. 286 del CPCCN) invocando fuerza mayor – por orden del Poder Ejecutivo no pudieron trabajar- pues la obligación que impone el citado artículo sólo cede respecto de quienes se encuentran exentos de pagar el sellado o tasa de justicia, según las disposiciones de las leyes nacionales respectivas, esto es, de aquellos que se encuentran comprendidos en el art. 13 de la ley 23.898 y en las normas especiales que contemplan excepciones a tales tributos, inclusión que debe ser expresa e interpretada con criterio restrictivo, circunstancia que no se verifican en los casos.","fullText":"<XML><VOCES>DEPOSITO PREVIO - RECURSO DE QUEJA - FUERZA MAYOR</VOCES><TEXTO>Resulta inatendible el pedido efectuado por las empresas recurrente en orden a que se las exima del pago del depósito previo (art. 286 del CPCCN) invocando fuerza mayor – por orden del Poder Ejecutivo no pudieron trabajar- pues la obligación que impone el citado artículo sólo cede respecto de quienes se encuentran exentos de pagar el sellado o tasa de justicia, según las disposiciones de las leyes nacionales respectivas, esto es, de aquellos que se encuentran comprendidos en el art. 13 de la ley 23.898 y en las normas especiales que contemplan excepciones a tales tributos, inclusión que debe ser expresa e interpretada con criterio restrictivo, circunstancia que no se verifican en los casos.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1620874800000,"tomo":344,"pagina":1047,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":2374,"anioFallo":2021,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1420,"codigoRelacion":101420,"valor":"DEPOSITO PREVIO"