[{"id":176375,"orden":1,"ordenRecurso":null,"voces":"SENTENCIA DE LA CORTE SUPREMA - CUESTION ABSTRACTA - PRONUNCIAMIENTO INOFICIOSO","texto":"<p>Las sentencias de la Corte deben atender a las condiciones existentes al<b> </b>momento en que se las dicta; y, en caso de advertir que un planteo devino abstracto, debe abstenerse de dictar pronunciamiento porque ella solo está habilitada para decidir colisiones efectivas de derechos en casos concretos. </p>","fullText":"<XML><VOCES>SENTENCIA DE LA CORTE SUPREMA - CUESTION ABSTRACTA - PRONUNCIAMIENTO INOFICIOSO</VOCES><TEXTO>Las sentencias de la Corte deben atender a las condiciones existentes al momento en que se las dicta; y, en caso de advertir que un planteo devino abstracto, debe abstenerse de dictar pronunciamiento porque ella solo está habilitada para decidir colisiones efectivas de derechos en casos concretos. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1772679600000,"tomo":349,"pagina":105,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":1,"holding":0,"linksCitantes":null,"numeroID":962,"anioFallo":2026,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3534,"codigoRelacion":103534,"valor":"SENTENCIA DE LA CORTE SUPREMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202603051741,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":1271,"codigoRelacion":101271,"valor":"CUESTION ABSTRACTA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202603051741,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":3092,"codigoRelacion":103092,"valor":"PRONUNCIAMIENTO INOFICIOSO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":3,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202603051741,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":8238031,"analisisDocumental":{"id":823803,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":80013,"valor":"DECLARA INOFICIOSO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009221235,"fechaModLong":201009221235,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":230004,"valor":"RECURSO DE REVOCATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 2 - ACTOR: GCBA S/ QUEJA POR RECURSO DE INCONSTITUCIONALIDAD DENEGADO (CIVIL) EN CA  s/INCIDENTE","inconstitucional":false,"falloDestacado":{"id":10342,"titulo":"Pedido de intervención de la Defensoría General de la Nación: pronunciamiento que devino inoficioso","cabecilla":"<p style=\"text-indent:2em\">En un pronunciamiento previo la Corte dictó sentencia declarando, por mayoría, al Tribunal Superior de Justicia de la Ciudad Autónoma de Buenos Aires competente para revisar la sentencia de la Cámara Nacional de Apelaciones en lo Civil que declaró desierto el recurso interpuesto por el Gobierno de la Ciudad Autónoma de Buenos Aires contra la decisión de primera instancia, en la que se había aprobado la liquidación de multas impuestas a su parte por la demora en otorgar una vacante en un hogar terapéutico.</p><p style=\"text-indent:2em\">Contra esa decisión la Defensora General de la Nación planteó recurso de reposición por no habérsele otorgado intervención previa a su dictado. Fundó su pedido en la circunstancia de que la liquidación de astreintes se encontraba firme y la remisión del pleito al TSJ dilataría la satisfacción de los derechos de su representado.</p><p style=\"text-indent:2em\">Mientras dicha reposición era estudiada por la Corte, el tribunal mencionado rechazó la queja presentada por el Gobierno, por recurso de inconstitucionalidad denegado dirigido contra la sentencia de la cámara. El Gobierno no recurrió esta resolución, y en primera instancia se encuentra tramitando el incidente de ejecución de sentencia.</p><p style=\"text-indent:2em\">Señaló la Corte que, en razón de las circunstancias sobrevinientes, la liquidación de multas y la intimación al pago quedaron firmes, por lo que perdió actualidad el agravio invocado por la Defensoría General de la Nación.</p><p style=\"text-indent:2em\">Por ello, el Tribunal declaró que resultaba inoficioso un pronunciamiento.</p>","esNovedad":true,"fecha":1772679600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1772801459324,"usuarioCreacion":11,"fechaCreacion":1772743329590,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":153200,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":39694498,"numeroExpediente":483,"anioExpediente":2024,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"Incidente Nº 2 - ACTOR: GCBA S/ QUEJA POR RECURSO DE INCONSTITUCIONALIDAD DENEGADO (CIVIL) EN CA  s/INCIDENTE","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"483. "},"recurso":{"id":7158729,"expediente":{"id":39694498,"numeroExpediente":483,"anioExpediente":2024,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"Incidente Nº 2 - ACTOR: GCBA S/ QUEJA POR RECURSO DE INCONSTITUCIONALIDAD DENEGADO (CIVIL) EN CA  s/INC