-body voto btn-link'><div class='row'><div class='col-xs-9 col-sm-8'> ROSENKRANTZ</div><div class='col-xs-3 col-sm-4 nroPagina'><i style='float: right; text-align: right'>p. 1</i></div></div><div class='row'><div class='col-xs-9 col-sm-8'> HIGHTON de NOLASCO</div></div><div class='row'><div class='col-xs-9 col-sm-8'> MAQUEDA</div></div><div class='row'><div class='col-xs-9 col-sm-8'> LORENZETTI</div></div></div></div><div class='panel panel-default' onclick='irAPagina(5)' style='padding: 2px;'><div class='panel-body voto btn-link'><div class='row'><div class='col-xs-9 col-sm-8'> ROSATTI</div><div class='col-xs-3 col-sm-4 nroPagina'><i style='float: right; text-align: right'>p. 5</i></div></div></div></div>"},"usuarioModificacion":null,"usuarioModificacionOld":"JUR0V0","fechaModificacion":201906211543,"usuarioCreacion":null,"usuarioCreacionOld":"JUR0V0","fechaCreacion":201906211543,"alias":null,"tieneDocumento":true,"linkDocumento":"/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7512891&cache=1777036763180","tieneDictamenes":true,"conAnalisis":true,"conAnalisisPrivado":false,"conVotos":true,"caratulaWeb":"Fernández, Andrés Iván s/ robo ","autos":"Fernández, Andrés Iván s/ robo ","sentenciaArbitraria":true,"inconstitucional":false,"numeroExpediente":"CCC 045525/2013/TO01/6/1/RH001","caratulaLex":"Recurso Queja Nº 1 - IMPUTADO: FERNANDEZ, ANDRES IVAN s/ROBO ","fechaString":"28/05/2019","stringVotosMayoria":"","stringVotosVoto":"","stringVotosDisidencia":"","stringVotosDisidenciaParcial":"","stringVotosAbstencion":"","textoResaltado":"Si el imputado cometió el robo por el que fue condenado en este proceso poco más de dos meses después de obtener la libertad condicional tras haber cumplido parcialmente la pena de cinco años de prisión impuesta más de dos años antes mediante una sentencia que adquirió firmeza once meses después de dictada, resulta aplicable el art. 50 del Código Penal y procede la declaración de reincidencia. ","vocesResaltadas":"CONDENA - LIBERTAD CONDICIONAL - PENA - REINCIDENCIA","desvinculado":false,"stringVotosAnalisis":""},{"id":150681,"orden":3,"ordenRecurso":null,"voces":"FALTA DE FUNDAMENTACION - REINCIDENCIA","texto":"Si el a quo no explicó los motivos por los cuales entendió que la declaración de reincidencia había perdido virtualidad, al no señalar qué vinculación guardaba el desarrollo que había efectuado en torno a la unificación de penas con el instituto contemplado en el art. 50 del Código Penal, la fundamentación de la sentencia resulta aparente, lo que acarrea que no pueda ser tenida como un acto jurisdiccional válido y que deba ser dejada sin efecto (Voto del juez Rosatti).","fullText":"<XML><VOCES>FALTA DE FUNDAMENTACION - REINCIDENCIA</VOCES><TEXTO>Si el a quo no explicó los motivos por los cuales entendió que la declaración de reincidencia había perdido virtualidad, al no señalar qué vinculación guardaba el desarrollo que había efectuado en torno a la unificación de penas con el instituto contemplado en el art. 50 del Código Penal, la fundamentación de la sentencia resulta aparente, lo que acarrea que no pueda ser tenida como un acto jurisdiccional válido y que deba ser dejada sin efecto (Voto del juez Rosatti).</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1559012400000,"tomo":342,"pagina":875,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":2396,"anioFallo":2019,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3906,"codigoRelacion":103906,"valor":"FALTA DE FUNDAMENTACION","activo":"S","usuarioCreacion":"JUR202","usuarioMod":"JUR202","fechaCreacionLong":201009270859,"fechaModLong":201009270859,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201906211546,"usuarioModificacion":null,"fechaModificacion":201906211546},{"tipoVoz":{"codigoTabla":null,"codigoValor":3387,"codigoRelacion":103387,"valor":"REINCIDENCIA","activo":"S"