[{"id":167096,"orden":1,"ordenRecurso":null,"voces":"COMPETENCIA - PROPIEDAD INTELECTUAL - DAÑOS Y PERJUICIOS - MODELOS Y DISEÑOS INDUSTRIALES","texto":"<p>Es competente la justicia civil para entender en la acción destinada a que se disponga el cese del uso no autorizado de un diseño cuya propiedad intelectual exclusiva invoca el actor y la reparación de los daños y perjuicios que su utilización con fines comerciales le habría ocasionado, pues el objeto principal del juicio se vincula -en principio- con la interpretación, sentido y alcance de aspectos relativos a los derechos de autor y de propiedad intelectual sobre el diseño indicado por el actor, regulados por la ley 11.723</p><p>-Del dictamen de la Procuración General al que la Corte remite-</p>","fullText":"<XML><VOCES>COMPETENCIA - PROPIEDAD INTELECTUAL - DAÑOS Y PERJUICIOS - MODELOS Y DISEÑOS INDUSTRIALES</VOCES><TEXTO>Es competente la justicia civil para entender en la acción destinada a que se disponga el cese del uso no autorizado de un diseño cuya propiedad intelectual exclusiva invoca el actor y la reparación de los daños y perjuicios que su utilización con fines comerciales le habría ocasionado, pues el objeto principal del juicio se vincula -en principio- con la interpretación, sentido y alcance de aspectos relativos a los derechos de autor y de propiedad intelectual sobre el diseño indicado por el actor, regulados por la ley 11.723-Del dictamen de la Procuración General al que la Corte remite-</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1724122800000,"tomo":347,"pagina":1021,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":4,"holding":0,"linksCitantes":null,"numeroID":6948,"anioFallo":2024,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":964,"codigoRelacion":100964,"valor":"COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden"