fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"EN-DNM-DISP 28367/05 (EXPTE 215355-3/96) c/ VIDAL JOSE s/RECURSO DIRECTO PARA JUZGADOS","alias":null,"caratula":"Recurso Queja Nº 1 - EN-DNM-DISP 28367/05 (EXPTE 215355-3/96) c/ VIDAL JOSE s/RECURSO DIRECTO PARA JUZGADOS","inconstitucional":false,"falloDestacado":{"id":3841,"titulo":"Carácter instrumental de la retención respecto de la medida de expulsión de migrantes","cabecilla":"<p>La Direcci&oacute;n de Migraciones inici&oacute; una causa con el objeto de que se ordenase la retenci&oacute;n del migrante al solo y &uacute;nico efecto de perfeccionar su expulsi&oacute;n del territorio nacional. Dicha medida fue autorizada por la c&aacute;mara. Contra esta decisi&oacute;n, el migrante interpuso recurso extraordinario. La Corte dej&oacute; sin efecto la decisi&oacute;n por considerar que resultaba prematura. Invoc&oacute; la norma correspondiente de la Ley de Migraciones y se&ntilde;al&oacute; el car&aacute;cter instrumental del instituto de la retenci&oacute;n respecto de la medida de expulsi&oacute;n, cuando esta &uacute;ltima se encontraba todav&iacute;a en debate y sin haberse dictado a&uacute;n pronunciamiento de primera instancia.</p>","esNovedad":true,"fecha":1650942000000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1651151017838,"usuarioCreacion":11,"fechaCreacion":1651000574260,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":33610,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":