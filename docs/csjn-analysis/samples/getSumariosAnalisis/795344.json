[{"id":163771,"orden":1,"ordenRecurso":null,"voces":"CUESTION ABSTRACTA - NULIDAD DE ACTOS ADMINISTRATIVOS - PRONUNCIAMIENTO INOFICIOSO - UNIVERSIDAD - AGOTAMIENTO DE LA VIA ADMINISTRATIVA","texto":"<p>Deviene abstracta la acción de amparo promovida contra una universidad a fin de impugnar las resoluciones emitidas el consejo directivo mediante las cuales se dispuso el inicio de juicio académico contra el actor, pues si bien al momento de iniciarse existía una situación de urgencia que tornaba necesaria la restitución inmediata de los derechos que se alegaron conculcados, lo cierto es que no podía soslayarse que el consejo superior había dictado una resolución que rechazaba el recurso jerárquico y que ello importaba el agotamiento de la vía administrativa, lo cual debía ser necesariamente impugnado empleando el remedio procesal que se considerara pertinente, tornado abstractas las cuestiones planteadas.</p><p>-Del dictamen de la Procuración General al que la Corte remite-</p>","fullText":"<XML><VOCES>CUESTION ABSTRACTA - NULIDAD DE ACTOS ADMINISTRATIVOS - PRONUNCIAMIENTO INOFICIOSO - UNIVERSIDAD - AGOTAMIENTO DE LA VIA ADMINISTRATIVA</VOCES><TEXTO>Deviene abstracta la acción de amparo promovida contra una universidad a fin de impugnar las resoluciones emitidas el consejo directivo mediante las cuales se dispuso el inicio de juicio académico contra el actor, pues si bien al momento de iniciarse existía una situación de urgencia que tornaba necesaria la restitución inmediata de los derechos que se alegaron conculcados, lo cierto es que no podía soslayarse que el consejo superior había dictado una resolución que rechazaba el recurso jerárquico y que ello importaba el agotamiento de la vía administrativa, lo cual debía ser necesariamente impugnado empleando el remedio procesal que se considerara pertinente, tornado abstractas las cuestiones planteadas.-Del dictamen de la Procuración General al que la Corte remite-</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1713236400000,"tomo":347,"pagina":339,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":6,"holding":0,"linksCitantes":null,"numeroID":2486,"anioFallo":2024,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1271,"codigoRelacion":101271,"valor":"CUESTION ABSTRACTA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202404170915,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":2790,"codigoRelacion":102790,"valor":"NULIDAD DE ACTOS ADMINISTRATIVOS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR0V0","fechaCreacionLong":201006301000,"fechaModLong":201811221228,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202404170915,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":3092,"codigoRelacion":103092,"valor":"PRONUNCIAMIENTO INOFICIOSO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":3,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202404170915,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":3794,"codigoRelacion":103794,"valor":"UNIVERSIDAD","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":4,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202404170915,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":4068,"codigoRelacion":104068,"valor":"AGOTAMIENTO DE LA VIA ADMINISTRATIVA","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201106131046,"fechaModLong":201106131046,"orden":null,"visible":null},"orden":5,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202404170915,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7953441,"analisisDocumental":{"id":795344,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 3 - VIALE, CARLOS ALBERTO c/ UNIVERSIDAD NACIONAL DE CATAMARCA (UNCA) s/ACCION DE AMPARO LEY 16986 C/CAUTELAR","inconstitucional":false,"falloDestacado":{"id":6721,"titulo":"Pronunciamiento inoficioso y aplicación de la doctrina \"Peso\"","cabecilla":"<p style=\"text-indent: 2em;\">En el marco de una causa donde se debatía si el Consejo Directivo de la Facultad de Derecho de Catamarca contaba con facultades para dictar las resoluciones mediante las cuales se había dispuesto el inicio de juicio académico contra el actor la cámara hizo lugar a su amparo y afirmó que dicho órgano carecía de competencia para ello.</p><p style=\"text-indent: 2em;\">Ante el recurso de la universidad demandada la Corte declaró inoficioso un pronunciamiento del Tribunal.</p><p style=\"text-indent: 2em;\">Consideró que en ninguno de los pronunciamientos de las instancias anteriores se había tenido en cuenta que el Consejo Superior resolvió la impugnación planteada en sede administrativa mientras se encontraba en trámite el proceso por lo cual, si bien al momento de iniciarse el amparo existía una situación de urgencia que tornaba necesaria la restitución inmediata de los derechos que el actor alegó que habían sido conculcados, no podía soslayarse que, una vez que se dictó la resolución rechazando el recurso jerárquico interpuesto por el actor, se habían tornado abstractas las cuestiones planteadas. Agregó que aquel acto - que importaba el agotamiento de la vía administrativa- debía ser necesariamente impugnado empleando el remedio procesal que se considerara pertinente.</p><p style=\"text-indent: 2em;\">Asimismo, por aplicación de la doctrina establecida en el precedente \"Peso\" (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=307&amp;pagina=2061\">307:2061</a>) el Tribunal entendió que correspondía revocar la sentencia recurrida.</p>","esNovedad":true,"fecha":1713236400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1713361154992,"usuarioCreacion":4,"fechaCreacion":1713361152856,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":119010,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31863764,"numeroExpediente":52513,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":27,"codigo":"27","abreviatura":"FTU","descripcion":"Justicia Federal de Tucuman","estado":0,"descripcionLarga":"FTU - Justicia Federal de Tucuman"},"objetoJuicio":{"id":4417,"descripcion":"ACCION DE AMPARO LEY 16986 C/CAUTELAR","idMateria":112,"tema":{"id":280,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 3 - VIALE, CARLOS ALBERTO c/ UNIVERSIDAD NACIONAL DE CATAMARCA (UNCA) s/ACCION DE AMPARO LEY 16986 