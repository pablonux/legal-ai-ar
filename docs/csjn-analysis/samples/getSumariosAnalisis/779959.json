[{"id":159745,"orden":1,"ordenRecurso":null,"voces":"CONSOLIDACION DE DEUDAS - INTERESES - COMPUTO DE LOS INTERESES - ORDEN PUBLICO - SENTENCIA ARBITRARIA","texto":"<p>Cabe revocar la sentencia que condenó la Banco Central al pago de la indemnización por despido con intereses conforme a la tasa activa del Banco de la Nación Argentina, pues las disposiciones del régimen de consolidación del pasivo estatal devienen de inexcusable aplicación habida cuenta de su carácter de orden público, razón por la cual el tribunal anterior en grado debió ordenar el cómputo de los intereses de la sentencia hasta la fecha de corte de la ley 25.344 -atento a que la causa o título de la obligación (el distracto) es anterior a ella- y no hasta el efectivo pago (artículos 6° y 16 de la ley 23.982, a los que remite el artículo 13 de la ley 25.344 y artículo 13 del decreto 1116/2000), pues a partir de la consolidación -que opera de pleno derecho después del reconocimiento judicial firme del crédito-, se produce la novación de la obligación originaria y de cualquiera de sus accesorios, por lo que solo subsisten para el acreedor los derechos derivados de la consolidación (artículo 17 de la ley 23.982).</p><p>-El juez Lorenzetti, en disidencia, consideró inadmisible el recurso extraordinario (art. 280 CPCCN)-</p>","fullText":"<XML><VOCES>CONSOLIDACION DE DEUDAS - INTERESES - COMPUTO DE LOS INTERESES - ORDEN PUBLICO - SENTENCIA ARBITRARIA</VOCES><TEXTO>Cabe revocar la sentencia que condenó la Banco Central al pago de la indemnización por despido con intereses conforme a la tasa activa del Banco de la Nación Argentina, pues las disposiciones del régimen de consolidación del pasivo estatal devienen de inexcusable aplicación habida cuenta de su carácter de orden público, razón por la cual el tribunal anterior en grado debió ordenar el cómputo de los intereses de la sentencia hasta la fecha de corte de la ley 25.344 -atento a que la causa o título de la obligación (el distracto) es anterior a ella- y no hasta el efectivo pago (artículos 6° y 16 de la ley 23.982, a los que remite el artículo 13 de la ley 25.344 y artículo 13 del decreto 1116/2000), pues a partir de la consolidación -que opera de pleno derecho después del reconocimiento judicial firme del crédito-, se produce la novación de la obligación originaria y de cualquiera de sus accesorios, por lo que solo subsisten para el acreedor los derechos derivados de la consolidación (artículo 17 de la ley 23.982).-El juez Lorenzetti, en disidencia, consideró inadmisible el recurso extraordinario (art. 280 CPCCN)-</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1667876400000,"tomo":345,"pagina":1266,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":2,"holding":0,"linksCitantes":null,"numeroID":6887,"anioFallo":2022,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1029,"codigoRelacion":101029,"valor":"CONSOLIDACION DE DEUDAS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202211081638,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":2233,"codigoRelacion":102233,"valor":"INTERESES","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMig