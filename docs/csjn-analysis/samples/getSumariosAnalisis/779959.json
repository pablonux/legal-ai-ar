ión Argentina para sus operaciones comunes de descuento desde la fecha del distracto hasta la del efectivo pago. Recurrida la sentencia la Corte, por mayoría, modificó el pronunciamiento al considerar que, siendo aplicable en el caso el régimen de consolidación, se debió ordenar el cómputo de los intereses de la sentencia hasta la fecha de corte de la ley 25.344 y no hasta el efectivo pago. Agregó que a partir de la consolidación -que opera de pleno derecho después del reconocimiento judicial firme del crédito-, se produce la novación de la obligación originaria y de cualquiera de sus accesorios, por lo que solo subsisten para el acreedor los derechos derivados de la consolidación.</p>","esNovedad":true,"fecha":1667876400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1668002663217,"usuarioCreacion":11,"fechaCreacion":1667935523776,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":105052,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":15749812,"numeroExpediente":13043076,"anioExpediente":1994,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":13,"codigo":"13","abreviatura":"FBB","descripcion":"Justicia Federal de Bahia Blanca","estado":0,"descripcionLarga":"FBB - Justicia Federal de Bahia Blanca"},"objetoJuicio":{"id":3560,"descripcion":"RECLAMOS VARIOS","idMateria":112,"tema":{"id":208,"codigo":"LABORAL"}},"caratula":"CORAZZA, SILVIA GLADYS c/ BANCO CENTRAL DE LA REPUBLICA ARGENTINA s/RECLAMOS VARIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"13043076. "},"recurso":{"id":5104701,"expediente":{"id":15749812,"numeroExpediente":13043076,"anioExpediente":1994,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":13,"codigo":"13","abreviatura":"FBB","descripcion":"Justicia F