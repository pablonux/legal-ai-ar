[{"id":148831,"orden":1,"ordenRecurso":null,"voces":"DESAPARICION FORZADA DE PERSONAS - INTERPRETACION DE LA LEY  - PRUEBA","texto":"Corresponde dejar sin efecto la sentencia que denegó el beneficio previsto en la ley 24.043 si un examen conjunto de las pruebas producidas a la luz del criterio amplio de interpretación que debe ser utilizado para este tipo de reclamaciones llevaba a la conclusión de que concurrían los presupuestos para acceder al mismo, ya que el actor probó el vínculo con su padre - a quien la alzada concedió dicho beneficio-, que siendo menor de edad permaneció fuera del país durante el período previsto en el régimen jurídico aplicable y la persecución política de su grupo familiar.","fullText":"<XML><VOCES>DESAPARICION FORZADA DE PERSONAS - INTERPRETACION DE LA LEY  - PRUEBA</VOCES><TEXTO>Corresponde dejar sin efecto la sentencia que denegó el beneficio previsto en la ley 24.043 si un examen conjunto de las pruebas producidas a la luz del criterio amplio de interpretación que debe ser utilizado para este tipo de reclamaciones llevaba a la conclusión de que concurrían los presupuestos para acceder al mismo, ya que el actor probó el vínculo con su padre - a quien la alzada concedió dicho beneficio-, que siendo menor de edad permaneció fuera del país durante el período previsto en el régimen jurídico aplicable y la persecución política de su grupo familiar.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1503975600000,"tomo":340,"pagina":1144,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":4035,"anioFallo":2017,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1546,"codigoRelacion":101546,"valor":"DESAPARICION FORZADA DE PERSONAS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fech