n":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":230004,"valor":"RECURSO DE REVOCATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"BARRERA LEMA, CRISTIAN IVAN c/ CESMAR SRL s/ DESPIDO","alias":null,"caratula":"BARRERA LEMA, CRISTIAN IVAN c/ CESMAR SRL s/DESPIDO","inconstitucional":false,"falloDestacado":{"id":5262,"titulo":"Recurso de queja extemporáneo e invocación de festividades religiosas","cabecilla":"<p>Ante la anterior sentencia de la Corte que había declarado extemporánea la queja interpuesta el recurrente planteó una revocatoria. Sostuvo que había presentado su recurso tardíamente por motivos vinculados con la religión que profesa, ya que en esos días se celebraba una de las festividades más importantes. El Tribunal desestimó lo solicitado recordando que sus sentencias definitivas e interlocutorias no son susceptibles de ser modificadas por la vía intentada. Consideró que tampoco se configuraba una circunstancia excepcional en tanto las razones dadas para justificar la extemporaneidad de la presentación del recurso no habían sido oportunamente invocadas al momento de su articulación, aludiéndose allí a que el mismo se interponía “en tiempo y forma”, sino solo al deducirse el pedido de revocatoria, por lo que resultaban claramente el fruto de reflexiones tardías.</p>","esNovedad":true,"fecha":1681354800000,"rel