[{"id":160734,"orden":1,"ordenRecurso":null,"voces":"RECURSO DE QUEJA - RECURSO DE REPOSICION O REVOCATORIA - PLAZO PARA INTERPONER EL RECURSO","texto":"<p>Resulta extemporánea la queja interpuesta fuera de su plazo pues, las razones dadas para justificar la extemporaneidad de la presentación del recurso de hecho (motivos vinculados con la religión que profesa en cuyo marco se celebraba en esos días una de las festividades más importantes)  no fueron oportunamente invocadas al momento de su articulación sino solo al deducirse el pedido de revocatoria por lo que resultan claramente el fruto de reflexiones tardías.</p><p> </p>","fullText":"<XML><VOCES>RECURSO DE QUEJA - RECURSO DE REPOSICION O REVOCATORIA - PLAZO PARA INTERPONER EL RECURSO</VOCES><TEXTO>Resulta extemporánea la queja interpuesta fuera de su plazo pues, las razones dadas para justificar la extemporaneidad de la presentación del recurso de hecho (motivos vinculados con la religión que profesa en cuyo marco se celebraba en esos días una de las festividades más importantes)  no fueron oportunamente invocadas al momento de su articulación sino solo al deducirse el pedido de revocatoria por lo que resultan claramente el fruto de reflexiones tardías. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1681354800000,"tomo":346,"pagina":254,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":1,"holding":0,"linksCitantes":null,"numeroID":1461,"anioFallo":2023,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3200,"codigoRelacion":103200,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigra