[{"id":161713,"orden":1,"ordenRecurso":null,"voces":"COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA - CIUDAD AUTONOMA DE BUENOS AIRES - ELECCIONES - CUESTION DE DERECHO LOCAL - LEYES LOCALES","texto":"<p>Es ajena a la competencia originaria la acción declarativa de certeza iniciada contra la Ciudad Autónoma de Buenos Aires a fin que de se declare que un precandidato a jefe de gobierno local no reúne los requisitos establecidos por el artículo 97 de la Constitución de la Ciudad Autónoma de Buenos Aires por no ser nativo de esa ciudad ni cumplir con los años de residencia habitual y permanente anteriores a la fecha de elección, toda vez que no se configura una cuestión federal predominante, ya que el pleito exige en forma ineludible interpretar cláusulas constitucionales de la ciudad mencionada vinculadas con las condiciones requeridas para ser electo como titular del Poder Ejecutivo local, asunto que concierne a su procedimiento jurídico político de organización, es decir, a un conjunto de actos que deben nacer, desarrollarse y tener cumplimiento dentro del ámbito estrictamente local. </p>","fullText":"<XML><VOCES>COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA - CIUDAD AUTONOMA DE BUENOS AIRES - ELECCIONES - CUESTION DE DERECHO LOCAL - LEYES LOCALES</VOCES><TEXTO>Es ajena a la competencia originaria la acción declarativa de certeza iniciada contra la Ciudad Autónoma de Buenos Aires a fin que de se declare que un precandidato a jefe de gobierno local no reúne los requisitos establecidos por el artículo 97 de la Constitución de la Ciudad Autónoma de Buenos Aires por no ser nativo de esa ciudad ni cumplir con los años de residencia habitual y permanente anteriores a la fecha de elección, toda vez que no se configura una cuestión federal predominante, ya que el pleito exige en forma ineludible interpretar cláusulas constitucionales de la ciudad mencionada vinculadas con las condiciones requeridas para ser electo como titular del Poder Ejecutivo local, asunto que concierne a su procedimiento jurídico político de organización, es decir, a un conjunto de actos que deben nacer, desarrollarse y tener cumplimiento dentro del ámbito estrictamente local. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1689044400000,"tomo":346,"pagina":745,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":6,"holding":0,"linksCitantes":null,"numeroID":3886,"anioFallo":2023,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":966,"codigoRelacion":100966,"valor":"COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202307111230,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":888,"codigoRelacion":100888,"valor":"CIUDAD AUTONOMA DE BUENOS AIRES","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202307111230,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":1645,"codigoRelacion":101645,"valor":"ELECCIONES","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"f