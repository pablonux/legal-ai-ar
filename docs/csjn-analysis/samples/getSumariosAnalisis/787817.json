visible":null},"orden":1}],"datosUsuarioCreacion":"20290388849"}}],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7878171,"analisisDocumental":{"id":787817,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":24,"codigoRelacion":80024,"valor":"DECLARA NULIDAD","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201011041306,"fechaModLong":201011041306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - DE TOMASO, DANIEL ANTONIO JESUS Y OTRO c/ ESTADO NACIONAL- INSTITUTO NACIONAL DE INVESTIGACION Y DESARROLLO PESQUERO s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":5845,"titulo":"Control de oficio del desarrollo del procedimiento cuando se encuentra involucrado el orden público","cabecilla":"<p>Empleados del Instituto Nacional de Investigación y Desarrollo Pesquero (INIDEP) promovieron una acción de amparo tendiente a que se declare la invalidez del convenio suscripto entre dicho organismo y la Prefectura Naval Argentina con el objeto de que personal de esa fuerza de seguridad asumiera diversos roles de un buque de investigación pesquera. La cámara admitió el pedido y ordenó al demandado que dejara sin efecto el convenio cuestionado, lo que originó la interposición de un recurso extraordinario por parte de este último. La Corte, <b>haciendo uso de sus facultades de excepción en procura de la debida salvaguarda de las garantías constitucionales</b> anuló las actuaciones. Advirtió que, a pesar de que la acción tenía por objeto que se declarara la inaplicabilidad del convenio suscripto entre el INIDEP y la Prefectura Naval Argentina, únicamente había sido traído al proceso como parte demandada el primero, sin haber dado oportunidad a dicha fuerza de seguridad a ejercer su derecho de defensa en juicio. Agregó que dicha omisión no podía justificarse mediante la invocación del principio de unidad de la hacienda estatal, pues el instituto mencionado no puede identificarse con el Estado Nacional por haber sido creado como un ente descentralizado.</p>","esNovedad":true,"fecha":1693969200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1694034784439,"usuarioCreacion":11,"fechaCreacion":1694033802895,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":113722,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35119949,"numeroExpediente":31926,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":8765,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":380,"codigo":"AMPAROS"}},"caratula":"Recurso Queja Nº 1 - DE TOMASO, DANIEL ANTONIO JESUS Y OTRO c/ ESTADO NACIONAL- INSTITUTO NACIONAL DE INVESTIGACION Y DESARROLLO PESQUERO s/AM