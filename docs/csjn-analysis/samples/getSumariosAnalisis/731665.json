[{"id":147688,"orden":1,"ordenRecurso":null,"voces":"RECURSOS LOCALES  - DEBIDO PROCESO - RECURSO EXTRAORDINARIO","texto":"Si bien las decisiones que declaran la improcedencia de los recursos locales deducidos por ante los tribunales de la causa no justifican el otorgamiento de la apelación extraordinaria -en razón del carácter fáctico y procesal de las cuestiones que suscitan-, cabe hacer excepción cuando lo resuelto conduce a una restricción sustancial de la vía utilizada por el apelante sin fundamentación idónea o suficiente, lo que se traduce en una violación de la garantía del debido proceso consagrada en el art. 18 de la Constitución Nacional. ","fullText":"<XML><VOCES>RECURSOS LOCALES  - DEBIDO PROCESO - RECURSO EXTRAORDINARIO</VOCES><TEXTO>Si bien las decisiones que declaran la improcedencia de los recursos locales deducidos por ante los tribunales de la causa no justifican el otorgamiento de la apelación extraordinaria -en razón del carácter fáctico y procesal de las cuestiones que suscitan-, cabe hacer excepción cuando lo resuelto conduce a una restricción sustancial de la vía utilizada por el apelante sin fundamentación idónea o suficiente, lo que se traduce en una violación de la garantía del debido proceso consagrada en el art. 18 de la Constitución Nacional. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1467082800000,"tomo":339,"pagina":864,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":3991,"anioFallo":2016,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3948,"codigoRelacion":103948,"valor":"RECURSOS LOCALES ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201010200858,"fechaModLong":201010200858,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201608041207,"usuarioModificacion":null,"fechaModificacion":201608041207},{"tipoVoz":{"codigoTabla":null,