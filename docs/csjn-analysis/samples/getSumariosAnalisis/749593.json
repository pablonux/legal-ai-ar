[{"id":150237,"orden":1,"ordenRecurso":null,"voces":"ACCIDENTES DEL TRABAJO - INTERPRETACION DE LA LEY","texto":"<p>Con solo atenerse a la literalidad del art. 3° de la ley 26.773 y sin necesidad de hacer un mayor esfuerzo intelectivo, es posible concluir que la intención del legislador plasmada en la norma ha sido la de circunscribir el beneficio a los infortunios laborales producidos u originados en el ámbito del establecimiento laboral y no a los accidentes in itinere. - Del precedente \"Páez Alfonzo\" al que la Corte remite-.</p>","fullText":"<XML><VOCES>ACCIDENTES DEL TRABAJO - INTERPRETACION DE LA LEY</VOCES><TEXTO>Con solo atenerse a la literalidad del art. 3° de la ley 26.773 y sin necesidad de hacer un mayor esfuerzo intelectivo, es posible concluir que la intención del legislador plasmada en la norma ha sido la de circunscribir el beneficio a los infortunios laborales producidos u originados en el ámbito del establecimiento laboral y no a los accidentes in itinere. - Del precedente \"Páez Alfonzo\" al que la Corte remite-.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1549940400000,"tomo":342,"pagina":49,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":0,"linksCitantes":null,"numeroID":178,"anioFallo":2019,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":463,"codigoRelacion":100463,"valor":"ACCIDENTES DEL TRABAJO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201902211153,"usuarioModificacion":null,"fechaModificacion":201902211153},{"tipoVoz":{"codigoTabla":null,"codigoValor":4187,"codigoRelacion":104187,"valor":"INTERPRETACION DE LA LEY ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201203220933,"fechaModLong":201203220933,"orden":null,"visible":null},"orden":2,"usuari