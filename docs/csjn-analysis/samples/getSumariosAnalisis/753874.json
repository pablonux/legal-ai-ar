[{"id":150945,"orden":1,"ordenRecurso":null,"voces":"RECURSOS - DEFENSA EN JUICIO - EXCESO RITUAL MANIFIESTO - RESOLUCION ADMINISTRATIVA","texto":"Si bien las cuestiones sobre la admisibilidad de los recursos judiciales contra decisiones administrativas -por su naturaleza fáctica y procesal- son propias de los jueces de la causa, debe hacer excepción a dicha regla cuando el examen de las condiciones a las que está supeditada la presentación de una apelación es efectuado con injustificado rigorismo formal, afectando de modo irremediable el derecho de defensa en juicio. ","fullText":"<XML><VOCES>RECURSOS - DEFENSA EN JUICIO - EXCESO RITUAL MANIFIESTO - RESOLUCION ADMINISTRATIVA</VOCES><TEXTO>Si bien las cuestiones sobre la admisibilidad de los recursos judiciales contra decisiones administrativas -por su naturaleza fáctica y procesal- son propias de los jueces de la causa, debe hacer excepción a dicha regla cuando el examen de las condiciones a las que está supeditada la presentación de una apelación es efectuado con injustificado rigorismo formal, afectando de modo irremediable el derecho de defensa en juicio. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1567479600000,"tomo":342,"pagina":1456,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":4447,"anioFallo":2019,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3332,"codigoRelacion":103332,"valor":"RECURSOS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201909231627,"usuarioModificacion":null,"fechaModificacion":201909231627},{"tipoVoz":{"codigoTabla":null,"codigoValor":1346,"codigoRelacion":101346,"valor":"DEFENSA EN JUICIO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLon