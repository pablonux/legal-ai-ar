[{"id":147129,"orden":1,"ordenRecurso":null,"voces":"UNIVERSIDAD - AUTONOMIA UNIVERSITARIA","texto":"Una interpretación razonable y armónica de la ley permite concluir que la prohibición que surge del art. 53, inc. d) de la ley 24.521 de Educación Superior solo se dirige a limitar la participación en los órganos de gobierno de los graduados en relación de dependencia con la universidad, a los fines de la representación de su claustro en el carácter que les es propio, esto es, el de graduados, pero nada dice respecto del agrupamiento de los representantes de diferentes estamentos y la conformación de los padrones, cuestiones previstas por las normas impugnadas del estatuto (arts. 88, inc. 4° y 94, 2° párrafo).\r\n","fullText":"<XML><VOCES>UNIVERSIDAD - AUTONOMIA UNIVERSITARIA</VOCES><TEXTO>Una interpretación razonable y armónica de la ley permite concluir que la prohibición que surge del art. 53, inc. d) de la ley 24.521 de Educación Superior solo se dirige a limitar la participación en los órganos de gobierno de los graduados en relación de dependencia con la universidad, a los fines de la representación de su claustro en el carácter que les es propio, esto es, el de graduados, pero nada dice respecto del agrupamiento de los representantes de diferentes estamentos y la conformación de los padrones, cuestiones previstas por las normas impugnadas del estatuto (arts. 88, inc. 4° y 94, 2° párrafo).\r\n</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1455591600000,"tomo":339,"pagina":115,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":231,"anioFallo":2016,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3794,"codigoRelacion":103794,"valor":"UNIVERSIDAD","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"f