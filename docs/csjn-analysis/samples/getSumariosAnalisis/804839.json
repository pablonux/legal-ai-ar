[{"id":169534,"orden":1,"ordenRecurso":null,"voces":"SUPERINTENDENCIA - RECURSO EXTRAORDINARIO","texto":"<p>Es inadmisible el recurso extraordinario interpuesto contra la resolución de la cámara que sancionó a un perito, pues la decisión del tribunal ha sido dictada en actuaciones de superintendencia que no constituyen -como regla- el juicio al que se refiere el art. 14 de la ley 48, ni se advierte que por ese medio se vulnere en forma irreparable derecho federal alguno, en tanto el apelante omitió demostrar que la resolución administrativa no es susceptible de revisión por las vías legales pertinentes.</p>","fullText":"<XML><VOCES>SUPERINTENDENCIA - RECURSO EXTRAORDINARIO</VOCES><TEXTO>Es inadmisible el recurso extraordinario interpuesto contra la resolución de la cámara que sancionó a un perito, pues la decisión del tribunal ha sido dictada en actuaciones de superintendencia que no constituyen -como regla- el juicio al que se refiere el art. 14 de la ley 48, ni se advierte que por ese medio se vulnere en forma irreparable derecho federal alguno, en tanto el apelante omitió demostrar que la resolución administrativa no es susceptible de revisión por las vías legales pertinentes.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1733972400000,"tomo":347,"pagina":2001,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":1,"holding":0,"linksCitantes":null,"numeroID":11871,"anioFallo":2024,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3633,"codigoRelacion":103633,"valor":"SUPERINTENDENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653",