mites iniciados ante el SECLO con anterioridad a esa fecha agotaba la instancia administrativa -&nbsp;Sentencia que instaba a la demandante a transitar una nueva instancia administrativa ante las comisiones m&eacute;dicas, sin ponderar que ya hab&iacute;a agotado el procedimiento ante el SECLO y ten&iacute;a expedita la v&iacute;a judicial - Exceso de rigor formal que no guarda relaci&oacute;n con las constancias de la causa y la normativa aplicable - Sentencia arbitraria - Se revoca la sentencia apelada.&nbsp;</p>","esNovedad":true,"fecha":1622689200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1623090629364,"usuarioCreacion":11,"fechaCreacion":1622806665486,"privado":false,"posicion":null,"resumen":null},"reciboEntrada":{"id":31062,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":31990024,"numeroExpediente":64495,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9701,"descripcion":"ACCIDENTE - LEY ESPECIAL","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - BALLESTEROS, GABRIELA VERONICA c/ EXPERTA ART S.A. s/ACCIDENTE - LEY ESPECIAL","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"64495. "},"recurso":{"id":5349839,"expediente":{"id":31990024,"numeroExpediente":64495,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9701,"descripcion":"ACCIDENTE - LEY ES