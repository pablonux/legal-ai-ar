n":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":4507,"codigoRelacion":104507,"valor":"DEFECTOS EN LA CONSIDERACION DE EXTREMOS CONDUCENTES","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201509021047,"fechaModLong":201509021047,"orden":null,"visible":null},"orden":7,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202503271549,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":8070051,"analisisDocumental":{"id":807005,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - BLANCO, ADRIAN ALBERTO c/ IBM ARGENTINA S.R.L. s/DESPIDO","inconstitucional":false,"falloDestacado":{"id":8461,"titulo":"Arbitrariedad en el rechazo de la homologación de un acuerdo conciliatorio con el trabajador","cabecilla":"<p style=\"text-indent: 2em;\">La Cámara Nacional de Apelaciones del Trabajo desestimó el acuerdo conciliatorio presentado en esa instancia y elevó el monto de condena e intereses dispuestos en la sentencia de grado. Indicó que el acuerdo no representaba una justa composición de los derechos e intereses del trabajador despedido sin causa y que, de confirmarse la sentencia de primera instancia, el monto de capital e intereses hubiese alcanzado a esa fecha una suma más elevada.</p><p style=\"text-indent: 2em;\">Ante el recurso interpuesto por la empresa demandada la Corte dejó sin efecto este pronunciamiento.</p><p style=\"text-indent: 2em;\">Consideró que el fundamento central utilizado para rechazar la homologación resultaba inconsistente con las constancias de la causa. Efectivamente, la sentencia había tomado como base de cálculo un capital más elevado que el de condena, ya que no contempló la deducción de lo percibido por el actor y expresamente descontado por la jueza de grado. Así, arribó a una cifra errónea que vaciaba de contenido su argumento ya que, de haber calculado la tasa acumulada sobre el capital neto, la suma hubiese resultado inferior a la del acuerdo.</p><p style=\"text-indent: 2em;\">Es decir, la cámara consideró que el acuerdo resultaba injusto porque el monto era inferior al monto de condena de primera instancia, cuando en realidad la cifra de lo acordado resultaba superior, lo que evidenciaba el carácter esencial del error cometido.</p>","esNovedad":true,"fecha":1743044400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1743105894397,"usuarioCreacion":4,"fechaCreacion":1743105892531,"privado":false,"posicion":2,"resumen":{"idResumen":119,"resumen":"La Corte revocó la decisión de la Cámara, que había rechazado un acuerdo conciliatorio por considerarlo inferior al monto de condena. La Corte determinó que la Cámara calculó erróneamente el monto de condena, lo que invalidaba su argumento para rechazar el acuerdo.","tituloTraducido":null,"traduccion":null}},"reciboEntrada":{"id":134518,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37578806,"numeroExpediente":48854,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - BLANCO, ADRIAN ALBERTO c/ IBM ARGENTINA S.R.L. s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"48854. "},"recurso":{"id":6522207,"expediente":{"id":37578806,"numeroExpediente":48854,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - BLANCO, ADRIAN ALBERTO c/ IBM ARGENTINA S.R.L. s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"48854. "},"tipoRecurso":{"id":1182,"codigo":"RHX","