[{"id":151318,"orden":1,"ordenRecurso":null,"voces":"SENTENCIA ARBITRARIA - VALORACION DE CIRCUNSTANCIAS DE HECHO Y PRUEBA","texto":"Si bien la apreciación de elementos de hecho y prueba constituye, como principio, facultad propia de los jueces de la causa y no es susceptible de revisión en la instancia extraordinaria, esta regla no es óbice para que el Tribunal conozca en los casos cuyas particularidades hacen excepción a ella cuando la decisión impugnada no se ajusta al principio que exige que las sentencias sean fundadas y constituyan una derivación razonada del derecho vigente con aplicación a las circunstancias probadas de la causa. ","fullText":"<XML><VOCES>SENTENCIA ARBITRARIA - VALORACION DE CIRCUNSTANCIAS DE HECHO Y PRUEBA</VOCES><TEXTO>Si bien la apreciación de elementos de hecho y prueba constituye, como principio, facultad propia de los jueces de la causa y no es susceptible de revisión en la instancia extraordinaria, esta regla no es óbice para que el Tribunal conozca en los casos cuyas particularidades hacen excepción a ella cuando la decisión impugnada no se ajusta al principio que exige que las sentencias sean fundadas y constituyan una derivación razonada del derecho vigente con aplicación a las circunstancias probadas de la causa. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1570503600000,"tomo":342,"pagina":1644,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":5278,"anioFallo":2019,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3532,"codigoRelacion":103532,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":202003031556,"usuarioModificacion":null,"fechaModificacion":202003031556},{"tipoVoz":{"codigoTabla":null,"codigoValor":4485,"co