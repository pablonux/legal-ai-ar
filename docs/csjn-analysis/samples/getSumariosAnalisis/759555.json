l-sm-8'>ROSENKRANTZ</div><div class='col-xs-3 col-sm-4 nroPagina'><i style='float: right; text-align: right'>p. 5</i></div></div><div class='row'><div class='col-xs-9 col-sm-8'>ROSATTI</div></div><div class='row'><div class='col-xs-12'><i style='font-size: 13px;'>(disidencia)</i></div></div></div></div>"},"usuarioModificacion":null,"usuarioModificacionOld":"SJC653","fechaModificacion":202009111022,"usuarioCreacion":null,"usuarioCreacionOld":"SJC653","fechaCreacion":202009111022,"caratulaLex":"Recurso Queja Nº 1 - OCAMPO ALESSIO MATIAS YAIR c/ BGH S.A. s/DESPIDO","autos":"Ocampo, Alessio Matías Yair c/ BGH S.A. s/ despido ","tieneDocumento":true,"linkDocumento":"/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7595551&cache=1777035119074","tieneDictamenes":false,"conAnalisis":true,"conAnalisisPrivado":false,"conVotos":true,"caratulaWeb":"Ocampo, Alessio Matías Yair c/ BGH S.A. s/ despido ","numeroExpediente":"CNT 046778/2014/1/RH001","sentenciaArbitraria":true,"inconstitucional":false,"alias":null,"stringVotosMayoria":"","stringVotosVoto":"","stringVotosDisidencia":"","stringVotosDisidenciaParcial":"","stringVotosAbstencion":"","textoResaltado":"Si bien el remedio federal remite al examen de cuestiones de derecho común que, en principio, no son susceptibles de revisión por la vía prevista en el artículo 14 de la ley 48, cabe hacer excepción a tal premisa cuando la sentencia apelada se apoya en meras consideraciones dogmáticas y prescinde de dar un tratamiento adecuado a la controversia de conformidad con las normas aplicables.","vocesResaltadas":"RECURSO EXTRAORDINARIO - CUESTION DE DERECHO COMUN  - SENTENCIA ARBITRARIA","desvinculado":false,"fechaString":"10/09/2020","stringVotosAnalisis":""},{"id":152097,"orden":2,"ordenRecurso":null,"voces":"DESPIDO - INDEMNIZACION - EXTINCION DEL CONTRATO DE TRABAJO  - ACUERDO - HOMOLOGACION - SENTENCIA ARBITRARIA","texto":"Es arbitraria la sentencia que hizo lugar al reclamo de indemnizaciones por despido promovido por el trabajador con posterioridad a la extinción de su contrato por mutuo acuerdo (art. 241 de la LCT), pues no se discute que el trabajador en forma personal, y la empleadora, mediante su representante legal, celebraron un acuerdo de extinción de la relación laboral ante un escribano público, en los términos del aludido artículo; de ahí que no constituya derivación razonada del derecho vigente la exigencia de la homologación administrativa o judicial de lo convenido en tanto ese requisito no se encuentra contemplado en la norma, que solo la exige para los supuestos de acuerdos transaccionales, conciliatorios o liberatorios cuando se realicen con intervención de la autoridad judicial o administrativa\" (art. 15 LCT).\r\n- Los jueces Rosenkrantz y Rosatti, en disidencia, consideraron que la queja no había cumplido con los requisitos exigidos en el art. 4° del reglamento aprobado por la acordada 4/2007-.\r\n\r\n","fullText":"<XML><VOCES>DESPIDO - INDEMNIZACION - EXTINCION DEL CONTRATO DE TRABAJO  - ACUERDO - HOMOLOGACION - SENTENCIA ARBITRARIA</VOCES><TEXTO>Es arbitraria la sentencia que hizo lugar al reclamo de indemnizaciones por despido promovido por el trabajador con posterioridad a la extinción de su contrato por mutuo acuerdo (art. 241 de la LCT), pues no se discute que el trabajador en forma personal, y la empleadora, mediante su representante legal, celebraron un acuerdo de extinción de la relación laboral ante un escribano público, en los términos del aludido artículo; de ahí que no constituya derivación razonada del derecho vigente la exigencia de la homologación administrativa o judicial de lo convenido en tanto ese requisito no se encuentra contemplado en la norma, que solo la exige para los supuestos de acuerdos transaccionales, conciliatorios o liberatorios cuando se realicen con intervención de la autoridad judicial o administrativa\" (art. 15 LCT).\r\n- Los jueces Rosenkrantz y Rosatti, en disidencia, consideraron que la queja no había cumplido con los requisitos exigidos en el art. 4° del reglamento aprobado por la acordada 4/2007-.\r\n\r\n</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1599706800000,"tomo":343,"pagina":947,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":2419,"anioFallo":2020,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1559,"codigoRelacion":101559,"valor":"DESPIDO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":202009111025,"usuarioModificacion":null,"fechaModificacion":202009111025},{"tipoVoz":{"codigoTabla":null,"codigoValor":2140,"codigoRelacion":102140,"valor":"INDEMNIZACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":null,"fechaCreacion":202009111025,"usuarioModificacion":null,"fechaModificacion":202009111025},{"tipoVoz":{"codigoTabla":null,"codigoValor":4136,"codigoRelacion":104136,"valor":"EXTINCION DEL CONTRATO DE TRABAJO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201112131047,"fechaModLong":201112131047,"orden":null,"visible":null},"orden":3,"usuarioCreacion":null,"fechaCreacion":202009111025,"usuarioModificacion":null,"fechaModificacion":202009111025},{"tipoVoz":{"codigoTabla":null,"codigoValor":4629,"codigoRelacion":104629,"valor":"ACUERDO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR0V0","fechaCreacionLong":201510151015,"fechaModLong":201903131440,"orden":null,"visible":null},"orden":4,"usuarioCreacion":null,"fechaCreacion":202009111025,"usuarioModificacion":null,"fechaModificacion":202009111025},{"tipoVoz":{"codigoTabla":null,"codigoValor":2047,"codigoRelacion":102047,"valor":"HOMOLOGACION","activo":"S","usuarioCr