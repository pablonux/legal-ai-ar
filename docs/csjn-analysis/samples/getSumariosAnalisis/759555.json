nel-danger' onclick='irAPagina(5)' style='padding: 2px; margin-bottom: 10px;'><div class='panel-body voto btn-link'><div class='row'><div class='col-xs-9 col-sm-8'>ROSENKRANTZ</div><div class='col-xs-3 col-sm-4 nroPagina'><i style='float: right; text-align: right'>p. 5</i></div></div><div class='row'><div class='col-xs-9 col-sm-8'>ROSATTI</div></div><div class='row'><div class='col-xs-12'><i style='font-size: 13px;'>(disidencia)</i></div></div></div></div>"},"usuarioModificacion":null,"usuarioModificacionOld":"SJC653","fechaModificacion":202009111025,"usuarioCreacion":null,"usuarioCreacionOld":"SJC653","fechaCreacion":202009111025,"caratulaLex":"Recurso Queja Nº 1 - OCAMPO ALESSIO MATIAS YAIR c/ BGH S.A. s/DESPIDO","autos":"Ocampo, Alessio Matías Yair c/ BGH S.A. s/ despido ","tieneDocumento":true,"linkDocumento":"/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7595551&cache=1777035119078","tieneDictamenes":false,"conAnalisis":true,"conAnalisisPrivado":false,"conVotos":true,"caratulaWeb":"Ocampo, Alessio Matías Yair c/ BGH S.A. s/ despido ","numeroExpediente":"CNT 046778/2014/1/RH001","sentenciaArbitraria":true,"inconstitucional":false,"alias":null,"stringVotosMayoria":"","stringVotosVoto":"","stringVotosDisidencia":"","stringVotosDisidenciaParcial":"","stringVotosAbstencion":"","textoResaltado":"Es arbitraria la sentencia que hizo lugar al reclamo de indemnizaciones por despido promovido por el trabajador con posterioridad a la extinción de su contrato por mutuo acuerdo (art. 241 de la LCT), pues no se discute que el trabajador en forma personal, y la empleadora, mediante su representante legal, celebraron un acuerdo de extinción de la relación laboral ante un escribano público, en los términos del aludido artículo; de ahí que no constituya derivación razonada del derecho vigente la exigencia de la homologación administrativa o judicial de lo convenido en tanto ese requisito no se encuentra contemplado en la norma, que solo la exige para los supuestos de acuerdos transaccionales, conciliatorios o liberatorios cuando se realicen con intervención de la autoridad judicial o administrativa\" (art. 15 LCT).\r\n- Los jueces Rosenkrantz y Rosatti, en disidencia, consideraron que la queja no había cumplido con los requisitos exigidos en el art. 4° del reglamento aprobado por la acordada 4/2007-.\r\n\r\n","vocesResaltadas":"DESPIDO - INDEMNIZACION - EXTINCION DEL CONTRATO DE TRABAJO  - ACUERDO - HOMOLOGACION - SENTENCIA ARBITRARIA","desvinculado":false,"fechaString":"10/09/2020","stringVotosAnalisis":""}]
