[{"id":152096,"orden":1,"ordenRecurso":null,"voces":"RECURSO EXTRAORDINARIO - CUESTION DE DERECHO COMUN  - SENTENCIA ARBITRARIA","texto":"Si bien el remedio federal remite al examen de cuestiones de derecho común que, en principio, no son susceptibles de revisión por la vía prevista en el artículo 14 de la ley 48, cabe hacer excepción a tal premisa cuando la sentencia apelada se apoya en meras consideraciones dogmáticas y prescinde de dar un tratamiento adecuado a la controversia de conformidad con las normas aplicables.","fullText":"<XML><VOCES>RECURSO EXTRAORDINARIO - CUESTION DE DERECHO COMUN  - SENTENCIA ARBITRARIA</VOCES><TEXTO>Si bien el remedio federal remite al examen de cuestiones de derecho común que, en principio, no son susceptibles de revisión por la vía prevista en el artículo 14 de la ley 48, cabe hacer excepción a tal premisa cuando la sentencia apelada se apoya en meras consideraciones dogmáticas y prescinde de dar un tratamiento adecuado a la controversia de conformidad con las normas aplicables.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1599706800000,"tomo":343,"pagina":947,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":2419,"anioFallo":2020,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3210,"codigoRelacion":103210,"valor":"RECURSO EXTRAORDINARIO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":202009111022,"usuarioModificacion":null,"fechaModificacion":202009111022},{"tipoVoz":{"codigoTabla":null,"codigoValor":4061,"codigoRelacion":104061,"valor":"CUESTION DE DERECHO COMUN ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201105261515,"fechaModLong":201105261515,"orden":null,"visible":null},"orden":2,"usuarioCreacion":n