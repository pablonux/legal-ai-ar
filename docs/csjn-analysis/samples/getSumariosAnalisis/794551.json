[{"id":165641,"orden":1,"ordenRecurso":null,"voces":"SENTENCIA ARBITRARIA - OMISION EN EL PRONUNCIAMIENTO - DESPIDO - INDEMNIZACION","texto":"<p>Es arbitraria la sentencia que omitió el tratamiento de un punto conducente para la adecuada solución del caso -inclusión del prorrateo del bono anual en la indemnización por despido-, pues el propio tribunal a quo, al conceder el recurso extraordinario, admitió haber incurrido en la omisión reprochada al tratar las cuestiones llevadas a su conocimiento por la parte actora. </p>","fullText":"<XML><VOCES>SENTENCIA ARBITRARIA - OMISION EN EL PRONUNCIAMIENTO - DESPIDO - INDEMNIZACION</VOCES><TEXTO>Es arbitraria la sentencia que omitió el tratamiento de un punto conducente para la adecuada solución del caso -inclusión del prorrateo del bono anual en la indemnización por despido-, pues el propio tribunal a quo, al conceder el recurso extraordinario, admitió haber incurrido en la omisión reprochada al tratar las cuestiones llevadas a su conocimiento por la parte actora. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1717470000000,"tomo":347,"pagina":594,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":1,"holding":0,"linksCitantes":null,"numeroID":4394,"anioFallo":2024,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3532,"codigoRelacion":103532,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202406041604,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":nu