[{"id":173471,"orden":1,"ordenRecurso":null,"voces":"MIGRACIONES - EXPULSION DE EXTRANJEROS - PENA - SENTENCIA CONDENATORIA - INTERPRETACION DE LA LEY","texto":"<p>El parámetro del art. 29 inc. c de la ley 25.871 (redacción original previa a las modificaciones introducidas por el DNU 366/25) referido a “delito que merezca para la legislación argentina pena privativa de la libertad de 3 años o más”, en los casos en los cuales el extranjero fue condenado en el país, requiere observar la condena que le fue aplicada en concreto, en tanto una interpretación razonable supone que, cuando el extranjero es condenado en el país, el término “legislación argentina” del citado art. 29 debe entenderse como comprensivo de todo el ordenamiento jurídico del cual también forman parte los principios de culpabilidad y personalidad de la pena, y por ende inclusivo de la valoración judicial y el merecimiento de la pena que los jueces de la República han llevado a cabo en un caso concreto. </p>","fullText":"<XML><VOCES>MIGRACIONES - EXPULSION DE EXTRANJEROS - PENA - SENTENCIA CONDENATORIA - INTERPRETACION DE LA LEY</VOCES><TEXTO>El parámetro del art. 29 inc. c de la ley 25.871 (redacción original previa a las modificaciones introducidas por el DNU 366/25) referido a “delito que merezca para la legislación argentina pena privativa de la libertad de 3 años o más”, en los casos en los cuales el extranjero fue condenado en el país, requiere observar la condena que le fue aplicada en concreto, en tanto una interpretación razonable supone que, cuando el extranjero es condenado en el país, el término “legislación argentina” del citado art. 29 debe entenderse como comprensivo de todo el ordenamiento jurídico del cual también forman parte los principios de culpabilidad y personalidad de la pena, y por ende inclusivo de la valoración judicial y el merecimiento de la pena que los jueces de la República han llevado a cabo en un caso concreto. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1757991600000,"tomo":348,"pagina":1076,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":5,"holding":1,"linksCitantes":null,"numeroID":7993,"anioFallo":2025,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":2725,"codigoRelacion":102725,"valor":"MIGRACIONES","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202509161634,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":1866,"codigoRelacion":101866,"valor":"EXPULSION DE EXTRANJEROS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202509161634,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":2906,"codigoRelacion":102906,"valor":"PENA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":3,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202509161634,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":3533,"codigoRelacion":103533,"valor":"SENTENCIA CONDENATORIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":4,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202509161634,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":4187,"codigoRelacion":104187,"valor":"INTERPRETACION DE LA LEY ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201203220933,"fechaModLong":201203220933,"orden":null,"visible":null},"orden":5,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202509161634,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":8139051,"analisisDocumental":{"id":813905,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 2 - FLORES MARTIN, EDER LUIS c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":9382,"titulo":"Migraciones - Impedimento de ingreso y permanencia: condena en el caso concreto","cabecilla":"<p style=\"text-indent:2em\">La cámara mantuvo la expulsión del migrante y sostuvo que la causal contemplada en el artículo 29, inciso c, de la <a href=\"https://www.argentina.gob.ar/normativa/nacional/92016/actualizacion\">ley 25.871</a> (redacción original) se sustenta “en la pena efectivamente impuesta al extranjero, sin tomar en consideración los mínimos o máximos de la conducta delictual que se le atribuyó\". La expulsión había sido motivada en una condena a tres (3) años de prisión de ejecución condicional por el delito de homicidio simple con exceso en la legítima defensa.</p><p style=\"text-indent:2em\">Ante el recurso interpuesto por el actor la Corte confirmó esta sentencia.</p><p style=\"text-indent:2em\">Señaló que la cuestión federal a decidir consistía en determinar si la norma mencionada, en cuanto impide el ingreso o permanencia de extranjeros que hubiesen sido condenados en el país por delitos que merezcan para la legislación argentina pena privativa de la libertad de tres años o más, exige <b>evaluar el mínimo de la escala penal en abstracto en el orden nacional o la condena impuesta en el caso concreto por el tribunal</b>.</p><p style=\"text-indent:2em\">El Tribunal expresó que una interpretación razonable supone que, cuando el extranjero es condenado en el país, el término “legislación argentina” del artículo 29 debe entenderse como comprensivo de todo el ordenamiento jurídico del cual también forman parte los principios de culpabilidad y personalidad de la pena, y por ende inclusivo de la valoración judicial y el merecimiento de la pena que los jueces de la República han llevado a cabo <b>en un caso concreto</b>.</p><p style=\"text-indent:2em\">Por lo tanto, el parámetro “delito que merezca para la legislación argentina pena privativa de la libertad de tres (3) años o más” en los casos en los cuales el extranjero fue condenado en el país, requiere observar la condena que le fue aplicada en concreto y la expulsión ordenada debía ser confirmada en el caso. </p>","esNovedad":true,"fecha":1757991600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1758203922809,"usuarioCreacion":11,"fechaCreacion":1758058800071,"privado":false,"posicion":6,"resumen":null},"reciboEntrada":{"id":142479,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33678273,"numeroExpediente":72821,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"