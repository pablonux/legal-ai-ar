[{"id":161071,"orden":1,"ordenRecurso":11,"voces":"AUTO DE CONCESION - RECURSO EXTRAORDINARIO - NULIDAD - CONCESION DEL RECURSO EXTRAORDINARIO - NORMAS FEDERALES - FALTA DE FUNDAMENTACION","texto":"<p>El auto de concesión del recurso extraordinario es nulo por carecer ostensiblemente de una debida fundamentación, toda vez que en su anterior fallo la cámara no formuló ninguna inteligencia sobre el alcance y aplicación al caso de una norma federal como lo es la ley 24.557 sino que se limitó a examinar lo atinente a la procedencia del recurso de apelación interpuesto por la ejecutada en función del monto debatido, lo cual evidencia que el tribunal a quo solo ha sustentado la viabilidad de la apelación federal en una motivación inexistente. </p>","fullText":"<XML><VOCES>AUTO DE CONCESION - RECURSO EXTRAORDINARIO - NULIDAD - CONCESION DEL RECURSO EXTRAORDINARIO - NORMAS FEDERALES - FALTA DE FUNDAMENTACION</VOCES><TEXTO>El auto de concesión del recurso extraordinario es nulo por carecer ostensiblemente de una debida fundamentación, toda vez que en su anterior fallo la cámara no formuló ninguna inteligencia sobre el alcance y aplicación al caso de una norma federal como lo es la ley 24.557 sino que se limitó a examinar lo atinente a la procedencia del recurso de apelación interpuesto por la ejecutada en función del monto debatido, lo cual evidencia que el tribunal a quo solo ha sustentado la viabilidad de la apelación federal en una motivación inexistente. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1683082800000,"tomo":346,"pagina":439,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":3,"holding":0,"linksCitantes":null,"numeroID":2077,"anioFallo":2023,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":4054,"codigoRelacion":104054,"valor":"AUTO DE CONCESION ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201105031200,"fechaModLong":201105031200,"orden"