rioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":24,"codigoRelacion":80024,"valor":"DECLARA NULIDAD","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201011041306,"fechaModLong":201011041306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"SUPERINTENDENCIA DE RIESGOS DEL TRABAJO c/ EXPERTA ASEGURADORA DE RIESGOS DEL TRABAJO S.A. s/EJECUTIVO","inconstitucional":false,"falloDestacado":{"id":5364,"titulo":"Nulidad del auto de concesión del recurso extraordinario con motivación inexistente","cabecilla":"<p>La cámara declaró mal concedidos los recursos de apelación por considerar que los valores económicos comprometidos no superaban el monto mínimo de apelabilidad previsto en el art. 242 del Código Procesal Civil y Comercial de la Nación. Contra tales pronunciamientos la ejecutada interpuso recursos extraordinarios fundados en la existencia de arbitrariedad y de cuestión federal. La cámara denegó las apelaciones en cuanto al primero de los fundamentos mencionados pero concedió los recursos al considerar que se cuestionaba la inteligencia proporcionada sobre el alcance y aplicación al caso de una norma federal como la ley 24.557. <b>La Corte declaró la </b><b>nulidad de estos autos de concesión por carecer ostensiblemente de una debida fundamentación</b>. Expresó que en sus anteriores fallos la cámara no formuló ninguna inteligencia sobre la norma mencionada sino que se limitó a examinar lo atinente a la procedencia de los recursos de apelación interpuestos por la ejecutada en función de los montos debatidos.</p>","esNovedad":true,"fecha":1683082800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1683207656400,"usuarioCreacion":4,"fechaCreacion":1683207650150,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":108018,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34544087,"numeroExpediente":325,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":9492,"descripcion":"EJECUTIVO","idMateria":4,"tema":{"id":510,"codigo":"EJECUTIVOS"}},"caratula":"SUPERINTENDENCIA DE RIESGOS DEL TRABAJO c/ EXPERTA ASEGURADORA DE RIESGOS DEL TRABAJO S.A. s/EJECUTIVO","verificacionMesa":"N","etiqueta":null,"hijos":[{"id":32840343,"numeroExpediente":27706,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":9492,"descripcion":"EJECUTIVO","idMateria":4,"tema":{"id":510,"codigo":"EJECUTIVOS"}},"caratula":"SUPERINTENDENCIA DE RIESGOS DEL TRABAJO c/ EXPERTA ASEGURADORA DE RIESGOS DEL TRABAJO S.A. s/EJECUTIVO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpedient