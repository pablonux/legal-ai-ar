usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":250006,"valor":"Laboral","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - KHAIAT, MOHAMED AMIR c/ COPPEL S.A. s/DESPIDO","inconstitucional":false,"falloDestacado":{"id":9222,"titulo":"Depósito previo: transferencia del importe y omisión de los datos relativos al expediente","cabecilla":"<p style=\"text-indent:2em\">El recurrente presentó un pedido de revocatoria de la resolución que había desestimado la queja por no haber sido cumplida debidamente y en tiempo oportuno la obligación de depositar. Alegó que la carga económica había sido satisfecha y que tal circunstancia había quedado adecuadamente acreditada.</p><p style=\"text-indent:2em\">La Corte desestimó este planteo.</p><p style=\"text-indent:2em\">Sostuvo que su anterior decisión tuvo sustento en el informe emanado del Banco de la Nación Argentina que daba cuenta de que, si bien había recibido una transferencia por el importe correspondiente al depósito, su acreditación no fue posible -y la suma debió ser reintegrada- en razón de que el interesado no suministró los datos relativos al expediente al que debía imputarse. Así pues, la finalidad de la transacción no pudo ser alcanzada por la omisión en que incurrió el apelante, sobre quien pesaba la responsabilidad de proporcionar los datos necesarios para el correcto ingreso del pago.</p>","esNovedad":true,"fecha":1754535600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1754593423676,"usuarioCreacion":4,"fechaCreacion":1754591412476,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":140178,"secretaria":{"id