aba cuenta de que, si bien había recibido una transferencia por el importe correspondiente al depósito, su acreditación no fue posible -y la suma debió ser reintegrada- en razón de que el interesado no suministró los datos relativos al expediente al que debía imputarse. Así pues, la finalidad de la transacción no pudo ser alcanzada por la omisión en que incurrió el apelante, sobre quien pesaba la responsabilidad de proporcionar los datos necesarios para el correcto ingreso del pago.</p>","esNovedad":true,"fecha":1754535600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1754593423676,"usuarioCreacion":4,"fechaCreacion":1754591412476,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":140178,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38617443,"numeroExpediente":21314,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - KHAIAT, MOHAMED AMIR c/ COPPEL S.A. s/DESPIDO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"21314. "},"recurso":{"id":6791224,"expediente":{"id":38617443,"numeroExpediente":21314,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":9707,"descripcion":"DESPIDO","idMateria":5,"tema":null},"caratula":"Recurso Queja Nº 1 - KHAIAT, MOHAMED AMIR c/ COPPE