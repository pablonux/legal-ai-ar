[{"id":172796,"orden":1,"ordenRecurso":7,"voces":"DEPOSITO PREVIO - RECURSO DE REPOSICION O REVOCATORIA","texto":"<p>Cabe rechazar el pedido de revocatoria de la resolución que desestimó la queja por no haber sido cumplida la obligación de depositar, pues del informe emanado del Banco de la Nación Argentina surge que, si bien esa entidad recibió una transferencia por el importe correspondiente al depósito, su acreditación no fue posible –y la suma debió ser reintegrada- en razón de que el interesado no suministró los datos relativos al expediente al que debía imputarse, es decir, la finalidad de la transacción no pudo ser alcanzada por la omisión en que incurrió el apelante, sobre quien pesaba la responsabilidad de proporcionar los datos necesarios para el correcto ingreso del pago.</p>","fullText":"<XML><VOCES>DEPOSITO PREVIO - RECURSO DE REPOSICION O REVOCATORIA</VOCES><TEXTO>Cabe rechazar el pedido de revocatoria de la resolución que desestimó la queja por no haber sido cumplida la obligación de depositar, pues del informe emanado del Banco de la Nación Argentina surge que, si bien esa entidad recibió una transferencia por el importe correspondiente al depósito, su acreditación no fue posible –y la suma debió ser reintegrada- en razón de que el interesado no suministró los datos relativos al expediente al que debía imputarse, es decir, la finalidad de la transacción no pudo ser alcanzada por la omisión en que incurrió el apelante, sobre quien pesaba la responsabilidad de proporcionar los datos necesarios para el correcto ingreso del pago.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1754535600000,"tomo":348,"pagina":809,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":1,"holding":0,"linksCitantes":null,"numeroID":6400,"anioFallo":2025,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1420,"codigoRelacion":101420,"valor":"DEPOSITO PREVIO","activo":"S","usuarioCreacion":"ADMIN","