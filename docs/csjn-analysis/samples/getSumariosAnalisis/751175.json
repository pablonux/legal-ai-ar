[{"id":150511,"orden":1,"ordenRecurso":null,"voces":"CORTE SUPREMA - SENTENCIA","texto":"<p>Si bien las sentencias de la Corte deben limitarse a lo peticionado por las partes en el recurso extraordinario, constituye un requisito previo emanado de su función jurisdiccional el control, aun de oficio, del desarrollo del procedimiento cuando se encuentran involucrados aspectos que atañen al orden público, ya que la existencia de un vicio capaz de provocar una nulidad absoluta y que afecta una garantía constitucional, no podría ser confirmado por las sentencias ulteriores.</p>","fullText":"<XML><VOCES>CORTE SUPREMA - SENTENCIA</VOCES><TEXTO>Si bien las sentencias de la Corte deben limitarse a lo peticionado por las partes en el recurso extraordinario, constituye un requisito previo emanado de su función jurisdiccional el control, aun de oficio, del desarrollo del procedimiento cuando se encuentran involucrados aspectos que atañen al orden público, ya que la existencia de un vicio capaz de provocar una nulidad absoluta y que afecta una garantía constitucional, no podría ser confirmado por las sentencias ulteriores.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1554778800000,"tomo":342,"pagina":606,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":0,"linksCitantes":null,"numeroID":1366,"anioFallo":2019,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1234,"codigoRelacion":101234,"valor":"CORTE SUPREMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201905221444,"usuarioModificacion":null,"fechaModificacion":201905221444},{"tipoVoz":{"codigoTabla":null,"codigoValor":3527,"codigoRelacion":103527,"valor":"SENTENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":20100