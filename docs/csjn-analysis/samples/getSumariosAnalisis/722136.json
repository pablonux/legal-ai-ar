[{"id":2027,"orden":1,"ordenRecurso":null,"voces":"IMPUESTO A LAS GANANCIAS - FUNDACION CASCOS BLANCOS - INTERPRETACION DE LA LEY  - EXENCION IMPOSITIVA","texto":"La sentencia que juzgó que el desarrollo de tareas humanitarias en el exterior por parte de la Fundación Cascos Blancos implica, aunque sea de manera indirecta, un beneficio para los fiscos del extranjeros -en los términos del art. 21 de la ley 20.628-, identificando ambos conceptos pese a que la AFIP los había diferenciado y había reconocido expresamente que no se verificaba dicha transferencia, desvirtuó el sentido de la norma mencionada e incurrió en un claro apartamiento de ella pues resulta indudable que la realización de tareas humanitarias en el exterior no es lo que mismo que transferir ingresos a fiscos extranjeros.","fullText":"<XML><VOCES>IMPUESTO A LAS GANANCIAS - FUNDACION CASCOS BLANCOS - INTERPRETACION DE LA LEY  - EXENCION IMPOSITIVA</VOCES><TEXTO>La sentencia que juzgó que el desarrollo de tareas humanitarias en el exterior por parte de la Fundación Cascos Blancos implica, aunque sea de manera indirecta, un beneficio para los fiscos del extranjeros -en los términos del art. 21 de la ley 20.628-, identificando ambos conceptos pese a que la AFIP los había diferenciado y había reconocido expresamente que no se verificaba dicha transferencia, desvirtuó el sentido de la norma mencionada e incurrió en un claro apartamiento de ella pues resulta indudable que la realización de tareas humanitarias en el exterior no es lo que mismo que transferir ingresos a fiscos extranjeros.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1433818800000,"tomo":338,"pagina":453,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":3657,"anioFallo":2015,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":2093,"codigoRelacion":102093,"valor":"IMPUESTO A LAS GANANCIAS","activo":"S","usuarioCr