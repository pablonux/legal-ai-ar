le":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GIMENEZ, MIRTA RAQUEL c/ PROGRAMA FEDERAL INCLUIR SALUD Y OTRO s/AMPARO LEY 16.986","inconstitucional":false,"falloDestacado":{"id":9021,"titulo":"Prórroga de la competencia originaria cuando la misma nace rationae personae","cabecilla":"<p style=\"text-indent:2em\">La actora promovió acción de amparo ante un juzgado federal de Paraná con el objeto de que procedan a otorgarle una prótesis de acuerdo con la prescripción médica.</p><p style=\"text-indent:2em\">La Provincia de Entre Ríos demandada se presentó y solicitó el rechazo del amparo, negando la existencia de una omisión del Estado provincial que revistiera arbitrariedad e ilegalidad manifiesta.</p><p style=\"text-indent:2em\">El titular del juzgado declaró su incompetencia y dispuso la remisión de las actuaciones a la Corte, que <b>declaró su incompetencia</b> para entender en el juicio por vía de su <b>instancia originaria</b>.</p><p style=\"text-indent:2em\">El Tribunal recordó la validez de la prórroga de dicha competencia en favor de tribunales inferiores de la Nación, cuando la misma nace <em>rationae personae,</em> por constituir una prerrogativa de carácter personal que puede ser renunciada expresa o tácitamente.</p><p style=\"text-indent:2em\">Destacó que la conducta asumida por la provincia al presentarse ante el juzgado federal, debía ser considerada como una clara renuncia a la prerrogativa que le confiere el artículo 117 de la Ley Fundamental, y una prórroga a favor de la justicia referida.</p><p style=\"text-indent:2em\">Agregó que no se advertía además la concurrencia de un interés federal o de razones institucionales de tal magnitud que hicieran impostergable la intervención de la Corte por lo que el proceso debía continuar su trámite ante el juzgado federal. </p>","esNovedad":true,"fecha":1750820400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1750957399645,"usuarioCreacion":11,"fechaCreacion":1750882005867,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":139398,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":37765013,"numeroExpediente":3457,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":2825,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":160,"codigo":"AMPAROS"}},"caratula":"GIMENEZ, MIRTA RAQUEL c/ PROGRAMA FEDERAL INCLUIR SALUD Y OTRO s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"3457. "},"recurso":{"id":6580482,"expediente":{"id":37765013,"numeroExpediente":3457,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":2825,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":160,"codigo":"AMPAROS"}},"caratula":"GIMENEZ, MIRTA RAQUEL c/ PROGRAMA FEDERAL INCLUIR SALUD Y OTRO s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"3457. "},"tipoRecurso":{"id":1185,"codigo":"DCO","descripcion":"DECLINACIÓN DE COMPETENCIA"},"claveRecurso":"FPA 003457/2023/CS002","identificacionExpediente":"FP