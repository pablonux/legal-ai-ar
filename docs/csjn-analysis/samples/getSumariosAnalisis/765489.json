[{"id":154824,"orden":1,"ordenRecurso":1,"voces":"RECURSO EXTRAORDINARIO - DEBIDO PROCESO - NOTIFICACION","texto":"<p>La adecuada notificación de las distintas etapas fundamentales del juicio, en especial la del pronunciamiento y la atinente al trámite previsto en el artículo 257 del Código Procesal Civil y Comercial de la Nación, tiene por objeto proporcionar a los litigantes la oportunidad de ejercer sus defensas con la amplitud que exige la garantía del debido proceso y plantear las cuestiones que crean conducentes para la correcta solución del litigio.</p>","fullText":"<XML><VOCES>RECURSO EXTRAORDINARIO - DEBIDO PROCESO - NOTIFICACION</VOCES><TEXTO>La adecuada notificación de las distintas etapas fundamentales del juicio, en especial la del pronunciamiento y la atinente al trámite previsto en el artículo 257 del Código Procesal Civil y Comercial de la Nación, tiene por objeto proporcionar a los litigantes la oportunidad de ejercer sus defensas con la amplitud que exige la garantía del debido proceso y plantear las cuestiones que crean conducentes para la correcta solución del litigio.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1621479600000,"tomo":344,"pagina":1146,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":0,"linksCitantes":null,"numeroID":2407,"anioFallo":2021,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3210,"codigoRelacion":103210,"valor":"RECURSO EXTRAORDINARIO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":202105201905,"usuarioModificacion":null,"fechaModificacion":202105201905},{"tipoVoz":{"codigoTabla":null,"codigoValor":1323,"codigoRelacion":101323,"valor":"DEBIDO PROCESO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":20100630100