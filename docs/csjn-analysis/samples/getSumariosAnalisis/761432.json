[{"id":152729,"orden":1,"ordenRecurso":null,"voces":"EXCARCELACION - DELITOS DE LESA HUMANIDAD - SENTENCIA ARBITRARIA - DEFECTOS EN LA CONSIDERACION DE EXTREMOS CONDUCENTES - PRESUNCION DE FUGA","texto":"Es arbitraria la decisión que concedió la excarcelación al imputado toda vez que se ha omitido considerar una cuestión conducente para la adecuada solución del caso como resulta ser que ante una situación análoga a la generada por la decisión que revocó la absolución del imputado por delitos de lesa humanidad, éste se fugó del país y se mantuvo en rebeldía durante cuatro años, verificándose en forma suficiente, en esa oportunidad, el riesgo que implica para la realización de los fines del proceso disponer su libertad ante la expectativa de una pena que, en abstracto supera ampliamente la que se le impuso en la sentencia revocada.\r\n-Del dictamen de la Procuración General al que la Corte remite -.\r\n- El Juez Rosenkrantz, en disidencia, consideró inadmisible el recurso extraordinario (art. 280 CPCCN) -.","fullText":"<XML><VOCES>EXCARCELACION - DELITOS DE LESA HUMANIDAD - SENTENCIA ARBITRARIA - DEFECTOS EN LA CONSIDERACION DE EXTREMOS CONDUCENTES - PRESUNCION DE FUGA</VOCES><TEXTO>Es arbitraria la decisión que concedió la excarcelación al imputado toda vez que se ha omitido considerar una cuestión conducente para la adecuada solución del caso como resulta ser que ante una situación análoga a la generada por la decisión que revocó la absolución del imputado por delitos de lesa humanidad, éste se fugó del país y se mantuvo en rebeldía durante cuatro años, verificándose en forma suficiente, en esa oportunidad, el riesgo que implica para la realización de los fines del proceso disponer su libertad ante la expectativa de una pena que, en abstracto supera ampliamente la que se le impuso en la sentencia revocada.\r\n-Del dictamen de la Procuración General al que la Corte remite -.\r\n- El Juez Rosenkrantz, en disidencia, consideró inadmisible el recurso extraordinario (art. 280 CPCCN) -.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1603940400000,"tomo":343,"pagina":1402,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":3906,"anioFallo":2020,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1787,"codigoRelacion":101787,"valor":"EXCARCELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":202010301145,"usuarioModificacion":null,"fechaModificacion":202010301145},{"tipoVoz":{"codigoTabla":null,"codigoValor":1398,"codigoRelacion":101398,"valor":"DELITOS DE LESA HUMANIDAD","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":null,"fechaCreacion":202010301145,"usuarioModificacion":null,"fechaModificacion":202010301145},{"tipoVoz":{"codigoTabla":null,"codigoValor":3532,"codigoRelacion":103532,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":3,"usuarioCreacion":null,"fechaCreacion":202010301145,"usuarioModificacion":null,"fechaModificacion":202010301145},{"tipoVoz":{"codigoTabla":null,"codigoValor":4507,"codigoRelacion":104507,"valor":"DEFECTOS EN LA CONSIDERACION DE EXTREMOS CONDUCENTES","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201509021047,"fechaModLong":201509021047,"orden":null,"visible":null},"orden":4,"usuarioCreacion":null,"fechaCreacion":202010301145,"usuarioModificacion":null,"fechaModificacion":202010301145},{"tipoVoz":{"codigoTabla":null,"codigoValor":4388,"codigoRelacion":104388,"valor":"PRESUNCION DE FUGA","activo":"S","usuarioCreacion":"JUR3WP",