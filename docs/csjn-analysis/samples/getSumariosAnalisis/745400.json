[{"id":149479,"orden":1,"ordenRecurso":null,"voces":"IMPUESTO A LAS GANANCIAS - AJUSTE POR INFLACION - CONFISCATORIEDAD - JURISPRUDENCIA","texto":"<p>La aplicación del mecanismo de ajuste por inflación en los términos del precedente \"Candy S.A.\" lo es al solo efecto de evitar la confiscatoriedad que se produciría al absorber el Estado una porción sustancial de la renta o el capital, lo que impide utilizar tal método correctivo para el reconocimiento de un mayor quebranto que pueda ser utilizado por el contribuyente en períodos posteriores, por la sencilla razón de que, en tal supuesto, no hay tributo a pagar que pueda ser cotejado con el capital o la renta gravados.</p>","fullText":"<XML><VOCES>IMPUESTO A LAS GANANCIAS - AJUSTE POR INFLACION - CONFISCATORIEDAD - JURISPRUDENCIA</VOCES><TEXTO>La aplicación del mecanismo de ajuste por inflación en los términos del precedente \"Candy S.A.\" lo es al solo efecto de evitar la confiscatoriedad que se produciría al absorber el Estado una porción sustancial de la renta o el capital, lo que impide utilizar tal método correctivo para el reconocimiento de un mayor quebranto que pueda ser utilizado por el contribuyente en períodos posteriores, por la sencilla razón de que, en tal supuesto, no hay tributo a pagar que pueda ser cotejado con el capital o la renta gravados.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1527562800000,"tomo":341,"pagina":581,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":0,"linksCitantes":null,"numeroID":2389,"anioFallo":2018,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":2093,"codigoRelacion":102093,"valor":"IMPUESTO A LAS GANANCIAS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201806041053,"usuarioModificacion":null,"fechaModificacion":201806