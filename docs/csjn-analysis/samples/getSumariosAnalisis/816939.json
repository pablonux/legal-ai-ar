[{"id":174220,"orden":1,"ordenRecurso":5,"voces":"SENTENCIA ARBITRARIA - APARTAMIENTO DE CONSTANCIAS DE LA CAUSA - BONO DE CONSOLIDACION DE DEUDAS","texto":"<p>Es arbitraria la sentencia que condenó al Estado Nacional a compensar a la actora la diferencia entre la cotización de los bonos octava serie que recibió y los bonos cuarta serie 2%, con sustento en que habían transcurrido más de quince años desde la sentencia de primera instancia sin que el actor haya podido satisfacer su crédito debido a los escritos recursivos del Estado, pues de la causa surge que fue la actuación de ambas partes la que motivó la prolongación del juicio, careciendo de asidero atribuir al Estado haber incumplido con su obligación de pago y sometido a una espera indebida al acreedor mediante un largo proceso de apelaciones y justificar sobre la base de esa errónea premisa la compensación otorgada. </p><p>-Los jueces Rosatti y Lorenzetti, en disidencia, consideraron que el recurso extraordinario no refutaba todos y cada uno de los fundamentos de la sentencia apelada-</p>","fullText":"<XML><VOCES>SENTENCIA ARBITRARIA - APARTAMIENTO DE CONSTANCIAS DE LA CAUSA - BONO DE CONSOLIDACION DE DEUDAS</VOCES><TEXTO>Es arbitraria la sentencia que condenó al Estado Nacional a compensar a la actora la diferencia entre la cotización de los bonos octava serie que recibió y los bonos cuarta serie 2%, con sustento en que habían transcurrido más de quince años desde la sentencia de primera instancia sin que el actor haya podido satisfacer su crédito debido a los escritos recursivos del Estado, pues de la causa surge que fue la actuación de ambas partes la que motivó la prolongación del juicio, careciendo de asidero atribuir al Estado haber incumplido con su obligación de pago y sometido a una espera indebida al acreedor mediante un largo proceso de apelaciones y justificar sobre la base de esa errónea premisa la compensación otorgada. -Los jueces Rosatti y Lorenzetti, en disidencia, consideraron que el recurso extraordinario no refutaba todos y cada uno de los fundamentos de la sentencia apelada-</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1760583600000,"tomo":348,"pagina":1262,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":2,"holding":1,"linksCitantes":null,"numeroID":10151,"anioFallo":2025,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3532,"codigoRelacion":103532,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202510161719,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":4506,"codigoRelacion":104506,"valor":"APARTAMIENTO DE CONSTANCIAS DE LA CAUSA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201509021046,"fechaModLong":201509021046,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202510161719,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":785,"codigoRelacion":100785,"valor":"BONO DE CONSOLIDACION DE DEUDAS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":3,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202510161719,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":331,"citasRex":[],"idFallo":8169391,"analisisDocumental":{"id":816939,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - REALES, MARTIN c/ Y.P.F. YACIMIENTOS PETROLIFEROS FISCALES S.A. Y OTRO s/PART. ACCION OBRERO","inconstitucional":false,"falloDestacado":{"id":9545,"titulo":"Arbitrariedad de sentencias: falta de  sustento en las constancias de la causa","cabecilla":"<p style=\"text-indent: 2em;\">La cámara revocó la sentencia de primera instancia y condenó al Estado Nacional a compensar a la actora la diferencia entre la cotización de los bonos octava serie que recibió y los bonos cuarta serie 2% y atribuyó al Estado haber incumplido con el pago a causa del “largo proceso de apelaciones” al que sometió a aquella.</p><p style=\"text-indent: 2em;\">La Corte, por mayoría, entendió que la sentencia impugnada tenía una <b>fundamentación aparente</b> y la <b>dejó sin efecto</b>.</p><p style=\"text-indent: 2em;\">Consideró que de las constancias de la causa y del propio relato efectuado por el tribunal anterior en grado, surgía que fue la actuación de ambas partes la que motivó la prolongación del juicio, mediante el ejercicio regular del derecho de defensa.</p><p style=\"text-indent: 2em;\">Concluyó así que carecía de asidero entonces atribuir al Estado haber incumplido con su obligación de pago y sometido a una espera indebida al acreedor mediante un largo proceso de apelaciones y justificar sobre la base de esta errónea premisa la compensación otorgada.</p>","esNovedad":true,"fecha":1760583600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1760651861193,"usuarioCreacion":4,"fechaCreacion":1760650540533,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":145331,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":24290334,"numeroExpediente":4235,"anioExpediente":1998,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":7,"codigo":"7","abreviatura":"CNT","descripcion":"Cámara Nacional de Apelaciones del Trabajo","estado":0,"descripcionLarga":"CNT - Cámara Nacional de Apelaciones del Trabajo"},"objetoJuicio":{"id":10825,"descripcion":"PART. ACCION OBRERO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 1 - REALES, MARTIN c/