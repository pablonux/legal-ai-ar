[{"id":149021,"orden":1,"ordenRecurso":null,"voces":"IMPUESTO A LAS GANANCIAS - FUSION DE SOCIEDADES - REORGANIZACION DE SOCIEDADES","texto":"De la resolución general 2245 de la Dirección General Impositiva dictada en virtud del art. 77, tercer párrafo, de la ley 20.628 y el art. 105 de su decreto reglamentario surge con claridad que si la inscripción del acto societario aún no fue otorgada al momento en que el contribuyente formula la pertinente comunicación de la reorganización al ente recaudador, la presentación de las constancias que acrediten la iniciación de los trámites de inscripción ante las autoridades competentes es bastante para tener por cumplido el aludido recaudo.","fullText":"<XML><VOCES>IMPUESTO A LAS GANANCIAS - FUSION DE SOCIEDADES - REORGANIZACION DE SOCIEDADES</VOCES><TEXTO>De la resolución general 2245 de la Dirección General Impositiva dictada en virtud del art. 77, tercer párrafo, de la ley 20.628 y el art. 105 de su decreto reglamentario surge con claridad que si la inscripción del acto societario aún no fue otorgada al momento en que el contribuyente formula la pertinente comunicación de la reorganización al ente recaudador, la presentación de las constancias que acrediten la iniciación de los trámites de inscripción ante las autoridades competentes es bastante para tener por cumplido el aludido recaudo.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1510628400000,"tomo":340,"pagina":1644,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":6090,"anioFallo":2017,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":2093,"codigoRelacion":102093,"valor":"IMPUESTO A LAS GANANCIAS","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201711281534,"usuarioModificacion":null,"