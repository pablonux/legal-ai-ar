7595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202512181550,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":4170,"codigoRelacion":104170,"valor":"DECLARACION DE OFICIO","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201203060838,"fechaModLong":201203060838,"orden":null,"visible":null},"orden":5,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202512181550,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":551,"citasRex":[],"idFallo":8218061,"analisisDocumental":{"id":821806,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":41,"codigoRelacion":80041,"valor":"DECLARA INEXISTENCIA","activo":"S","usuarioCreacion":"JURJ3F","usuarioMod":"JURJ3F","fechaCreacionLong":202509111053,"fechaModLong":202509111053,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ASOCIACION GREMIAL DE EMPLEADOS JUDICIALES DE LA PROVINCIA DE SANTA CRUZ 3 DE JULIO c/ PROVINCIA DE SANTA CRUZ s/ACCIÓN DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":10061,"titulo":"Denegatoria del recurso extraordinario y debido proceso","cabecilla":"<p style=\"text-indent: 2em;\">Los recurrentes ocurren en queja contra la resolución que denegó el remedio federal que solo fue suscripta por una de las vocales del superior tribunal provincial y sin haber cumplido en forma previa con el traslado previsto en el artículo 257 del Código Procesal Civil y Comercial de la Nación.</p><p style=\"text-indent: 2em;\">La Corte señaló que, tratándose de un tribunal colegiado, la resolución firmada por uno solo de sus miembros no puede ser considerada como el pronunciamiento del tribunal de la causa en punto a la concesión o denegatoria del recurso extraordinario.</p><p style=\"text-indent: 2em;\">Declaró entonces la inexistencia de dicha resolución y remitió las actuaciones al tribunal de origen para que, por quien corresponda y sin dilaciones, dicte una nueva decisión que respete los recaudos y el trámite que exige la norma mencionada.</p><p style=\"text-indent: 2em;\">Recordó el Tribunal que la adecuada notificación de las distintas etapas fundamentales del proceso, particularmente el traslado del recurso extraordinario federal, tiene por objeto proporcionar a los litigantes la oportunidad de ejercer sus defensas con la amplitud que exige el debido proceso y plantear las cuestiones que crean conducentes para la correcta solución de la causa.</p>","esNovedad":true,"fecha":1766026800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1766086766742,"usuarioCreacion":11,"fechaCreacion":1766084058263,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":150462,"s