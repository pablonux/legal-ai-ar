[{"id":175718,"orden":1,"ordenRecurso":2,"voces":"RECURSO EXTRAORDINARIO - AUTO DE CONCESION - TRIBUNALES COLEGIADOS - FIRMA - DECLARACION DE OFICIO","texto":"<p>Corresponde declarar, incluso de oficio, la inexistencia como sentencia del auto denegatorio del recurso extraordinario que fue suscripto por uno de los vocales del máximo tribunal provincial, pues tratándose de un tribunal colegiado, la resolución firmada por uno solo de ellos no puede ser considerada como el pronunciamiento del tribunal de la causa que exige el art. 257 del Código Procesal Civil y Comercial de la Nación, en punto a la concesión o denegatoria del recurso extraordinario.</p>","fullText":"<XML><VOCES>RECURSO EXTRAORDINARIO - AUTO DE CONCESION - TRIBUNALES COLEGIADOS - FIRMA - DECLARACION DE OFICIO</VOCES><TEXTO>Corresponde declarar, incluso de oficio, la inexistencia como sentencia del auto denegatorio del recurso extraordinario que fue suscripto por uno de los vocales del máximo tribunal provincial, pues tratándose de un tribunal colegiado, la resolución firmada por uno solo de ellos no puede ser considerada como el pronunciamiento del tribunal de la causa que exige el art. 257 del Código Procesal Civil y Comercial de la Nación, en punto a la concesión o denegatoria del recurso extraordinario.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1766026800000,"tomo":348,"pagina":1730,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":1,"holding":1,"linksCitantes":null,"numeroID":14798,"anioFallo":2025,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3210,"codigoRelacion":103210,"valor":"RECURSO EXTRAORDINARIO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fec