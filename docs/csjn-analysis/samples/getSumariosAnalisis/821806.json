ciamiento":{"codigoTabla":null,"codigoValor":41,"codigoRelacion":80041,"valor":"DECLARA INEXISTENCIA","activo":"S","usuarioCreacion":"JURJ3F","usuarioMod":"JURJ3F","fechaCreacionLong":202509111053,"fechaModLong":202509111053,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ASOCIACION GREMIAL DE EMPLEADOS JUDICIALES DE LA PROVINCIA DE SANTA CRUZ 3 DE JULIO c/ PROVINCIA DE SANTA CRUZ s/ACCIÓN DE INCONSTITUCIONALIDAD","inconstitucional":false,"falloDestacado":{"id":10061,"titulo":"Denegatoria del recurso extraordinario y debido proceso","cabecilla":"<p style=\"text-indent: 2em;\">Los recurrentes ocurren en queja contra la resolución que denegó el remedio federal que solo fue suscripta por una de las vocales del superior tribunal provincial y sin haber cumplido en forma previa con el traslado previsto en el artículo 257 del Código Procesal Civil y Comercial de la Nación.</p><p style=\"text-indent: 2em;\">La Corte señaló que, tratándose de un tribunal colegiado, la resolución firmada por uno solo de sus miembros no puede ser considerada como el pronunciamiento del tribunal de la causa en punto a la concesión o denegatoria del recurso extraordinario.</p><p style=\"text-indent: 2em;\">Declaró entonces la inexistencia de dicha resolución y remitió las actuaciones al tribunal de origen para que, por quien corresponda y sin dilaciones, dicte una nueva decisión que respete los recaudos y el trámite que exige la norma mencionada.</p><p style=\"text-indent: 2em;\">Recordó el Tribunal que la adecuada notificación de las distintas etapas fundamentales del proceso, particularmente el traslado del recurso extraordinario federal, tiene por objeto proporcionar a los litigantes la oportunidad de ejercer sus defensas con la amplitud que exige el debido proceso y plantear las cuestiones que crean conducentes para la correcta solución de la causa.</p>","esNovedad":true,"fecha":1766026800000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1766086766742,"usuarioCreacion":11,"fechaCreacion":1766084058263,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":150462,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":40821789,"numeroExpediente":3205,"anioExpediente":2025,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ASOCIACION GREMIAL DE EMPLEADOS JUDICIALES DE LA PROVINCIA DE SANTA CRUZ 3 DE JULIO c/ PROVINCIA DE SANTA CRUZ s/ACCIÓN DE INCONSTITUCIONALIDAD","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"3205. "},"recurso":{"id":7490829,"expediente":{"id":40821789,"numeroExpediente":3205,"anioExpediente":2025,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":nul