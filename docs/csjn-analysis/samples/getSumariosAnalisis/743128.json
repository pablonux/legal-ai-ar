[{"id":149260,"orden":1,"ordenRecurso":null,"voces":"DESPIDO - DESPIDO DISCRIMINATORIO - PRUEBA","texto":"<p>El mero señalamiento de que la supuesta conducta reprobada no surge del acto mismo del despido resulta inconsistente para dar sustento al pronunciamiento pues la discriminación, por lo común, se caracteriza por constituir una conducta solapada, oculta o encubierta, que no es reconocida por quien la ejecuta y, por lo tanto, es harto improbable que surja de los términos de una notificación rescisoria, por lo que debe necesariamente ser demostrada mediante otras pruebas.</p>","fullText":"<XML><VOCES>DESPIDO - DESPIDO DISCRIMINATORIO - PRUEBA</VOCES><TEXTO>El mero señalamiento de que la supuesta conducta reprobada no surge del acto mismo del despido resulta inconsistente para dar sustento al pronunciamiento pues la discriminación, por lo común, se caracteriza por constituir una conducta solapada, oculta o encubierta, que no es reconocida por quien la ejecuta y, por lo tanto, es harto improbable que surja de los términos de una notificación rescisoria, por lo que debe necesariamente ser demostrada mediante otras pruebas.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1517886000000,"tomo":341,"pagina":29,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":0,"linksCitantes":null,"numeroID":69,"anioFallo":2018,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1559,"codigoRelacion":101559,"valor":"DESPIDO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201802201541,"usuarioModificacion":null,"fechaModificacion":201802201541},{"tipoVoz":{"codigoTabla":null,"codigoValor":4946,"codigoRelacion":104946,"valor":"DESPIDO DISCRIMINATORIO","activo":"S","usuarioCreacion":"JUR0V0","usuarioMod":"JUR0V0","fechaCreacionLong":201802201541