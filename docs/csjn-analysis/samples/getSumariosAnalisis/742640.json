[{"id":149203,"orden":1,"ordenRecurso":null,"voces":"SENTENCIA DE LA CORTE SUPREMA - CORTE SUPREMA - CUESTION FEDERAL","texto":"<p>La interpretación de las sentencias de la Corte en las mismas causas en que ellas han sido dictadas constituye cuestión federal suficiente para ser examinada en la instancia de excepción, en los supuestos en que la decisión impugnada consagra un inequívoco apartamiento de lo dispuesto por el Tribunal y desconoce, en lo esencial, aquella decisión.</p>","fullText":"<XML><VOCES>SENTENCIA DE LA CORTE SUPREMA - CORTE SUPREMA - CUESTION FEDERAL</VOCES><TEXTO>La interpretación de las sentencias de la Corte en las mismas causas en que ellas han sido dictadas constituye cuestión federal suficiente para ser examinada en la instancia de excepción, en los supuestos en que la decisión impugnada consagra un inequívoco apartamiento de lo dispuesto por el Tribunal y desconoce, en lo esencial, aquella decisión.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1514257200000,"tomo":340,"pagina":1969,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":0,"linksCitantes":null,"numeroID":7055,"anioFallo":2017,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3534,"codigoRelacion":103534,"valor":"SENTENCIA DE LA CORTE SUPREMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201802141527,"usuarioModificacion":null,"fechaModificacion":201802141527},{"tipoVoz":{"codigoTabla":null,"codigoValor":1234,"codigoRelacion":101234,"valor":"CORTE SUPREMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":null,"fechaCreacion":201802141527,"usuarioModificacion":null,"fechaModificacion":201802141527},{"tipoVoz