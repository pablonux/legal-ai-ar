[{"id":167272,"orden":1,"ordenRecurso":null,"voces":"RETARDO DE JUSTICIA","texto":"<p>Corresponde admitir la queja por retardo de justicia, pues desde hace más de 9 años el proceso -acción de expropiación inversa- se encuentra tramitando ante el tribunal superior provincial, con motivo de los recursos extraordinarios de inaplicabilidad de ley incoados, sin que aún haya recaído resolución alguna.</p>","fullText":"<XML><VOCES>RETARDO DE JUSTICIA</VOCES><TEXTO>Corresponde admitir la queja por retardo de justicia, pues desde hace más de 9 años el proceso -acción de expropiación inversa- se encuentra tramitando ante el tribunal superior provincial, con motivo de los recursos extraordinarios de inaplicabilidad de ley incoados, sin que aún haya recaído resolución alguna.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1724727600000,"tomo":347,"pagina":1081,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":2,"holding":0,"linksCitantes":null,"numeroID":7299,"anioFallo":2024,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3447,"codigoRelacion":103447,"valor":"RETARDO DE JUSTICIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR4UC","fechaCreacionLong":201006301000,"fechaModLong":201604280942,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202408271654,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":8003341,"analisisDocumental":{"id":800334,"competencia":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":190013,"valor":"QUEJA POR RETARDO DE JUSTICIA","activo":"S","usuarioCreacion":"CYCJ3F","usuarioMod":"CYCJ3F","fechaCreacionLong":202603171152,"fechaModLong":202603171152,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":80009,"valor":"ADMITE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231243,"fechaModLong":201008231243,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"INDUSTRIAS ISACO S.A. S/ QUIEBRA c/ PROVINCIA DE BUENOS AIRES s/EXPROPIACIÓN IRREGULAR","inconstitucional":false,"falloDestacado":{"id":7424,"titulo":"Queja por retardo de justicia: procedencia","cabecilla":"<p style=\"text-indent:2em\">Una empresa se presenta directamente ante la Corte con motivo de la demora que atribuye a la Suprema Corte de Justicia de la Provincia de Buenos Aires en resolver los recursos interpuestos en un juicio en el que ella es parte actora; solicita que se ordene la resolución del asunto.</p><p style=\"text-indent:2em\">De dicha presentación y de la documentación acompañada resulta que la actora, en junio de 2009, promovió una acción de expropiación inversa ante la justicia en lo Contencioso Administrativo del Departamento Judicial de San Martín y que, el 11 de septiembre de 2014, la cámara de apelaciones confirmó la sentencia definitiva dictada en la  instancia anterior. Contra esa decisión las partes interpusieron sendos recursos extraordinarios de inaplicabilidad de ley, que fueron concedidos.</p><p style=\"text-indent:2em\">También se desprende de las constancias obrantes en autos que en el mes de noviembre de 2014 las actuaciones fueron recibidas en la Suprema Corte de Justicia de la Provincia de Buenos Aires.</p><p style=\"text-indent:2em\">A la luz de estos hechos, y luego de solicitado el informe respectivo, <b>la Corte hizo lugar a la queja por retardo de justicia y dispuso que el Tribunal Provincial se pronuncie sin dilación alguna sobre los recursos interpuestos ante sus estrados</b>.</p><p style=\"text-indent:2em\">En sus fundamentos, se expone que la Corte ha reiterado en varios precedentes (Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=233&amp;pagina=213\">233:213</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=307&amp;pagina=2504\">307:2504</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=315&amp;pagina=1940\">315:1940</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=322&amp;pagina=2424\">322:2424</a>; <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=327&amp;pagina=3510\">327:3510</a> y <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=340&amp;pagina=1383\">340:1383</a>) que la dilación injustificada de un tribunal no puede redundar en un perjuicio irreparable para los recurrentes que, como consecuencia de una conducta ajena y que no pueden modificar, se ven impedidos de obtener una sentencia definitiva en tiempo útil.</p><p style=\"text-indent:2em\">Asimismo, sostuvo el Tribunal,  en el caso se configura uno de esos supuestos excepcionales ya que del informe recibido resulta que asiste razón a la presentante en su planteo pues desde hace más de nueve (9) años el proceso se encuentra tramitando ante los estrados del tribunal superior provincial, con motivo de los recursos extraordinarios de inaplicabilidad de ley incoados, sin que aún haya recaído resolución alguna.</p>","esNovedad":true,"fecha":1724727600000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1724871054865,"usuarioCreacion":11,"fechaCreacion":1724787037293,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":126258,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33046560,"numeroExpediente":94402,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":1923,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":0,"codigo":"AMPAROS"}},"caratula":"RUIZ, FRANCISCO OMAR c/ AFIP-DGI s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"94402. "},"recurso":{"id":5989102,"expediente":{"id":33046560,"numeroExpediente":94402,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":25,"codigo":"25","abreviatura":"FRO","descripcion":"Justicia Federal de Rosario","estado":0,"descripcionLarga":"FRO - Justicia Federal de Rosario"},"objetoJuicio":{"id":1923,"descripcion":"AMPARO LEY 16.986","idMateria":112,"tema":{"id":0,"codigo":"AMPAROS"}},"caratula":"RUIZ, FRANCISCO OMAR c/ AFIP-DGI s/AMPARO LEY 16.986","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"94402. "},"tipoRecurso":{"id":1166,"codigo":"REX","descripcion":"RECURSO EXTRAORDINARIO"},"claveRecurso":"FRO 094402/2018/CS001","identificacionExpediente":"FRO 094402/2018/CS001"},"piezas":null,"urgente":null,"observaciones":null,"usuarioCreacion":{"id":16,"nombreUsuario":"27209880461","apellido":"Slaibe","nombre":"Eugenia","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1663158351000,"nombreUsu