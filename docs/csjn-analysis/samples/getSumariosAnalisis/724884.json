[{"id":2476,"orden":1,"ordenRecurso":null,"voces":"LITISCONSORCIO - ECONOMIA PROCESAL","texto":"El litisconsorcio facultativo (art. 88 Código Procesal Civil y Comercial de la Nación) responde al propósito de preservar la unidad del proceso y garantizar la economía procesal, lo que supone que medien razones justificadas de concentración que habiliten ese agrupamiento y que las pretensiones que enlazan esa pluralidad de litigantes sean conexas por el título o por el objeto o por ambos elementos a la vez, pues de lo contrario se daría lugar a serios inconvenientes en la sustanciación del proceso y se desnaturalizarían dichos objetivos. ","fullText":"<XML><VOCES>LITISCONSORCIO - ECONOMIA PROCESAL</VOCES><TEXTO>El litisconsorcio facultativo (art. 88 Código Procesal Civil y Comercial de la Nación) responde al propósito de preservar la unidad del proceso y garantizar la economía procesal, lo que supone que medien razones justificadas de concentración que habiliten ese agrupamiento y que las pretensiones que enlazan esa pluralidad de litigantes sean conexas por el título o por el objeto o por ambos elementos a la vez, pues de lo contrario se daría lugar a serios inconvenientes en la sustanciación del proceso y se desnaturalizarían dichos objetivos. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1443063600000,"tomo":338,"pagina":927,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":6226,"anioFallo":2015,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":2656,"codigoRelacion":102656,"valor":"LITISCONSORCIO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":null,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":1630,"codigoRelacion":101630,"valor":"E