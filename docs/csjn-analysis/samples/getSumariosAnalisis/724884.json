antes, como a cada una de las reparticiones y provincias demandadas y dichas relaciones no se encuentran vinculadas, ni subordinadas entre sí.","fullText":"<XML><VOCES>LITISCONSORCIO - COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA - IMPUESTO SOBRE LOS INGRESOS BRUTOS - TRANSPORTE INTERJURISDICCIONAL - PROVINCIAS - TRANSPORTE DE PASAJEROS</VOCES><TEXTO>No se configuran los presupuestos de un litisconsorcio facultativo en la demanda tendiente a que se declare la inconstitucionalidad de la pretensión de gravar con el impuesto sobre los ingresos brutos la actividad de transporte interjurisdiccional de pasajeros si se trata de relaciones jurídicas tributarias distintas e individuales, tanto en lo que atañe a cada una de las empresas demandantes, como a cada una de las reparticiones y provincias demandadas y dichas relaciones no se encuentran vinculadas, ni subordinadas entre sí.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1443063600000,"tomo":338,"pagina":927,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":6226,"anioFallo":2015,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":2656,"codigoRelacion":102656,"valor":"LITISCONSORCIO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":null,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":966,"codigoRelacion":100966,"valor":"COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":null,"fechaCreacion":null,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":2113,"codigoRelacion":102113,"valo