[{"id":149872,"orden":1,"ordenRecurso":null,"voces":"SENTENCIA ARBITRARIA - CUESTION DE DERECHO COMUN  - DEFECTOS EN LA CONSIDERACION DE EXTREMOS CONDUCENTES - DEFENSA EN JUICIO - DERECHO DE PROPIEDAD","texto":"Aun cuando los agravios de la recurrente remiten al examen de cuestiones de hecho, prueba y derecho común, materia propia de los jueces de la causa y ajena -como regla y por su naturaleza- al remedio del art. 14 de la ley 48, ello no resulta óbice para su consideración por la vía intentada cuando, con menoscabo de los derechos de defensa en juicio y propiedad, la cámara omitió considerar elementos conducentes para la solución del litigio y realizado afirmaciones dogmáticas que dan fundamento solo aparente a su resolución.","fullText":"<XML><VOCES>SENTENCIA ARBITRARIA - CUESTION DE DERECHO COMUN  - DEFECTOS EN LA CONSIDERACION DE EXTREMOS CONDUCENTES - DEFENSA EN JUICIO - DERECHO DE PROPIEDAD</VOCES><TEXTO>Aun cuando los agravios de la recurrente remiten al examen de cuestiones de hecho, prueba y derecho común, materia propia de los jueces de la causa y ajena -como regla y por su naturaleza- al remedio del art. 14 de la ley 48, ello no resulta óbice para su consideración por la vía intentada cuando, con menoscabo de los derechos de defensa en juicio y propiedad, la cámara omitió considerar elementos conducentes para la solución del litigio y realizado afirmaciones dogmáticas que dan fundamento solo aparente a su resolución.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1540868400000,"tomo":341,"pagina":1450,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":5346,"anioFallo":2018,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3532,"codigoRelacion":103532,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible