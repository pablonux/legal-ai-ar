[{"id":154660,"orden":1,"ordenRecurso":null,"voces":"RECURSO EXTRAORDINARIO - SENTENCIA DE LA CORTE SUPREMA - CUESTION FEDERAL","texto":"<p>El recurso extraordinario es procedente, pues la interpretación de las sentencias de la Corte Suprema en las mismas causas en que ellas han sido dictadas constituye cuestión federal suficiente para ser examinada en la instancia extraordinaria, cuando la decisión impugnada consagra un inequívoco apartamiento de lo dispuesto por ella y desconoce en lo esencial aquella decisión.</p>","fullText":"<XML><VOCES>RECURSO EXTRAORDINARIO - SENTENCIA DE LA CORTE SUPREMA - CUESTION FEDERAL</VOCES><TEXTO>El recurso extraordinario es procedente, pues la interpretación de las sentencias de la Corte Suprema en las mismas causas en que ellas han sido dictadas constituye cuestión federal suficiente para ser examinada en la instancia extraordinaria, cuando la decisión impugnada consagra un inequívoco apartamiento de lo dispuesto por ella y desconoce en lo esencial aquella decisión.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1620270000000,"tomo":344,"pagina":1010,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":0,"linksCitantes":null,"numeroID":2044,"anioFallo":2021,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3210,"codigoRelacion":103210,"valor":"RECURSO EXTRAORDINARIO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":202105061958,"usuarioModificacion":null,"fechaModificacion":202105061958},{"tipoVoz":{"codigoTabla":null,"codigoValor":3534,"codigoRelacion":103534,"valor":"SENTENCIA DE LA CORTE SUPREMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":null,"fechaCreaci