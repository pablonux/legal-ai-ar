[{"id":167811,"orden":1,"ordenRecurso":null,"voces":"COMPETENCIA FEDERAL - TRANSPORTE AEREO","texto":"<p>Es competente la justicia federal para entender en la causa iniciada con el objeto de que se reparen los daños y perjuicios provocados por la cancelación de los pasajes adquiridos en razón de las restricciones impuestas por la pandemia -“covid-19”-, pues se controvierte la regularidad del proceder de la línea aérea en relación con los boletos adquiridos y su devolución; es decir la cuestión central debatida en el expediente se vincula principalmente con el servicio de transporte aéreo.</p>","fullText":"<XML><VOCES>COMPETENCIA FEDERAL - TRANSPORTE AEREO</VOCES><TEXTO>Es competente la justicia federal para entender en la causa iniciada con el objeto de que se reparen los daños y perjuicios provocados por la cancelación de los pasajes adquiridos en razón de las restricciones impuestas por la pandemia -“covid-19”-, pues se controvierte la regularidad del proceder de la línea aérea en relación con los boletos adquiridos y su devolución; es decir la cuestión central debatida en el expediente se vincula principalmente con el servicio de transporte aéreo.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1728356400000,"tomo":347,"pagina":1383,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":1,"holding":0,"linksCitantes":null,"numeroID":8862,"anioFallo":2024,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3931,"codigoRelacion":103931,"valor":"COMPETENCIA FEDERAL ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201010051033,"fechaModLong":201010051033,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":4,"nombreUsuario":"20346628686","apellido":"Marquez","nombre":"Juan Santiago","estado":"A","tieneToken":"N","cargo":"ESCRIBIENTE AUXILIAR","fechaModificacion":null,"fechaCreacion":1533610800000,"nombreUsuarioMigrado":null,"codigo":"CYCJ3F","mail":