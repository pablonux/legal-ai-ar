CreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GUERRA, ANDREA ELIZABETH c/ DESPEGAR.COM.AR S.A. Y OTRO s/ORDINARIO","inconstitucional":false,"falloDestacado":{"id":7661,"titulo":"Cancelación de pasajes aéreos en pandemia: competencia federal","cabecilla":"<p style=\"text-indent:2em\">La cámara comercial declaró la competencia del fuero para conocer en el caso en que se solicitaba la reparación de los daños y perjuicios que habían sido irrogados por la cancelación de los pasajes adquiridos, en razón de las restricciones impuestas por la pandemia causada por el virus “covid-19”.</p><p style=\"text-indent:2em\">La Corte revocó la sentencia apelada y declaró que resultaba competente para conocer en las actuaciones la <em>justicia nacional en lo civil y comercial federal</em> en tanto, al controvertirse la regularidad del proceder de la línea aérea en relación con los boletos adquiridos y su devolución, la cuestión central debatida en el expediente se vinculaba principalmente con el servicio de transporte aéreo.</p>","esNovedad":true,"fecha":1728356400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1728485348333,"usuarioCreacion":4,"fechaCreacion":1728415750426,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":128428,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34089121,"numeroExpediente":22379,"anioExpediente":2019,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":1105,"descripcion":"INHIBITORIA","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"ESTADO NA