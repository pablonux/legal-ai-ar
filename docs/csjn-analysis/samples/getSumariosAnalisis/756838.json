[{"id":151451,"orden":1,"ordenRecurso":null,"voces":"SENTENCIA ARBITRARIA - RECURSO EXTRAORDINARIO - RECURSOS LOCALES ","texto":"Los agravios expresados con sustento en la doctrina de la arbitrariedad suscitan cuestión federal suficiente para su tratamiento, pues si bien, en principio, es facultad privativa de los jueces de la causa determinar si los recursos locales ante ellos planteados están debidamente fundados, debe dejarse de lado esa regla cuando el examen de los recaudos pertinentes ha sido efectuado con un injustificado rigor formal, que conduce a la frustración del derecho invocado, con evidente menoscabo de la garantía de la defensa en juicio. ","fullText":"<XML><VOCES>SENTENCIA ARBITRARIA - RECURSO EXTRAORDINARIO - RECURSOS LOCALES </VOCES><TEXTO>Los agravios expresados con sustento en la doctrina de la arbitrariedad suscitan cuestión federal suficiente para su tratamiento, pues si bien, en principio, es facultad privativa de los jueces de la causa determinar si los recursos locales ante ellos planteados están debidamente fundados, debe dejarse de lado esa regla cuando el examen de los recaudos pertinentes ha sido efectuado con un injustificado rigor formal, que conduce a la frustración del derecho invocado, con evidente menoscabo de la garantía de la defensa en juicio. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1582772400000,"tomo":343,"pagina":110,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":521,"anioFallo":2020,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3532,"codigoRelacion":103532,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":202003131515,"usuarioModificacion":null,"fechaModificacion":202003131515},{"tipoVoz":{"codigoTa