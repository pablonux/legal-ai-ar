001","identificacionExpediente":"O. 42. L. RHE"},"piezas":1,"urgente":"N","observaciones":null,"usuarioCreacion":null,"usuarioCreacionOld":"JUR202","usuarioModificacion":null,"usuarioModificacionOld":"JURXQ9","fechaCreacion":201509171108,"fechaModificacion":201509180932}],"fecha":1442458800000,"fechaLong":20150917,"observaciones":null,"codigoUsuario":"JUR202","fechaString":"17/09/2015"},"observaciones":"<p>La Corte Suprema remite a la causa CSJ 838/2013 (49-L)/CS1 \"Lolli, Fabricio Acta n° 17.875 La Plata s/ infracción ley 22.802, quien con remisión al dictamen de la señora Procuradora Fiscal, en donde se remitió a lo resuelto en la causa competencia CSJ 592/2011(47-C) resolvio que era competente la justicai de la Provincia de Misiones, toda vez que se excedió en sus facultades cuando dispuso, en el art. 7° de la ley III 6, que las sancines administrativas definitivas impuestas porla autoridad local serán apelabls ante la Cámara Federal de Apelaciones en razón del lugar de asiento de la autoridad que dictó la condena, puesto que una ley provincial no puede ampliar ni restringir la competencia del fuero federal sin violar los dispuesto por los art. 116 y 117 de la Constitución Nacional</p>","comentarios":null,"enPreparacion":"N","formulaDesarrollo":null,"audPublica":"N","articulo16Ley48":"N","inicializacion":"N","amicue_curie":"N","conOpinion":null,"chequeoVoto":"S","cambiaJurisp":"N","sentenciaModelo":"N","citaDoctrina":"N","citaExtranjera":"N","votosOpinion":"N","art11Acordada4":"N","resolucionOriginarios":null,"cuestionesFederales":[],"formulas":[],"recusExcus":[],"voces":[{"tipoVoz":{"codigoTabla":null,"codigoValor":964,"codigoRelacion":100964,"valor":"COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":"JURJ3F","usuarioModificacion":"JURJ3F","fechaCreacion":202102121551,"fechaModificacion":202102121551},{"tipoVoz":{"codigoTab