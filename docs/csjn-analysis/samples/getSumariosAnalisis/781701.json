:null,"visible":null},"orden":4,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202303141644,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7817011,"analisisDocumental":{"id":781701,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"AGUILERA, CINTHYA s/ INCIDENTE DE INCOMPETENCIA","alias":null,"caratula":"AGUILERA, CINTHYA s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":5163,"titulo":"Competencia en caso de ingreso y uso ilegítimo a cuenta bancaria","cabecilla":"<p>El denunciante alegó que alguien había ingresado ilegítimamente a su cuenta bancaria -radicada en la ciudad de Daireaux- y había solicitado un crédito cuyo importe fue transferido posteriormente a la cuenta de otra persona que residía en Tartagal, Salta. En ese marco, se originó una contienda negativa de competencia entre un juzgado de garantías de Trenque Lauquen y un juzgado de garantías de Orán. Llegadas las actuaciones a la Corte, esta resolvió que la incidencia debía resolverse atendiendo a razones de economía procesal y teniendo en cuenta los lugares en que se habían desarrollado los actos con relevancia típica. De ese modo, consideró que resultaba competente el juzgado de garantías de Orán, Salta, dado que allí se encontraban los mayores elementos probatorios. Esto toda vez que <b>en aquella provincia se domiciliaba la persona titular de la cuenta de destino y además el día en que se habían efectuado las transferencias</b> se había realizado una extracción en un cajero automático de esa localidad.</p>","esNovedad":true,"fecha":1678762800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1678894627220,"usuarioCreacion":4,"fechaCreacion":1678823840440,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":106255,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36038231,"numeroExpediente":2627,"anioExpediente":2021,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"AGUILERA, CINTHYA s/INCIDENTE DE INCOMPETENCIA","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"2627. "},"rec