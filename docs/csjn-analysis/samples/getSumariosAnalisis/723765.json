[{"id":2279,"orden":1,"ordenRecurso":null,"voces":"PRINCIPIO DE PRECLUSION - CADUCIDAD DE LA INSTANCIA - COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA - PRINCIPIO DE PROGRESIVIDAD - EXCEPCIONES - PLAZO - PRECLUSION","texto":"<p>La postura de quien interpone un recurso de reposición contra la resolución que denegó el pedido de suspensión del plazo para oponer excepciones con motivo del acuse de caducidad de la instancia articulado, entra en pugna con los principios de progresividad y preclusión, ya que frente a la hipótesis eventual de que su acuse de caducidad sea desestimado obtendría una prolongación incierta del plazo para oponer excepciones, lo cual no puede recibir amparo jurisdiccional.</p>","fullText":"<XML><VOCES>PRINCIPIO DE PRECLUSION - CADUCIDAD DE LA INSTANCIA - COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA - PRINCIPIO DE PROGRESIVIDAD - EXCEPCIONES - PLAZO - PRECLUSION</VOCES><TEXTO>La postura de quien interpone un recurso de reposición contra la resolución que denegó el pedido de suspensión del plazo para oponer excepciones con motivo del acuse de caducidad de la instancia articulado, entra en pugna con los principios de progresividad y preclusión, ya que frente a la hipótesis eventual de que su acuse de caducidad sea desestimado obtendría una prolongación incierta del plazo para oponer excepciones, lo cual no puede recibir amparo jurisdiccional.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1439262000000,"tomo":null,"pagina":null,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":0,"linksCitantes":null,"numeroID":5188,"anioFallo":2015,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3046,"codigoRelacion":103046,"valor":"PRINCIPIO DE PRECLUSION","activo":"N","usuarioCreacion":"ADMIN","usuarioMod":"SJC008","fechaCreacionLong":201006301000,"fechaModLong":202309151423,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":null,"usuarioModif