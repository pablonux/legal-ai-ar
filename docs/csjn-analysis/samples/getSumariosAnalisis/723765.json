reUsuarioMigrado":null,"codigo":"SJC008","mail":"vdiez@csjn.gov.ar","intentos":0,"notificacion":false},"usuarioModificacionOld":"JUR0V0","fechaModificacion":202309151345,"usuarioCreacion":null,"usuarioCreacionOld":"JUR0V0","fechaCreacion":201508131312,"alias":null,"tieneDocumento":true,"linkDocumento":"/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7237651&cache=1777042801073","tieneDictamenes":false,"conAnalisis":true,"conAnalisisPrivado":false,"conVotos":true,"caratulaWeb":"Obra Social para la Actividad Docente ","autos":"Obra Social para la Actividad Docente ","sentenciaArbitraria":false,"inconstitucional":false,"numeroExpediente":"O. 27. XLIX. ORI","caratulaLex":"OBRA SOCIAL PARA LA ACTIVIDAD DOCENTE (OSPLAD) c/ SALTA, PROVINCIA DE s/ejecución fiscal","fechaString":"11/08/2015","stringVotosMayoria":"","stringVotosVoto":"","stringVotosDisidencia":"","stringVotosDisidenciaParcial":"","stringVotosAbstencion":"","textoResaltado":"<p>La postura de quien interpone un recurso de reposición contra la resolución que denegó el pedido de suspensión del plazo para oponer excepciones con motivo del acuse de caducidad de la instancia articulado, entra en pugna con los principios de progresividad y preclusión, ya que frente a la hipótesis eventual de que su acuse de caducidad sea desestimado obtendría una prolongación incierta del plazo para oponer excepciones, lo cual no puede recibir amparo jurisdiccional.</p>","vocesResaltadas":"PRINCIPIO DE PRECLUSION - CADUCIDAD DE LA INSTANCIA - COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA - PRINCIPIO DE PROGRESIVIDAD - EXCEPCIONES - PLAZO - PRECLUSION","desvinculado":false,"stringVotosAnalisis":""},{"id":2280,"orden":2,"ordenRecurso":null,"voces":"SEGURIDAD JURIDICA - PRINCIPIO DE PRECLUSION - PRINCIPIO DE PROGRESIVIDAD - PRECLUSION","texto":"<p>Tanto el principio de progresividad como el de preclusión reconocen su fundamento en motivos de seguridad jurídica y en la necesidad de lograr una administración de justicia rápida dentro de lo razonable, evitando así que los procesos se retrotraigan a etapas ya superadas, o que se reabran los plazos procesales transcurridos, o se rehabiliten facultades procesales después de vencidos los límites legales para su ejercicio.</p>","fullText":"<XML><VOCES>SEGURIDAD JURIDICA - PRINCIPIO DE PRECLUSION - PRINCIPIO DE PROGRESIVIDAD - PRECLUSION</VOCES><TEXTO>Tanto el principio de progresividad como el de preclusión reconocen su fundamento en motivos de seguridad jurídica y en la necesidad de lograr una administración de justicia rápida dentro de lo razonable, evitando así que los procesos se retrotraigan a etapas ya superadas, o que se reabran los plazos procesales transcurridos, o se rehabiliten facultades procesales después de vencidos los límites legales para su ejercicio.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1439262000000,"tomo":null,"pagina":null,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":0,"linksCitantes":null,"numeroID":5188,"anioFallo":2015,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3517,"codigoRelacion":103517,"valor":"SEGURIDAD JURIDICA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":null,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":3046,"codigoRelacion":103046,"valor":"PRINCIPIO DE PRECLUSION","activo":"N","usuarioCreacion":"ADMIN","usuarioMod":"SJC008","fechaCreacionLong":201006301000,"fechaModLong":202309151423,"orden":null,"visible":null},"orden":2,"usuarioCreacion":null,"fechaCreacion":null,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":3047,"codigoRelacion":103047,"valor":"PRINCIPIO DE PROGRESIVIDAD","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacio