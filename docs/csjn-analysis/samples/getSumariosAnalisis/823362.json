s de los artículos 27 y 28 de la ley local 402 y 113 de la Constitución de la Ciudad Autónoma de Buenos Aires, que derivó en un conflicto jurisdiccional que fue resuelto por la Corte declarando competente al Tribunal Superior de Justicia de la Ciudad Autónoma de Buenos Aires para revisar aquella sentencia (<b>Fallos: <a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verDocumentoByIdLinksJSP.html?idDocumento=8055351&amp;cache=1772132208810\">347:2286</a></b>).</p><p style=\"text-indent:2em\">A partir de dicha decisión el Tribunal declaró inoficioso pronunciarse respecto de la queja al haber devenido abstracta la cuestión planteada.</p>","esNovedad":true,"fecha":1772074800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1772201516032,"usuarioCreacion":4,"fechaCreacion":1772132235226,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":152518,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":33715789,"numeroExpediente":78500,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":648,"descripcion":"RENDICION DE CUENTAS","idMateria":1,"tema":{"id":401,"codigo":"PAT"}},"caratula":"Recurso Queja Nº 1 - FERRARI, MARIA ALICIA Y OTRO c/ LEVINAS, GABRIEL ISAIAS s/RENDICION DE CUENTAS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"78500. "},"recurso":{"id":5620596,"expediente":{"id":33715789,"numeroExpediente":78500,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelacio