[{"id":150899,"orden":1,"ordenRecurso":null,"voces":"EXPROPIACION - TRIBUNAL DE TASACIONES - INDEMNIZACION","texto":"A los fines de la determinación del monto indemnizatorio en un supuesto de expropiación debe estarse a las conclusiones del Tribunal de Tasaciones de la Nación salvo que se evidencien hechos reveladores de error u omisión manifiestos en la determinación de los valores en razón de la fuerza probatoria que supone la idoneidad técnica de sus integrantes, los elementos de convicción en que se fundan y el grado de uniformidad con que se expiden.\r\n","fullText":"<XML><VOCES>EXPROPIACION - TRIBUNAL DE TASACIONES - INDEMNIZACION</VOCES><TEXTO>A los fines de la determinación del monto indemnizatorio en un supuesto de expropiación debe estarse a las conclusiones del Tribunal de Tasaciones de la Nación salvo que se evidencien hechos reveladores de error u omisión manifiestos en la determinación de los valores en razón de la fuerza probatoria que supone la idoneidad técnica de sus integrantes, los elementos de convicción en que se fundan y el grado de uniformidad con que se expiden.\r\n</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1567047600000,"tomo":342,"pagina":1404,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":4396,"anioFallo":2019,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1840,"codigoRelacion":101840,"valor":"EXPROPIACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201909131223,"usuarioModificacion":null,"fechaModificacion":201909131223},{"tipoVoz":{"codigoTabla":null,"codigoValor":3761,"codigoRelacion":103761,"valor":"TRIBUNAL DE TASACIONES","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":20100630