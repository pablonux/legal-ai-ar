[{"id":167451,"orden":1,"ordenRecurso":52,"voces":"SENTENCIA ARBITRARIA - PRESCRIPCION ADQUISITIVA - OMISION EN EL PRONUNCIAMIENTO - LEGITIMACION - RECURSO DE CASACION","texto":"<p>El rechazo del recurso de casación interpuesto contra la sentencia que acogió la acción de prescripción adquisitiva es arbitrario, pues aun cuando los recurrentes hubiesen contestado la demanda de forma extemporánea, el tribunal no podía soslayar que ya se les había otorgado participación en el proceso como herederos del titular registral fallecido, por lo cual se encontraban debidamente legitimados para acudir a una etapa recursiva tendiente a hacer valer sus derechos de defensa en juicio, debido proceso, propiedad e igualdad ante la ley, que se invocaban vulnerados.</p>","fullText":"<XML><VOCES>SENTENCIA ARBITRARIA - PRESCRIPCION ADQUISITIVA - OMISION EN EL PRONUNCIAMIENTO - LEGITIMACION - RECURSO DE CASACION</VOCES><TEXTO>El rechazo del recurso de casación interpuesto contra la sentencia que acogió la acción de prescripción adquisitiva es arbitrario, pues aun cuando los recurrentes hubiesen contestado la demanda de forma extemporánea, el tribunal no podía soslayar que ya se les había otorgado participación en el proceso como herederos del titular registral fallecido, por lo cual se encontraban debidamente legitimados para acudir a una etapa recursiva tendiente a hacer valer sus derechos de defensa en juicio, debido proceso, propiedad e igualdad ante la ley, que se invocaban vulnerados.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1725937200000,"tomo":347,"pagina":1215,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":3,"holding":0,"linksCitantes":null,"numeroID":7809,"anioFallo":2024,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3532,"codigoRelacion":103532,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201