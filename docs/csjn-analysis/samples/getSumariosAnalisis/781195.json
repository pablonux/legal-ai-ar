rden":4,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202212151622,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[{"nota":{"fechaModificacion":1773678427000,"fechaCreacion":"05/10/2021 09:29","id":4,"titulo":"Subsistencia de los requisitos y pronunciamiento inoficioso","categoria":{"id":1,"descripcion":"NOTA"},"activo":true,"publico":true,"orden":3,"voces":[{"tipoVoz":{"codigoTabla":null,"codigoValor":4898,"codigoRelacion":104898,"valor":"SUBSISTENCIA DE LOS REQUISITOS","activo":"S","usuarioCreacion":"JUR0V0","usuarioMod":"JUR0V0","fechaCreacionLong":201510261556,"fechaModLong":201510261556,"orden":null,"visible":null},"orden":0},{"tipoVoz":{"codigoTabla":null,"codigoValor":3092,"codigoRelacion":103092,"valor":"PRONUNCIAMIENTO INOFICIOSO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1},{"tipoVoz":{"codigoTabla":null,"codigoValor":1271,"codigoRelacion":101271,"valor":"CUESTION ABSTRACTA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2}],"datosUsuarioCreacion":"20290388849"}}],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7811951,"analisisDocumental":{"id":781195,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":22,"codigoRelacion":80022,"valor":"DECLARA ABSTRACTA LA CUESTION","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201010011430,"fechaModLong":201010011430,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":"C. A., D. c/ T., E. L. s/ IMPUGNACIÓN DE FILIACIÓN","alias":null,"caratula":"Recurso Queja Nº 1 - C. A., D. c/ T., E. L. s/IMPUGNACION DE FILIACION","inconstitucional":false,"falloDestacado":{"id":4885,"titulo":"Circunstancias sobrevinientes que tornan inoficioso un pronunciamiento de la Corte","cabecilla":"<p>El actor promovió una acción con el objeto de impugnar la paternidad respecto de la niña nacida de su matrimonio con la demandada. Afirmó que ante la sospecha de no resultar ser el padre de la niña, se había sometido a un estudio genético del que surgió que su probabilidad de paternidad era del 0%, según informe de un laboratorio. El reclamo prosperó en ambas instancias pero el Ministerio Público señaló que dicho informe prejudicial resultaba insuficiente para hacer viable el pedido, cuando el propio estudio no garantizaba la imprescindible cadena de custodia del material genético aportado ni la identidad de los involucrados y dedujo un recurso extraordinario. La Corte recordó que sus sentencias deben atender a las circunstancias existentes al momento de la decisión, aunque ellas sean sobrevinientes al mencionado recurso. Señaló que la realización de un nuevo estudio genético en legal forma por el Laboratorio de Huellas Digitales Genéticas de la Secretaría Nacional de Niñez, Adolescencia y Familia, que confirmó la exclusión del vínculo biológico de paternidad, permitía superar los reparos planteados en el remedio federal. Concluyó entonces que no cabía pronunciamiento alguno ya que dicha situación había tornado inoficiosa la decisión pendiente y declaró abstracta la cuestión.</p>","esNovedad":true,"fecha":1671073200000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1671134715650,"usuarioCreacion":11,"fechaCreacion":1671134660029,"privado":false,"posicion":7,"resumen":null},"reciboEntrada":{"id":105772,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32517625,"numeroExpediente":91969,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":11095,"descripcion":"IMPUGNACION DE FILIACION","idMateria":1,"tema":{"id":400,"codigo":"FAM"}},"caratula":"Recurso Queja Nº 1 - C. A., D. c/ T., E. L. s/IMPUGNACION DE FILIACION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"91969. "},"recurso":{"id":5420237,"expediente":{"id":32517625,"numeroExpediente":91969,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":11095,"descripcion":"IMPUGNACION DE FILIACION","idMateria":1,"tema":{"id":400,"codigo":"FAM"}},"caratula":"Recurso Queja Nº 1 - C. A., D. c/ T., E. L