[{"id":176776,"orden":1,"ordenRecurso":null,"voces":"LEGITIMACION PROCESAL - QUERELLANTE - NULIDAD PROCESAL - RECURSO EXTRAORDINARIO - COSA JUZGADA","texto":"<p>Cabe rechazar el planeo de nulidad de la sentencia que revocó el sobreseimiento de los imputados y elevó la causa a juicio con sustento en que el recurso de casación que habilitó la competencia del a quo había sido interpuesto por quien no tenía legitimación para actuar como querellante, pues la decisión de tener por querellantes a los padres de la víctima quedó firme luego de que la defensa agotara la vía recursiva local y omitiera acudir en queja ante la Corte tras declararse inadmisible su recurso extraordinario contra lo resuelto al respecto, por lo que la reiteración del agravio en el recurso federal mediante el cual la parte pretende impugnar una decisión posterior del superior tribunal de la causa, cuyo objeto es ajeno a aquella cuestión ya resuelta y pasada en autoridad de cosa juzgada, debe considerarse formalmente improcedente.</p><p>-Del dictamen de la Procuración General al que la Corte remite-</p>","fullText":"<XML><VOCES>LEGITIMACION PROCESAL - QUERELLANTE - NULIDAD PROCESAL - RECURSO EXTRAORDINARIO - COSA JUZGADA</VOCES><TEXTO>Cabe rechazar el planeo de nulidad de la sentencia que revocó el sobreseimiento de los imputados y elevó la causa a juicio con sustento en que el recurso de casación que habilitó la competencia del a quo había sido interpuesto por quien no tenía legitimación para actuar como querellante, pues la decisión de tener por querellantes a los padres de la víctima quedó firme luego de que la defensa agotara la vía recursiva local y omitiera acudir en queja ante la Corte tras declararse inadmisible su recurso extraordinario contra lo resuelto al respecto, por lo que la reiteración del agravio en el recurso federal mediante el cual la parte pretende impugnar una decisión posterior del superior tribunal de la causa, cuyo objeto es ajeno a aquella cuestión ya resuelta y pasada en autoridad de cosa juzgada, debe considerarse formalmente improcedente.-Del dictamen de la Procuración General al que la Corte remite-</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1773716400000,"tomo":349,"pagina":210,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":6,"holding":1,"linksCitantes":null,"numeroID":1702,"anioFallo":2026,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":2551,"codigoRelacion":102551,"valor":"LEGITIMACION PROCESAL","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202603171528,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":3154,"codigoRelacion":103154,"valor":"QUERELLANTE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202603171528,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":2800,"codigoRelacion":102800,"valor":"NULIDAD PROCESAL","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201006301000,"fechaModLong":201203161022,"orden":null,"visible":null},"orden":3,"usuario