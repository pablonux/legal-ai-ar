ionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"ABALLAY, MICAELA Y OTROS s/RECURSO EXTRAORDINARIO FEDERAL ","inconstitucional":false,"falloDestacado":{"id":10403,"titulo":"Acuerdo para juicio abreviado que vuelve abstracta la cuestión planteada en el recurso","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal local revocó el sobreseimiento y confirmó el auto de elevación a juicio respecto de los hechos calificados como facilitación de un lugar para el consumo de estupefacientes y homicidio culposo. La defensa planteó la nulidad de lo resuelto por entender que el recurso que había habilitado la competencia había sido interpuesto por quien no tenía legitimación para actuar como querellante. </p><p style=\"text-indent:2em\">La Corte desestimó el recurso interpuesto.</p><p style=\"text-indent:2em\">En primer lugar señaló que la decisión de tener por querellantes a los padres de la víctima había quedado firme luego de que la defensa agotara la vía recursiva local y omitiera acudir en queja ante el Tribunal tras declararse inadmisible el recurso extraordinario.</p><p style=\"text-indent:2em\">Sin embargo, sin perjuicio de ello, consideró pertinente advertir que luego de la interposición del recurso de queja los imputados y la fiscalía acordaron, con la plena conformidad de los querellantes, un juicio abreviado, lo cual no se compadece entonces con el mantenimiento efectivo de los agravios planteados en el recurso federal.</p><p style=\"text-indent:2em\">Recordó la Corte que para el ejercicio de su jurisdicción, tanto originaria como apelada, es necesario que la controversia que se intente traer a su conocimiento no se reduzca a una cuestión abstracta, debiéndose atender a las circunstancias existentes al momento de la decisión, aunque sean sobrevinientes a la interposición de la apelación federal.</p>","esNovedad":true,"fecha":1773716400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1773930363598,"usuarioCreacion":4,"fechaCreacion":1773777572066,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":154082,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":38304231,"numeroExpediente":1983,"anioExpediente":2023,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"ABALLAY, MICAELA Y OTROS s/RECURSO EXTRAORDINARIO FEDERAL ","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":