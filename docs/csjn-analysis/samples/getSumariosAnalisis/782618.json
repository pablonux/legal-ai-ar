v.ar","intentos":0,"notificacion":false},"usuarioCreacionOld":null,"fechaCreacion":202303281546,"caratulaLex":"Recurso Queja Nº 1 - HSBC BANK ARGENTINA SA Y OTROS c/ BANCO CENTRAL DE LA REPUBLICA ARGENTINA s/ENTIDADES FINANCIERAS - LEY 21526 - ART 42","autos":"HSBC BANK ARGENTINA SA Y OTROS c/ BANCO CENTRAL DE LA REPUBLICA ARGENTINA s/ ENTIDADES FINANCIERAS - LEY 21526 - ART 42","tieneDocumento":true,"linkDocumento":"/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7826181&cache=1777029589433","tieneDictamenes":false,"conAnalisis":true,"conAnalisisPrivado":false,"conVotos":true,"caratulaWeb":"HSBC BANK ARGENTINA SA Y OTROS c/ BANCO CENTRAL DE LA REPUBLICA ARGENTINA s/ ENTIDADES FINANCIERAS - LEY 21526 - ART 42","numeroExpediente":"CAF 018726/2019/1/RH001","sentenciaArbitraria":false,"inconstitucional":false,"alias":null,"stringVotosMayoria":"","stringVotosVoto":"","stringVotosDisidencia":"","stringVotosDisidenciaParcial":"","stringVotosAbstencion":"","textoResaltado":"<p>Es inadmisible el recurso de queja para impugnar la declaración de la caducidad de la instancia abierta con la interposición del recurso extraodrinario, pues como resulta del art. 285 del Código Procesal Civil y Comercial de la Nación, la queja constituye un medio de impugnación solo de resoluciones que deniegan recursos deducidos ante la Corte, sin que sea idónea para cuestionar otras decisiones, aun cuando se relacionen con el trámite de aquellos recursos. </p>","vocesResaltadas":"RECURSO DE QUEJA - CADUCIDAD DE LA INSTANCIA - DENEGATORIA DEL RECURSO EXTRAORDINARIO","desvinculado":false,"fechaString":"28/03/2023","stringVotosAnalisis":""},{"id":160611,"orden":2,"ordenRecurso":null,"voces":"RECURSO DE QUEJA - DENEGATORIA DEL RECURSO EXTRAORDINARIO","texto":"<p>Frente a la ausencia de toda decisión denegatoria -expresa o implícita- del recurso extraordinario, la queja es inadmisible.</p>","fullText":"<XML><VOCES>RECURSO DE QUEJA - DENEGATORIA DEL RECURSO EXTRAORDINARIO</VOCES><TEXTO>Frente a la ausencia de toda decisión denegatoria -expresa o implícita- del recurso extraordinario, la queja es inadmisible.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1679972400000,"tomo":346,"pagina":233,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":2,"holding":0,"linksCitantes":null,"numeroID":1221,"anioFallo":2023,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3200,"codigoRelacion":103200,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202303311047,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":5038,"codigoRelacion":105038,"valor":"DENEGATORIA DEL RECURSO EXTRAORDINARIO","activo":"S","usuarioCreacion":"SJC008","usuarioMod":"SJC008","fechaCreacionLong":202303300856,"fechaModLong":202303300856,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202303311047,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7826181,"analisisDocumental":{"id":782618,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreaci