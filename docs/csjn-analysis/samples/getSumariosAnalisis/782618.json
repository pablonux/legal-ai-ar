[{"id":160553,"orden":1,"ordenRecurso":null,"voces":"RECURSO DE QUEJA - CADUCIDAD DE LA INSTANCIA - DENEGATORIA DEL RECURSO EXTRAORDINARIO","texto":"<p>Es inadmisible el recurso de queja para impugnar la declaración de la caducidad de la instancia abierta con la interposición del recurso extraodrinario, pues como resulta del art. 285 del Código Procesal Civil y Comercial de la Nación, la queja constituye un medio de impugnación solo de resoluciones que deniegan recursos deducidos ante la Corte, sin que sea idónea para cuestionar otras decisiones, aun cuando se relacionen con el trámite de aquellos recursos. </p>","fullText":"<XML><VOCES>RECURSO DE QUEJA - CADUCIDAD DE LA INSTANCIA - DENEGATORIA DEL RECURSO EXTRAORDINARIO</VOCES><TEXTO>Es inadmisible el recurso de queja para impugnar la declaración de la caducidad de la instancia abierta con la interposición del recurso extraodrinario, pues como resulta del art. 285 del Código Procesal Civil y Comercial de la Nación, la queja constituye un medio de impugnación solo de resoluciones que deniegan recursos deducidos ante la Corte, sin que sea idónea para cuestionar otras decisiones, aun cuando se relacionen con el trámite de aquellos recursos. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1679972400000,"tomo":346,"pagina":233,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":2,"holding":0,"linksCitantes":null,"numeroID":1221,"anioFallo":2023,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3200,"codigoRelacion":103200,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"