:null,"visible":null},"orden":0},{"tipoVoz":{"codigoTabla":null,"codigoValor":3200,"codigoRelacion":103200,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":0}],"datosUsuarioCreacion":"20346628686"}}],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7826181,"analisisDocumental":{"id":782618,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":250007,"valor":"Tributario - Bancario","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"HSBC BANK ARGENTINA SA Y OTROS c/ BANCO CENTRAL DE LA REPUBLICA ARGENTINA s/ ENTIDADES FINANCIERAS - LEY 21526 - ART 42","alias":null,"caratula":"Recurso Queja Nº 1 - HSBC BANK ARGENTINA SA Y OTROS c/ BANCO CENTRAL DE LA REPUBLICA ARGENTINA s/ENTIDADES FINANCIERAS - LEY 21526 - ART 42","inconstitucional":false,"falloDestacado":{"id":5223,"titulo":"Improcedencia de la interposición del recurso de queja ante la Corte sin previa denegación del recurso extraordinario","cabecilla":"<p>La actora interpuso recurso extraordinario contra la sentencia de cámara y ésta declaró la caducidad de la instancia abierta con dicha interposición con fundamento en que había transcurrido el plazo de tres meses sin que la recurrente impulsara el procedimiento. Contra ese pronunciamiento la recurrente dedujo recurso de queja ante la Corte, que fue desestimado. <b>Recordó que la queja constituye un medio de impugnación solo de resoluciones que deniegan recursos deducidos ante el Tribunal, sin que sea idónea para cuestionar otras decisiones, aun cuando se relacionen con el trámite de aquellos recursos</b>. Frente a la ausencia de toda decisión denegatoria -expresa o implícita- del recurso extraordinario concluyó entonces que la queja resultaba inadmisible.</p>","esNovedad":true,"fecha":1679972400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1680111055420,"usuarioCreacion":11,"fechaCreacion":1680029106851,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":107608,"secretaria":{"id":14,"tipo":"S","descripcion":"Sec. Judicial Nº 7","orden":7,"activo":"S","codigoRelacion":250007,"descripcionWeb":"Tributario- Bancario","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":3464674,"numeroExpediente":21008258,"anioExpediente":2008,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":22,"codigo":"22","abreviatura":"FPA","descripcion":"Justicia Federal de Paraná","estado":0,"descripcionLarga":"FPA - Justicia Federal de Paraná"},"objetoJuicio":{"id":3054,"descripcion":"CONTENCIOSO","idMateria":112,"tema":null},"caratula":"RIO URUGUAY  COOP DE SEGUROS LTDA c/ ESTADO NACIONAL - AFIP s/CONTENCIOSO","verificacionMesa":"M","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"21008258. "},"recurso":{"id":5968960,"expediente":{"id":3464674,"numeroExpediente":21008258,"anioExpediente":2008,"tomoExpediente":null,"let