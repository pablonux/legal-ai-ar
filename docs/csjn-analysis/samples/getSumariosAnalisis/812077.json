[{"id":172680,"orden":1,"ordenRecurso":19,"voces":"ADOPCION - SENTENCIA ARBITRARIA - OMISION EN EL PRONUNCIAMIENTO","texto":"<p>Es arbitraria la sentencia que, sustentada en la falta de legitimación del progenitor de la niña para intervenir en el proceso de adopción una vez declarada la situación de adoptabilidad, omitió pronunciarse sobre el pedido que había formulado para que se mantuviera el vínculo jurídico en los términos previstos por el artículo 621 del Código Civil y Comercial de la Nación, pues su consideración había sido expresamente diferida por la jueza de grado para la oportunidad del dictado de la sentencia de adopción; pronunciamiento que no emitió, no obstante haber analizado la aplicación del citado artículo respecto de los hermanos biológicos de aquella.</p>","fullText":"<XML><VOCES>ADOPCION - SENTENCIA ARBITRARIA - OMISION EN EL PRONUNCIAMIENTO</VOCES><TEXTO>Es arbitraria la sentencia que, sustentada en la falta de legitimación del progenitor de la niña para intervenir en el proceso de adopción una vez declarada la situación de adoptabilidad, omitió pronunciarse sobre el pedido que había formulado para que se mantuviera el vínculo jurídico en los términos previstos por el artículo 621 del Código Civil y Comercial de la Nación, pues su consideración había sido expresamente diferida por la jueza de grado para la oportunidad del dictado de la sentencia de adopción; pronunciamiento que no emitió, no obstante haber analizado la aplicación del citado artículo respecto de los hermanos biológicos de aquella.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1752721200000,"tomo":348,"pagina":751,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":3,"holding":0,"linksCitantes":null,"numeroID":6134,"anioFallo":2025,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":575,"codigoRelacion":100575,"valor":"ADOPCION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202507171545,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":3532,"codigoRelacion":103532,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202507171545,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":4034,"codigoRelacion":104034,"valor":"OMISION EN EL PRONUNCIAMIENTO ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201103211456,"fechaModLong":201103211456,"orden":null,"visible":null},"orden":3,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202507171545,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":350,"citasRex":[],"idFallo":8120771,"analisisDocumental":{"id":812077,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"R., V. s/SITUACION - EXPTE NRO. MEX-10761/18 DEL JUZGADO DE FAMILIA, NIÑEZ Y ADOLESCENCIA NRO. 4 (DIGITAL)","inconstitucional":false,"falloDestacado":{"id":9163,"titulo":"Adopción: subsistencia del vínculo con el progenitor","cabecilla":"<p style=\"text-indent:2em\">En oportunidad de notificarse la sentencia que declaraba la situación de adoptabilidad de la niña y otorgaba su guarda, el progenitor -que la había reconocido como hija biológica y solicitado su restitución y un régimen de comunicación- pidió que se mantuviera subsistente el vínculo familiar en virtud de lo dispuesto en el artículo 621 del Código Civil y Comercial de la Nación. La jueza otorgó la adopción plena sin pronunciarse sobre dicha petición.</p><p style=\"text-indent:2em\">La Corte dejó sin efecto esta sentencia.</p><p style=\"text-indent:2em\">Señaló que, en cuanto se fundó solo en la falta de legitimación del progenitor para intervenir en el proceso de adopción una vez declarada la situación de adoptabilidad de su hija, omitió un pronunciamiento sobre el pedido que había formulado para que se mantuviera el vínculo jurídico cuando su consideración había sido expresamente diferida por la jueza para la oportunidad del dictado de la sentencia de adopción.</p><p style=\"text-indent:2em\">Agregó que no justificaba dicha omisión que el mencionado artículo del código de fondo prevea que al otorgar la adopción el juez “puede” mantener subsistente el vínculo jurídico con uno o varios parientes de la familia de origen, como así tampoco que las normas locales citadas por el tribunal a quo o las disposiciones nacionales (artículo 617, inciso a del Código Civil y Comercial de la Nación) establezcan que en el proceso de adopción las partes son los pretensos adoptantes y el pretenso adoptado.</p><p style=\"text-indent:2em\">Finalmente, tuvo en cuenta que el pronunciamiento omitió considerar el pedido del progenitor no obstante haber analizado la aplicación del invocado artículo 621 respecto de los hermanos biológicos de la niña.</p>","esNovedad":true,"fecha":1752721200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1752853975143,"usuarioCreacion":11,"fechaCreacion":1752778518791,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":140679,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":39360612,"numeroExpediente":1996,"anioExpediente":2024,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"R.,