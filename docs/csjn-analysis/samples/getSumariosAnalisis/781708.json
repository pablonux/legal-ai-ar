r":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"GOYA, ROCIO AYELEN Y OTRO c/ AEROVIAS DE MEXICO SAC DE CV s/ DAÑOS Y PERJUICIOS","alias":null,"caratula":"GOYA, ROCIO AYELEN Y OTRO c/ AEROVIAS DE MEXICO SAC DE CV s/DAÑOS Y PERJUICIOS","inconstitucional":false,"falloDestacado":{"id":5101,"titulo":"Competencia federal para el reclamo de daños y perjuicios basado en la suspensión de vuelos internacionales","cabecilla":"<p>Frente a un reclamo a una empresa aérea de los daños y perjuicios ocasionados a raíz de la suspensión de vuelos internacionales como consecuencia de las medidas adoptadas por el Covid-19, que originó que las reclamantes quedaran varadas en otro país durante dos meses y finalmente tuvieran que adquirir nuevos boletos a través de otra compañía, se generó un conflicto negativo de competencia. La Justicia federal rechazó la radicación por interpretar que el supuesto incumplimiento contractual se relacionaba de modo directo con los derechos de los usuarios del transporte aerocomercial y de los consumidores en general y la justicia nacional en lo comercial tampoco la aceptó por considerar que la ley 13.998 establece la competencia civil y comercial federal para las causas que versen sobre hechos, actos y contratos concernientes al derecho aeronáutico. La Corte atribuyó la competencia al fuero federal, al que le incumbe el juzgamiento de los asuntos relacionados principalmente con el servicio de transporte aéreo comercial, entendido como la serie de actos destinados al traslado en aeronave de personas o de cosas, de un aeródromo a otro, y sujetas a los preceptos del Código Aeronáutico, su reglamentación y las disposiciones operativas de la autoridad aeronáutica.</p>","esNovedad":true,"fecha":1677553200000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1677696396902,"usuarioCreacion":11,"fechaCreacion":1677676106969,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":106262,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35111014,"numeroExpediente":11006,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":1341,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":3,"tema":{"id":444,"codigo":"DAÑOSYPER"}},"caratula":"GOYA, ROCIO AYELEN Y OTRO c/ AEROVIAS DE MEXICO SAC DE CV s/DAÑOS Y PERJUICIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"11006. "},"recurso":{"id":6097639,"expediente":{"id":35111014,"numeroExpediente":11006,"anioExpediente":2020,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":10,"codigo":"10","abreviatura":"COM","descripcion":"Camara Nacional de Apelaciones en lo Comercial","estado":0,"descripcionLarga":"COM - Camara Nacional de Apelaciones en lo Comercial"},"objetoJuicio":{"id":1341,"descripcion":"DAÑOS Y PERJUICIOS","idMateria":3,"tema":{"id":444,"codigo":"DAÑOSYPER"}},"caratula":"GOYA, ROCIO AYELEN Y OTRO c/ AEROVIAS DE MEXICO SAC DE CV s/DAÑOS Y PERJUICIOS","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"11006. "},"tipoRecurso":{"id":1103,"codigo":"COM","descripcion":"COMPETENCIA"},"clav