00856,"orden":null,"visible":null},"orden":0},{"tipoVoz":{"codigoTabla":null,"codigoValor":3200,"codigoRelacion":103200,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":0}],"datosUsuarioCreacion":"20346628686"}}],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7862431,"analisisDocumental":{"id":786243,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":12,"codigoRelacion":80012,"valor":"DESESTIMA ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201009220853,"fechaModLong":201009220853,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - WANG, DINGJIAN c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":5762,"titulo":"Recurso de queja sin previa denegación del recurso extraordinario","cabecilla":"<p>La cámara declaró la caducidad de la instancia abierta con la interposición de un recurso extraordinario y contra este pronunciamiento el recurrente dedujo un recurso de queja. La Corte desestimó esta presentación. Recordó que la queja constituye un medio de impugnación solo de resoluciones que deniegan recursos deducidos para ante la Corte, para lo cual es preciso que se haya interpuesto y denegado una apelación sobre el motivo del agravio. Señaló que la vía del recurso directo no es idónea para cuestionar otras resoluciones aun cuando se relacionen con el trámite del recurso extraordinario y que tales asuntos, de suscitar agravios de carácter federal, deben ser articulados según las formas y los plazos previstos en el art. 257 del Código Procesal Civil y Comercial de la Nación.</p>","esNovedad":true,"fecha":1692241200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1692375527488,"usuarioCreacion":11,"fechaCreacion":1692298977356,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":111797,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":34267514,"numeroExpediente":49522,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1192,"descripcion":"RECURSO DIRECTO DNM","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"Recurso Queja Nº 1 - YUE, FAMING c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"49522. "},"recurso":{"id":5726058,"expediente":{"id":34267514,"numeroExpediente":49522,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviat