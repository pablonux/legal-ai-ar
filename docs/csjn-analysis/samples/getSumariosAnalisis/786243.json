[{"id":161926,"orden":1,"ordenRecurso":null,"voces":"RECURSO EXTRAORDINARIO - CADUCIDAD DE LA INSTANCIA - RECURSO DE QUEJA","texto":"<p>Corresponde desestimar el recurso de queja deducido contra la sentencia que declaró la caducidad de la instancia abierta con la interposición del recurso extraordinario, pues como resulta del art. 285 del Código Procesal Civil y Comercial de la Nación, la queja en él contemplada constituye un medio de impugnación solo de resoluciones que deniegan recursos deducidos para ante la Corte, para lo cual es preciso que se haya interpuesto y denegado una apelación sobre el motivo del agravio. </p>","fullText":"<XML><VOCES>RECURSO EXTRAORDINARIO - CADUCIDAD DE LA INSTANCIA - RECURSO DE QUEJA</VOCES><TEXTO>Corresponde desestimar el recurso de queja deducido contra la sentencia que declaró la caducidad de la instancia abierta con la interposición del recurso extraordinario, pues como resulta del art. 285 del Código Procesal Civil y Comercial de la Nación, la queja en él contemplada constituye un medio de impugnación solo de resoluciones que deniegan recursos deducidos para ante la Corte, para lo cual es preciso que se haya interpuesto y denegado una apelación sobre el motivo del agravio. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1692241200000,"tomo":346,"pagina":885,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":1,"holding":0,"linksCitantes":null,"numeroID":4487,"anioFallo":2023,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3210,"codigoRelacion":103210,"valor":"RECURSO EXTRAORDINARIO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsu