ateria":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":250004,"valor":"Administrativo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Recurso Queja Nº 1 - WANG, DINGJIAN c/ EN-M INTERIOR OP Y V-DNM s/RECURSO DIRECTO DNM","inconstitucional":false,"falloDestacado":{"id":5762,"titulo":"Recurso de queja sin previa denegación del recurso extraordinario","cabecilla":"<p>La cámara declaró la caducidad de la instancia abierta con la interposición de un recurso extraordinario y contra este pronunciamiento el recurrente dedujo un recurso de queja. La Corte desestimó esta presentación. Recordó que la queja constituye un medio de impugnación solo de resoluciones que deniegan recursos deducidos para ante la Corte, para lo cual es preciso que se haya interpuesto y denegado una apelación sobre el motivo del agravio. Señaló que la vía del recurso directo no es idónea para cuestionar otras resoluciones aun cuando se relacionen con el trámite del recurso extraordinario y que tales asuntos, de suscitar agravios de carácter federal, deben ser articulados según las formas y los plazos previstos en el art. 257 del Código Procesal Civil y Comercial de la Nación.</p>","esNovedad":true,"fecha":1692241200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1692375527488,"usuarioCreacion":11,"fechaCreacion":1692298977356,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":111797,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codi