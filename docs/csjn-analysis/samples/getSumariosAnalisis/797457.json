sible":null},"orden":4,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202405290834,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":5054,"codigoRelacion":105054,"valor":"CASACION HORIZONTAL","activo":"S","usuarioCreacion":"SJC008","usuarioMod":"SJC008","fechaCreacionLong":202406061412,"fechaModLong":202406061412,"orden":null,"visible":null},"orden":5,"usuarioCreacion":{"id":12,"nombreUsuario":"27378371215","apellido":"Diez","nombre":"Victoria","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847527000,"nombreUsuarioMigrado":null,"codigo":"SJC008","mail":"vdiez@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202406061546,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":133,"citasRex":[],"idFallo":7974571,"analisisDocumental":{"id":797457,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":80009,"valor":"ADMITE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231243,"fechaModLong":201008231243,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"MAIDANA, KARINA DE LOURDES Y OTROS s/SUP/ROBO CALIFICADO-CAPITAL-EXPTE. N° 8768 C.C.1","inconstitucional":false,"falloDestacado":{"id":6924,"titulo":"Casación horizontal: supuesto que proviene de la jurisdicción local","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal provincial revocó la absolución dictada por un tribunal oral y condenó a los imputados como autores del delito de robo calificado. </p><p style=\"text-indent:2em\">Ante el recurso de los condenados la Corte declaró admisibles los recursos en tanto se encontraba en tela de juicio el alcance del <b>derecho a recurrir ampliamente la primera sentencia condenatoria</b>.</p><p style=\"text-indent:2em\">Recordó que en el precedente \"P., S.M\" (Fallos: 342:2389) el Tribunal estableció que ante el dictado de una sentencia condenatoria en sede casatoria, la garantía de la doble instancia que asiste al imputado debe ser salvaguardada directamente en dicho ámbito mediante la interposición de un recurso de casación que deberán resolver otros magistrados que integren ese tribunal, sin necesidad de que el imputado deba previamente recurrir a la Corte para obtener una decisión que ordene que tenga lugar dicha revisión.</p><p style=\"text-indent:2em\">Señaló que si bien dichas consideraciones fueron vertidas con motivo del recurso deducido ante la denegación por la Cámara Federal de Casación Penal, éstas resultaban <b>aplicables al caso en el que los recurrentes procuraban obtener el doble conforme de un fallo condenatorio dictado por el superior tribunal provincial</b>.</p><p style=\"text-indent:2em\">Agregó que como el caso constituía la primera oportunidad en que se aplicaba dicho criterio respecto de un supuesto proveniente de la jurisdicción local resultaba necesario fijar la línea divisoria de aplicación de esta nueva jurisprudencia respecto al recaudo de superior tribunal de la causa y precisar que ésta no regirá en las causas en que la sentencia condenatoria dictada por el superior tribunal provincial haya sido notificada con anterioridad a dicho pronunciamiento.</p>","esNovedad":true,"fecha":1716865200000,"relevancia":2,"usuarioModificacion":11,"fechaModificacion":1716985872663,"usuarioCreacion":11,"fechaCreacion":1716985605920,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":121604,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28775813,"numeroExpediente":1310,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MAIDANA, KARINA DE LOURDES Y OTROS s/SUP/ROBO CALIFICADO-CAPITAL-EXPTE. N° 8768 C.C.1","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1310. "},"recurso":{"id":4916782,"expediente":{"id":28775813,"numeroExpediente":1310,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"MAIDANA, KARINA DE LOURDES Y OTROS s/SUP/ROBO CALIFICADO-CAPITAL-EXPTE. N° 8768 C.C.1","verifica