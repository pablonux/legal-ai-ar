[{"id":173700,"orden":1,"ordenRecurso":7,"voces":"SENTENCIA ARBITRARIA - VERIFICACION DE CREDITOS - MULTAS - APORTES PREVISIONALES - APRECIACION DE LA PRUEBA - VALORACION DE CIRCUNSTANCIAS DE HECHO Y PRUEBA","texto":"<p>La sentencia del superior tribunal provincial que confirmó el rechazo de la verificación de la deuda reclamada por la AFIP, sobre la base de que el ente recaudador no había cumplido con la carga de acreditar su pretensión en el proceso concursal, es arbitraria, pues omitió ponderar que los documentos obrantes en el expediente que constituyen, en los términos de la resolución general (AFIP) 1566/2010, los actos administrativos mediante los cuales el organismo aplicó a la sociedad fallida diferentes multas por infracciones al régimen de la seguridad social.</p><p>-Del dictamen de la Procuración General al que la Corte remite-</p>","fullText":"<XML><VOCES>SENTENCIA ARBITRARIA - VERIFICACION DE CREDITOS - MULTAS - APORTES PREVISIONALES - APRECIACION DE LA PRUEBA - VALORACION DE CIRCUNSTANCIAS DE HECHO Y PRUEBA</VOCES><TEXTO>La sentencia del superior tribunal provincial que confirmó el rechazo de la verificación de la deuda reclamada por la AFIP, sobre la base de que el ente recaudador no había cumplido con la carga de acreditar su pretensión en el proceso concursal, es arbitraria, pues omitió ponderar que los documentos obrantes en el expediente que constituyen, en los términos de la resolución general (AFIP) 1566/2010, los actos administrativos mediante los cuales el organismo aplicó a la sociedad fallida diferentes multas por infracciones al régimen de la seguridad social.-Del dictamen de la Procuración General al que la Corte remite-</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1758596400000,"tomo":348,"pagina":1149,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":5,"holding":0,"linksCitantes":null,"numeroID":8727,"anioFallo":2025,"vocesSumario":[{"tipoVoz":{"codigoTabla":null