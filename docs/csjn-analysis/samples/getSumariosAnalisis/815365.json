so":331,"citasRex":[],"idFallo":8153651,"analisisDocumental":{"id":815365,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":80002,"valor":"REVOCA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":250001,"valor":"Civil - Comercial","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111335,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"TUCUMAN VIDRIOS SRL s/QUIEBRA DECLARADA S/ INCIDENTE DE REVISION","inconstitucional":false,"falloDestacado":{"id":9423,"titulo":"Rechazo de la verificación de la deuda reclamada por la AFIP: arbitrariedad de la sentencia","cabecilla":"<p style=\"text-indent:2em\">El superior tribunal provincial desestimó el recurso de casación interpuesto por la Administración Federal de Ingresos Públicos - Dirección General Impositiva y rechazó la verificación de la deuda reclamada sobre la base de que el ente recaudador no había cumplido con la carga de acreditar su pretensión en el proceso concursal, pues no había adjuntado resolución alguna mediante la cual le hubiere impuesto a la empresa actora las multas que pretendía verificar.</p><p style=\"text-indent:2em\">La Corte descalificó este pronunciamiento con fundamento en la doctrina de la arbitrariedad de sentencias.</p><p style=\"text-indent:2em\">Sostuvo que, al resolver de ese modo, el tribunal provincial omitió ponderar que los documentos obrantes en el expediente constituían, en los términos de la resolución general (AFIP) 1566/2010, los actos administrativos mediante los cuales el organismo aplicó a la sociedad fallida diferentes multas por infracciones al régimen de la seguridad social y que, en dichos actos, el ente recaudador puso en conocimiento de la empresa el derecho que le asistía a interponer, contra esas sanciones, los recursos previstos en diferentes normas.</p><p style=\"text-indent:2em\">Concluyó así que el a quo debió evaluar tales cuestiones, a fin de determinar si resultaba procedente o no la verificación de las sanciones reclamadas por la AFIP.</p>","esNovedad":true,"fecha":1758596400000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1758803911329,"usuarioCreacion":11,"fechaCreacion":1758660327083,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":143721,"secretaria":{"id":8,"tipo":"S","descripcion":"Sec. Judicial Nº 1","orden":1,"activo":"S","codigoRelacion":250001,"descripcionWeb":"Civil y Comercial","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36968830,"numeroExpediente":82504,"anioExpediente":2009,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":1,"codigo":"1","abreviatura":"CIV","descripcion":"Cámara Nacional de Apelaciones en lo Civil","estado":0,"descripcionLarga":"CIV - Cámara Nacional de Apelaciones en lo Civil"},"objetoJuicio":{"id":8496,"descripcion":"DAÑOS Y PERJUICIOS(ACC.TRAN. C/LES. O MUERTE)","idMateria":1,"tema