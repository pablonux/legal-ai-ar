[{"id":160471,"orden":1,"ordenRecurso":null,"voces":"COMPETENCIA FEDERAL - COMPETENCIA - MEDIO AMBIENTE - PRINCIPIO PRECAUTORIO - ECONOMIA PROCESAL","texto":"<p>A la luz del principio precautorio (art. 4° de la ley 25.675) y con la finalidad de evitar la profusión de trámites, situación que va en desmedro del principio de economía procesal y del buen servicio de justicia, así como de impedir la perduración de situaciones que podrían llegar a configurar un caso de privación jurisdiccional para las partes, corresponde mantener la competencia de la justicia federal para dictar sentencia definitiva en la acción de amparo ambiental iniciada por obras que podrían afectar yacimientos paleontológicos y arqueológicos; ello a fin de preservar las garantías constitucionales de defensa en juicio y del debido proceso que asisten a las partes, ante la necesidad de obtener una rápida y eficaz decisión judicial que ponga fin a la controversia.</p><p>-Del dictamen de la Procuración General al que la Corte remite-</p>","fullText":"<XML><VOCES>COMPETENCIA FEDERAL - COMPETENCIA - MEDIO AMBIENTE - PRINCIPIO PRECAUTORIO - ECONOMIA PROCESAL</VOCES><TEXTO>A la luz del principio precautorio (art. 4° de la ley 25.675) y con la finalidad de evitar la profusión de trámites, situación que va en desmedro del principio de economía procesal y del buen servicio de justicia, así como de impedir la perduración de situaciones que podrían llegar a configurar un caso de privación jurisdiccional para las partes, corresponde mantener la competencia de la justicia federal para dictar sentencia definitiva en la acción de amparo ambiental iniciada por obras que podrían afectar yacimientos paleontológicos y arqueológicos; ello a fin de preservar las garantías constitucionales de defensa en juicio y del debido proceso que asisten a las partes, ante la necesidad de obtener una rápida y eficaz decisión judicial que ponga fin a la controversia.-Del dictamen de la Procuración General al que la Corte remite-</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1678762800000,"tomo":346,"pagina":175,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":11,"holding":0,"linksCitantes":null,"numeroID":872,"anioFallo":2023,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3931,"codigoRelacion":103931,"valor":"COMPETENCIA FEDERAL ","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201010051033,"fechaModLong":201010051033,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202303141610,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":964,"codigoRelacion":100964,"valor":"COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202303141610,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":2712,"codigoRelacion":102712,"valor":"MEDIO AMBIENTE","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":3,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fec