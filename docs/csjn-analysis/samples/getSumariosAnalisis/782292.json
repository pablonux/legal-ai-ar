null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":230001,"valor":"RECURSO DE QUEJA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011307,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":9,"codigoRelacion":250009,"valor":"Ambiental","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":"GODOY ALEJANDRO DAVID DOMINGO Y OTRO c/ SANTI ALEJANDRO LUIS Y OTRO s/SUMARISIMO","alias":null,"caratula":"Recurso Queja Nº 6 - GODOY ALEJANDRO DAVID DOMINGO Y OTRO c/ SANTI ALEJANDRO LUIS Y OTRO s/SUMARISIMO","inconstitucional":false,"falloDestacado":{"id":5162,"titulo":"La competencia y el principio precautorio","cabecilla":"<p>La Cámara Federal de Apelaciones de Mar del Plata hizo parcialmente lugar a la acción de amparo ambiental y suspendió las obras realizadas en el “Parador Frontera Sur” del vivero dunícola “Florentino Ameghino”, hasta que se presente la evaluación y declaración de impacto ambiental correspondientes y, en consecuencia, declaró la incompetencia de la justicia federal, remitiendo los autos a la Cámara Civil y Comercial de la Provincia de Buenos Aires en orden a la naturaleza de la pretensión. Para decidir de esa manera, consideró que se trata de una cuestión medioambiental de derecho público local. <b>Cuestionada la decisión ante la Corte, ésta dejó sin efecto la sentencia</b>.  En ese orden, a la luz del principio precautorio (art. 4° de la ley 25.675) y con la finalidad de evitar la profusión de trámites, situación que va en desmedro del principio de economía procesal y del buen servicio de justicia, así como de impedir la perduración de situaciones que, de mantenerse en el tiempo, podrían llegar a configurar un caso de privación jurisdiccional para las partes (debido al tiempo que lleva el trámite de la causa), <b>decidió mantener la competencia de la justicia federal </b>para dictar sentencia definitiva a fin de preservar las garantías constitucionales de defensa en juicio y del debido proceso que asisten a las partes, ante la necesidad de obtener una rápida y eficaz decisión judicial que ponga fin a la controversia.</p>","esNovedad":true,"fecha":1678762800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1678894614173,"usuarioCreacion":4,"fechaCreacion":1678823759769,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":107243,"secretaria":{"id":20,"tipo":"S","descripcion":"Sec. de Juicios Ambientales","orden":10,"activo":"S","codigoRelacion":250009,"descripcionWeb":"Ambiental","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":35531264,"numeroExpediente":21091802,"anioExpediente":2010,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":19,"codigo":"19","abreviatura":"FMP","descripcion":"Justicia Federal de Mar del Plata","estado":0,"descripcionLarga":"FMP - Justicia Federal de Mar del Plata"},"objetoJuicio":{"id":9163,"descripcion":"SUMARISIMO","idMateria":112,"tema":null},"caratula":"Recurso Queja Nº 6 - GODOY ALEJANDRO DAVID DOMINGO Y OTRO c/ SANTI ALEJANDRO LUIS Y OTRO s/SUMARISIMO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"21091802. "},"recurso":{"id":6044391,"expediente":{"id":35531264,"numeroExpediente":21091802,"anioExpediente":2010,"tomo