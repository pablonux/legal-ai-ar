entos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7769141,"analisisDocumental":{"id":776914,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":4,"codigoRelacion":80004,"valor":"DEJA SIN EFECTO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181259,"fechaModLong":201008181259,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":13,"codigoRelacion":250013,"valor":"Salud","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201709221157,"fechaModLong":201709221157,"orden":null,"visible":null},"caratulaFallo":"JACOBO, PATRICIA ANDREA c/ INSTITUTO DE OBRA SOCIAL DE LA PROVINCIA DE ENTRE RÍOS s/ ACCIÓN DE AMPARO","alias":null,"caratula":"JACOBO, PATRICIA ANDREA c/ INSTITUTO DE OBRA SOCIAL DE LA PROVINCIA DE ENTRE RIOS s/ACCION DE AMPARO","inconstitucional":false,"falloDestacado":{"id":4303,"titulo":"Sentencia arbitraria en materia de prestaciones médico asistenciales","cabecilla":"<p>El superior tribunal provincial rechazó la incorporación de la peticionaria como afiliada al Instituto demandado. Recurrida la resolución por ante la Corte, ésta por unanimidad revocó la sentencia y ordenó dictar un nuevo pronunciamiento sobre la base de que el tribunal provincial, si bien mencionó algunas de las probanzas de la causa, omitió ponderar que con ellas se demuestra, por un lado, que la actora no cuenta con la afiliación señalada y, por otro, que padece una afección de salud por la que requiere tratamiento. Dichas circunstancias -a criterio de la Corte- son suficientes para poner de manifiesto que el apartamiento de las constancias de la causa en que incurrió el tribunal provincial afecta de modo directo e inmediato la garantía constitucional de defensa en juicio que asiste a la recurrente.</p>","esNovedad":true,"fecha":1660273200000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1660671191922,"usuarioCreacion":11,"fechaCreacion":1660329277737,"privado":false,"posicion":4,"resumen":null},"reciboEntrada":{"id":34700,"secretaria":{"id":13,"tipo":"S","descripcion":"Sec. Judicial Nº 6","orden":6,"activo":"S","codigoRelacion":250006,"descripcionWeb":"Laboral","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":32589601,"numeroExpediente":1923,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"JACOBO, PATRICIA ANDREA c/ INSTITUTO DE OBRA SOCIAL DE LA PROVINCIA DE ENTRE RIOS s/ACCION DE AMPARO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"1923. "},"recurso":{"id":5435133,"expediente":{"id":32589601,"numeroExpediente":1923,"anioExpediente":2018,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":9801,"descripcion":"A DETERMINAR","idMateria":0,"tema":null},"caratula":"JACOBO, PATRICIA ANDREA c/ INSTITUTO DE OBRA SOCIAL DE LA