[{"id":158451,"orden":1,"ordenRecurso":null,"voces":"DERECHO A LA SALUD - AFILIACION - SENTENCIA ARBITRARIA - APARTAMIENTO DE CONSTANCIAS DE LA CAUSA - DEFENSA EN JUICIO - OBRA SOCIAL","texto":"<p>Es arbitraria la sentencia que rechazó la acción de amparo promovida contra una obra social para que se ordenara la incorporación de la actora como afiliada, toda vez que omitió ponderar que conforme las pruebas de la causa la actora no contaba con la afiliación a otra obra social y padecía una afección de salud que requería tratamiento, es decir el apartamiento de las constancias de la causa en que incurrió el tribunal a quo afectó de modo directo e inmediato la garantía constitucional de defensa en juicio que asiste a la recurrente. </p>","fullText":"<XML><VOCES>DERECHO A LA SALUD - AFILIACION - SENTENCIA ARBITRARIA - APARTAMIENTO DE CONSTANCIAS DE LA CAUSA - DEFENSA EN JUICIO - OBRA SOCIAL</VOCES><TEXTO>Es arbitraria la sentencia que rechazó la acción de amparo promovida contra una obra social para que se ordenara la incorporación de la actora como afiliada, toda vez que omitió ponderar que conforme las pruebas de la causa la actora no contaba con la afiliación a otra obra social y padecía una afección de salud que requería tratamiento, es decir el apartamiento de las constancias de la causa en que incurrió el tribunal a quo afectó de modo directo e inmediato la garantía constitucional de defensa en juicio que asiste a la recurrente. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1660273200000,"tomo":345,"pagina":683,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":3,"holding":0,"linksCitantes":null,"numeroID":4313,"anioFallo":2022,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1444,"codigoRelacion":101444,"valor":"DERECHO A LA SALUD","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},