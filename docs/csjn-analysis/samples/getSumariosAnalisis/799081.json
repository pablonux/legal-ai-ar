[{"id":166653,"orden":1,"ordenRecurso":null,"voces":"PRORROGA DE LA COMPETENCIA - EJECUCION FISCAL - CIUDAD AUTONOMA DE BUENOS AIRES - COMPETENCIA FEDERAL - COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA","texto":"<p>Toda vez que Gobierno de la Ciudad de Buenos Aires -ejecutante en la causa- ha prestado su conformidad con la tramitación del proceso ante los tribunales en lo Contencioso Administrativo Federal, ello debe ser entendido como una renuncia a la prerrogativa de litigar en la competencia originaria y una prórroga a favor del mencionado fuero.</p>","fullText":"<XML><VOCES>PRORROGA DE LA COMPETENCIA - EJECUCION FISCAL - CIUDAD AUTONOMA DE BUENOS AIRES - COMPETENCIA FEDERAL - COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA</VOCES><TEXTO>Toda vez que Gobierno de la Ciudad de Buenos Aires -ejecutante en la causa- ha prestado su conformidad con la tramitación del proceso ante los tribunales en lo Contencioso Administrativo Federal, ello debe ser entendido como una renuncia a la prerrogativa de litigar en la competencia originaria y una prórroga a favor del mencionado fuero.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1720666800000,"tomo":347,"pagina":823,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":1,"holding":0,"linksCitantes":null,"numeroID":5975,"anioFallo":2024,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3898,"codigoRelacion":103898,"valor":"PRORROGA DE LA COMPETENCIA ","activo":"S","usuarioCreacion":"JUR202","usuarioMod":"JUR202","fechaCreacionLong":201009221305,"fechaModLong":201009221305,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202407111451,"usuarioMo