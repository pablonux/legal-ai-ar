haModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":966,"codigoRelacion":100966,"valor":"COMPETENCIA ORIGINARIA DE LA CORTE SUPREMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":5,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202407111451,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7990811,"analisisDocumental":{"id":799081,"competencia":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":190001,"valor":"COMPETENCIA ORIGINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231249,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":8,"codigoRelacion":250008,"valor":"Originarios","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"GCBA c/ CORREO OFICIAL DE LA RA SA Y OTRO s/EJECUCION FISCAL TRIBUTARIOS","inconstitucional":false,"falloDestacado":{"id":7182,"titulo":"Prórroga de la competencia originaria de la Corte","cabecilla":"<p style=\"text-indent:2em\">La Corte declaró que una causa proveniente de un juzgado federal de ejecuciones fiscales y tributario resultaba ajena a su competencia originaria y devolvió el expediente a dicho tribunal para que continúe su trámite.</p><p style=\"text-indent:2em\">Expresó para ello que en su pronunciamiento publicado en Fallos: <a target=\"_blank\" href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/consultaSumarios/buscarTomoPagina.html?tomo=342&amp;pagina=533\">342:533</a> declaró que la Ciudad Autónoma de Buenos Aires tiene derecho a la competencia originaria prevista en el artículo 117 de la Constitución Nacional, con el mismo alcance que el reconocido a las provincias pero que también ha aplicado de manera constante y reiterada una doctrina rigurosa en materia de prórroga -expresa o tácita- de dicha competencia.</p><p style=\"text-indent:2em\">En ese sentido, entonces, tuvo en cuenta que la propia ejecutante había prestado su conformidad con la tramitación del proceso ante los tribunales en lo contencioso administrativo federal, lo cual debía ser entendido como una renuncia a la prerrogativa de litigar en la competencia originaria y una prórroga a favor del mencionado fuero.</p>","esNovedad":true,"fecha":1720666800000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1720726293015,"usuarioCreacion":4,"fechaCreacion":1720721271245,"privado":false,"posicion":2,"resumen":null},"reciboEntrada":{"id":123179,"secretaria":{"id":15,"tipo":"S","descripcion":"Sec. Juicios Originarios","orden":8,"activo":"S","codigoRelacion":250008,"descripcionWeb":"Originarios","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":28992724,"numeroExpediente":1733,"anioExpediente":2016,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":0,"codigo":"0","abreviatura":"CSJ","descripcion":"Corte Suprema de Justicia de la Nación","estado":0,"descripcionLarga":"CSJ - Corte Suprema de Justicia de la Nación"},"objetoJuicio":{"id":10565,"descripcion":"ACCION 