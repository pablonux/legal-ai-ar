ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":null,"tipoRecurso":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":230003,"valor":"RECURSO ORDINARIO DE APELACION","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290934,"fechaModLong":201110290934,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":3,"codigoRelacion":250003,"valor":"Penal","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"CASTILLO PADILLA, LUCY SUSY s/ EXTRADICIÓN","alias":null,"caratula":"REQUERIDO: CASTILLO PADILLA, LUCY SUSY s/EXTRADICION","inconstitucional":false,"falloDestacado":{"id":3961,"titulo":"Extradición: Insuficiencia de la invocación general y abstracta del interés superior del niño para oponerse","cabecilla":"<p>El juzgado de primera instancia declaró procedente la extradición de una ciudadana peruana a su país de origen para ser sometida a juicio por el delito de tráfico ilícito de drogas. Apelada la decisión ante la Corte, ésta, por unanimidad, confirmó el fallo recurrido. Consideró que los reparos de la recurrente para solicitar la improcedencia del pedido de extradición solo se apoyaban en la invocación general y abstracta del interés superior del niño, sin referencia a las particularidades del caso y sin hacerse cargo de que la jueza había dado intervención a la Defensoría Pública de Menores e Incapaces. Remarcó que la defensa se había limitado a reiterar el argumento ya esgrimido en sede oral sin hacerse cargo de centrar sus críticas en la respuesta brindada por la jueza de la causa.</p>","esNovedad":true,"fecha":1652151600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1683665224878,"usuarioCreacion":11,"fechaCreacion":1652270500181,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":33913,"secretaria":{"id":10,"tipo":"S","descripcion":"Sec. Judicial Nº 3","orden":3,"activo":"S","codigoRelacion":250003,"descripcionWeb":"Penal","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":15989767,"numeroExpediente":10870,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"REQUERIDO: CASTILLO PADILLA, LUCY SUSY s/EXTRADICION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10870. "},"recurso":{"id":5726631,"expediente":{"id":15989767,"numeroExpediente":10870,"anioExpediente":2013,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":8,"codigo":"8","abreviatura":"CFP","descripcion":"Camara Criminal y Correccional Federal","estado":0,"descripcionLarga":"CFP - Camara Criminal y Correccional Federal"},"objetoJuicio":{"id":1841,"descripcion":"EXPEDIENTES PENALES","idMateria":11,"tema":null},"caratula":"REQUERIDO: CASTILLO PADILLA, LUCY SUSY s/EXTRADICION","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"10870. "},"tipoRecurso":{"id":1168,"codigo":"ROR","descripcion":"RECURSO ORDINARIO"},"claveRecurso":"CFP 010870/2013/CS001","identificacionExpediente":"CFP 010870/2013/CS001"},"piezas":1,"urgente":"N","observaciones":null,"usuarioCreacion":null,"usuarioCreacionOld":"JURW6J","usuarioModificacion":null,"usuarioModificacionOl