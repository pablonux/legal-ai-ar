[{"id":157658,"orden":1,"ordenRecurso":null,"voces":"EXTRADICION - INTERES SUPERIOR DEL NIÑO","texto":"<p>Los reparos de la parte recurrente para solicitar la improcedencia del pedido de extradici&oacute;n son improcedentes, toda vez que solo se apoyan en la invocaci&oacute;n general y abstracta del inter&eacute;s superior del ni&ntilde;o, sin referencia a las particularidades del caso a la luz de los extremos de hecho que confluyen y a la soluci&oacute;n dise&ntilde;ada sobre esa base, por la jueza del caso, nada de lo cual ha sido controvertido, lo que priva de sustento al agravio esgrimido.</p>","fullText":"<XML><VOCES>EXTRADICION - INTERES SUPERIOR DEL NIÑO</VOCES><TEXTO>Los reparos de la parte recurrente para solicitar la improcedencia del pedido de extradición son improcedentes, toda vez que solo se apoyan en la invocación general y abstracta del interés superior del niño, sin referencia a las particularidades del caso a la luz de los extremos de hecho que confluyen y a la solución diseñada sobre esa base, por la jueza del caso, nada de lo cual ha sido controvertido, lo que priva de sustento al agravio esgrimido.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1652151600000,"tomo":345,"pagina":278,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":1,"holding":null,"linksCitantes":null,"numeroID":2178,"anioFallo":2022,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":4245,"codigoRelacion":104245,"valor":"EXTRADICION","activo":"S","usuarioCreacion":"JUR0V0","usuarioMod":"JUR0V0","fechaCreacionLong":201207021146,"fechaModLong":201207021146,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},