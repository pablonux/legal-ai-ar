[{"id":149934,"orden":3,"ordenRecurso":9,"voces":"SENTENCIA ARBITRARIA - CONTRADICCION - DERECHO COMUN","texto":"Los agravios planteados suscitan cuestión federal bastante para su tratamiento por la vía extraordinaria si, aunque remiten al examen de cuestiones regidas por el derecho común, ajenas como regla y por su naturaleza a dicha vía, cabe hacer excepción a ese principio cuando la decisión resulta autocontradictoria y se aparta de la solución normativa prevista para el caso con evidente menoscabo del derecho de defensa de la recurrente.","fullText":"<XML><VOCES>SENTENCIA ARBITRARIA - CONTRADICCION - DERECHO COMUN</VOCES><TEXTO>Los agravios planteados suscitan cuestión federal bastante para su tratamiento por la vía extraordinaria si, aunque remiten al examen de cuestiones regidas por el derecho común, ajenas como regla y por su naturaleza a dicha vía, cabe hacer excepción a ese principio cuando la decisión resulta autocontradictoria y se aparta de la solución normativa prevista para el caso con evidente menoscabo del derecho de defensa de la recurrente.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1505185200000,"tomo":340,"pagina":1259,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":4387,"anioFallo":2017,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":3532,"codigoRelacion":103532,"valor":"SENTENCIA ARBITRARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201907160932,"usuarioModificacion":null,"fechaModificacion":201907160932},{"tipoVoz":{"codigoTabla":null,"codigoValor":4489,"codigoRelacion":104489,"valor":"CONTRADICCION","activo":"S","usuarioCreacion":"JUR0V0","usuarioMod":"JUR0V0","fechaCreacionLong":201507101615,"fechaModLong":201507101615,"orden":null,"visible":null