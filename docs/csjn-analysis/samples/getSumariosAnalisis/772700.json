[{"id":156983,"orden":1,"ordenRecurso":null,"voces":"DERECHO AL VOTO - CONDENA - SENTENCIA - EJECUCION DE SENTENCIA - CONGRESO NACIONAL - SENTENCIA EXHORTATIVA","texto":"<p>La fijaci&oacute;n de un plazo indeterminado no significa que la sentencia sea meramente declarativa, ni que deje librado su cumplimiento al arbitrio de los &oacute;rganos estatales competentes, pues la pauta temporal &quot;a la mayor brevedad posible&quot; contiene un l&iacute;mite claro, que implica el requerimiento de una conducta urgente que puede ser judicialmente exigida; por lo cual la parte recurrente tiene la posibilidad de solicitar la ejecuci&oacute;n de la condena sobre la base del vencimiento de la pauta temporal impuesta en la sentencia apelada; m&aacute;xime cuando han transcurrido m&aacute;s de cinco a&ntilde;os desde que la C&aacute;mara Electoral dict&oacute; sentencia y el Congreso de la Naci&oacute;n ni siquiera ha dado tratamiento a los diversos proyectos de ley presentados a efectos de implementar el derecho a votar de los condenados.</p><p>&nbsp;</p>","fullText":"<XML><VOCES>DERECHO AL VOTO - CONDENA - SENTENCIA - EJECUCION DE SENTENCIA - CONGRESO NACIONAL - SENTENCIA EXHORTATIVA</VOCES><TEXTO>La fijación de un plazo indeterminado no significa que la sentencia sea meramente declarativa, ni que deje librado su cumplimiento al arbitrio de los órganos estatales competentes, pues la pauta temporal \"a la mayor brevedad posible\" contiene un límite claro, que implica el requerimiento de una conducta urgente que puede ser judicialmente exigida; por lo cual la parte recurrente tiene la posibilidad de solicitar la ejecución de la condena sobre la base del vencimiento de la pauta temporal impuesta en la sentencia apelada; máxime cuando han transcurrido más de cinco años desde que la Cámara Electoral dictó sentencia y el Congreso de la Nación ni siquiera ha dado tratamiento a los diversos proyectos de ley presentados a efectos de implementar el derecho a votar de los condenados. </TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1644462000000,"tomo":345,"pagina":50,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":2,"holding":null,"linksCitantes":null,"numeroID":149,"anioFallo":2022,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":4952,"codigoRelacion":104952,"valor":"DERECHO AL VOTO","activo":"S","usuarioCreacion":"JUR0V0","usuarioMod":"JUR0V0","fechaCreacionLong":201808021517,"fechaModLong":201808021517,"orden":null,"visible":null},"orden":1,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202202111026,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":987,"codigoRelacion":100987,"valor":"CONDENA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR0V0","fechaCreacionLong":201006301000,"fechaModLong":201205301035,"orden":null,"visible":null},"orden":2,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202202111026,"usuarioModificacion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":3527,"codigoRelacion":103527,"valor":"SENTENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":3,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModific