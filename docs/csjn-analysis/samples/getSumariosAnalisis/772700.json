":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202202151107,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7727001,"analisisDocumental":{"id":772700,"competencia":{"codigoTabla":null,"codigoValor":6,"codigoRelacion":190006,"valor":"APELACION EXTRAORDINARIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201110290932,"fechaModLong":201110290932,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":80001,"valor":"CONFIRMA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006051033,"fechaModLong":201006051033,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":230002,"valor":"RECURSO EXTRAORDINARIO FEDERAL ","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"JUR3WP","fechaCreacionLong":201110290934,"fechaModLong":201111011308,"orden":null,"visible":null},"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":250005,"valor":"DDHH- Institucional","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041607,"fechaModLong":201604111334,"orden":null,"visible":null},"caratulaFallo":"ORAZI, MARTIN OSCAR s/INHABILITACIÓN (ART. 3 CEN)","alias":null,"caratula":"ORAZI, MARTIN OSCAR s/INHABILITACIÓN (ART. 3 CEN)","inconstitucional":false,"falloDestacado":{"id":3423,"titulo":"Derecho al sufragio de los condenados y regulación por parte de los otros poderes del Estado","cabecilla":"<p>El actor solicit&oacute; la rehabilitaci&oacute;n para poder ejercer su derecho al voto a pesar de estar cumpliendo pena de prisi&oacute;n. La C&aacute;mara Nacional Electoral declar&oacute; la inconstitucionalidad de la limitaci&oacute;n legal y entendi&oacute; indispensable requerir al Congreso de la Naci&oacute;n que revise, a la mayor brevedad posible, la regulaci&oacute;n vigente relativa al derecho al sufragio de los condenados. Contra esta sentencia el demandante recurri&oacute; a la Corte que, por unanimidad, confirm&oacute; la sentencia apelada. Se&ntilde;al&oacute; que la misma segu&iacute;a la l&iacute;nea fijada en el precedente de&nbsp;<strong><a href=\"https://sjconsulta.csjn.gov.ar/sjconsulta/documentos/verUnicoDocumentoLink.html?idAnalisis=518293&amp;cache=1644520503417\">Fallos: 325:524</a> &ldquo;Mignone</strong>&rdquo; y que en ambos casos se parti&oacute; de la base de que el ejercicio efectivo del&nbsp;<em>derecho al sufragio exige una regulaci&oacute;n espec&iacute;fica</em>,&nbsp;<em>cuyo dictado es resorte exclusivo de otros poderes del Estado.</em>&nbsp;Sostuvo que la fijaci&oacute;n de un plazo indeterminado no significa que la sentencia sea meramente declarativa, ni que deje librado su cumplimiento al arbitrio de los &oacute;rganos estatales competentes y que la pauta temporal &quot;a la mayor brevedad posible&quot; contiene un l&iacute;mite claro, que implica el requerimiento de una conducta urgente que puede ser judicialmente exigida. De este modo concluy&oacute; que la parte recurrente tiene la posibilidad de solicitar la ejecuci&oacute;n de la condena sobre la base del vencimiento de la pauta temporal impuesta en la sentencia apelada, m&aacute;xime cuando han transcurrido m&aacute;s de cinco a&ntilde;os desde que la c&aacute;mara dict&oacute; sentencia y el Congreso de la Naci&oacute;n ni siquiera ha dado tratamiento a los diversos proyectos de ley presentados a efectos de implementar el derecho a votar de los condenados.</p>","esNovedad":true,"fecha":1644462000000,"relevancia":2,"usuarioModificacion":4,"fechaModificacion":1644925990304,"usuarioCreacion":4,"fechaCreacion":1644520549695,"privado":false,"posicion":1,"resumen":null},"reciboEntrada":{"id":33149,"secretaria":{"id":11,"tipo":"S","descripcion":"Sec. Judicial Nº 4","orden":4,"activo":"S","codigoRelacion":250004,"descripcionWeb":"Administrativo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":27054219,"numeroExpediente":3995,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":4,"codigo":"4","abreviatura":"CNE","descripcion":"Cámara Nacional Electoral","estado":0,"descripcionLarga":"CNE - Cámara Nacional Electoral"},"objetoJuicio":{"id":10862,"descripcion":"INHABILITACIÓN (ART. 3 CEN)","idMateria":92,"tema":null},"caratula":"ORAZI, MARTIN OSCAR s/INHABILITACIÓN (ART. 3 CEN)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"3995. "},"recurso":{"id":4952302,"expediente":{"id":27054219,"numeroExpediente":3995,"anioExpediente":2015,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":4,"codigo":"4","abreviatura":"CNE","descripcion":"Cámara Nacional Electoral","estado":0,"descripcionLarga":"CNE - Cámara Nacional Electoral"},"objetoJuicio":{"id":10862,"descripcion":"INHABILITACIÓN (ART. 3 CEN)","idMateria":92,"tema":null},"caratula":"ORAZI, MARTIN OSCAR s/INHABILITACIÓN (ART. 3 CEN)","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"3995. "},"tipoRecurso":{"id":1166,"codigo":"REX","descripcion":"RECURSO EXTRAORDINARIO"},"claveRecurso":"CNE 003995/2015/CS001","identificacionExpediente":"CNE 003995/2015/CS001"},"piezas":1,"urgente":"S","observaciones":null,"usuarioCreacion":null,"usuarioCreacionOld":"JURW6J","usuarioModificacion":null,"usuarioModificacionOld":"JURW6J","fechaCreacion":202202041649,"fechaModificacion":202202041723}],"fecha":16439436000