acion":null,"fechaModificacion":null},{"tipoVoz":{"codigoTabla":null,"codigoValor":5032,"codigoRelacion":105032,"valor":"PERSONAS VULNERABLES","activo":"S","usuarioCreacion":"SJC653","usuarioMod":"SJC653","fechaCreacionLong":202112141415,"fechaModLong":202112141415,"orden":null,"visible":null},"orden":4,"usuarioCreacion":{"id":13,"nombreUsuario":"27230157427","apellido":"Lucero","nombre":"Maria Silvina","estado":"A","tieneToken":"N","cargo":null,"fechaModificacion":null,"fechaCreacion":1583847595000,"nombreUsuarioMigrado":null,"codigo":"SJC653","mail":"slucero@csjn.gov.ar","intentos":0,"notificacion":false},"fechaCreacion":202404091652,"usuarioModificacion":null,"fechaModificacion":null}],"notas":[],"suplementos":[],"obsMigra":null,"idRecurso":null,"citasRex":[],"idFallo":7946881,"analisisDocumental":{"id":794688,"competencia":{"codigoTabla":null,"codigoValor":5,"codigoRelacion":190005,"valor":"CUESTION DE COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008231250,"fechaModLong":201008231250,"orden":null,"visible":null},"tipoAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":26,"codigoRelacion":80026,"valor":"DECLARA DESIERTO","activo":"S","usuarioCreacion":"JUR3WP","usuarioMod":"JUR3WP","fechaCreacionLong":201102141308,"fechaModLong":201102141308,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":1,"codigoRelacion":210001,"valor":"TOTAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"Incidente Nº 1 -  NN: N.N. s/INCIDENTE DE INCOMPETENCIA","inconstitucional":false,"falloDestacado":{"id":6663,"titulo":"Conflicto de competencia ante un presunto delito de trata","cabecilla":"<p style=\"text-indent: 2em;\">Un inspector del Registro Nacional de Trabajadores Rurales y Empleadores realizó una denuncia mediante el Programa Nacional de Rescate y Acompañamiento a las Personas Damnificadas por el Delito de Trata y manifestó que hacía ocho años que dos trabajadores rurales –padre e hijo− residían en un campo sin percibir ninguna remuneración de quien sería el dueño del lugar y que las condiciones habitacionales en las que se encontrarían serían paupérrimas. Ello originó un conflicto negativo de competencia entre la justicia federal y la justicia provincial.</p><p style=\"text-indent: 2em;\">La Corte resolvió que sea el juzgado local quien prosiga con la pesquisa, sin perjuicio de cuanto resulte con posterioridad.</p><p style=\"text-indent: 2em;\">Tuvo en cuenta que si bien es posible inferir un posible aprovechamiento de la situación de vulnerabilidad de la víctima y de la confianza que ésta habría mantenido ante la promesa del dueño del inmueble de mejorar sus condiciones económicas, no surgen otras circunstancias que permitan, al menos de momento, vislumbrar la concurrencia de los supuestos a los que se refiere la ley 26.364 (cf. texto de la ley 26.842), pero sí exigen profundizar la investigación sobre la hipótesis de naturaleza común planteada.</p>","esNovedad":true,"fecha":1712631600000,"relevancia":1,"usuarioModificacion":4,"fechaModificacion":1712694252395,"usuarioCreacion":4,"fechaCreacion":1712694250157,"privado":false,"posicion":3,"resumen":null},"reciboEntrada":{"id":118502,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":36625887,"numeroExpediente":40474,"anioExpe