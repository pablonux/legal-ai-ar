oAccion":null,"sentidoPronunciamiento":{"codigoTabla":null,"codigoValor":7,"codigoRelacion":80007,"valor":"DECLARA COMPETENCIA","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201008181306,"fechaModLong":201008181306,"orden":null,"visible":null},"materia":null,"remision":{"codigoTabla":null,"codigoValor":2,"codigoRelacion":210002,"valor":"PARCIAL AL DICTAMEN PGN","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201009301210,"fechaModLong":201203071224,"orden":null,"visible":null},"tipoRecurso":null,"dependencia":null,"dependenciaHija":null,"publico":"S","materiaSecretaria":{"codigoTabla":null,"codigoValor":10,"codigoRelacion":250010,"valor":"Consumo","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201604041608,"fechaModLong":201604111333,"orden":null,"visible":null},"caratulaFallo":null,"alias":null,"caratula":"PROMEDON SA c/ GCBA-AGIP-DGR s/PROCESO DE CONOCIMIENTO","inconstitucional":false,"falloDestacado":{"id":5863,"titulo":"El principio de radicación como límite para la transferencia de expedientes","cabecilla":"<p>En un conflicto positivo de competencia entre el fuero nacional de apelaciones en lo contencioso administrativo y la justicia en lo contencioso administrativo y tributario de la Ciudad de Buenos Aires la Corte resolvió que aquél debía continuar con el trámite de la causa. Señaló que <b>el límite para la transferencia de expedientes está dado por el</b> <b>principio de radicación</b>, el cual se consolida con el dictado de \"actos típicamente jurisdiccionales\", que son aquellos que importan la decisión de un conflicto mediante la adecuación de las normas aplicables. Expresó que las causas en las que ha recaído un acto jurisdiccional de ese tipo −ya sea que se encuentre firme o no, o que dé por terminado el proceso por alguna de las formas de extinción previstas en la ley−, deben continuar su trámite por ante el juez que lo dictó. Y tuvo en cuenta que antes del dictado de la sentencia del superior tribunal local que hizo lugar al planteo de inhibitoria, la magistrada a cargo del juzgado nacional de primera instancia en lo contencioso administrativo federal había dispuesto la apertura a prueba, la clausura del período probatorio y que se pusieran los autos para alegar, pasando posteriormente los autos a  sentencia.</p>","esNovedad":true,"fecha":1694487600000,"relevancia":1,"usuarioModificacion":11,"fechaModificacion":1694550590493,"usuarioCreacion":11,"fechaCreacion":1694549001760,"privado":false,"posicion":5,"resumen":null},"reciboEntrada":{"id":113836,"secretaria":{"id":21,"tipo":"S","descripcion":"Secretaría de Relaciones de Consumo","orden":11,"activo":"S","codigoRelacion":250010,"descripcionWeb":"Consumo","descripcionVacia":""},"reciboEntradaExpedientes":[{"expediente":{"id":30581276,"numeroExpediente":70878,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codigo":"CONT"}},"caratula":"PROMEDON SA c/ GCBA-AGIP-DGR s/PROCESO DE CONOCIMIENTO","verificacionMesa":"N","etiqueta":null,"hijos":[],"oldIdentificadorExpediente":"70878. "},"recurso":{"id":6077633,"expediente":{"id":30581276,"numeroExpediente":70878,"anioExpediente":2017,"tomoExpediente":null,"letraExpediente":null,"tipoExpediente":null,"camara":{"id":2,"codigo":"2","abreviatura":"CAF","descripcion":"Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal","estado":0,"descripcionLarga":"CAF - Cámara Nacional de Apelaciones en lo Contencioso Administrativo Federal"},"objetoJuicio":{"id":1114,"descripcion":"PROCESO DE CONOCIMIENTO","idMateria":2,"tema":{"id":340,"codig