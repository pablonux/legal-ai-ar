suarioCreacionOld":"JUR0V0","fechaCreacion":201804241517,"caratulaLex":"Recurso Queja Nº 1 - DOLORES CORRECHER GIL Y OTRO c/ REMAR ARGENTINA ASOCIACION CIVIL Y OTRO s/DESPIDO","autos":"Correcher Gil, Dolores c/ REMAR Argentina Asoc. Civil s/ despido ","tieneDocumento":true,"linkDocumento":"/documentos/verDocumentoByIdLinksJSP.html?idDocumento=7448672&cache=1777039025790","tieneDictamenes":true,"conAnalisis":true,"conAnalisisPrivado":false,"conVotos":true,"caratulaWeb":"Correcher Gil, Dolores c/ REMAR Argentina Asoc. Civil s/ despido ","numeroExpediente":"CNT 021761/2008/1/RH001","sentenciaArbitraria":true,"inconstitucional":false,"alias":null,"stringVotosMayoria":"","stringVotosVoto":"","stringVotosDisidencia":"","stringVotosDisidenciaParcial":"","stringVotosAbstencion":"","textoResaltado":"Los agravios de la recurrente suscitan cuestión federal suficiente que habilita su tratamiento si, a pesar de remitir al examen de cuestiones fácticas y de derecho común, ello no es óbice para la apertura del recurso cuando el a quo ha omitido examinar una prueba que resultaba prima facie conducente para la correcta solución del litigio. -La Dra. Elena I. Highton de Nolasco y el Dr. Horacio Rosatti, en disidencia, consideraron que el recurso extraordinario era inadmisible (art. 280 CPCCN)-.","vocesResaltadas":"SENTENCIA ARBITRARIA - VALORACION DE CIRCUNSTANCIAS DE HECHO Y PRUEBA - EXCESOS U OMISIONES EN EL PRONUNCIAMIENTO","desvinculado":false,"fechaString":"24/04/2018","stringVotosAnalisis":""},{"id":149397,"orden":2,"ordenRecurso":32,"voces":"DESPIDO - PRUEBA DE TESTIGOS - RELACION DE DEPENDENCIA - SENTENCIA ARBITRARIA - TESTIGOS","texto":"Resulta dogmática la sentencia que concluyó que entre la actora y la entidad demandada había existido un vínculo de naturaleza laboral dependiente e hizo lugar a la demanda de indemnizaciones por despido y falta de registro de la relación si, sin proporcionar ningún fundamento válido que justificase su actitud, prescindió totalmente de las declaraciones de los testigos pese a que constituían un material sumamente relevante para esclarecer los hechos debatidos al destacar el ingreso de la actora como voluntaria social a la asociación demandada y la falta de retribución alguna por su actividad en ella.\r\n\r\n-La Dra. Elena I. Highton de Nolasco y el Dr. Horacio Rosatti, en disidencia, consideraron que el recurso extraordinario era inadmisible (art. 280 CPCCN)-.","fullText":"<XML><VOCES>DESPIDO - PRUEBA DE TESTIGOS - RELACION DE DEPENDENCIA - SENTENCIA ARBITRARIA - TESTIGOS</VOCES><TEXTO>Resulta dogmática la sentencia que concluyó que entre la actora y la entidad demandada había existido un vínculo de naturaleza laboral dependiente e hizo lugar a la demanda de indemnizaciones por despido y falta de registro de la relación si, sin proporcionar ningún fundamento válido que justificase su actitud, prescindió totalmente de las declaraciones de los testigos pese a que constituían un material sumamente relevante para esclarecer los hechos debatidos al destacar el ingreso de la actora como voluntaria social a la asociación demandada y la falta de retribución alguna por su actividad en ella.\r\n\r\n-La Dra. Elena I. Highton de Nolasco y el Dr. Horacio Rosatti, en disidencia, consideraron que el recurso extraordinario era inadmisible (art. 280 CPCCN)-.</TEXTO></XML>","textoAResaltar":null,"terminos":null,"fechaFallo":1524538800000,"tomo":341,"pagina":416,"documentosDTO":null,"referencias":[],"votos":null,"paginaAlternativa":null,"publico":"S","paginaFallo":null,"holding":null,"linksCitantes":null,"numeroID":1750,"anioFallo":2018,"vocesSumario":[{"tipoVoz":{"codigoTabla":null,"codigoValor":1559,"codigoRelacion":101559,"valor":"DESPIDO","activo":"S","usuarioCreacion":"ADMIN","usuarioMod":"ADMIN","fechaCreacionLong":201006301000,"fechaModLong":201006301000,"orden":null,"visible":null},"orden":1,"usuarioCreacion":null,"fechaCreacion":201907121250,"usuarioModificacion":null,"fechaModificacion":201907121250},{"tipoVoz":