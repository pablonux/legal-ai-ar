---
title: "F1-19 · Ontology Graph Schema — Node Types, Edge Types, Layout Strategy"
---

%% Updated 2026-04-30: Added ProcesoJudicial, FuenteDelDerecho, Jurisdiccion.
%% Juez is now a role of PersonaHumana (dotted edge), not a subclass.

graph TD
    subgraph nodeTypes [Node Types]
        CoreNode["Core Class (round-rect, blue-600)"]
        SubclassNode["Subclass (round-rect, blue-400)"]
        TaxonomyNode["Taxonomy (diamond, green-600)"]
        KbEntityNode["KB Entity (ellipse, orange-600)"]
        PlannedNode["Planned (ellipse, gray-400, dashed)"]
    end

    subgraph edgeTypes [Edge Types]
        IsAEdge["is-a (solid, gray, no arrow)"]
        RelEdge["relationship (dashed, labeled, arrow)"]
        RoleEdge["role (dotted, labeled)"]
    end

    subgraph layout [Layout Strategy]
        Dagre["dagre (hierarchical, default)"]
        Cose["cose (force-directed, toggle)"]
    end

    subgraph graphStructure [Graph Structure]
        Thing["owl:Thing"]
        NormaJuridica["NormaJuridica (core)"]
        SujetoDeDerecho["SujetoDeDerecho (core)"]
        OrganoEstatal["OrganoEstatal (core)"]
        ProcesoJudicial["ProcesoJudicial (core)"]
        FuenteDelDerecho["FuenteDelDerecho (core)"]
        Jurisdiccion["Jurisdiccion (core)"]
        Sentencia["Sentencia (kb-entity)"]
        Tribunal["Tribunal (kb-entity)"]
        Persona["Persona (kb-entity)"]

        Ley["Ley (subclass)"]
        Decreto["Decreto (subclass)"]
        PersonaHumana["PersonaHumana (subclass)"]
        PersonaJuridica["PersonaJuridica (subclass)"]
        OrganoJudicial["OrganoJudicial (subclass)"]

        LegalBranch["LegalBranch (taxonomy)"]
        NormType["NormType (taxonomy)"]
        CourtType["CourtType (taxonomy)"]
        PersonType["PersonType (taxonomy)"]
        ProcessType["ProcessType (taxonomy)"]

        Thing -->|"is-a"| NormaJuridica
        Thing -->|"is-a"| SujetoDeDerecho
        Thing -->|"is-a"| OrganoEstatal
        Thing -->|"is-a"| ProcesoJudicial
        Thing -->|"is-a"| FuenteDelDerecho
        Thing -->|"is-a"| Jurisdiccion

        NormaJuridica -->|"is-a"| Ley
        NormaJuridica -->|"is-a"| Decreto
        SujetoDeDerecho -->|"is-a"| PersonaHumana
        SujetoDeDerecho -->|"is-a"| PersonaJuridica
        OrganoEstatal -->|"is-a"| OrganoJudicial
        OrganoJudicial -->|"is-a"| Tribunal

        PersonaHumana -.->|"rol: Juez"| Tribunal
        PersonaHumana -.->|"rol: Fiscal"| OrganoEstatal
        PersonaHumana -.->|"rol: Abogado"| ProcesoJudicial

        NormaJuridica -.->|"ramaDelDerecho"| LegalBranch
        NormaJuridica -.->|"tipo"| NormType
        Tribunal -.->|"tipoTribunal"| CourtType
        Persona -.->|"tipoPerson"| PersonType
        ProcesoJudicial -.->|"tipoProceso"| ProcessType

        Sentencia -.->|"citaNorma"| NormaJuridica
        Sentencia -.->|"emitidoPor"| Tribunal
        Sentencia -.->|"firmadoPor"| Persona
        Sentencia -.->|"citaFallo"| Sentencia
        Sentencia -.->|"tramitadoEn"| ProcesoJudicial
        ProcesoJudicial -.->|"radicadoEn"| Tribunal
        ProcesoJudicial -.->|"partes"| Persona

        FuenteDelDerecho -.->|"comprende"| Sentencia
        FuenteDelDerecho -.->|"comprende"| NormaJuridica
    end
