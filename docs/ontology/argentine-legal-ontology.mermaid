classDiagram
    direction TB

    %% ══════════════════════════════════════════
    %% LEGAL SOURCES
    %% ══════════════════════════════════════════

    class LegalSource {
        +String name
        +Integer hierarchyLevel
        +Enum bindingForce
        +Enum territorialScope
    }

    class ConstitutionalNorm {
        +String sourceTreaty
        +Integer reformYear
    }

    class InternationalTreaty {
        +Date ratificationDate
        +String internationalOrganization
    }

    class LegalNorm {
        +String normNumber
        +String name
        +String commonName
        +Date enactmentDate
        +Date promulgationDate
        +Date publicationDate
        +Date effectiveDate
        +Boolean isInForce
        +String fullText
        +Enum lawBranch
        +Enum territorialScope
    }

    class NationalLaw {
        +Enum lawType
        +String chamber
    }

    class DecreeLaw {
        +Boolean isDNU
        +String justification
    }

    class ProvincialNorm {
        +String province
        +Enum normType
    }

    class MunicipalNorm {
        +String municipality
        +Enum normType
    }

    class CaseLaw {
        +Boolean isEnBanc
        +Boolean isBinding
    }

    class Custom {
        +String applicationScope
        +Boolean isConsolidated
    }

    class Article {
        +String articleNumber
        +String normativeText
        +Boolean isInForce
    }

    class Clause {
        +String letter
        +String text
    }

    LegalSource <|-- ConstitutionalNorm
    LegalSource <|-- InternationalTreaty
    LegalSource <|-- LegalNorm
    LegalSource <|-- CaseLaw
    LegalSource <|-- Custom
    LegalNorm <|-- NationalLaw
    LegalNorm <|-- DecreeLaw
    LegalNorm <|-- ProvincialNorm
    LegalNorm <|-- MunicipalNorm
    LegalNorm "1" --> "N" Article : hasArticle
    Article "1" --> "N" Clause : hasClause
    LegalNorm "N" --> "N" LegalNorm : amends
    LegalNorm "N" --> "N" LegalNorm : repeals
    LegalNorm "N" --> "N" LegalNorm : regulates

    %% ══════════════════════════════════════════
    %% LEGAL SUBJECTS
    %% ══════════════════════════════════════════

    class LegalSubject {
        +String identifier
        +Domicile domicile
    }

    class NaturalPerson {
        +String lastName
        +String firstName
        +Date birthDate
        +Date deathDate
        +String nationalIdNumber
        +String CUIL
        +Enum maritalStatus
        +String nationality
        +Boolean hasFullLegalCapacity
    }

    class LegalEntity {
        +String name
        +String CUIT
        +Date incorporationDate
        +Enum legalEntityType
        +String corporatePurpose
    }

    class PublicLegalEntity {
        +Enum stateLevel
    }

    class PrivateLegalEntity {
        +Enum companyType
        +String registrationNumber
    }

    class Domicile {
        +String street
        +String number
        +String locality
        +String province
        +String postalCode
        +Enum domicileType
    }

    class LegalCapacity {
        +Boolean isFull
        +Enum restriction
        +String courtJudgment
    }

    LegalSubject <|-- NaturalPerson
    LegalSubject <|-- LegalEntity
    LegalEntity <|-- PublicLegalEntity
    LegalEntity <|-- PrivateLegalEntity
    LegalSubject "1" --> "1" Domicile : hasDomicile
    LegalSubject "1" --> "1" LegalCapacity : hasCapacity

    %% ══════════════════════════════════════════
    %% LEGAL ACTS AND FACTS
    %% ══════════════════════════════════════════

    class LegalFact {
        +Date date
        +String description
        +Enum factType
    }

    class NaturalFact {
        +String phenomenon
    }

    class VoluntaryHumanFact {
        +Boolean hasDiscernment
        +Boolean hasIntention
        +Boolean hasFreedom
    }

    class LegalAct {
        +Date date
        +String place
        +Boolean isOnerous
        +Boolean isConditional
        +Boolean isModal
        +Enum requiredForm
        +Boolean isVoid
        +Enum nullityCause
    }

    class Contract {
        +Enum contractType
        +String contractObject
        +Decimal priceOrConsideration
        +String term
        +Enum executionForm
    }

    class LegalActDefect {
        +Enum defectType
        +Enum nullityType
        +String applicableNorm
    }

    LegalFact <|-- NaturalFact
    LegalFact <|-- VoluntaryHumanFact
    VoluntaryHumanFact <|-- LegalAct
    LegalAct <|-- Contract
    LegalAct "1" --> "N" LegalActDefect : hasDefect
    Contract "N" --> "N" LegalSubject : enters

    %% ══════════════════════════════════════════
    %% LEGAL RELATIONSHIPS
    %% ══════════════════════════════════════════

    class LegalRelationship {
        +String relationshipObject
        +Boolean isPatrimonial
        +Boolean isTransferable
    }

    class RealRight {
        +Enum realRightType
        +String cccnArticle
        +Boolean isNumerusClausus
    }

    class Obligation {
        +Enum performanceType
        +String performanceObject
        +Decimal debtAmount
        +Decimal interestRate
        +Enum interestType
        +Date dueDate
        +Boolean isExtinguished
        +Enum extinctionCause
    }

    class Mortgage {
        +String propertyData
        +Decimal guaranteedAmount
    }

    class Pledge {
        +String pledgedAsset
        +Decimal guaranteedAmount
    }

    LegalRelationship <|-- RealRight
    LegalRelationship <|-- Obligation
    RealRight <|-- Mortgage
    RealRight <|-- Pledge
    LegalRelationship "N" --> "1" LegalSubject : activeSubject
    LegalRelationship "N" --> "N" LegalSubject : passiveSubjects
    Obligation "N" --> "1" Contract : derivesFrom

    %% ══════════════════════════════════════════
    %% CRIMINAL LAW
    %% ══════════════════════════════════════════

    class Crime {
        +Enum crimeType
        +Enum classification
        +String protectedLegalInterest
        +Boolean isAttempt
        +Boolean isContinuing
        +String codeArticle
        +Integer minPenalty
        +Integer maxPenalty
        +Enum penaltyType
        +Boolean allowsSuspendedSentence
        +Integer prescription
    }

    class Defendant {
        +Enum criminalProcessStatus
        +Boolean hasRecord
        +Boolean isRepeatOffender
    }

    class Conviction {
        +Date convictionDate
        +String imposedPenalty
        +Integer durationYears
        +Boolean isSuspended
        +Boolean isFinal
        +Date endDate
        +String penitentiaryFacility
    }

    class CriminalPrecautionaryMeasure {
        +Enum type
        +Date impositionDate
        +Date endDate
    }

    Defendant --> NaturalPerson : isPerson
    Defendant "1" --> "N" Crime : isAccusedOf
    Defendant "1" --> "N" CriminalPrecautionaryMeasure : hasMeasure
    Conviction "N" --> "1" Defendant : fallsOn
    Conviction "N" --> "N" Crime : isConvictedOf

    %% ══════════════════════════════════════════
    %% JUDICIAL PROCEEDING
    %% ══════════════════════════════════════════

    class Proceeding {
        +String caseFileNumber
        +String caption
        +Enum procedureType
        +Enum procedureSubtype
        +Date startDate
        +Enum proceedingStatus
        +Enum jurisdiction
        +Enum courtVenue
        +Enum instance
    }

    class ProceduralAct {
        +Enum actType
        +Date actDate
        +String actContent
        +Boolean isNotified
        +Date notificationDate
    }

    class Judgment {
        +Enum judgmentType
        +Date issueDate
        +Enum outcome
        +Boolean isFinal
        +Enum costs
        +String reasoning
        +Boolean isAppealable
    }

    class Remedy {
        +Enum remedyType
        +Date filingDate
        +String remedyGrounds
        +Enum status
    }

    class Lawyer {
        +String barLicense
        +String barAssociation
        +Enum lawyerType
    }

    class Judge {
        +String fullName
        +Enum position
        +Date appointmentDate
        +Boolean hasLifeTenure
        +Enum specialty
    }

    Proceeding "N" --> "N" LegalSubject : hasParties
    Proceeding "N" --> "1" Judge : hasJudge
    Proceeding "1" --> "N" ProceduralAct : containsAct
    Proceeding "1" --> "N" Judgment : culminatesIn
    Judgment "1" --> "N" Remedy : admitsRemedy
    Proceeding "N" --> "N" Lawyer : hasCounsel
    Proceeding "N" --> "N" Crime : concerns
    Proceeding "N" --> "1" Defendant : hasDefendant

    %% ══════════════════════════════════════════
    %% STATE BODIES
    %% ══════════════════════════════════════════

    class StateBody {
        +String name
        +Enum branchOfGovernment
        +Enum jurisdictionalScope
        +String competence
    }

    class JudicialBody {
        +Enum instance
        +Enum courtVenue
        +String territorialJurisdiction
    }

    class LegislativeBody {
        +Enum chamber
        +Integer legislatorCount
    }

    class ExecutiveBody {
        +String head
        +Enum governmentLevel
    }

    class PublicProsecution {
        +Enum type
        +String head
    }

    StateBody <|-- JudicialBody
    StateBody <|-- LegislativeBody
    StateBody <|-- ExecutiveBody
    StateBody <|-- PublicProsecution
    JudicialBody "1" --> "N" Judge : hasJudges
    ExecutiveBody "1" --> "N" LegalNorm : isEnactedBy
    LegislativeBody "1" --> "N" NationalLaw : enacts
    PublicProsecution "1" --> "N" Proceeding : intervenes

    %% ══════════════════════════════════════════
    %% LABOR LAW
    %% ══════════════════════════════════════════

    class EmploymentRelationship {
        +Enum contractType
        +Date startDate
        +Date endDate
        +Enum terminationCause
        +Decimal grossSalary
        +String agreementCategory
        +Enum workSchedule
        +Integer weeklyHours
        +Boolean isRegistered
    }

    class CollectiveBargainingAgreement {
        +String cctNumber
        +String activitySector
        +String signatoryUnion
        +String employerChamber
        +Enum applicationScope
        +Date ratificationDate
        +Date validity
    }

    class Union {
        +String name
        +String unionStatus
        +String representationScope
    }

    EmploymentRelationship "N" --> "1" NaturalPerson : employee
    EmploymentRelationship "N" --> "1" LegalSubject : employer
    EmploymentRelationship "N" --> "1" CollectiveBargainingAgreement : isGovernedBy
    CollectiveBargainingAgreement "N" --> "N" Union : isSignedBy

    %% ══════════════════════════════════════════
    %% FAMILY LAW
    %% ══════════════════════════════════════════

    class FamilyBond {
        +Enum bondType
        +Date incorporationDate
        +Boolean isInForce
    }

    class Marriage {
        +Date celebrationDate
        +String celebrationPlace
        +Enum regime
        +Boolean isDissolved
        +Enum dissolutionCause
        +Date dissolutionDate
    }

    class CivilUnion {
        +Date startDate
        +Boolean isRegistered
        +String registrationRegistry
    }

    class Filiation {
        +Enum filiationType
        +Boolean isAcknowledged
    }

    class Adoption {
        +Enum adoptionType
        +Date judgmentDate
        +String adoptingCourt
    }

    class ParentalResponsibility {
        +Boolean isSharedCustody
        +Decimal childSupport
        +String visitationSchedule
    }

    FamilyBond <|-- Marriage
    FamilyBond <|-- CivilUnion
    FamilyBond <|-- Filiation
    FamilyBond <|-- Adoption
    FamilyBond <|-- ParentalResponsibility
    Marriage "N" --> "2" NaturalPerson : spouse
    CivilUnion "N" --> "2" NaturalPerson : cohabitant
    Filiation "N" --> "1" NaturalPerson : parent
    Filiation "N" --> "1" NaturalPerson : child
    Adoption "N" --> "1" NaturalPerson : adoptee
    ParentalResponsibility "N" --> "N" NaturalPerson : parent

    %% ══════════════════════════════════════════
    %% TAX LAW
    %% ══════════════════════════════════════════

    class Tax {
        +String name
        +Enum taxType
        +Enum jurisdictionalLevel
        +String taxableEvent
        +String taxableBase
        +Decimal rate
        +Enum periodicity
    }

    class TaxObligation {
        +Date dueDate
        +Decimal declaredAmount
        +Decimal paidAmount
        +Boolean isOverdue
        +Boolean isChallenged
    }

    Tax <|-- IncomeTax
    Tax <|-- VAT
    Tax <|-- PersonalAssetsTax

    class IncomeTax {
        +String applicableLaw
        +Enum incomeCategory
    }

    class VAT {
        +Decimal generalRate
        +Decimal reducedRate
    }

    class PersonalAssetsTax {
        +Decimal taxFreeThreshold
    }

    Tax "N" --> "1" StateBody : collectingBody
    Tax "N" --> "1" LegalNorm : creatingNorm
    TaxObligation "N" --> "1" Tax : correspondsTo
    TaxObligation "N" --> "1" LegalSubject : isTaxDebtor

    %% ══════════════════════════════════════════
    %% ADMINISTRATIVE LAW
    %% ══════════════════════════════════════════

    class AdministrativeAct {
        +Enum actType
        +Date date
        +String actNumber
        +Boolean isRegulatory
        +Boolean isReasoned
        +Boolean isNotified
        +Boolean isFinal
        +Boolean isEnforced
    }

    class AdministrativeRemedy {
        +Enum remedyType
        +Integer businessDaysTerm
        +Enum status
        +Date filingDate
    }

    class AdministrativeContract {
        +Enum contractType
        +Decimal amount
        +String object
        +Date awardDate
    }

    class PublicTender {
        +String caseFileNumber
        +Decimal officialBudget
        +Date openingDate
        +String awardee
    }

    AdministrativeAct "N" --> "1" StateBody : issuingBody
    AdministrativeAct "N" --> "1" LegalSubject : recipient
    AdministrativeAct "1" --> "N" AdministrativeRemedy : admitsRemedy
    AdministrativeContract "N" --> "1" StateBody : contractingBody
    AdministrativeContract "N" --> "1" LegalSubject : contractor
    PublicTender "1" --> "1" AdministrativeContract : resultsIn

    %% ══════════════════════════════════════════
    %% CROSS-CUTTING RELATIONSHIPS
    %% ══════════════════════════════════════════

    LegalNorm "N" --> "1" StateBody : isEnactedBy
    Proceeding "N" --> "1" JudicialBody : isProcessedIn
    Judgment "N" --> "1" JudicialBody : isIssuedBy
    Judge "N" --> "1" JudicialBody : belongsTo
    Conviction "N" --> "1" JudicialBody : isIssuedBy
